@model Wms.Theme.Web.Components.DataTableViewModel

<div class="bg-white rounded-lg shadow">
        @if (!string.IsNullOrEmpty(Model.Title) || (Model.ActionButtons != null && Model.ActionButtons.Count > 0))
    {
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center bg-white rounded-t-lg">
            @if (!string.IsNullOrEmpty(Model.Title))
            {
                <h3 class="text-lg font-semibold text-gray-900">@Model.Title</h3>
            }
            
            @if (Model.ActionButtons != null && Model.ActionButtons.Count > 0)
            {
                <div class="flex gap-2">
                    @foreach (var btn in Model.ActionButtons)
                    {
                        @if (!string.IsNullOrEmpty(btn.OnClick))
                        {
                            <button id="@btn.Id" onclick="@btn.OnClick" class="@btn.CssClass">@Html.Raw(btn.Text)</button>
                        }
                        else
                        {
                            <a id="@btn.Id" href="@btn.Href" target="@btn.Target" class="@btn.CssClass">@Html.Raw(btn.Text)</a>
                        }
                    }
                </div>
            }
        </div>
    }

    @* --- TABLE CONTENT --- *@
    <div class="overflow-x-auto w-full">
        <table class="w-full whitespace-nowrap">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                     @if (Model.RowActions?.Count > 0)
                    {
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">Actions</th>
                    }
                    @foreach (var col in Model.Columns)
                    {
                        @if (col == "Select")
                        {
                            <th class="px-6 py-3 text-center text-xs font-medium text-gray-700 uppercase tracking-wider w-16">
                                <input type="checkbox" id="selectAll" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" onchange="toggleAllCheckboxes(this)">
                            </th>
                        }

                        else
                        {
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider cursor-pointer hover:bg-gray-100 @(Model.ColumnClasses.ContainsKey(col) ? Model.ColumnClasses[col] : "")">
                                <div class="flex items-center gap-2">
                                    @col
                                    @if (col != "STT" && col != "Image")
                                    {
                                        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m0 0l4 4m6-4v12m0 0l4-4m0 0l-4-4"></path>
                                        </svg>
                                    }
                                </div>
                            </th>
                        }
                    }
                   
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.Columns.Count + (Model.RowActions?.Count > 0 ? 1 : 0))" class="px-6 py-8 text-center text-gray-500">
                            <div class="flex flex-col items-center">
                                <svg class="w-12 h-12 text-gray-400 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                                </svg>
                                No data found
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Rows)
                    {
                        <tr class="hover:bg-gray-50 transition @(row.ContainsKey("_RowClass") ? row["_RowClass"] : "")">
                              @* --- ACTION BUTTONS (Moved to Start) --- *@
                            @if (Model.RowActions?.Count > 0)
                            {
                                <td class="px-6 py-4 text-sm text-left">
                                    <div class="flex gap-3 justify-start">
                                        @foreach (var action in Model.RowActions)
                                        {
                                            // Check conditional visibility
                                            bool shouldHide = false;
                                            if (row.ContainsKey($"_HideAction_{action.Text}") && row[$"_HideAction_{action.Text}"] is bool bText && bText) shouldHide = true;
                                            if (!shouldHide && !string.IsNullOrEmpty(action.Id) && row.ContainsKey($"_HideAction_{action.Id}") && row[$"_HideAction_{action.Id}"] is bool bId && bId) shouldHide = true;

                                            if (shouldHide) continue;

                                            var href = action.Href;
                                            var onClick = action.OnClick;
                                            var actionId = action.Id; // Lấy ID template
                                            foreach (var key in row.Keys)
                                            {
                                                var val = row[key]?.ToString();
                                                if (!string.IsNullOrEmpty(href)) href = href.Replace($"{{{key.ToLower()}}}", val, StringComparison.OrdinalIgnoreCase);
                                                if (!string.IsNullOrEmpty(onClick)) onClick = onClick.Replace($"{{{key.ToLower()}}}", val, StringComparison.OrdinalIgnoreCase);
                                                if (!string.IsNullOrEmpty(actionId)) actionId = actionId.Replace($"{{{key.ToLower()}}}", val, StringComparison.OrdinalIgnoreCase);
                                            }

                                            if (!string.IsNullOrEmpty(onClick))
                                            {
                                                <button id="@actionId" onclick="@onClick" class="@action.CssClass">@Html.Raw(action.Text)</button>
                                            }
                                            else
                                            {
                                                <a id="@actionId" href="@href" target="@action.Target" class="@action.CssClass">@Html.Raw(action.Text)</a>
                                            }
                                        }
                                    </div>
                                </td>
                            }

                            @foreach (var col in Model.Columns)
                            {
                                <td class="px-6 py-4 text-sm text-gray-900 @(col == "Select" ? "text-center" : "") @(col == "STT" ? "text-center font-medium" : "") @(Model.ColumnClasses.ContainsKey(col) ? Model.ColumnClasses[col] : "")">
                                    @if (row.ContainsKey(col))
                                    {
                                        var value = row[col];
                                      
                                        var colType = Model.ColumnTypes.ContainsKey(col) ? Model.ColumnTypes[col] : "Text";

                                        @if (col == "Select")
                                        {
                                            if (value != null)
                                            {
                                                <input type="checkbox" class="row-checkbox rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                                       style="pointer-events: fill !important;"
                                                       value="@(row.ContainsKey("Id") ? row["Id"] : "")" 
                                                       onchange="updateSelectAllCheckbox()">
                                            }
                                        }
                                        else if (colType == "Badge")
                                        {
                                            var st = value?.ToString();
                                            var badgeClass = st switch
                                            {
                                                "New" => "bg-gray-100 text-gray-800",
                                                "Counting" => "bg-blue-100 text-blue-800",
                                                "Reconciling" => "bg-purple-100 text-purple-800",
                                                "Completed" => "bg-green-100 text-green-800",
                                                "Pending" => "bg-yellow-100 text-yellow-800",
                                                "Approved" => "bg-green-100 text-green-800",
                                                "Rejected" => "bg-red-100 text-red-800",
                                                _ => "bg-gray-100 text-gray-800"
                                            };
                                            <span class="px-2.5 py-0.5 rounded-full text-xs font-medium @badgeClass">@st</span>
                                        }
                                        else if (colType == "TextRed")
                                        {
                                            <span class="text-red-600 font-bold">@value</span>
                                        }
                                        else if (col == "STT")
                                        {
                                            <span class="inline-flex items-center justify-center w-8 h-8 text-xs font-medium text-gray-700 bg-gray-100 rounded-full">
                                                @(value?.ToString() ?? "-")
                                            </span>
                                        }
                                        else if (colType == "Html")
                                        {
                                            @Html.Raw(value)
                                        }
                                        else if (colType == "Image")
                                        {
                                            <div class="flex-shrink-0 h-10 w-10">
                                                <img class="h-10 w-10 rounded-md object-cover border border-gray-200"
                                                     src="@(value ?? "/images/placeholder.png")"
                                                     alt="Product Img"
                                                     onerror="this.src='https://via.placeholder.com/40?text=No+Img'">
                                            </div>
                                        }
                                        else if (colType == "Link")
                                        {
                                            var id = row.ContainsKey("Id") ? row["Id"] : "#";
                                            <a href="/Inventory/Detail/@id" class="text-blue-600 hover:text-blue-900 font-medium hover:underline">
                                                @value
                                            </a>
                                        }
                                        else if (colType == "ExpiryDate" && value is DateTime expDate)
                                        {
                                            var daysLeft = (expDate - DateTime.UtcNow).TotalDays;
                                            if (daysLeft < 0)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                                    @expDate.ToString("dd/MM/yyyy") 
                                                </span>
                                            }
                                            else if (daysLeft < 30)
                                            {
                                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                                    @expDate.ToString("dd/MM/yyyy") (Sắp hết)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-gray-900">@expDate.ToString("dd/MM/yyyy")</span>
                                            }
                                        }             
                                        else if (Model.StatusMappings.ContainsKey(col))
                                        {
                                            var key = value?.ToString();
                                            var mappings = Model.StatusMappings[col];
                                            if (key != null && mappings.ContainsKey(key))
                                            {
                                                var badge = mappings[key];
                                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full @badge.CssClass">@badge.Text</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">@(value?.ToString() ?? "Unknown")</span>
                                            }
                                        }
                                        else
                                        {
                                            if (value is DateTime dt)
                                            {

                                                @dt.ToString("dd/MM/yyyy HH:mm")
                                            }
                                            else if (value is bool b)
                                            {

                                                <span class="px-3 py-1 rounded-full text-xs font-medium @(b ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">@(b ? "Yes" : "No")</span>
                                            }
                                            else
                                            {
                                                @(value?.ToString() ?? "-")
                                            }
                                        }
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

@* --- PAGINATION --- *@
@if (Model.ShowPagination && (Model.TotalPages > 1 || Model.TotalRecords > 0))
{
        <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 flex justify-between items-center">

            <div class="text-sm text-gray-600">
                Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecords) of @Model.TotalRecords results
            </div>

            <div class="flex gap-2">
                @{
                    int startPage = Math.Max(1, Model.CurrentPage - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                }

                @if (Model.CurrentPage > 1)
                {
                    <button type="button" onclick="loadTableData(@(Model.CurrentPage - 1))"
                            class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                        Previous
                    </button>
                }
                else
                {
                    <span class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm font-medium text-gray-400 cursor-not-allowed">Previous</span>
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <span class="px-3 py-2 bg-blue-600 border border-blue-600 text-white rounded-lg text-sm font-medium shadow-sm">@i</span>
                    }
                    else
                    {
                        <button type="button" onclick="loadTableData(@i)"
                                class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                            @i
                        </button>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <button type="button" onclick="loadTableData(@(Model.CurrentPage + 1))"
                            class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 transition">
                        Next
                    </button>
                }
                else
                {
                    <span class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm font-medium text-gray-400 cursor-not-allowed">Next</span>
                }
            </div>
        </div>
}
  </div>   



