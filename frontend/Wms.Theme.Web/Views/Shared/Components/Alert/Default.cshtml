    @model Wms.Theme.Web.Components.AlertViewModel

    @{
        var bgClass = Model.Type switch
        {
            Wms.Theme.Web.Components.AlertType.Success => "bg-green-50 border-green-200",
            Wms.Theme.Web.Components.AlertType.Error => "bg-red-50 border-red-200",
            Wms.Theme.Web.Components.AlertType.Warning => "bg-yellow-50 border-yellow-200",
            _ => "bg-blue-50 border-blue-200"
        };

        var textClass = Model.Type switch
        {
            Wms.Theme.Web.Components.AlertType.Success => "text-green-800",
            Wms.Theme.Web.Components.AlertType.Error => "text-red-800",
            Wms.Theme.Web.Components.AlertType.Warning => "text-yellow-800",
            _ => "text-blue-800"
        };

        var iconClass = Model.Type switch
        {
            Wms.Theme.Web.Components.AlertType.Success => "text-green-400",
            Wms.Theme.Web.Components.AlertType.Error => "text-red-400",
            Wms.Theme.Web.Components.AlertType.Warning => "text-yellow-400",
            _ => "text-blue-400"
        };
    }

    <div class="alert border-l-4 rounded-lg p-4 mb-4 @bgClass @textClass" role="alert">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                @if (Model.Type == Wms.Theme.Web.Components.AlertType.Success)
                {
                    <svg class="h-5 w-5 @iconClass" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                }
                else if (Model.Type == Wms.Theme.Web.Components.AlertType.Error)
                {
                    <svg class="h-5 w-5 @iconClass" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                }
                else if (Model.Type == Wms.Theme.Web.Components.AlertType.Warning)
                {
                    <svg class="h-5 w-5 @iconClass" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                }
                else
                {
                    <svg class="h-5 w-5 @iconClass" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                    </svg>
                }
            </div>
            <div class="flex-1 ml-3">
                <p class="text-sm font-medium">
                    @Model.Message
                </p>
            </div>
            @if (Model.Dismissible)
            {
                <button class="ml-3 inline-flex flex-shrink-0 text-@(Model.Type == Wms.Theme.Web.Components.AlertType.Success ? "green" : Model.Type == Wms.Theme.Web.Components.AlertType.Error ? "red" : Model.Type == Wms.Theme.Web.Components.AlertType.Warning ? "yellow" : "blue")-400 hover:text-@(Model.Type == Wms.Theme.Web.Components.AlertType.Success ? "green" : Model.Type == Wms.Theme.Web.Components.AlertType.Error ? "red" : Model.Type == Wms.Theme.Web.Components.AlertType.Warning ? "yellow" : "blue")-600 focus:outline-none" type="button" onclick="this.parentElement.style.display='none'">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </button>
            }
        </div>
    </div>
