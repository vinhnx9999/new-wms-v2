                                                        </div>
                                                        <button type="button" onclick="removeDetailItem(${index})" class="text-gray-400 hover:text-red-500 p-2 rounded-md transition mb-1" title="@L["Delete"]">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </div>

                                                    <!-- Row 2: Supplier, Quantity, Price, Expiry Date, Weight, Volume -->
                                                    <div class="grid grid-cols-2 md:grid-cols-6 gap-4">
