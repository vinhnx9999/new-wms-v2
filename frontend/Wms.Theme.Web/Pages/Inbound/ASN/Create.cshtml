        function onGoodsOwnerChange(selectElement) {
            const selectedOption = selectElement.selectedOptions[0];
            const hiddenInput = document.querySelector('input[name="CreateRequest.GoodsOwnerName"]');
            if (hiddenInput) hiddenInput.value = selectedOption.value ? (selectedOption.dataset.name || selectedOption.text) : '';
        }

        function onSkuChange(selectElement, index) {
            const option = selectElement.selectedOptions[0];
            const itemEl = selectElement.closest('.detail-item');

            // Check if this is a PO-imported item being modified
            // PO-imported items check removed: SKU select is locked so user cannot change SKU.
            // Keeping the attribute allows correct tracking for Reset functionality.

            if (option.value) {
                // Set hidden fields
                const mapping = {
                    'SpuId': 'spuId', 'SpuCode': 'spuCode', 'SpuName': 'spuName',
                    'SkuCode': 'skuCode', 'SkuName': 'skuName', 'Origin': 'origin'
                };
                for (const [field, dataKey] of Object.entries(mapping)) {
                    const input = document.querySelector(`input[name="CreateRequest.DetailList[${index}].${field}"]`);
                    if (input) input.value = option.dataset[dataKey] || '';
                }

                // Set Supplier
                const supplierNameInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].SupplierName"]`);
                const supplierIdInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].SupplierId"]`);
                const supId = option.dataset.supplierId;
                const supName = option.dataset.supplierName || "@Html.Raw(L["DefaultSupplier"])";
                if (supplierIdInput) supplierIdInput.value = supId || "0";
                if (supplierNameInput) supplierNameInput.value = supName;

                // Set Weight from SKU if available
                const weightInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].Weight"]`);
                if (weightInput && option.dataset.weight) {
                    weightInput.value = option.dataset.weight;
                }

                // Set Volume from SKU if available
                const volumeInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].Volume"]`);
                if (volumeInput && option.dataset.volume) {
                    volumeInput.value = option.dataset.volume;
                }

                // Set Expiry Date from SKU if available
                const expiryInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].ExpiryDate"]`);
                if (expiryInput && option.dataset.expireDate) {
                    expiryInput.value = option.dataset.expireDate;
                }

            } else {
                // Clear all fields when no SKU selected
                const supplierNameInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].SupplierName"]`);
                const supplierIdInput = document.querySelector(`input[name="CreateRequest.DetailList[${index}].SupplierId"]`);
                if (supplierIdInput) supplierIdInput.value = "";
                if (supplierNameInput) supplierNameInput.value = "";
            }
        }

        /**
         * Checks if any PO items remain. If not, resets PO tracking.
         */
        function checkAndResetPoTracking() {
            const container = document.getElementById('detail-items-container');
            const remainingPoItems = container.querySelectorAll('.detail-item[data-po-item="true"]');

            if (remainingPoItems.length === 0) {
                // No more PO items, reset tracking
                const poIdInput = document.querySelector('input[name="CreateRequest.PoId"]');
                if (poIdInput) poIdInput.value = '';

                // Reset Alpine component state using global function
                if (typeof window.resetPoTracking === 'function') {
                    window.resetPoTracking();
                } else {
                    console.error('window.resetPoTracking not available');
                }
            }
        }

        function calculateTotals() {
            let totalWeight = 0;
            let totalVolume = 0;

            const items = document.querySelectorAll('.detail-item');
            items.forEach(item => {
                const qty = parseFloat(item.querySelector('input[name*="AsnQty"]').value) || 0;
                const weight = parseFloat(item.querySelector('input[name*="Weight"]').value) || 0;
                const volume = parseFloat(item.querySelector('input[name*="Volume"]').value) || 0;

                totalWeight += qty * weight;
                totalVolume += qty * volume;
            });

            const wInput = document.getElementById('total-weight');
            if (wInput) wInput.value = totalWeight.toFixed(2);

            const vInput = document.getElementById('total-volume');
            if (vInput) vInput.value = totalVolume.toFixed(2);
        }

        function addDetailItem() {
            if (globalSkuList.length === 0 && globalSupplierList.length === 0) return;
            const container = document.getElementById('detail-items-container');
            const itemHtml = generateDetailItemHtml(detailItemIndex);
            container.insertAdjacentHTML('beforeend', itemHtml);
            const newItem = container.lastElementChild;
            initFlatpickr(newItem);
            newItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
            detailItemIndex++;
        }

        function removeDetailItem(index) {
            const item = document.querySelector(`[data-detail-index="${index}"]`);
            if (item) {
                // Check if this was a PO item before removing
                const wasPoItem = item.getAttribute('data-po-item') === 'true';
                item.remove();
                calculateTotals();
                // If it was a PO item, check if we need to reset PO tracking
                if (wasPoItem) {
                    console.log('Removing PO item, checking if PO tracking needs reset');
                    checkAndResetPoTracking();
                }
            }
        }

        async function removeSelectedItems() {
            const checkboxes = document.querySelectorAll('.detail-checkbox:checked');
            if (checkboxes.length === 0) {
                Notify.warning("@Html.Raw(L["NoItemsSelected"])");
                return;
            }
            const isConfirmed = await Notify.confirm("@Html.Raw(L["ConfirmDelete"])", `@Html.Raw(L["AreYouSureDelete"]) ${checkboxes.length} @Html.Raw(L["Items"])?`);

            if (isConfirmed) {
                checkboxes.forEach(checkbox => {
                    const item = checkbox.closest('.detail-item');
                    if (item) item.remove();
                });
                calculateTotals();

                Notify.success("@Html.Raw(L["ItemsRemoved"])");
            }
        }

        // Parses a date string in dd/mm/yyyy format to ISO format.
        function parseDate(dateStr) {
            if (!dateStr) return new Date().toISOString();
            // Split date and time
            const [datePart, timePart] = dateStr.split(" ");
            const [day, month, year] = datePart.split("/").map(Number);
            const [hours, minutes] = timePart.split(":").map(Number);

            // Create a Date object (months are 0-based in JS)
            const dateObj = new Date(year, month - 1, day, hours, minutes);

            // Convert to ISO string
            return dateObj.toISOString();

            // const parts = dateStr.split('/');
            // if (parts.length !== 3) return new Date().toISOString();
            // // Format: dd/mm/yyyy -> yyyy-mm-dd
            // return `${parts[2]}-${parts[1].padStart(2, '0')}-${parts[0].padStart(2, '0')}T00:00:00`;
        }

        function parseDateDMY(dateStr) {
            if (!dateStr) return new Date().toISOString();
            const parts = dateStr.split('/');
            if (parts.length !== 3) return new Date().toISOString();
            // Format: dd/mm/yyyy -> yyyy-mm-dd
            return `${parts[2]}-${parts[1].padStart(2, '0')}-${parts[0].padStart(2, '0')}T00:00:00`;
        }

        /**
         * Validates the ASN form before submission.
         * Checks: Required fields, Duplicate {SkuId, ExpiryDate} combinations, Quantity > 0.
         * Returns boolean - True if valid, false otherwise.
         */
        function validateForm() {
            let errors = [];
            const asnNo = document.querySelector('input[name="CreateRequest.AsnNo"]').value.trim();
            if (!asnNo) errors.push("@Html.Raw(L["ASNNumberRequired"])");

            const owner = document.querySelector('select[name="CreateRequest.GoodsOwnerId"]').value;
            if (!owner) errors.push("@Html.Raw(L["GoodsOwnerRequired"])");

            const eta = document.querySelector('input[name="CreateRequest.EstimatedArrivalTime"]').value;
            if (!eta) errors.push("@Html.Raw(L["EstimatedArrivalTimeRequired"])");

            const items = document.querySelectorAll('.detail-item');
            // Use Map<SkuId, Set<ExpiryDate>> for proper duplicate detection
            const detailsMap = new Map();

            if (items.length === 0) {
                errors.push("@Html.Raw(L["AtLeastOneItemRequired"])");
            } else {
                items.forEach((item, i) => {
                    const skuSelect = item.querySelector('select[name*="SkuId"]');
                    const qtyInput = item.querySelector('input[name*="AsnQty"]');
                    const expiryInput = item.querySelector('input[name*="ExpiryDate"]');

                    const skuId = skuSelect.value;
                    const qty = qtyInput.value;
                    const expiryDate = expiryInput ? expiryInput.value.trim() : '';

                    skuSelect.classList.remove('border-red-500');
                    if (expiryInput) expiryInput.classList.remove('border-red-500');

                    if (!skuId) {
                        errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["ProductRequired"])`);
                    } else {
                        // Duplicate check using Map<SkuId, Set<ExpiryDate>>
                        if (detailsMap.has(skuId)) {
                            if (detailsMap.get(skuId).has(expiryDate)) {
                                errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["DuplicateSkuWithSameExpiryDate"])`);
                                skuSelect.classList.add('border-red-500');
                                if (expiryInput) expiryInput.classList.add('border-red-500');
                            } else {
                                detailsMap.get(skuId).add(expiryDate);
                            }
                        } else {
                            detailsMap.set(skuId, new Set([expiryDate]));
                        }
                    }

                    // Check quantity
                    if (!qty || parseFloat(qty) <= 0) {
                        errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["ValidQuantityRequired"])`);
                    }

                    const price = parseNumber(item.querySelector('input[name*="Price"]').value);
                    const weight = item.querySelector('input[name*="Weight"]').value;
                    const volume = item.querySelector('input[name*="Volume"]').value;

                    if (price && price < 0) errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["PriceCannotBeNegative"])`);
                    if (weight && parseFloat(weight) < 0) errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["WeightCannotBeNegative"])`);
                    if (volume && parseFloat(volume) < 0) errors.push(`@Html.Raw(L["Item"]) ${i + 1}: @Html.Raw(L["VolumeCannotBeNegative"])`);
                });
            }

            // --- 3. Display errors ---
            if (errors.length > 0) {
                errors.forEach(error => {
                    Notify.warning(error);
                });
                return false;
            }

            return true;
        }

        // --- 5. UPDATED: SUBMIT FORM ---
        async function submitAsnForm(event) {
            event.preventDefault();

            if (!validateForm()) return;

            const submitBtn = document.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="animate-spin inline-block mr-2">↻</span> Processing...';

            try {
                const getInt = (val) => val ? parseInt(val) : 0;
                const getFloat = (val) => val ? parseFloat(val) : 0;
                const getString = (val) => val ? val.trim() : "";
                const getDate = (val) => val ? val : null;

                const payload = {
                    asn_no: getString(document.querySelector('input[name="CreateRequest.AsnNo"]').value),
                    asn_batch: getString(document.querySelector('input[name="CreateRequest.AsnBatch"]').value),
                    estimated_arrival_time: parseDate(document.getElementById('estimatedArrivalTime').value),
                    weight: getFloat(document.querySelector('input[name="CreateRequest.Weight"]').value),
                    volume: getFloat(document.querySelector('input[name="CreateRequest.Volume"]').value),
                    goods_owner_id: getInt(document.querySelector('select[name="CreateRequest.GoodsOwnerId"]').value),
                    goods_owner_name: getString(document.querySelector('input[name="CreateRequest.GoodsOwnerName"]').value),
                    po_id: getInt(document.querySelector('input[name="CreateRequest.PoId"]').value) || null,
                    asn_status: 1,
                    creator: "System",
                    detailList: []
                };

                const items = document.querySelectorAll('.detail-item');
                items.forEach((item) => {
                    const v = (namePart) => {
                        const el = item.querySelector(`[name*="${namePart}"]`);
                        return el ? el.value : "";
                    };
                    payload.detailList.push({
                        id: 0, asnmaster_id: 0,
                        sku_id: getInt(v('SkuId')),
                        supplier_id: getInt(v('SupplierId')), // Helper input
                        supplier_name: getString(v('SupplierName')), // Input type=text
                        asn_qty: getInt(v('AsnQty')),
                        actual_qty: 0,
                        price: parseNumber(v('Price')),
                        weight: getFloat(v('Weight')),
                        volume: getFloat(v('Volume')),
                        expiry_date: parseDateDMY(getDate(v('ExpiryDate'))),
                        spu_id: getInt(v('SpuId')),
                        spu_code: getString(v('SpuCode')),
                        spu_name: getString(v('SpuName')),
                        sku_code: getString(v('SkuCode')),
                        sku_name: getString(v('SkuName')),
                        origin: getString(v('Origin')),
                        is_valid: true
                    });
                });

                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const response = await fetch(window.location.pathname, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) throw new Error(`HTTP Error: ${response.status}`);

                const result = await response.json();

                if (result.success) {
                    Notify.success(result.message);
                    setTimeout(() => {
                        window.location.href = result.redirectUrl;
                    }, 100);
                } else {
                    Notify.error(result.message);
                }

            } catch (error) {
                console.error('Error submitting form:', error);
                Notify.error('@Html.Raw(L["ErrorSendingData"])');
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnText;
            }
        }

    </script>
}