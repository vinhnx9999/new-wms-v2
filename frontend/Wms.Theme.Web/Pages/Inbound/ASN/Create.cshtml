                                                            <input name="CreateRequest.DetailList[${index}].ExpiryDate" type="text" placeholder="dd/mm/yyyy" class="date-picker w-full px-3 py-2 bg-white border border-gray-300 text-sm rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white" />
