                                                        data-spu-name="${s.spu_name}" 
                                                        data-sku-code="${s.sku_code}" 
                                                        data-sku-name="${s.sku_name}" 
                                                        data-origin="${s.origin}" 
                                                        data-supplier-id="${s.supplier_id}" 
                                                        data-supplier-name="${s.supplier_name}"
