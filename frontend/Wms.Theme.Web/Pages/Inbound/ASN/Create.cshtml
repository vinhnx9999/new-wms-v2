                                                            <label class="block text-xs font-medium text-gray-500 uppercase mb-1">@L["Supplier"]</label>
                                                            <input type="text" name="CreateRequest.DetailList[${index}].SupplierName" readonly class="w-full px-3 py-2 bg-gray-100 border border-gray-200 text-sm rounded-lg text-gray-600 dark:bg-gray-600 dark:text-gray-300 cursor-not-allowed" />
