                                                        </div>
                                                        <div>
                                                            <label class="block text-xs font-medium text-gray-500 uppercase mb-1">@L["Price"]</label>
                                                            <input name="CreateRequest.DetailList[${index}].Price" type="text" oninput="onPriceInput(this)" class="w-full px-3 py-2 bg-white border border-gray-300 text-sm rounded-lg dark:bg-gray-700 dark:border-gray-600 dark:text-white text-right" />
                                                        </div>
                                                        <div>
