@page "/inbound/asn/detail/{id:int}"
@using Wms.Theme.Web.Util
@model Wms.Theme.Web.Pages.Inbound.ASN.DetailModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L

@functions {
    public string GetStatusText(byte statusCode, Microsoft.Extensions.Localization.IStringLocalizer L)
    {
        return statusCode switch
        {
            0 => L["New"].Value,
            1 => L["InProgress"].Value,
            2 => L["Completed"].Value,
            8 => L["Cancelled"].Value,
            _ => L["Unknown"].Value
        };
    }

    public string GetStatusBadgeClass(byte statusCode)
    {
        return statusCode switch
        {
            0 => "bg-blue-100 text-blue-800",
            1 => "bg-yellow-100 text-yellow-800",
            2 => "bg-green-100 text-green-800",
            8 => "bg-red-100 text-red-800",
            _ => "bg-gray-100 text-gray-800"
        };
    }

    public string GetStatusIcon(byte statusCode)
    {
        return statusCode switch
        {
            0 => "fa-solid fa-circle-plus",
            1 => "fa-solid fa-spinner",
            2 => "fa-solid fa-circle-check",
            8 => "fa-solid fa-circle-xmark",
            _ => "fa-solid fa-circle-question"
        };
    }

    public string GetStatusColor(byte statusCode)
    {
        return statusCode switch
        {
            0 => "text-blue-600 dark:text-blue-400",
            1 => "text-yellow-600 dark:text-yellow-400",
            2 => "text-green-600 dark:text-green-400",
            8 => "text-red-600 dark:text-red-400",
            _ => "text-gray-600 dark:text-gray-400"
        };
    }
}

@{
    ViewData["Title"] = L["AsnDetail"];

    var status = Model.AsnMasterDetail.AsnStatus;
    string statusText = GetStatusText(status, L);
    string statusClass = GetStatusBadgeClass(status);
}

<div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">

    <!-- 1. Header Section -->
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
        <div>
            <div class="flex items-center gap-3">
                <h1 class="text-2xl font-bold text-gray-900 dark:text-white">ASN : @Model.AsnMasterDetail.AsnNo</h1>
                <span
                    class="px-2.5 py-0.5 rounded text-xs font-bold uppercase tracking-wide border border-transparent @statusClass">
                    @statusText
                </span>
            </div>            
        </div>
        <div class="flex items-center gap-2 mt-2 text-sm text-gray-500">
            <i class="fa-regular fa-calendar text-gray-400"></i>
            <span class="font-medium text-gray-700 dark:text-gray-300">
                ETA:
                @Model.AsnMasterDetail.EstimatedArrivalTime.Convert2LocalDate()
            </span>
            <button class="text-gray-400 hover:text-gray-600">
                <i class="fa-solid fa-pen-to-square text-xs"></i>
            </button>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            <a asp-page="Index" class="btn btn-white text-gray-700 border-gray-300 hover:bg-gray-50">
                <i class="fa-solid fa-arrow-left mr-2"></i> @L["Back"]
            </a>
        </div>
    </div>

    <!-- 2. Business Summary Cards -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4">
        <h2 class="text-base font-bold text-gray-900 dark:text-white mb-4">Business Summary</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

            <!-- Goods Owner -->
            <div
                class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 flex items-center gap-3 border border-gray-100 dark:border-gray-700">

                <div>
                    <span class="text-xs text-gray-500 block">@L["GoodsOwner"]</span>
                    <span class="font-bold text-gray-900 dark:text-white truncate block max-w-[250px]"
                        title="@Model.AsnMasterDetail.GoodsOwnerName">
                        @Model.AsnMasterDetail.GoodsOwnerName
                    </span>
                </div>
            </div>

            <!-- Total Qty -->
            <div
                class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 flex items-center gap-3 border border-gray-100 dark:border-gray-700">

                <div>
                    <span class="text-xs text-gray-500 block">@L["TotalQty"]</span>
                    <div class="font-bold text-gray-900 dark:text-white">
                        @Model.AsnMasterDetail.DetailList.Sum(x => x.AsnQty).FormatPrice()
                    </div>
                </div>
            </div>

            <!-- SKU Count -->
            <div
                class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 flex items-center gap-3 border border-gray-100 dark:border-gray-700">

                <div>
                    <span class="text-xs text-gray-500 block">@L["SkuCount"]</span>
                    <div class="font-bold text-gray-900 dark:text-white">
                        @Model.AsnMasterDetail.DetailList.Count
                    </div>
                </div>
            </div>

            <!-- Total Weight -->
            <div
                class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-3 flex items-center gap-3 border border-gray-100 dark:border-gray-700">

                <div>
                    <span class="text-xs text-gray-500 block">@L["TotalWeight"]</span>
                    <div class="font-bold text-gray-900 dark:text-white">
                        @Model.AsnMasterDetail.Weight.ToString("N1") <span
                            class="text-xs font-normal text-gray-500">kg</span>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- 3. Split Layout: Items & Info -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">

        <!-- Left: ASN Items (75%) -->
        <div class="lg:col-span-3 space-y-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">

                <!-- Table -->
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                        <thead class="bg-gray-50 dark:bg-gray-800">
                            <tr>
                                <th scope="col"
                                    class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    @L["Product"]</th>                                
                                <th scope="col"
                                    class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    @L["Quantity"]</th>
                                <th scope="col"
                                    class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    @L["Status"]</th>
                                <th scope="col"
                                    class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    @L["Supplier"]</th>
                                <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">
                                    @L["ExpiryDate"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                            @if (Model.AsnMasterDetail.DetailList.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-gray-500">@L["NoItemsFound"]</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.AsnMasterDetail.DetailList)
                                {
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
                                        <!-- Product -->
                                        <td class="px-6 py-4">
                                            <div class="flex items-center">
                                                <div class="ml-4">
                                                    <div class="text-sm font-bold text-gray-900 dark:text-white">@item.SkuCode
                                                    </div>
                                                    <div class="text-sm text-gray-500 truncate max-w-xs" title="@item.SkuName">
                                                        @item.SkuName</div>
                                                </div>
                                            </div>
                                        </td>                                 
                                        <!-- Quantity Badge -->
                                        <td class="px-6 py-4 text-center">
                                            <span
                                                class="inline-flex items-center px-2.5 py-1 rounded text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">
                                                @item.AsnQty
                                            </span>
                                        </td>

                                        <!-- Status -->
                                        <td class="px-6 py-4">
                                            <div class="flex items-center @GetStatusColor(item.AsnStatus) font-medium text-sm">                                               
                                                @GetStatusText(item.AsnStatus, L)
                                            </div>
                                        </td>

                                        <!-- Supplier -->
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col">
                                                <div class="flex items-center text-sm text-gray-900 dark:text-white font-medium">
                                                    <span class="truncate max-w-[250px]"
                                                        title="@item.SupplierName">@item.SupplierName</span>
                                                </div>                                                
                                            </div>
                                        </td>
                                        
                                        <td class="px-6 py-4">
                                            <div class="flex items-center text-sm text-gray-500 mt-1">
                                                <span>@item.ExpiryDate.Convert2LocalDate()</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: System Info (25%) -->
        <div class="lg:col-span-1 space-y-4">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="font-bold text-gray-900 dark:text-white mb-4">System Info</h3>

                <div class="space-y-4">
                    <div>
                        <label class="text-xs text-gray-500 font-medium uppercase">@L["AsnBatch"]</label>
                        <div
                            class="mt-1 font-mono text-sm bg-gray-50 dark:bg-gray-700 px-3 py-1.5 rounded border border-gray-200 dark:border-gray-600 text-gray-700 dark:text-gray-300 break-all">
                            @(string.IsNullOrEmpty(Model.AsnMasterDetail.AsnBatch) ? "-" :
                                                        Model.AsnMasterDetail.AsnBatch)
                        </div>
                    </div>

                    <div>
                        <label class="text-xs text-gray-500 font-medium uppercase">@L["CreatedBy"]</label>
                        <div class="mt-1 text-sm font-medium text-gray-900 dark:text-white">
                            @Model.AsnMasterDetail.Creator</div>
                    </div>

                    <div>
                        <label class="text-xs text-gray-500 font-medium uppercase">@L["CreateTime"]</label>
                        <div class="mt-1 text-sm text-gray-700 dark:text-gray-300">
                            @Model.AsnMasterDetail.CreateTime.Convert2LocalTime()
                        </div>
                    </div>

                    <div>
                        <label class="text-xs text-gray-500 font-medium uppercase">@L["LastUpdate"]</label>
                        <div class="mt-1 text-sm text-gray-700 dark:text-gray-300">
                            @Model.AsnMasterDetail.LastUpdateTime.Convert2LocalTime()
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>