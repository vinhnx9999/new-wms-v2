@page
@model Wms.Theme.Web.Pages.Inbound.ASN.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@{
    ViewData["Title"] = L["ASN"];
}
@Html.AntiForgeryToken()

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/airbnb.css">
}

<div class="px-6 pb-6" x-data="{ ...AlpineDataTable(asnConfig), showAdvanced: false }"
    @@datatable-reload.window="reload()">

    <!-- Custom Search Bar -->
    <div class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-slate-200 dark:border-gray-700">
        <!-- Main Search Row -->
        <div class="flex items-end gap-2">
            <!-- Search Text -->
            <div class="flex-1 flex flex-col gap-1">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text" x-model="filters.text" @@keydown.enter="reload()"
                        @@input.debounce.500ms="reload()" placeholder="@Html.Raw(L["SearchPlaceholder"])"
                        class="w-full pl-10 px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border border-slate-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:text-white">
                </div>
            </div>

            <!-- Toggle Advanced Filter Button -->
            <button @@click="showAdvanced = !showAdvanced"
                class="px-3 py-2 text-sm font-medium rounded-lg border border-slate-300 dark:border-gray-600 hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors flex items-center gap-2"
                :class="showAdvanced ? 'bg-blue-50 text-blue-600 border-blue-200 dark:bg-blue-900/20 dark:text-blue-400 dark:border-blue-800' : 'text-slate-600 dark:text-slate-300 bg-white dark:bg-gray-800'">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                </svg>
            </button>

            <!-- Create Button -->
            <a href="/Inbound/ASN/Create" title="@Html.Raw(L["CreateASN"])"
                class="px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-colors shadow-sm flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
            </a>

            <!-- Export Button -->
            <button onclick="validateAndExportASN()" title="@Html.Raw(L["ExportASN"])"
                class="px-3 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 focus:ring-4 focus:ring-green-300 transition-colors shadow-sm flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
            </button>
        </div>

        <!-- Advanced Filters (Collapsible) -->
        <div x-show="showAdvanced" x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2" style="display: none;"
            class="mt-4 pt-4 border-t border-slate-200 dark:border-gray-700 grid grid-cols-12 gap-4 items-end">

            <!-- Exact ETA Date Range -->
            <div class="col-span-12 md:col-span-6 lg:col-span-4 flex flex-col gap-1">
                <label class="text-xs font-semibold text-slate-500 dark:text-slate-400">@Html.Raw(L["ETA"])</label>
                <div class="relative">
                    <input type="text" x-init="
                            const el = $el;
                            const initPicker = () => {
                                flatpickr(el, {
                                    mode: 'range',
                                    dateFormat: 'Y-m-d',
                                    altInput: true,
                                    altFormat: 'd/m/Y',
                                    defaultDate: [filters.expectedDeliveryDateFrom, filters.expectedDeliveryDateTo],
                                    onChange: function(selectedDates, dateStr, instance) {
                                        if (selectedDates.length === 2) {
                                            filters.expectedDeliveryDateFrom = instance.formatDate(selectedDates[0], 'Y-m-d');
                                            filters.expectedDeliveryDateTo = instance.formatDate(selectedDates[1], 'Y-m-d');
                                        } else {
                                            filters.expectedDeliveryDateFrom = null;
                                            filters.expectedDeliveryDateTo = null;
                                        }
                                    }
                                });
                            };
                            
                            if (typeof flatpickr !== 'undefined') {
                                initPicker();
                            } else {
                                const check = setInterval(() => {
                                    if (typeof flatpickr !== 'undefined') {
                                        initPicker();
                                        clearInterval(check);
                                    }
                                }, 50);
                            }
                        "
                        class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border border-slate-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:text-white"
                        placeholder="@Html.Raw(L["ETA"])">
                    <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                            </path>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Status -->
            <div class="col-span-12 md:col-span-6 lg:col-span-2 flex flex-col gap-1">
                <label class="text-xs font-semibold text-slate-500 dark:text-slate-400">@Html.Raw(L["Status"])</label>
                <select x-model="filters.status" @@change="reload()"
                    class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border border-slate-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:text-white">
                    <option value="-1">@Html.Raw(L["All"])</option>
                    <option value="0">@Html.Raw(L["New"])</option>
                    <option value="1">@Html.Raw(L["InProgress"])</option>
                    <option value="2">@Html.Raw(L["Completed"])</option>
                    <option value="8">@Html.Raw(L["Cancelled"])</option>
                </select>
            </div>

            <!-- Action Buttons (Apply & Clear) -->
            <div class="col-span-12 md:col-span-6 lg:col-span-2 flex justify-end gap-2">
                <button @@click="reload()" title="@Html.Raw(L["Apply"])"
                    class="p-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-colors shadow-sm flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </button>
                <button @@click="filters = { status: -1, text: '' }; reload()" title="@Html.Raw(L["Clear"])"
                    class="p-2 bg-white dark:bg-gray-800 text-slate-600 dark:text-slate-300 border border-slate-300 dark:border-gray-600 rounded-lg hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors flex items-center justify-center">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <partial name="Shared/Components/_AlpineDataTable" />
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/components/alpine-datatable.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('asnPage', () => ({
                init() {
                }
            }));
        });

        const asnConfig = {
            apiUrl: '?handler=DataTable',
            filters: {
                text: '',
                expectedDeliveryDateFrom: '',
                expectedDeliveryDateTo: '',
                status: -1
            },
            columns: [
                {
                    title: '@Html.Raw(L["ASNNumber"])', field: 'asnNo', sortable: true,
                    class: 'font-medium text-gray-900 dark:text-white',
                    render: (row) => `<a href="/Inbound/ASN/Detail/${row.id}" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 p-1 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded transition-colors" title="@Html.Raw(L["Detail"])">
                              ${row.asnNo}
                         </a>`
                },
                { title: '@Html.Raw(L["ASNBatch"])', field: 'asnBatch', sortable: true },
                { title: '@Html.Raw(L["ETA"])', field: 'eta', sortable: true, render: (row) => row.eta ? GlobalFormatDate(row.eta) : '' },
                { title: '@Html.Raw(L["GoodsOwnerName"])', field: 'goodsOwnerName', sortable: true },
                { title: '@Html.Raw(L["Status"])', field: 'asnStatus', render: (row) => renderStatusBadge(row.asnStatus) },
                { title: '', field: null, sortable: false, class: 'text-right', render: (row) => renderActions(row) }
            ],
            options: {
                pageSize: 10
            }
        };

        window.alpineDataTableConfig = asnConfig;

        function renderStatusBadge(status) {
            const statusMap = {
                0: { text: '@Html.Raw(L["New"])', class: 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300' },
                1: { text: '@Html.Raw(L["InProgress"])', class: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' },
                2: { text: '@Html.Raw(L["Completed"])', class: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' },
                8: { text: '@Html.Raw(L["Cancelled"])', class: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300' },
                99: { text: '@Html.Raw(L["Unknown"])', class: 'bg-gray-100 text-gray-800' }
            };
            const s = statusMap[status] || statusMap[99];
            return `<span class="px-2 py-1 rounded text-xs font-semibold ${s.class}">${s.text}</span>`;
        }

        function renderActions(row) {
            let html = `<div class="flex justify-end gap-2">`;

            // Delete Button (Trash Icon) - Only if status is New/Created (0)
            if (row.asnStatus === 0) {
                html += `<button onclick="deleteAsn(${row.id})" class="text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300 p-1 hover:bg-red-100 dark:hover:bg-red-900/30 rounded transition-colors" title="@Html.Raw(L["Delete"])">
                                   <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                     <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                   </svg>
                               </button>`;
            }
            html += `</div>`;
            return html;
        }

        async function deleteAsn(id) {
            const confirmed = await Notify.confirm("@Html.Raw(L["ConfirmDeleteMessage"])", "@Html.Raw(L["ConfirmDelete"])", "@Html.Raw(L["DeleteNow"])", true);
            if (!confirmed) return;

            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenElement ? tokenElement.value : '';

            try {
                const response = await fetch('?handler=Delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ id: id })
                });

                const result = await response.json();
                if (result.success) {
                    Notify.success(result.message);
                    window.dispatchEvent(new CustomEvent('datatable-reload'));
                } else {
                    Notify.error(result.message);
                }
            } catch (error) {
                console.error(error);
                Notify.error("@Html.Raw(L["ConnectionError"])");
            }
        }

        function validateAndExportASN() {
            // Basic CSR export logic - can be refined to download filtered result
            if (typeof exportAllRows === 'function') {
                exportAllRows('asn_list');
            } else {
                // Fallback or alert
                Notify.warning("Export feature is being updated for new table.");
            }
        }
    </script>
}