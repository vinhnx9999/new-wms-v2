        async function saveNewWarehouse() {
             const name = document.getElementById('newWhName').value.trim();
             const city = document.getElementById('newWhCity').value.trim();
             const address = document.getElementById('newWhAddress').value.trim();
             const manager = document.getElementById('newWhManager').value.trim();
             const email = document.getElementById('newWhEmail').value.trim();
             const contactTel = document.getElementById('newWhContactTel').value.trim();

             if (!name) { Notify.info(L.validWhName); return; }
             if (!city) { Notify.info(L.validWhCity); return; }
             if (!address) { Notify.info(L.validWhAddress); return; }
             if (contactTel ){
                const phoneRegex = /^[+]?[(]?[0-9]{1,4}[)]?[-\s./0-9]*$/;
                if (!phoneRegex.test(contactTel)) { Notify.info(L.validWhContactTel); return; }
             }

             const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
             try {
                 const response = await fetch('?handler=AddWareHouse', {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                     body: JSON.stringify({ warehouseName: name, city: city, address: address, email: email, manager: manager, contactTel: contactTel })
                 });
                 const result = await response.json();
                 if (result.success) {
                     Notify.info('@Html.Raw(Localizer["OperationSuccessfull"])');
                     searchInput.value = name;
                     selectedWarehouseIdInput.value = result.id ?? '';
                     closeWarehouseModal();
                 } else {
                     Notify.info('@Html.Raw(Localizer["OperationFailed"])');
                 }
             } catch (error) {
                 console.error('Error saving warehouse:', error);
                 Notify.info('@Html.Raw(Localizer["OperationFailed"])');
             }
        }

   
        // ITEM SEARCH MODAL 
        const itemSearchModal = document.getElementById('itemSearchModal');
        const itemSearchInput = document.getElementById('itemSearchInput');
        const itemSearchResultBody = document.getElementById('itemSearchResultBody');
        let currentRowIdForItemSearch = null;
        let itemSearchAbortController = null;
        let currentPage = 1;
        const pageSize = 20; 
        let isFetching = false;
        let hasMoreData = true;


        async function fetchSkuItems(supplierId, keyword = '' , pageIndex = 1){
            
            if(itemSearchAbortController != null){
                  itemSearchAbortController.abort();
            }
            itemSearchAbortController = new AbortController();
            try {
                  const keyWordParam = keyword?.trim()
                     ? `&keyWord=${encodeURIComponent(keyword.trim())}`
                     : '';

                 const url = `?handler=SearchSku&supplierId=${supplierId}${keyWordParam}&pageIndex=${pageIndex}&pageSize=${pageSize}`;
                 const response = await fetch(url, {
                     signal: itemSearchAbortController.signal
                 });

                 if (!response.ok) return null;
                 return await response.json();
            } catch (e){
                 if (e.name === 'AbortError') return null;
                 console.error('Error fetching SKU items:', e);
                 return [];
            }
        }


       async function openItemSearchModal(rowNodeId) {
            const supplierId = document.getElementById('selectedSupplierId').value.trim();
            if (!supplierId) {
                Notify.info(L.validSupplier);
                return [];
            }

            currentPage = 1;
            hasMoreData = true;
            currentRowIdForItemSearch = rowNodeId;
            itemSearchInput.value = '';
            scrollContainer.scrollTop = 0;
            
            showItemSearchLoading();
            itemSearchModal.classList.remove('hidden');
            setTimeout(() => itemSearchInput.focus(), 100);
            isFetching = true;
            const data = await fetchSkuItems(supplierId, '', currentPage);
            isFetching = false;
            if (data !== null) {
                renderItemTable(data , false);
            }
        }

        function closeItemSearchModal() {
             itemSearchModal.classList.add('hidden');
             currentRowIdForItemSearch = null;

             if (itemSearchAbortController) {
                 itemSearchAbortController.abort();
                 itemSearchAbortController = null;
             }
        }

        function renderItemTable(data , isAppend = false) {
             if (!isAppend) {
                itemSearchResultBody.innerHTML = '';
             }

            
             if (!Array.isArray(data) || data.length === 0) {
                 if (!isAppend) {
                     itemSearchResultBody.innerHTML = `
                         <tr>
                             <td colspan="5" class="px-6 py-4 text-center text-gray-500">
                                 ${L.noItemFound}
                             </td>
                         </tr>`;
                 }
                 hasMoreData = false;
                 scrollAnchor.classList.add('hidden');
                 return;
             }

             if (data.length < pageSize) {
                hasMoreData = false;
                scrollAnchor.classList.add('hidden');
             
             } else {
                hasMoreData = true;
                scrollAnchor.classList.remove('hidden');
             }

            data.forEach(item => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
        
                tr.onclick = () => {
                    selectItem(
                    item.skuId,
                    item.skuCode,
                    item.skuName,
                    item.unitName ?? '',
                    item.skuUomId ?? 0
                    );
                };
                 tr.innerHTML = `
                     <td class="px-6 py-3 whitespace-nowrap text-sm font-medium  text-gray-900">
                         ${item.skuCode ?? ''}
                     </td>
                     <td class="px-6 py-3 text-sm text-gray-700">${item.skuName ?? ''}</td>
                     <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">
                         ${item.unitName ?? ''}
                     </td>
                     <td class="px-6 py-3 whitespace-nowrap text-sm text-blue-600 font-medium">
                         ${item.supplierName ?? ''}
                     </td>
                    
                 `;
                 itemSearchResultBody.appendChild(tr);
             });
        }

        function showItemSearchLoading(){
              itemSearchResultBody.innerHTML = `
                 <tr>
                     <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                         <div class="flex justify-center items-center gap-2">
                             <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg"
                                  fill="none" viewBox="0 0 24 24">
                                 <circle class="opacity-25" cx="12" cy="12" r="10"
                                         stroke="currentColor" stroke-width="4"></circle>
                                 <path class="opacity-75" fill="currentColor"
                                       d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                             </svg>
                            @Html.Raw(L["Loading"])
                         </div>
                     </td>
                 </tr>`;
        }

       
         const scrollContainer = document.getElementById('scrollContainer');
         const scrollAnchor = document.getElementById('scroll-anchor');
         const loadingIndicator = document.getElementById('loading-indicator');
         const observerOptions = {
            root: scrollContainer,
            rootMargin: '0px 0px 100px 0px', 
            threshold: 0
         };

        const infiniteScrollObserver = new IntersectionObserver(async (entries) => {
            const target = entries[0];
    
          
            if (target.isIntersecting && !isFetching && hasMoreData) {
                isFetching = true;
                loadingIndicator.classList.remove('hidden');

                currentPage++;
                const supplierId = document.getElementById('selectedSupplierId').value.trim();
                const keyword = itemSearchInput.value;

                const data = await fetchSkuItems(supplierId, keyword, currentPage);
        
                if (data !== null) {
                    renderItemTable(data, true);
                }

                loadingIndicator.classList.add('hidden');
                isFetching = false;
            }
        }, observerOptions);

        
         infiniteScrollObserver.observe(scrollAnchor);
         const debouncedSkuSearch = debounce(async function () {
             isFetching = true;

             currentPage = 1;
             hasMoreData = true;
             showItemSearchLoading();

             const supplierId = document.getElementById('selectedSupplierId').value.trim();
             const keyword = itemSearchInput.value;
             try {
                 const data = await fetchSkuItems(supplierId, keyword, currentPage);
                 if (data !== null) {
                    renderItemTable(data, false); 
                 }          
             }
             finally{
                 isFetching = false;
             }
         }, 300);

         itemSearchInput.addEventListener('input', debouncedSkuSearch);

         function selectItem(skuId, code, name, uom , skuUomId) {
             if (!currentRowIdForItemSearch) return;

             const rowNode = gridApi.getRowNode(currentRowIdForItemSearch);
             if (rowNode) {
                 rowNode.setDataValue('itemCode', code);
                 rowNode.setDataValue('itemName', name);
                 rowNode.setDataValue('uom', uom);
                 rowNode.data.skuId = parseInt(skuId) || 0;
                 rowNode.data.skuUomId = parseInt(skuUomId) || 0;
             }
             closeItemSearchModal();
         }

        // =====================================
        // LOCATION MAP MODAL 
        // =====================================
        const locationSearchModal = document.getElementById('locationSearchModal');
        const locationGridContainer = document.getElementById('locationGridContainer');
        let currentRowIdForLocation = null;
        let locationFetchAbortController = null;

        function openLocationModal(rowNodeId) {
            const warehouseId = document.getElementById('selectedWarehouseId').value;
            if (!warehouseId) { Notify.info(L.validSelectWhFirst); return; }
            const rowNode = gridApi.getRowNode(rowNodeId);
            const rowQty = rowNode?.data?.qty ?? 0;
            currentRowIdForLocation = rowNodeId;
            locationSearchModal.classList.remove('hidden');            
            fetchLocationsFromServer(warehouseId, rowQty);
        }

        function closeLocationModal() {
             hideLocationTooltip();
             locationSearchModal.classList.add('hidden');
             currentRowIdForLocation = null;
             if (locationFetchAbortController) {
                 locationFetchAbortController.abort();
                 locationFetchAbortController = null;
             }
        }

        async function fetchLocationsFromServer(warehouseId , qty = 0) {
            locationGridContainer.innerHTML = `<div class="col-span-full text-center text-gray-500 py-8 flex justify-center items-center gap-2"><svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>${L.loadingLocationMap}</div>`;
            if(locationFetchAbortController) locationFetchAbortController.abort();
            locationFetchAbortController = new AbortController();
            try {
                    const url = `?handler=SearchLocationWithPallet&warehouseId=${encodeURIComponent(warehouseId)}&qty=${encodeURIComponent(qty)}`;
                    const response = await fetch(url, { signal: locationFetchAbortController.signal });
                 
                    if (!response.ok){
                         locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">${L.locationLoadError}</div>`;
                        return;
                    }
                    const data = await response.json();
                    const mapped = (data ?? []).map(item => {
                        const hasPallet = item.palletCode && item.palletCode !== '';
                        return {
                            locationId: item.goodLocationId,
                            locCode: item.goodLocationName,
                            palletCode: item.palletCode || '',
                            items: item.items ?? [],
                            status: hasPallet ? 'has-pallet' : 'empty'
                        };
                    });
                    renderLocationBlocks(mapped);
            } catch (e) {
                if (e.name === 'AbortError') return;
                console.error('Error fetching locations:', e);
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">${L.connectionError}</div>`;
            }
        }

        function renderLocationBlocks(data) {
            locationGridContainer.innerHTML = '';
            if(!data || data.length === 0) {
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-gray-500 py-8">${L.noLocationData}</div>`;
                return;
            }
            data.forEach(item => {
               const isEmpty = item.status === 'empty';
                const hasPallet = item.status === 'has-pallet';

                const baseClass = "border-2 rounded-lg p-3 text-center transition-all duration-200 flex flex-col justify-center items-center relative ";

                let styleClass;
                if (isEmpty) {
                    styleClass = "border-green-400 bg-green-50 hover:bg-green-100 hover:shadow-md hover:-translate-y-1 cursor-pointer h-24";
                } else if (hasPallet) {
                    styleClass = "border-blue-300 bg-blue-50/50 cursor-not-allowed opacity-80 h-24";
                } else {
                    styleClass = "border-gray-200 bg-gray-100 opacity-60 cursor-not-allowed h-24";
                }

                const block = document.createElement('div');
                block.className = baseClass + styleClass + " group";

                if (isEmpty) {
                    block.onclick = () => selectLocation(item.locationId, item.locCode, item.palletCode);
                }
                if (hasPallet && item.items && item.items.length > 0) {
                    block.addEventListener('mouseenter', e => showLocationTooltip(e, item.palletCode, item.items));
                    block.addEventListener('mouseleave', hideLocationTooltip);
                }
                const dotColor = isEmpty ? 'bg-green-500' : 'bg-blue-500';
                const nameColor = isEmpty ? 'text-green-700' : 'text-blue-700';
                const subColor = isEmpty ? 'text-green-600' : 'text-blue-600';
                const label = isEmpty ? 'Trống' : item.palletCode;
                block.innerHTML = `
                    <div class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full ${dotColor} ${isEmpty ? 'animate-pulse' : ''}"></div>
                    <span class="text-sm font-bold ${nameColor} leading-tight">${item.locCode}</span>
                    <span class="text-[10px] font-medium ${subColor}">${label}</span>
                `;
                locationGridContainer.appendChild(block);
            });
        }

        let activeTooltipEl = null;
        function showLocationTooltip(e, palletCode, items) {
            hideLocationTooltip();
            const tip = document.createElement('div');
            tip.id = 'loc-floating-tooltip';
            tip.innerHTML = `
                <div style="font-weight:700;color:#1d4ed8;font-size:13px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin-bottom:6px;">${palletCode}</div>
                ${items.map(i => `<div style="display:flex;justify-content:space-between;gap:24px;padding:2px 0;"><span style="color:#374151;">${i.skuName}</span><span style="color:#1d4ed8;font-weight:700;">${i.qty}</span></div>`).join('')}
            `;
            Object.assign(tip.style, { position:'fixed', zIndex:'9999', background:'#fff', border:'1px solid #e5e7eb', borderRadius:'8px', boxShadow:'0 10px 25px rgba(0,0,0,.15)', padding:'10px 14px', fontSize:'12px', pointerEvents:'none', width:'max-content', maxWidth:'460px' });
            document.body.appendChild(tip);
            activeTooltipEl = tip;
            const rect = e.currentTarget.getBoundingClientRect();
            const tipRect = tip.getBoundingClientRect();
            let top = rect.top - tipRect.height - 8;
            if (top < 4) top = rect.bottom + 8;
            let left = rect.left + rect.width / 2 - tipRect.width / 2;
            left = Math.max(4, Math.min(left, window.innerWidth - tipRect.width - 4));
            tip.style.top = top + 'px';
            tip.style.left = left + 'px';
        }

        function hideLocationTooltip() {
            if (activeTooltipEl) { activeTooltipEl.remove(); activeTooltipEl = null; }
        }

       async function selectLocation(locationId , locCode, palletCode) {
            if (!currentRowIdForLocation) return;

            const rowNode = gridApi.getRowNode(currentRowIdForLocation);
            if (!rowNode) return;

            rowNode.setDataValue('location', locCode);
            rowNode.data.locationId = locationId;

            closeLocationModal();

            if (palletCode) {
                rowNode.setDataValue('pallet', palletCode);
                rowNode.data.palletSource = 'map';
                return; 
            }
             
            let reusedPalletCode = null;
            gridApi.forEachNode(node => {
           
                if (node.id === currentRowIdForLocation) return;
        
                if (node.data.locationId === locationId && node.data.pallet) {
                    reusedPalletCode = node.data.pallet;
                }
            });

            if (reusedPalletCode) {
                rowNode.setDataValue('pallet', reusedPalletCode);
                rowNode.data.palletSource = 'grid-reuse'; 
               // Notify.success(`Đã tự động gom chung vào Pallet ${reusedPalletCode} tại vị trí này.`);
                return; 
            }

            try {

                const response = await fetch('?handler=GeneratePalletCode');
        
                if (!response.ok) {
                throw new Error("Lỗi HTTP từ server");
                }
        
                const result = await response.json();
                const newCode = result?.palletCode ?? result?.data?.palletCode;

                if (newCode) {
                    rowNode.setDataValue('pallet', newCode);
                    rowNode.data.palletSource = 'auto-generated';
                  
                } 
                else {
                    rowNode.setDataValue('pallet', null);
                    Notify.error("Không thể lấy mã Pallet mới từ server.");
                    console.error('Server did not return a pallet code:', result);
                }
                
            } catch (error) {
                console.error('Lỗi khi sinh mã Pallet tự động:', error);
                rowNode.setDataValue('pallet', null);
             
            }
       }
      

        // PALLET SEARCH MODAL (Nguyên gốc)
         const palletSearchModal = document.getElementById('palletSearchModal');
         const palletSearchInput = document.getElementById('palletSearchInput');
         const palletSearchResultBody = document.getElementById('palletSearchResultBody');
         let currentRowIdForPallet = null;
         let palletSearchAbortController = null;
         const palletStatusMap = {
             @foreach (var kvp in palletStatus)
             {
               <text>@kvp.Key: '@kvp.Value',</text>
             }
         };

         async function fetchPallets(keyword = '', pageIndex = 1) {
             if (palletSearchAbortController) palletSearchAbortController.abort();
             palletSearchAbortController = new AbortController();
             try {
                 const keyWordParam = keyword?.trim() ? `&keyword=${encodeURIComponent(keyword.trim())}` : '';
                 const url = `?handler=SearchPallet${keyWordParam}&pageIndex=${pageIndex}`;
                 const response = await fetch(url, { signal: palletSearchAbortController.signal });
                 if (!response.ok) return null;
                 return await response.json();
             } catch (e) {
                 if (e.name === 'AbortError') return null;
                 console.error('Error fetching pallets:', e);
                 return [];
             }
         }

          function openPalletSearchModal(rowNodeId) {
             currentRowIdForPallet = rowNodeId;
             palletSearchInput.value = '';
             showPalletSearchLoading();
             palletSearchModal.classList.remove('hidden');
             setTimeout(() => palletSearchInput.focus(), 100);
             fetchPallets('').then(data => renderPalletTable(data));
         }

          function closePalletSearchModal() {
             palletSearchModal.classList.add('hidden');
             currentRowIdForPallet = null;
             if (palletSearchAbortController) {
                 palletSearchAbortController.abort();
                 palletSearchAbortController = null;
             }
         }

          function showPalletSearchLoading() {
             palletSearchResultBody.innerHTML = `<tr><td colspan="3" class="px-6 py-8 text-center text-gray-500"><div class="flex justify-center items-center gap-2"><svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>${L.searchingPallet}</div></td></tr>`;
         }

         function renderPalletTable(response) {
             palletSearchResultBody.innerHTML = '';
             const data = response?.data?.rows ?? response?.rows ?? response;
             if (!Array.isArray(data) || data.length === 0) {
                 palletSearchResultBody.innerHTML = `<tr><td colspan="3" class="px-6 py-4 text-center text-gray-500">${L.noPalletFound}</td></tr>`;
                 return;
             }
             data.forEach(pallet => {
                 const statusText = palletStatusMap[pallet.palletStatus] ?? `Status ${pallet.palletStatus}`;
                 const isAvailable = pallet.palletStatus === 1;
                 const statusClass = isAvailable ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700';
                 const formattedDate = pallet.createTime ? new Date(pallet.createTime).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' }) : '';
                 const tr = document.createElement('tr');
                 tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
                 tr.onclick = () => selectPallet(pallet.palletCode);
                 tr.innerHTML = `<td class="hidden">${pallet.id}</td><td class="px-6 py-3 text-sm font-bold text-blue-700">${pallet.palletCode}</td><td class="px-6 py-3 text-sm text-gray-600">${formattedDate}</td><td class="px-6 py-3"><span class="px-2 py-1 text-xs font-semibold rounded ${statusClass}">${statusText}</span></td>`;
                 palletSearchResultBody.appendChild(tr);
             });
         }

         const debouncedPalletSearch = debounce(async function () {
             showPalletSearchLoading();
             const data = await fetchPallets(palletSearchInput.value);
             renderPalletTable(data);
         }, 300);

         palletSearchInput.addEventListener('input', debouncedPalletSearch);

         function selectPallet(palletCode) {
             if (!currentRowIdForPallet) return;
             const rowNode = gridApi.getRowNode(currentRowIdForPallet);
             if (rowNode) {
                 rowNode.setDataValue('pallet', palletCode);
                 rowNode.data.palletSource = 'manual';
             }
             closePalletSearchModal();
         }

         async function quickCreatePalletCode() {
             try {
                 const response = await fetch('?handler=GeneratePalletCode');
                 if (!response.ok) { Notify.info(L.palletGenerateError); return; }
                 const result = await response.json();
                 const newCode = result?.palletCode ?? result?.data?.palletCode;
                 if (!newCode) { Notify.info(L.palletNoResponse); return; }

                 if (currentRowIdForPallet) {
                     const rowNode = gridApi.getRowNode(currentRowIdForPallet);
                     if (rowNode) {
                         rowNode.setDataValue('pallet', newCode);
                         rowNode.data.palletSource = 'manual';
                     }
                     closePalletSearchModal();
                     Notify.info(`${L.palletCreatedAssigned} ${newCode}`);
                 } else {
                     showPalletSearchLoading();
                     const data = await fetchPallets('');
                     renderPalletTable(data);
                     Notify.info(`${L.palletCreated} ${newCode}`);
                 }
              } catch (error) {
                  console.error('Error generating pallet code:', error);
                  Notify.info(L.connectionError);
              }
         }

        document.getElementById('isStored').addEventListener('change', function(e) {
            const isChecked = e.target.checked;

            gridApi.setColumnsVisible(['location'], isChecked);

        });

        // handel Reference Order Search Modal
        const orderSearchModal = document.getElementById('orderSearchModal');
        const orderSearchResultBody = document.getElementById('orderSearchResultBody');
        const orderSearchInput = document.getElementById('orderSearchInput');

        const orderItemSelectionModal = document.getElementById('orderItemSelectionModal');
        const orderItemSelectionBody = document.getElementById('orderItemSelectionBody');

        let currentlyViewingOrder = null;
        let currentOrderItems = [];

        let poSearchAbortController = null;
        let poItemsAbortController = null;

        async function fetchPurchaseOrders(keyword = '', pageIndex = 1) {
            if (poSearchAbortController) poSearchAbortController.abort();
            poSearchAbortController = new AbortController();

            const q = new URLSearchParams({
                keyword: keyword ?? '',
                pageIndex: pageIndex.toString(),
                pageSize: '20'
            });

            const response = await fetch(`?handler=SearchPurchaseOrder&${q.toString()}`, {
                method: 'GET',
                signal: poSearchAbortController.signal
            });

            if (!response.ok) return { data: [] };
            return await response.json();
        }

        async function fetchPurchaseOrderItems(poId) {
            if (poItemsAbortController) poItemsAbortController.abort();
            poItemsAbortController = new AbortController();

            const response = await fetch(`?handler=PurchaseOrderItems&poId=${encodeURIComponent(poId)}`, {
                method: 'GET',
                signal: poItemsAbortController.signal
            });

            if (!response.ok) return { poNo: '', items: [] };
            return await response.json();
        }

        async function openOrderModal() {
            orderSearchInput.value = '';
            orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">${L.searching}</td></tr>`;
            orderSearchModal.classList.remove('hidden');

            const result = await fetchPurchaseOrders('');
            renderOrderTable(result?.data ?? []);
        }

        function closeOrderModal() {
            orderSearchModal.classList.add('hidden');
        }

        function renderOrderTable(data) {
            orderSearchResultBody.innerHTML = '';
            if (!Array.isArray(data) || data.length === 0) {
                orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">Không có Purchase Order phù hợp.</td></tr>`;
                return;
            }

            data.forEach(order => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-blue-50';
                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm font-bold text-blue-600">${order.poNo ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-600">${order.expectedDate ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-600">${order.supplierName ?? ''}</td>
                    <td class="px-6 py-3 text-right">
                        <button type="button" onclick="selectOrder(${order.id}, '${(order.poNo ?? '').replace(/'/g, "\\'")}')" class="bg-green-600 text-white px-4 py-1.5 rounded shadow-sm hover:bg-green-700 text-sm font-medium">
                            ${L.referenceBtn}
                        </button>
                    </td>
                `;
                orderSearchResultBody.appendChild(tr);
            });
        }

        orderSearchInput.addEventListener('input', debounce(async function () {
            orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">${L.searching}</td></tr>`;
            const result = await fetchPurchaseOrders(orderSearchInput.value || '');
            renderOrderTable(result?.data ?? []);
        }, 300));

        async function selectOrder(poId, poNo) {
            closeOrderModal();

            const detail = await fetchPurchaseOrderItems(poId);
            console.log('Fetched PO Items:', detail);
            currentlyViewingOrder = { id: poId, code: detail?.poNo || poNo };

            document.getElementById('selectionModalTitle').textContent = `${L.orderDetailPrefix} ${currentlyViewingOrder.code}`;
            currentOrderItems = detail?.items ?? [];
            renderItemSelectionTable(currentOrderItems);

            orderItemSelectionModal.classList.remove('hidden');
        }

        function closeOrderItemSelectionModal() {
            orderItemSelectionModal.classList.add('hidden');
        }

        function renderItemSelectionTable(items) {
            orderItemSelectionBody.innerHTML = '';
            document.getElementById('selectAllItems').checked = false;
            updateSelectedCount();

            if (!Array.isArray(items) || items.length === 0) {
                orderItemSelectionBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">PO này không còn số lượng mở để nhận.</td></tr>`;
                return;
            }

            items.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-blue-50 cursor-pointer border-b';
                tr.onclick = function (e) {
                    if (e.target.type !== 'checkbox') {
                        const cb = document.getElementById(`chk_item_${index}`);
                        cb.checked = !cb.checked;
                        updateSelectedCount();
                    }
                };

                tr.innerHTML = `
                    <td class="px-6 py-3">
                        <input type="checkbox" id="chk_item_${index}" value="${index}" onchange="updateSelectedCount()" class="item-checkbox w-4 h-4 text-blue-600 rounded">
                    </td>
                    <td class="px-6 py-3 text-sm font-bold">${item.itemCode ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${item.itemName ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-500">${item.uom ?? ''}</td>
                    <td class="px-6 py-3 text-right text-sm font-bold text-blue-600">${item.qtyOpen ?? 0}</td>
                `;
                orderItemSelectionBody.appendChild(tr);
            });
        }

        function toggleAllItems(source) {
            document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = source.checked);
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const checkedCount = document.querySelectorAll('.item-checkbox:checked').length;
            document.getElementById('selectedItemsCount').textContent = checkedCount;
            const total = document.querySelectorAll('.item-checkbox').length;
            document.getElementById('selectAllItems').checked = (checkedCount === total && total > 0);
        }

        function confirmSelectedItems() {
            const checkboxes = document.querySelectorAll('.item-checkbox:checked');
            if (checkboxes.length === 0) {
                Notify.info(L.validSelectAtLeastOneItem);
                return;
            }

            const selectedItemsToImport = [];
            checkboxes.forEach(cb => {
                const item = currentOrderItems[Number(cb.value)];
                const unitName = item.unitName ?? item.uom ?? '';
                selectedItemsToImport.push({
                    id: Math.random().toString(36).substring(2, 9),
                    skuId: item.skuId || 0,
                    skuUomId: item.skuUomId || 0,
                    itemCode: item.itemCode || '',
                    itemName: item.itemName || '',
                    uom: unitName || '',
                    unitName: unitName, 
                    qty: Number(item.qtyOpen || 0),
                    expiryDate: item.expiryDate || null,
                    location: '',
                    pallet: '',
                    referenceCode: currentlyViewingOrder?.code || '',
                    asnId: currentlyViewingOrder?.id || null
                });
            });

            gridApi.applyTransaction({ add: selectedItemsToImport });
            closeOrderItemSelectionModal();
            updateReferenceUI();
        }

        function updateReferenceUI() {
            const container = document.getElementById('referenceOrderContainer');
            const placeholder = document.getElementById('refPlaceholder');

            const uniqueOrders = new Set();
            gridApi.forEachNode(node => {
                if (node.data.referenceCode) uniqueOrders.add(node.data.referenceCode);
            });

            container.querySelectorAll('.order-chip').forEach(el => el.remove());

            if (uniqueOrders.size > 0) {
                placeholder.style.display = 'none';
                uniqueOrders.forEach(code => {
                    const chip = document.createElement('span');
                    chip.className = 'order-chip bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded-md border border-blue-200 flex items-center gap-1';
                    chip.innerHTML = `${code}`;
                    container.appendChild(chip);
                });
            } else {
                placeholder.style.display = 'block';
            }
        }

        // SUPPLIER MODAL SEARCH 
        const supplierSearchModal = document.getElementById('supplierSearchModal');
        const supplierModalSearchInput = document.getElementById('supplierModalSearchInput');
        const supplierSearchResultBody = document.getElementById('supplierSearchResultBody');
        const mainSupplierInput = document.getElementById('supplierSearch');
        const mainSupplierHiddenInput = document.getElementById('selectedSupplierId');

        let supplierSearchAbortController = null;
        let supplierCurrentPage = 1;
        const supplierPageSize = 20; 
        let supplierIsFetching = false;
        let supplierHasMoreData = true;

        async function fetchSuppliers(keyword = '', pageIndex = 1) {
            if (supplierSearchAbortController) {
                supplierSearchAbortController.abort();
            }
            supplierSearchAbortController = new AbortController();
            try {
                const keyWordParam = keyword?.trim() ? `&keyword=${encodeURIComponent(keyword.trim())}` : '';
                const url = `?handler=SearchSupplier${keyWordParam}&pageIndex=${pageIndex}&pageSize=${supplierPageSize}`;

                const response = await fetch(url, { signal: supplierSearchAbortController.signal });
                if (!response.ok) return null;
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') return null;
                console.error('Error fetching suppliers:', e);
                return [];
            }
        }

        async function openSupplierModal() {
            supplierCurrentPage = 1;
            supplierHasMoreData = true;
            supplierModalSearchInput.value = '';
            document.getElementById('supplierScrollContainer').scrollTop = 0;

            showSupplierSearchLoading();
            supplierSearchModal.classList.remove('hidden');
            setTimeout(() => supplierModalSearchInput.focus(), 100);

            supplierIsFetching = true ;
            const data = await fetchSuppliers('', supplierCurrentPage);
            supplierIsFetching = false;
            if (data !== null) {
                renderSupplierTable(data, false);
            }
        }

        function closeSupplierModal() {
            supplierSearchModal.classList.add('hidden');
            if (supplierSearchAbortController) {
                supplierSearchAbortController.abort();
                supplierSearchAbortController = null;
            }
        }

        function showSupplierSearchLoading() {
            supplierSearchResultBody.innerHTML = `
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                        <div class="flex justify-center items-center gap-2">
                            <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                           ${L.searching}
                        </div>
                    </td>
                </tr>`;
        }

        function renderSupplierTable(response , isAppend = false) {
            if (!isAppend) {
                supplierSearchResultBody.innerHTML = '';
            }
            const data = response ?? [];
            if (!Array.isArray(data) || data.length === 0) {
                if (!isAppend) {
                    supplierSearchResultBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">Không tìm thấy nhà cung cấp nào.</td></tr>`;
                }
                supplierHasMoreData = false;
                return;
            }

            if (data.length < supplierPageSize) {
                supplierHasMoreData = false;
            } else {
                supplierHasMoreData = true;
            }

            data.forEach(supplier => {
                const tr = document.createElement('tr');
             
                tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
        
                const escapedName = (supplier.supplierName ?? '').replace(/'/g, "\\'");
        
                tr.onclick = () => selectSupplier(supplier.id, escapedName);

                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm text-gray-900 truncate">${supplier.supplierName ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.address ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.city ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.email ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.contactTel ?? ''}</td>
                `;
                supplierSearchResultBody.appendChild(tr);
            });
        }

     
        const supplierScrollContainer = document.getElementById('supplierScrollContainer');
        const supplierScrollAnchor = document.getElementById('supplier-scroll-anchor');
        const supplierLoadingIndicator = document.getElementById('supplier-loading-indicator');

        const supplierObserverOptions = {
            root: supplierScrollContainer,
            rootMargin: '0px 0px 100px 0px', 
            threshold: 0
        };

        const supplierInfiniteScrollObserver = new IntersectionObserver(async (entries) => {
            const target = entries[0];

          
            if (target.isIntersecting && !supplierIsFetching && supplierHasMoreData) {
                supplierIsFetching = true;
                supplierLoadingIndicator.classList.remove('hidden'); 

                supplierCurrentPage++;
                const keyword = supplierModalSearchInput.value;

                const data = await fetchSuppliers(keyword, supplierCurrentPage);
    
                if (data !== null) {
                    renderSupplierTable(data, true); 
                }

                supplierLoadingIndicator.classList.add('hidden'); 
                supplierIsFetching = false;
            }
        }, supplierObserverOptions);

      
        supplierInfiniteScrollObserver.observe(supplierScrollAnchor);

        const debouncedSupplierSearch = debounce(async function () {
            supplierCurrentPage = 1;
            supplierHasMoreData = true;

            showSupplierSearchLoading();

            supplierIsFetching = true;
            const data = await fetchSuppliers(supplierModalSearchInput.value, supplierCurrentPage);
            supplierIsFetching = false;
           
            if (data !== null) {
                renderSupplierTable(data, false);
            }
        }, 300);

        supplierModalSearchInput.addEventListener('input', debouncedSupplierSearch);

     
        async function selectSupplier(id, name) {
            const currentSupplierId = mainSupplierHiddenInput.value.trim();

            if (currentSupplierId === id) {
                closeSupplierModal();
                return;
            }
            let hasData = false;
            if (gridApi) {
                gridApi.forEachNode(node => {
                  
                    if (node.data && node.data.itemCode && node.data.itemCode.trim() !== "") {
                        hasData = true;
                    }
                });
            }

            if (currentSupplierId !== "" && hasData) {
            const isConfirm = await Notify.confirm(
            "Xác nhận thay đổi",
            "Thay đổi Nhà cung cấp sẽ xóa toàn bộ danh sách hàng hóa hiện tại. Bạn có chắc chắn muốn đổi?",
            "Đồng ý đổi"
            );

            if (!isConfirm) {
                closeSupplierModal();
                return;
            }
            clearGridData();
            } else if (currentSupplierId !== "" && !hasData) {         
                clearGridData();
            }

        
            mainSupplierInput.value = name;
            mainSupplierHiddenInput.value = id;
            closeSupplierModal();
        }


        function clearGridData() {
            if (gridApi) {
                const initRecord = { 
                    id: Math.random().toString(36).substring(2, 9), 
                    itemCode: "", 
                    itemName: "", 
                    uom: "", 
                    qty: null,
                    expiryDate: null,
                    referenceCode: ""
                };
               
                gridApi.setGridOption('rowData', [initRecord]);
       
            }
        }

        // Retry Inbound Task

       async function retryInboundTask() {
            const receiptId = document.getElementById('receiptId')?.value || 0; 

            const errorItems = [];
            const missingInputItems = []; 

            if (typeof gridApi !== 'undefined') {
                gridApi.forEachNode(node => {
                    const row = node.data;
            
                 
                    if (row && row.isException) {
                        const locId = parseInt(row.locationId) || 0;
                        const pallet = (row.pallet || '').toString().trim();

                      
                        if (locId === 0 || pallet === '') {
                            missingInputItems.push(row.itemCode || row.itemName || `Dòng ${node.rowIndex + 1}`);
                        } else {
                            errorItems.push({
                                DetailId: row.detailDbId, 
                                LocationId: locId,
                                PalletCode: pallet
                            });
                        }
                    }
                });
            }

           
            if (missingInputItems.length > 0) {
                Notify.info(`Vui lòng chọn Vị trí và nhập Pallet mới cho các mã hàng: ${missingInputItems.join(', ')} trước khi Thử lại!`);
                return; 
            }

            if (errorItems.length === 0) {
                Notify.info("Không tìm thấy dòng hàng nào bị lỗi cần thử lại.");
                return;
            }

           
            const requestData = {
                ReceiptId: parseInt(receiptId),
                Items: errorItems
            };

            try {
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';

                const response = await fetch('?handler=RetryInboundTask', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(requestData)
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();

                if (result.success) {
                    Notify.info("Đã gửi lệnh thử lại xuống WCS thành công!");
            
                   setTimeout(() => {
                        window.location.href = `/Inbound/Receipt/Detail/${receiptId}`;
                    }, 1000)
                } else {
                    Notify.info(result.message || "Xử lý thử lại thất bại.");
                }

            } catch (error) {
                console.error("Lỗi khi gọi RetryInboundTask:", error);
                Notify.info("Lỗi kết nối đến máy chủ.");
            }
        }
    </script>
}