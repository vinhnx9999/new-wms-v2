        function formatText(template, ...args) {
            return template.replace(/\{(\d+)\}/g, (_, index) => args[index] ?? '');
       }

       function toIsoDateOnly(value) {
            if (!value) return null;
    
 
            if (value instanceof Date && !isNaN(value.getTime())) return toLocalIsoDate(value); 
    
            const text = value.toString().trim();
            if (!text) return null;

       
            const isoMatch = text.match(/^(\d{4}-\d{2}-\d{2})/);
            if (isoMatch) return isoMatch[1]; 

        
            const vn = text.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (vn) return `${vn[3]}-${vn[2]}-${vn[1]}`;

            const d = new Date(text);
            if (!isNaN(d.getTime())) return toLocalIsoDate(d);

            return null;
        }

        function toDisplayDate(value) {
            const iso = toIsoDateOnly(value);
            if (!iso) return '';
    
            const parts = iso.split('-');
            if (parts.length !== 3) return '';
    
            return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        async function saveReceipt(isUpgradeStatus = false) {
            const receiptId = document.getElementById('receiptId').value;
            const isStoredChecked = document.getElementById('isStored').checked;
            const receiptNumber = document.getElementById('receiptNumber').value.trim();
            const receiptDate = document.getElementById('receiptDate').value.trim();
            const warehouseId = document.getElementById('selectedWarehouseId').value.trim();
            const receiptType = document.getElementById('receiptType').value;
            const supplierId = document.getElementById('selectedSupplierId').value.trim();
            const description = document.getElementById('message')?.value?.trim() ?? '';
            const deliverer = document.getElementById('deliverer')?.value?.trim() ?? '';
            const invoiceNumber = document.getElementById('invoiceNumber')?.value?.trim() ?? '';
            const expectedDeliveryDate = document.getElementById('expectedDeliveryDate')?.value?.trim() ?? '';                
            const txtMultiPallets = document.getElementById('txtMultiPallets').value?.trim() ?? '';

            if (!receiptNumber) { Notify.info(L.validReceiptNo); return; }
            if (!receiptDate) { Notify.info(L.validReceiptDate); return; }
            if (!receiptType) { Notify.info(L.validReceiptType); return; }
            if (!warehouseId) { Notify.info(L.validWarehouse); return; }
            if (!supplierId) { Notify.info(L.validSupplier); return; }
                      
            let multiPallets = txtMultiPallets === "MultiPallets";               
            console.log("txtMultiPallets", txtMultiPallets, "ssss", multiPallets);

            const details = [];
            const invalidExpiryRows = [];
            const invalidQtyRows = [];
            const missingLocationPalletRows = [];

            gridApi.forEachNode(node => {
                const row = node.data;
                if (!row.itemCode) return; 

                 const qty = Number(row.qty);
                 if (!Number.isFinite(qty) || qty <= 0) {
                     invalidQtyRows.push(row.itemCode || row.itemName || node.id);
                     return;
                 }

                const expiryIso = toIsoDateOnly(row.expiryDate ?? row.expireDate ?? row.expiredDate);
                // if (!expiryIso) {
                //     invalidExpiryRows.push(row.itemCode || row.itemName || node.id);
                //     return;
                // }
                      
                if (isUpgradeStatus && isStoredChecked && !multiPallets) {                              
                    if (!row.locationId || !row.pallet) {
                        missingLocationPalletRows.push(row.itemCode || row.itemName);
                    }
                }

                const detail = {
                     id: row.detailDbId || 0, 
                     skuId: row.skuId || 0,
                     quantity: row.qty || 0,
                     skuUomId: row.skuUomId || 0,
                     locationId: isStoredChecked ? (parseInt(row.locationId) || 1) : 1,
                     locationName: (row.location || '').toString().trim(),
                     palletCode: isStoredChecked ? (row.pallet || null) : null,
                     expiryDate: expiryIso,
                     asnId: row.asnId || null,
                     sourceNumber: row.referenceCode || null
                 };
                 details.push(detail);
            });

            if (invalidQtyRows.length > 0) { Notify.info(formatText(L.validQtyPerItem, invalidQtyRows.join(', '))); return; }
            if (details.length === 0) { Notify.info(L.msgAddAtLeastOneItem); return; }
            if (invalidExpiryRows.length > 0) { 
                Notify.info(formatText(L.validExpiryPerItem, invalidExpiryRows.join(', '))); 
                return; 
            }
            if (missingLocationPalletRows.length > 0) {
                Notify.info(`Vui lòng nhập đầy đủ Vị trí và Mã Pallet cho các mã hàng: ${missingLocationPalletRows.join(', ')} trước khi chốt phiếu!`);
                return;
            }

            if (isStoredChecked) {
                const check = validatePalletLocationMapping(details);
                if (!check.isValid) {
                    if (check.type === 'pallet-multi-location') {
                        Notify.info(formatText(L.palletLocationConflict, check.palletCode, check.firstLocationName, check.conflictLocationName));
                    } else {
                        Notify.info(formatText(L.locationPalletConflict ?? 'Vị trí {0} đang gán nhiều pallet ({1} và {2}).', check.locationName, check.firstPalletCode, check.conflictPalletCode));
                    }
                    return;
                }
            }
             
            const parts = receiptDate.split('/');            
            const isoDate = parts.length === 3 ? `${parts[2]}-${parts[1]}-${parts[0]}` : null;

            const expParts = expectedDeliveryDate.split('/');
            const expectedDeliveryIso =  expParts.length === 3 ? `${expParts[2]}-${expParts[1]}-${expParts[0]}` : null;

             const request = {
                 id: parseInt(receiptId),
                 receiptNo: receiptNumber,
                 warehouseId: parseInt(warehouseId),
                 supplierId: parseInt(supplierId),
                 description: description,
                 type: receiptType,
                 isStored: isStoredChecked,
                 createdDate: isoDate,
                 isUpgradeStatus : isUpgradeStatus,
                 deliverer: deliverer,
                 invoiceNumber: invoiceNumber ,
                 expectedDeliveryDate : expectedDeliveryIso,
                 details: details,                   
                 multiPallets: multiPallets
             };

             try {
               
                 const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                 const response = await fetch(`?handler=UpdateReceipt&id=${receiptId}`, {
                    method: 'POST', 
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(request)
                });

                 const result = await response.json();

                 if (result.success) {
                     Notify.info("Lưu thay đổi thành công!");
                     window.location.href = `/Inbound/Receipt/Detail/${receiptId}`;
                 } else {
                     Notify.info(result.message || "Đã xảy ra lỗi khi lưu.");
                 }
             } catch (error) {
                 console.error("Error updating receipt:", error);
                 Notify.info(L.connectionError);
             }
        }

        function validatePalletLocationMapping(details) {
            const palletToLocationMap = new Map();
            const locationToPalletMap = new Map();

            for (const d of details) {
                const palletCode = (d.palletCode ?? '').toString().trim().toUpperCase();
                const locationId = Number(d.locationId ?? 0);
                const locationName = (d.locationName ?? '').toString().trim();

                if (!palletCode || locationId <= 0) continue;
             
                if (palletToLocationMap.has(palletCode)) {
                    const first = palletToLocationMap.get(palletCode);
                    if (first.locationId !== locationId) {
                        return { isValid: false, type: 'pallet-multi-location', palletCode, firstLocationId: first.locationId, firstLocationName: first.locationName || first.locationId, conflictLocationId: locationId, conflictLocationName: locationName || locationId };
                    }
                } else {
                    palletToLocationMap.set(palletCode, { locationId, locationName });
                }
               
                if (locationToPalletMap.has(locationId)) {
                    const first = locationToPalletMap.get(locationId);
                    if (first.palletCode !== palletCode) {
                        return { isValid: false, type: 'location-multi-pallet', locationId, locationName: first.locationName || locationName || locationId, firstPalletCode: first.palletCode, conflictPalletCode: palletCode };
                    }
                } else {
                    locationToPalletMap.set(locationId, { palletCode, locationName });
                }
            }
            return { isValid: true };
        }

