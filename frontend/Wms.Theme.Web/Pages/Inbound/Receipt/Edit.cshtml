@page "/Inbound/Receipt/Edit/{id:int}"
@model Wms.Theme.Web.Pages.Inbound.Receipt.EditModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Edit"];
    var currentStatus = Model.Receipt.Status;

    Dictionary<int, string> palletStatus = new Dictionary<int, string>
    {
        { 1, Localizer["CreateReceipt_PalletStatusAvailable"] },
        { 2, Localizer["CreateReceipt_PalletStatusOccupied"] },
    };
}
@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
}

@Html.AntiForgeryToken()

<input type="hidden" id="receiptId" value="@Model.Receipt.Id" />
<input type="hidden" id="txtMultiPallets" value="@Model.MultiPallets" />

<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div class="flex items-center justify-start mb-2 pb-2">
        @await Html.PartialAsync("_StatusPartialView", currentStatus)
    </div>
    <div class="flex justify-end gap-3 mb-2 pb-2">
        <a href="/Inbound/Receipt"
           class="inline-block px-6 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors font-medium text-center">
            @Localizer["Common_Back"]
        </a>

        @if (Model.Receipt.Status == 0) // 0: DRAFT
        {
            <button type="button" onclick="saveReceipt(false)"
                    class="px-6 py-2 bg-blue-50 text-blue-700 border border-blue-200 rounded-md hover:bg-blue-100 transition-colors font-medium">
                @Html.Raw(Localizer["Save_Draft"])
            </button>

            <button type="button" onclick="saveReceipt(true)"
                    class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium flex items-center gap-2">
                @Html.Raw(Localizer["CreateReceipt_Save"])
            </button>
        }
        else if (Model.Receipt.Status == 2 && Model.Receipt.Details.Any(x => x.IsException))
        {
            <button type="button" onclick="retryInboundTask()"
                    class="px-6 py-2 bg-yellow-500 text-white rounded-md hover:bg-yellow-600 shadow-md transition-colors font-medium">
                @Html.Raw(Localizer["Retry"])
            </button>
        }
        else
        {
            <button type="button" onclick="saveReceipt(false)"
                    class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium">
                @Html.Raw(Localizer["Save"])
            </button>
        }
    </div>
</div>
<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        
        <div>
            <label for="receiptNumber" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptNumber"] <span class="text-red-500">*</span>
            </label>
            <input type="text" id="receiptNumber" name="receiptNumber" readonly
                   value="@Model.Receipt.ReceiptNo"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 cursor-not-allowed focus:outline-none transition-colors">
        </div>

        <div>
            <label for="receiptDate" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptDate"] <span class="text-red-500">*</span>
            </label>
            <input type="text" id="receiptDate" name="receiptDate"
                   value="@(Model.Receipt.CreatedDate?.ToString("dd/MM/yyyy"))" disabled readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 cursor-not-allowed focus:outline-none transition-colors">
        </div>

        <div>
            <label for="receiptType" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptType"] <span class="text-red-500">*</span>
            </label>
            <select id="receiptType" name="receiptType" class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
                <option value="PURCHASE" selected="@(Model.Receipt.Type == "PURCHASE")">@Localizer["CreateReceipt_TypePurchase"]</option>
                <option value="RETURN" selected="@(Model.Receipt.Type == "RETURN")">@Localizer["CreateReceipt_TypeReturn"]</option>
                <option value="TRANSFER" selected="@(Model.Receipt.Type == "TRANSFER")">@Localizer["CreateReceipt_TypeTransfer"]</option>
                <option value="MISC" selected="@(Model.Receipt.Type == "MISC")">@Localizer["CreateReceipt_TypeMisc"]</option>
            </select>
        </div>

        <div>
            <label for="warehouseSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_Warehouse"] <span class="text-red-500">*</span>
            </label>
            <div class="flex">
                <div class="relative flex-1">
                    <input type="text" id="warehouseSearch" autocomplete="off" spellcheck="false"
                           value="@Model.Receipt.WarehouseName"
                           placeholder="@Localizer["CreateReceipt_SearchWarehouse"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">

                    <input type="hidden" id="selectedWarehouseId" name="selectedWarehouseId" value="@Model.Receipt.WarehouseId" />
                    <ul id="warehouseDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto [&::-webkit-scrollbar]:w-1.5">
                    </ul>
                </div>

                <button type="button" title="@Localizer["CreateReceipt_AddWarehouse"]" onclick="openWarehouseModal()" class="px-3 py-1.5 bg-gray-50 border border-gray-300 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>

        <div class="relative">
            <label for="supplierSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["Supplier"] <span class="text-red-500">*</span>
            </label>

            <div class="flex">
                <div class="relative flex-1 cursor-pointer" onclick="openSupplierModal()">
                    <input type="text" id="supplierSearch" readonly
                           value="@Model.Receipt.SupplierName"
                           placeholder="@Localizer["Enter"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white cursor-pointer pr-8">
                   
                </div>

                <button type="button"
                        title="@Localizer["AddNew"]"
                        onclick="event.stopPropagation(); openSupplierAddModal();"
                        class="px-2 py-1.5 bg-gray-50 border border-gray-300 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>

            <input type="hidden" value="@Model.Receipt.SupplierId" id="selectedSupplierId" name="supplierId">
        </div>


        <div class="flex items-center pt-5">
            @{
                var disableIsStored = currentStatus > 0;
            }
            <div class="flex items-center h-5">
                <input id="isStored" name="isStored" type="checkbox"
                @(Model.Receipt.IsStored ? "checked" : "")
                @(disableIsStored ? "disabled" : "")
                       class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 @(disableIsStored ? "cursor-not-allowed opacity-60 bg-gray-50" : "cursor-pointer")">
            </div>
            <div class="ml-2 text-xs">
                <label for="isStored" class="font-medium text-gray-700 @(disableIsStored ? "cursor-not-allowed" : "cursor-pointer")">
                    @Localizer["CreateReceipt_IsStored"]
                </label>
            </div>
        </div>

        <div>
            <label for="deliverer" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["Deliverer"]
            </label>
            <input type="text"
                   id="deliverer"
                   name="deliverer"
                   placeholder=""
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="invoiceNumber" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["InvoiceNumber"]
            </label>
            <input type="text"
                   id="invoiceNumber"
                   name="invoiceNumber"
                   placeholder=""
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["ExpectedDeliveryDate"]
            </label>
            <input type="text" value="@(Model.Receipt.ExpectedDeliveryDate?.ToString("dd/MM/yyyy"))" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div class="md:col-span-3">
            <label for="message" class="block mb-1 text-xs font-medium text-gray-700">
                @Localizer["AddNote"]
            </label>
            <textarea id="message" name="message" rows="2" placeholder="@Localizer["EnterNote"]" class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white resize-none">@Model.Receipt.Description</textarea>
        </div>

        <div class="md:col-span-3">
            <label class="block text-xs font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_Reference"]</label>
            <div class="flex items-stretch">
                <div id="referenceOrderContainer" onclick="openOrderModal()" class="flex-1 px-3 py-1.5 border border-gray-300 border-r-0 rounded-l-md bg-gray-50 flex flex-wrap gap-2 items-center cursor-pointer focus-within:ring-2 focus-within:ring-blue-500 transition-all">
                    <span id="refPlaceholder" class="text-gray-400 text-sm italic leading-5">@Localizer["CreateReceipt_ReferencePlaceholder"]</span>
                </div>
                <button type="button" onclick="openOrderModal()" class="px-3 bg-blue-50 border border-blue-200 border-l-0 rounded-r-md text-blue-600 hover:bg-blue-100 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>
            </div>
        </div>

    </div>
</div>
<div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold text-gray-800">@Localizer["CreateReceipt_ItemDetails"]</h2>
    <button type="button" onclick="addRow()" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 shadow-sm transition-colors flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
        @Localizer["CreateReceipt_AddRow"]
    </button>
</div>

<div id="myGrid" class="ag-theme-quartz" style="height: 400px; width: 100%;"></div>

<!--Modal Warehouse-->
@await Html.PartialAsync("Warehouses/_WarehouseModal")
<!--Modal search Sku Item-->
@await Html.PartialAsync("Inbound/_SkuSearchModal")
<!--Modal locations-->
@await Html.PartialAsync("Inbound/_LocationModal")
<!--Pallet Search Modal-->
@await Html.PartialAsync("Inbound/_PalletSearchModal")
<!--Modal Search Inbound Order-->
@await Html.PartialAsync("Inbound/_SearchInboundOrderModal")
<!--Supplier Search Modal-->
@await Html.PartialAsync("Inbound/_SupplierSearchModal")
<!--Add Supplier Modal-->
@await Html.PartialAsync("Inbound/_AddSupplierModal")

@section Scripts {
    <script>
        // Localized strings for JavaScript
        const L = {
            colItemCode: '@Html.Raw(Localizer["CreateReceipt_ColItemCode"])',
            colItemName: '@Html.Raw(Localizer["CreateReceipt_ColItemName"])',
            colUom: '@Html.Raw(Localizer["CreateReceipt_ColUom"])',
            colQuantity: '@Html.Raw(Localizer["CreateReceipt_ColQuantity"])',
            colLocation: '@Html.Raw(Localizer["CreateReceipt_ColLocation"])',
            colPalletCode: '@Html.Raw(Localizer["CreateReceipt_ColPalletCode"])',
            colReference: '@Html.Raw(Localizer["CreateReceipt_ColReference"])',
            colActions: '@Html.Raw(Localizer["CreateReceipt_ColActions"])',
            noWarehouseFound: '@Html.Raw(Localizer["CreateReceipt_NoWarehouseFound"])',
            noItemFound: '@Html.Raw(Localizer["CreateReceipt_NoItemFound"])',
            searching: '@Html.Raw(Localizer["CreateReceipt_Searching"])',
            clickToSearchItem: '@Html.Raw(Localizer["CreateReceipt_ClickToSearchItem"])',
            loadingLocationMap: '@Html.Raw(Localizer["CreateReceipt_LoadingLocationMap"])',
            locationLoadError: '@Html.Raw(Localizer["CreateReceipt_LocationLoadError"])',
            noLocationData: '@Html.Raw(Localizer["CreateReceipt_NoLocationData"])',
            locationEmpty: '@Html.Raw(Localizer["CreateReceipt_LocationEmpty"])',
            searchingPallet: '@Html.Raw(Localizer["CreateReceipt_SearchingPallet"])',
            noPalletFound: '@Html.Raw(Localizer["CreateReceipt_NoPalletFound"])',
            select: '@Html.Raw(Localizer["Common_Select"])',
            referenceBtn: '@Html.Raw(Localizer["CreateReceipt_ReferenceBtn"])',
            orderDetailPrefix: '@Html.Raw(Localizer["CreateReceipt_OrderDetailPrefix"])',
            deleteRowTitle: '@Html.Raw(Localizer["CreateReceipt_DeleteRowTitle"])',
            validReceiptNo: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptNo"])',
            validReceiptDate: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptDate"])',
            validReceiptType: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptType"])',
            validWarehouse: '@Html.Raw(Localizer["CreateReceipt_ValidWarehouse"])',
            validAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidAtLeastOneItem"])',
            saveSuccess: '@Html.Raw(Localizer["CreateReceipt_SaveSuccess"])',
            saveFailed: '@Html.Raw(Localizer["CreateReceipt_SaveFailed"])',
            connectionError: '@Html.Raw(Localizer["Common_ConnectionError"])',
            validWhName: '@Html.Raw(Localizer["CreateReceipt_ValidWhName"])',
            validWhCity: '@Html.Raw(Localizer["CreateReceipt_ValidWhCity"])',
            validWhAddress: '@Html.Raw(Localizer["CreateReceipt_ValidWhAddress"])',
            whSaveSuccess: '@Html.Raw(Localizer["CreateReceipt_WhSaveSuccess"])',
            whSaveFailed: '@Html.Raw(Localizer["CreateReceipt_WhSaveFailed"])',
            validSelectWhFirst: '@Html.Raw(Localizer["CreateReceipt_ValidSelectWhFirst"])',
            palletGenerateError: '@Html.Raw(Localizer["CreateReceipt_PalletGenerateError"])',
            palletNoResponse: '@Html.Raw(Localizer["CreateReceipt_PalletNoResponse"])',
            palletCreatedAssigned: '@Html.Raw(Localizer["CreateReceipt_PalletCreatedAssigned"])',
            palletCreated: '@Html.Raw(Localizer["CreateReceipt_PalletCreated"])',
            validSelectAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidSelectAtLeastOneItem"])',
            validWhContactTel: '@Html.Raw(Localizer["CreateReceipt_ValidWhContactTel"])',
            palletLocationConflict: '@Html.Raw(Localizer["CreateReceipt_PalletLocationConflict"])',
            msgAddAtLeastOneItem : '@Html.Raw(Localizer["CreateReceipt_MsgAddAtLeastOneItem"])',
            validSupplier: '@Html.Raw(Localizer["CreateReceipt_ValidSupplier"])',
            validQtyPerItem: '@Html.Raw(Localizer["CreateReceipt_ValidQtyPerItem"])',      
            validExpiryPerItem: '@Html.Raw(Localizer["CreateReceipt_ValidExpiryPerItem"])', 
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>

        // Util State Function
        function debounce (fn , delay){
            let timer; 
            return function (...args) {
                clearTimeout(timer);
                timer = setTimeout(() => fn.apply(this, args), delay);
            };
        }

        const existingDetails = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Receipt.Details));
        const isStoredOnLoad = document.getElementById('isStored').checked;

        let mappedRowData = [];
        if (existingDetails && existingDetails.length > 0) {
            mappedRowData = existingDetails.map(item => ({
                id: Math.random().toString(36).substring(2, 9), 
                detailDbId: item.Id || item.id || 0, 
                skuId: item.SkuId || item.skuId,
                itemCode: item.SkuCode || item.skuCode ,
                itemName: item.SkuName || item.skuName,
                uom: item.UnitName || item.unitName,
                skuUomId: item.SkuUomId || item.skuUomId || 0,
                qty: item.Quantity || item.quantity,
                locationId: item.LocationId || item.locationId,
                location: item.LocationName || item.locationName || '',
                pallet: item.PalletCode || item.palletCode || '',
                expiryDate: item.ExpiryDate || item.expiryDate,
                isException : item.IsException || item.isException || false,
            }));
        } else {
            mappedRowData = [{ id: "row-init", detailDbId: 0, itemCode: "", itemName: "", uom: "", qty: null }];
        }

        // Handle for Warehouse Search Dropdown
        let warehouses = [];
        const searchInput = document.getElementById('warehouseSearch');
        const dropdown = document.getElementById('warehouseDropdown');
        const selectedWarehouseIdInput = document.getElementById('selectedWarehouseId');
        let currentAbortController = null;
        
        async function fetchWarehouses(keyword = '' , pageIndex = 1){            
            if (currentAbortController) currentAbortController.abort(); 
            currentAbortController = new AbortController();
            try {
               const keyWordParam = keyword?.trim() ? `&keyWord=${encodeURIComponent(keyword.trim())}` : ''; 
                const url = `?handler=SearchWareHouse${keyWordParam}&pageIndex=${pageIndex}`;          
                const response = await fetch(url , { signal : currentAbortController.signal });
                if (!response.ok) return [];
                return await response.json();
            } catch (e) {
               if (e.name === 'AbortError') return null; 
                console.error('Error fetching warehouses:', e);
                return [];
            }
        }

        function renderDropdown(data) {
            if(data === null) return;
            if(!Array.isArray(data)) return;
            dropdown.innerHTML = '';
            if (data.length === 0) {
                dropdown.innerHTML = `<li class="px-4 py-2 text-gray-500 text-sm">${L.noWarehouseFound}</li>`;
                dropdown.classList.remove('hidden');
                return;
            }
            data.forEach(wh => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = `${wh.warehouseName}`
                li.onclick = () => {
                    searchInput.value = wh.warehouseName; 
                    selectedWarehouseIdInput.value = wh.id;
                    dropdown.classList.add('hidden');
                };
                dropdown.appendChild(li);
            });
             dropdown.classList.remove('hidden');
        }

        const debouncedSearch = debounce(async function () {
            const data = await fetchWarehouses(searchInput.value);
            renderDropdown(data);
        }, 300);    

        searchInput.addEventListener('input', debouncedSearch);
            
        searchInput.addEventListener('focus', async function () {
            if (!dropdown.classList.contains('hidden')) return;
            const data = await fetchWarehouses(this.value);
            renderDropdown(data);
        });

        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });

        class FlatpickrCellEditor {
            init(params) {
                this.params = params;
                const today = new Date();
                
                const todayIso = toLocalIsoDate(today);
                const rawIso = toIsoDateOnly(params.value);         
                this.selectedIso = rawIso || '';

                this.eInput = document.createElement('input');
                this.eInput.type = 'text';
                this.eInput.className = 'w-full h-full px-2 outline-none bg-transparent dark:text-gray-200';
                this.eInput.value = this.selectedIso ? toDisplayDate(this.selectedIso) : '';

                this.fp = flatpickr(this.eInput, {
                    dateFormat: "d/m/Y",
                    allowInput: false,
                    disableMobile: true,              
                    minDate: today,
                    defaultDate: rawIso ? new Date(rawIso) : today,
    
                    onReady: function(selectedDates, dateStr, instance) {
                        if (instance.calendarContainer) {
                            instance.calendarContainer.classList.add('ag-custom-component-popup');
                          
                        }
                    },
    
                    onChange: (selectedDates) => {
                    
                
                        if (selectedDates?.length) {
                            this.selectedIso = toLocalIsoDate(selectedDates[0]);

                        }
                
                     
                        setTimeout(() => this.params.stopEditing(), 0);
                        }
                    });
            }
            getGui() { return this.eInput; }
            afterGuiAttached() { setTimeout(() => { this.eInput.focus(); this.fp.open(); }, 0); }
            getValue() { 
              
                return this.selectedIso; 
            }
            isPopup() { return false; }
            destroy() { this.fp?.destroy(); }
        }


        function toLocalIsoDate(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        // Global Grid State
        let gridApi; 
        const columnDefs = [
            { 
                headerName: L.colItemCode, 
                field: "itemCode", 
                flex: 1.5, 
                  pinned : "left",
                editable: false, 
                cellClass: 'hover:bg-blue-50 transition-colors cursor-pointer',
                cellRenderer: function(params) {
                    const displayValue = params.value ? 
                        `<span class="font-medium text-blue-700">${params.value}</span>` : 
                        `<span class="text-gray-400 italic"></span>`;
                    return `
                          <div class="flex justify-between items-center w-full h-full" onclick="openItemSearchModal('${params.node.id}')" title="${L.clickToSearchItem}">
                            <div class="truncate pr-2">${displayValue}</div>   
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-1 flex-shrink-0 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                             </svg>
                        </div>
                    `;
                }
            },
            { 
                headerName: L.colItemName,
                field: "itemName",
                flex: 2,
                editable: false,
                wrapText : true,
                autoHeight : true,
                cellClass: 'py-3 px-3 leading-tight' },
            { 
                headerName: L.colUom, field: "uom", flex: 1, editable: false , 
                cellRenderer: function(params) {
                    return `<div class="flex items-center h-full w-full">${params.value || ''}</div>`;
                }
            },
            { 
                headerName: L.colQuantity,
                field: "qty",
                flex: 1,
                editable: true,
                cellEditor: 'agNumberCellEditor' , 
                cellEditorParams: { min: 0.001, step: 'any' },
                valueParser: function(params) {
                    const num = parseFloat(params.newValue);
                    if (isNaN(num) || num <= 0) return null;
                    return num;
                },
                cellClass: 'bg-blue-50 border border-blue-100 cursor-text font-semibold text-blue-700',
                cellRenderer: function(params) {
                    const val = params.value !== undefined && params.value !== null ? params.value : '';
                    return `<div class="flex items-center h-full w-full">${val}</div>`;
                }
            },
            { 
                headerName: L.colLocation, field: "location", width: 150, editable: false, hide: !isStoredOnLoad, 
