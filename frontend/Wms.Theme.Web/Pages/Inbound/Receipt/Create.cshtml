        async function saveNewWarehouse() {
             const name = document.getElementById('newWhName').value.trim();
             const city = document.getElementById('newWhCity').value.trim();
             const address = document.getElementById('newWhAddress').value.trim();
             const manager = document.getElementById('newWhManager').value.trim();
             const email = document.getElementById('newWhEmail').value.trim();
             const contactTel = document.getElementById('newWhContactTel').value.trim();

             if (!name) {
                Notify.info(L.validWhName);
                return;
             }
             if (!city) {
                Notify.info(L.validWhCity);
                return;
             }
             if (!address) {
                Notify.info(L.validWhAddress);
                return;
             }
             if (contactTel ){
                const phoneRegex = /^[+]?[(]?[0-9]{1,4}[)]?[-\s./0-9]*$/;
                if (!phoneRegex.test(contactTel)) {
                    Notify.info(L.validWhContactTel);
                    return;
                }
             }

             const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

             try {
                 const response = await fetch('?handler=AddWareHouse', {
                     method: 'POST',
                     headers: {
                         'Content-Type': 'application/json',
                         'RequestVerificationToken': token
                     },
                     body: JSON.stringify({
                         warehouseName: name,
                         city: city,
                         address: address,
                         email: email,
                         manager: manager,
                         contactTel: contactTel
                     })
                 });

                 const result = await response.json();

                 if (result.success) {
                     Notify.info(L.msgCreateWarehouseSuccess);
                     searchInput.value = name;
                     selectedWarehouseIdInput.value = result.id ?? '';
                     closeWarehouseModal();
                 } else {
                     Notify.info(result.message || L.msgCreateWarehouseFail);
                 }
             } catch (error) {
                 console.error('Error saving warehouse:', error);
                 Notify.info(L.msgConnectionError);
             }
        }

