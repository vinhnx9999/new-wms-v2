        async function fetchLocationsFromServer(warehouseId , qty, skuId) {
            locationGridContainer.innerHTML = `
                <div class="col-span-full text-center text-gray-500 py-8 flex justify-center items-center gap-2">
                    <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        ${L.loadingLocationMap}
                </div>`;

            if(locationFetchAbortController) {
                locationFetchAbortController.abort();
            }

            locationFetchAbortController = new AbortController();
            try {
                
                 const supplierId = document.getElementById('selectedSupplierId').value.trim();
                //SearchLocationWithSku                        
                 const params = {
                       warehouseId: warehouseId,
                       qty: qty,                         
                       skuId: skuId,                          
                       supplierId: parseInt(supplierId)
                 };                           

                const queryString = Object.keys(params)
                    .map(key => `&${encodeURIComponent(key)}=${encodeURIComponent(params[key])}`)
                    .join("&");
                    
                     //const url = `?handler=SearchLocationWithPallet&warehouseId=${encodeURIComponent(warehouseId)}&qty=${encodeURIComponent(qty)}&skuId=${encodeURIComponent(skuId)}`;
                    const url = `?handler=SearchLocationWithSku${queryString}`;
                
                    const response = await fetch(url, {
                        signal: locationFetchAbortController.signal
                    });
                 
                    if (!response.ok){
                         locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">${L.validLocationLoadError}</div>`;
                        return;
                    }

                    const data = await response.json();

                    const mapped = (data ?? []).map(item => {
                        const hasPallet = item.palletCode && item.palletCode !== '';
                        return {
                            locationId: item.goodLocationId,
                            locCode: item.goodLocationName,
                            palletCode: item.palletCode || '',
                            items: item.items ?? [],
                            status: hasPallet ? 'has-pallet' : 'empty',
                            available: item.availableQuantity
                        };
                    });

                    renderLocationBlocks(mapped);
            } catch (e) {
                if (e.name === 'AbortError') return;
                console.error('Error fetching locations:', e);
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">${L.connectionError}</div>`;
            }
        }

        function renderLocationBlocks(data) {
            locationGridContainer.innerHTML = '';

            if(!data || data.length === 0) {
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-gray-500 py-8">${L.noLocationData}</div>`;
                return;
            }
             let totalAvailable = 0;
            data.forEach(item => {
                const isEmpty = item.status === 'empty';
                const hasPallet = item.status === 'has-pallet';

                const baseClass = "border-2 rounded-lg p-3 text-center transition-all duration-200 flex flex-col justify-center items-center relative ";

                let styleClass;
                if (isEmpty) {
                    styleClass = "border-green-400 bg-green-50 hover:bg-green-100 hover:shadow-md hover:-translate-y-1 cursor-pointer h-24";
                } else if (hasPallet) {
                    styleClass = "border-blue-300 bg-blue-50/50 cursor-not-allowed opacity-80 h-24";
                } else {
                    styleClass = "border-gray-200 bg-gray-100 opacity-60 cursor-not-allowed h-24";
                }

                const block = document.createElement('div');
                block.className = baseClass + styleClass + " group";

                if (isEmpty) {
                    block.onclick = () => selectLocation(item.locationId, item.locCode, item.palletCode);
                }

                if (hasPallet && item.items && item.items.length > 0) {
                    const tipItems = item.items;
                    const tipPallet = item.palletCode;
                    block.addEventListener('mouseenter', e => showLocationTooltip(e, tipPallet, tipItems));
                    block.addEventListener('mouseleave', hideLocationTooltip);
                }

                const dotColor = isEmpty ? 'bg-green-500' : 'bg-blue-500';
                const nameColor = isEmpty ? 'text-green-700' : 'text-blue-700';
                const subColor = isEmpty ? 'text-green-600' : 'text-blue-600';
                const label = isEmpty ? '@Html.Raw(L["Empty"])' : item.palletCode;

                block.innerHTML = `
                    <div class="absolute top-1.5 right-1.5 w-2 h-2 rounded-full ${dotColor} ${isEmpty ? 'animate-pulse' : ''}"></div>
                    <span class="text-sm font-bold ${nameColor} leading-tight">${item.locCode}</span>
                    <span class="text-[10px] font-medium ${subColor}">${label}</span>
                    <span class="text-[10px] font-medium ${subColor}">available ${item.available}</span>
                `;

                locationGridContainer.appendChild(block);
            });
        }


        let activeTooltipEl = null;

        function showLocationTooltip(e, palletCode, items) {
            hideLocationTooltip();
            const tip = document.createElement('div');
            tip.id = 'loc-floating-tooltip';
            tip.innerHTML = `
                <div style="font-weight:700;color:#1d4ed8;font-size:13px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin-bottom:6px;">${palletCode}</div>
                ${items.map(i => `
                    <div style="display:flex;justify-content:space-between;gap:24px;padding:2px 0;">
                        <span style="color:#374151;">${i.skuName}</span>
                        <span style="color:#1d4ed8;font-weight:700;">${i.qty}</span>
                    </div>`).join('')}
            `;
            Object.assign(tip.style, {
                position:'fixed', zIndex:'9999', background:'#fff',
                border:'1px solid #e5e7eb', borderRadius:'8px',
                boxShadow:'0 10px 25px rgba(0,0,0,.15)',
                padding:'10px 14px', fontSize:'12px',
                pointerEvents:'none', width:'max-content', maxWidth:'460px'
            });
            document.body.appendChild(tip);
            activeTooltipEl = tip;

            const rect = e.currentTarget.getBoundingClientRect();
            const tipRect = tip.getBoundingClientRect();
            let top = rect.top - tipRect.height - 8;
            if (top < 4) top = rect.bottom + 8;
            let left = rect.left + rect.width / 2 - tipRect.width / 2;
            left = Math.max(4, Math.min(left, window.innerWidth - tipRect.width - 4));
            tip.style.top = top + 'px';
            tip.style.left = left + 'px';
        }

        function hideLocationTooltip() {
            if (activeTooltipEl) { activeTooltipEl.remove(); activeTooltipEl = null; }
        }

       async function selectLocation(locationId , locCode, palletCode) {
            if (!currentRowIdForLocation) return;

            const rowNode = gridApi.getRowNode(currentRowIdForLocation);
            if (!rowNode) return;

            rowNode.setDataValue('location', locCode);
            rowNode.data.locationId = locationId;

            closeLocationModal();

            if (palletCode) {
                rowNode.setDataValue('pallet', palletCode);
                rowNode.data.palletSource = 'map';
                return; 
            }
             
            let reusedPalletCode = null;
            gridApi.forEachNode(node => {
           
                if (node.id === currentRowIdForLocation) return;
        
                if (node.data.locationId === locationId && node.data.pallet) {
                    reusedPalletCode = node.data.pallet;
                }
            });

            if (reusedPalletCode) {
                rowNode.setDataValue('pallet', reusedPalletCode);
                rowNode.data.palletSource = 'grid-reuse'; 
          
                return; 
            }

            try {

                const response = await fetch('?handler=GeneratePalletCode');
        
                if (!response.ok) {
                throw new Error("Lỗi HTTP từ server");
                }
        
                const result = await response.json();
                const newCode = result?.palletCode ?? result?.data?.palletCode;

                if (newCode) {
                    rowNode.setDataValue('pallet', newCode);
                    rowNode.data.palletSource = 'auto-generated';
            
                } 
                else {
                    rowNode.setDataValue('pallet', null);
                    console.error('Server did not return a pallet code:', result);
                }
                
            } catch (error) {
                console.error('Lỗi khi sinh mã Pallet tự động:', error);
                rowNode.setDataValue('pallet', null);
             
            }
       }
       

