         async function quickCreatePalletCode() {
             try {
                 const response = await fetch('?handler=GeneratePalletCode');
                 if (!response.ok) {
                       Notify.info(L.palletGenerateError);
                     return;
                 }
                 const result = await response.json();
                 const newCode = result?.palletCode ?? result?.data?.palletCode;

                 if (!newCode) {
                     Notify.info(L.palletNoResponse);
                     return;
                 }

                 if (currentRowIdForPallet) {
                     const rowNode = gridApi.getRowNode(currentRowIdForPallet);
                     if (rowNode) {
                         rowNode.setDataValue('pallet', newCode);
                         rowNode.data.palletSource = 'manual';
                     }
                     closePalletSearchModal();
                     Notify.info(`${L.palletCreatedAssigned} ${newCode}`);
                 } else {
                     showPalletSearchLoading();
                     const data = await fetchPallets('');
                     renderPalletTable(data);
                     Notify.info(`${L.palletCreated} ${newCode}`);
                 }
                 } catch (error) {
                     console.error('Error generating pallet code:', error);
                     Notify.info(L.connectionError);
                 }
         }

        // check box handling
        document.getElementById('isStored').addEventListener('change', function(e) {
            const isChecked = e.target.checked;

            gridApi.setColumnsVisible(['location'], isChecked);

        });


        // handel Reference Order Search Modal
        const orderSearchModal = document.getElementById('orderSearchModal');
        const orderSearchResultBody = document.getElementById('orderSearchResultBody');
        const orderSearchInput = document.getElementById('orderSearchInput');

        const orderItemSelectionModal = document.getElementById('orderItemSelectionModal');
        const orderItemSelectionBody = document.getElementById('orderItemSelectionBody');

        let currentlyViewingOrder = null;
        let currentOrderItems = [];

        let poSearchAbortController = null;
        let poItemsAbortController = null;

        async function fetchPurchaseOrders(keyword = '', pageIndex = 1) {
            if (poSearchAbortController) poSearchAbortController.abort();
            poSearchAbortController = new AbortController();

            const q = new URLSearchParams({
                keyword: keyword ?? '',
                pageIndex: pageIndex.toString(),
                pageSize: '20'
            });

            const response = await fetch(`?handler=SearchPurchaseOrder&${q.toString()}`, {
                method: 'GET',
                signal: poSearchAbortController.signal
            });

            if (!response.ok) return { data: [] };
            return await response.json();
        }

        async function fetchPurchaseOrderItems(poId) {
            if (poItemsAbortController) poItemsAbortController.abort();
            poItemsAbortController = new AbortController();

            const response = await fetch(`?handler=PurchaseOrderItems&poId=${encodeURIComponent(poId)}`, {
                method: 'GET',
                signal: poItemsAbortController.signal
            });

            if (!response.ok) return { poNo: '', items: [] };
            return await response.json();
        }

        async function openOrderModal() {
            orderSearchInput.value = '';
            orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">${L.searching}</td></tr>`;
            orderSearchModal.classList.remove('hidden');

            const result = await fetchPurchaseOrders('');
            renderOrderTable(result?.data ?? []);
        }

        function closeOrderModal() {
            orderSearchModal.classList.add('hidden');
        }

        function renderOrderTable(data) {
            orderSearchResultBody.innerHTML = '';
            if (!Array.isArray(data) || data.length === 0) {
                orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">Không có Purchase Order phù hợp.</td></tr>`;
                return;
            }

            data.forEach(order => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-blue-50';
                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm font-bold text-blue-600">${order.poNo ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-600">${order.expectedDate ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-600">${order.supplierName ?? ''}</td>
                    <td class="px-6 py-3 text-right">
                        <button type="button" onclick="selectOrder(${order.id}, '${(order.poNo ?? '').replace(/'/g, "\\'")}')" class="bg-green-600 text-white px-4 py-1.5 rounded shadow-sm hover:bg-green-700 text-sm font-medium">
                            ${L.referenceBtn}
                        </button>
                    </td>
                `;
                orderSearchResultBody.appendChild(tr);
            });
        }

        orderSearchInput.addEventListener('input', debounce(async function () {
            orderSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">${L.searching}</td></tr>`;
            const result = await fetchPurchaseOrders(orderSearchInput.value || '');
            renderOrderTable(result?.data ?? []);
        }, 300));

        async function selectOrder(poId, poNo) {
            closeOrderModal();

            const detail = await fetchPurchaseOrderItems(poId);
            console.log('Fetched PO Items:', detail);
            currentlyViewingOrder = { id: poId, code: detail?.poNo || poNo };

            document.getElementById('selectionModalTitle').textContent = `${L.orderDetailPrefix} ${currentlyViewingOrder.code}`;
            currentOrderItems = detail?.items ?? [];
            renderItemSelectionTable(currentOrderItems);

            orderItemSelectionModal.classList.remove('hidden');
        }

        function closeOrderItemSelectionModal() {
            orderItemSelectionModal.classList.add('hidden');
        }

        function renderItemSelectionTable(items) {
            orderItemSelectionBody.innerHTML = '';
            document.getElementById('selectAllItems').checked = false;
            updateSelectedCount();

            if (!Array.isArray(items) || items.length === 0) {
                orderItemSelectionBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">PO này không còn số lượng mở để nhận.</td></tr>`;
                return;
            }

            items.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-blue-50 cursor-pointer border-b';
                tr.onclick = function (e) {
                    if (e.target.type !== 'checkbox') {
                        const cb = document.getElementById(`chk_item_${index}`);
                        cb.checked = !cb.checked;
                        updateSelectedCount();
                    }
                };

                tr.innerHTML = `
                    <td class="px-6 py-3">
                        <input type="checkbox" id="chk_item_${index}" value="${index}" onchange="updateSelectedCount()" class="item-checkbox w-4 h-4 text-blue-600 rounded">
                    </td>
                    <td class="px-6 py-3 text-sm font-bold">${item.itemCode ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${item.itemName ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-500">${item.uom ?? ''}</td>
                    <td class="px-6 py-3 text-right text-sm font-bold text-blue-600">${item.qtyOpen ?? 0}</td>
                `;
                orderItemSelectionBody.appendChild(tr);
            });
        }

        function toggleAllItems(source) {
            document.querySelectorAll('.item-checkbox').forEach(cb => cb.checked = source.checked);
            updateSelectedCount();
        }

        function updateSelectedCount() {
            const checkedCount = document.querySelectorAll('.item-checkbox:checked').length;
            document.getElementById('selectedItemsCount').textContent = checkedCount;
            const total = document.querySelectorAll('.item-checkbox').length;
            document.getElementById('selectAllItems').checked = (checkedCount === total && total > 0);
        }

        function confirmSelectedItems() {
            const checkboxes = document.querySelectorAll('.item-checkbox:checked');
            if (checkboxes.length === 0) {
                Notify.info(L.validSelectAtLeastOneItem);
                return;
            }

            const selectedItemsToImport = [];
            checkboxes.forEach(cb => {
                const item = currentOrderItems[Number(cb.value)];
                const unitName = item.unitName ?? item.uom ?? '';
                selectedItemsToImport.push({
                    id: Math.random().toString(36).substring(2, 9),
                    skuId: item.skuId || 0,
                    skuUomId: item.skuUomId || 0,
                    itemCode: item.itemCode || '',
                    itemName: item.itemName || '',
                    uom: unitName || '',
                    unitName: unitName, 
                    qty: Number(item.qtyOpen || 0),
                    expiryDate: item.expiryDate || null,
                    location: '',
                    pallet: '',
                    referenceCode: currentlyViewingOrder?.code || '',
                    asnId: currentlyViewingOrder?.id || null
                });
            });

            gridApi.applyTransaction({ add: selectedItemsToImport });
            closeOrderItemSelectionModal();
            updateReferenceUI();
        }

        function updateReferenceUI() {
            const container = document.getElementById('referenceOrderContainer');
            const placeholder = document.getElementById('refPlaceholder');

            const uniqueOrders = new Set();
            gridApi.forEachNode(node => {
                if (node.data.referenceCode) uniqueOrders.add(node.data.referenceCode);
            });

            container.querySelectorAll('.order-chip').forEach(el => el.remove());

            if (uniqueOrders.size > 0) {
                placeholder.style.display = 'none';
                uniqueOrders.forEach(code => {
                    const chip = document.createElement('span');
                    chip.className = 'order-chip bg-blue-100 text-blue-700 text-xs font-bold px-2 py-1 rounded-md border border-blue-200 flex items-center gap-1';
                    chip.innerHTML = `${code}`;
                    container.appendChild(chip);
                });
            } else {
                placeholder.style.display = 'block';
            }
        }

        // HANDLE SUPPLIER MODAL SEARCH
        const supplierSearchModal = document.getElementById('supplierSearchModal');
        const supplierModalSearchInput = document.getElementById('supplierModalSearchInput');
        const supplierSearchResultBody = document.getElementById('supplierSearchResultBody');
        const mainSupplierInput = document.getElementById('supplierSearch');
        const mainSupplierHiddenInput = document.getElementById('selectedSupplierId');

        let supplierSearchAbortController = null;
        let supplierCurrentPage = 1;
        const supplierPageSize = 20; 
        let supplierIsFetching = false;
        let supplierHasMoreData = true;

        async function fetchSuppliers(keyword = '', pageIndex = 1) {
            if (supplierSearchAbortController) {
                supplierSearchAbortController.abort();
            }
            supplierSearchAbortController = new AbortController();
            try {
                const keyWordParam = keyword?.trim() ? `&keyword=${encodeURIComponent(keyword.trim())}` : '';
                const url = `?handler=SearchSupplier${keyWordParam}&pageIndex=${pageIndex}&pageSize=${supplierPageSize}`;

                const response = await fetch(url, { signal: supplierSearchAbortController.signal });
                if (!response.ok) return null;
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') return null;
                console.error('Error fetching suppliers:', e);
                return [];
            }
        }

        async function openSupplierModal() {
            supplierCurrentPage = 1;
            supplierHasMoreData = true;
            supplierModalSearchInput.value = '';
            document.getElementById('supplierScrollContainer').scrollTop = 0;

            showSupplierSearchLoading();
            supplierSearchModal.classList.remove('hidden');
            setTimeout(() => supplierModalSearchInput.focus(), 100);

            supplierIsFetching = true ;
            const data = await fetchSuppliers('', supplierCurrentPage);
            supplierIsFetching = false;
            if (data !== null) {
                renderSupplierTable(data, false);
            }
        }

        function closeSupplierModal() {
            supplierSearchModal.classList.add('hidden');
            if (supplierSearchAbortController) {
                supplierSearchAbortController.abort();
                supplierSearchAbortController = null;
            }
        }

        function showSupplierSearchLoading() {
            supplierSearchResultBody.innerHTML = `
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                        <div class="flex justify-center items-center gap-2">
                            <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                           ${L.searching}
                        </div>
                    </td>
                </tr>`;
        }

        function renderSupplierTable(response , isAppend = false) {
            if (!isAppend) {
                supplierSearchResultBody.innerHTML = '';
            }
            const data = response ?? [];
            if (!Array.isArray(data) || data.length === 0) {
                if (!isAppend) {
                    supplierSearchResultBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">Không tìm thấy nhà cung cấp nào.</td></tr>`;
                }
                supplierHasMoreData = false;
                return;
            }

            if (data.length < supplierPageSize) {
                supplierHasMoreData = false;
            } else {
                supplierHasMoreData = true;
            }

            data.forEach(supplier => {
                const tr = document.createElement('tr');
             
                tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
        
                const escapedName = (supplier.supplierName ?? '').replace(/'/g, "\\'");
        
                tr.onclick = () => selectSupplier(supplier.id, escapedName);

                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm text-gray-900 truncate">${supplier.supplierName ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.address ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.city ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.email ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700 truncate">${supplier.contactTel ?? ''}</td>
                `;
                supplierSearchResultBody.appendChild(tr);
            });
        }

     
        const supplierScrollContainer = document.getElementById('supplierScrollContainer');
        const supplierScrollAnchor = document.getElementById('supplier-scroll-anchor');
        const supplierLoadingIndicator = document.getElementById('supplier-loading-indicator');

        const supplierObserverOptions = {
            root: supplierScrollContainer,
            rootMargin: '0px 0px 100px 0px', 
            threshold: 0
        };

        const supplierInfiniteScrollObserver = new IntersectionObserver(async (entries) => {
            const target = entries[0];

          
            if (target.isIntersecting && !supplierIsFetching && supplierHasMoreData) {
                supplierIsFetching = true;
                supplierLoadingIndicator.classList.remove('hidden'); 

                supplierCurrentPage++;
                const keyword = supplierModalSearchInput.value;

                const data = await fetchSuppliers(keyword, supplierCurrentPage);
    
                if (data !== null) {
                    renderSupplierTable(data, true); 
                }

                supplierLoadingIndicator.classList.add('hidden'); 
                supplierIsFetching = false;
            }
        }, supplierObserverOptions);

      
        supplierInfiniteScrollObserver.observe(supplierScrollAnchor);

        const debouncedSupplierSearch = debounce(async function () {
            supplierCurrentPage = 1;
            supplierHasMoreData = true;

            showSupplierSearchLoading();

            supplierIsFetching = true;
            const data = await fetchSuppliers(supplierModalSearchInput.value, supplierCurrentPage);
            supplierIsFetching = false;
           
            if (data !== null) {
                renderSupplierTable(data, false);
            }
        }, 300);

        supplierModalSearchInput.addEventListener('input', debouncedSupplierSearch);

     
        async function selectSupplier(id, name) {
            const currentSupplierId = mainSupplierHiddenInput.value.trim();

            if (currentSupplierId === id) {
                closeSupplierModal();
                return;
            }
            let hasData = false;
            if (gridApi) {
                gridApi.forEachNode(node => {
                  
                    if (node.data && node.data.itemCode && node.data.itemCode.trim() !== "") {
                        hasData = true;
                    }
                });
            }

            if (currentSupplierId !== "" && hasData) {
            const isConfirm = await Notify.confirm(
            "Xác nhận thay đổi",
            "Thay đổi Nhà cung cấp sẽ xóa toàn bộ danh sách hàng hóa hiện tại. Bạn có chắc chắn muốn đổi?",
            "Đồng ý đổi"
            );

            if (!isConfirm) {
                closeSupplierModal();
                return;
            }
            clearGridData();
            } else if (currentSupplierId !== "" && !hasData) {         
                clearGridData();
            }

        
            mainSupplierInput.value = name;
            mainSupplierHiddenInput.value = id;
            closeSupplierModal();
        }


        function clearGridData() {
            if (gridApi) {
                const initRecord = { 
                    id: Math.random().toString(36).substring(2, 9), 
                    itemCode: "", 
                    itemName: "", 
                    uom: "", 
                    qty: null,
                    expiryDate: null,
                    referenceCode: ""
                };
               
                gridApi.setGridOption('rowData', [initRecord]);
       
            }
        }

        // handle for Supplier Add Modal
        function openSupplierAddModal() {
            const modal = document.getElementById('supplierAddModal');        
            modal.classList.remove('hidden');
        }

        function closeSupplierAddModal() {
            document.getElementById('supplierAddModal').classList.add('hidden');
        }

        async function saveSupplier() {
           
            const data = {
                supplierName: document.getElementById('newSupplierName').value.trim(),
                address: document.getElementById('newSupplierAddress').value.trim(),
                city: document.getElementById('newSupplierCity').value.trim(),
                email: document.getElementById('newSupplierEmail').value.trim(),
                contactTel: document.getElementById('newSupplierTel').value.trim(),
                manager: document.getElementById('newSupplierManager').value.trim()
            };

        
            if (!data.supplierName || !data.address || !data.city) {
                Notify.info('@Html.Raw(Localizer["AtLeastOneItemRequired"])');
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                const response = await fetch('?handler=AddSupplier', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    Notify.info('@Html.Raw(Localizer["OperationSuccessfull"])');
           
                    const mainInput = document.getElementById('supplierSearch');
                    const mainHidden = document.getElementById('selectedSupplierId');
                    if (mainInput && mainHidden) {
                        mainInput.value = data.supplierName;
                        mainHidden.value = result.id;
                    }
                    closeSupplierAddModal();
                } else {
                   Notify.info('@Html.Raw(Localizer["OperationFailed"])');
                }
            } catch (error) {
                console.error("Error saving supplier:", error);
                Notify.info('@Html.Raw(Localizer["OperationFailed"])');
            }
        }


    </script>
}