@page "/Inbound/Receipt/Create"
@model Wms.Theme.Web.Pages.Inbound.Receipt.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CreateReceipt_Title"];
}

@{
    Dictionary<int , string> palletStatus = new Dictionary<int, string>
    {
        { 1, Localizer["CreateReceipt_PalletStatusAvailable"] },
        { 2, Localizer["CreateReceipt_PalletStatusOccupied"] },
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
}

@Html.AntiForgeryToken()


<!--Receipt button-->
@await Html.PartialAsync("Inbound/_InboundReceiptButton")
@await Html.PartialAsync("Inbound/InputReceiptForm")
@await Html.PartialAsync("Warehouses/_WarehouseModal")

<div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold text-gray-800">@Localizer["CreateReceipt_ItemDetails"]</h2>
    <button type="button" onclick="addRow()" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 shadow-sm transition-colors flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
        @Localizer["CreateReceipt_AddRow"]
    </button>
</div>

<div id="myGrid" class="ag-theme-quartz" style="max-height: calc(90vh - 260px); height: 260px; width: 100%;"></div>


<!--Modal search Sku Item-->
@await Html.PartialAsync("Inbound/_SkuSearchModal")
<!--Modal locations-->
@await Html.PartialAsync("Inbound/_LocationModal")
<!--Pallet Search Modal-->
@await Html.PartialAsync("Inbound/_PalletSearchModal")
<!--Modal Search Inbound Order-->
@await Html.PartialAsync("Inbound/_SearchInboundOrderModal")
<!--Supplier Search Modal-->
@await Html.PartialAsync("Inbound/_SupplierSearchModal")
<!--Add Supplier Modal-->
@await Html.PartialAsync("Inbound/_AddSupplierModal")

@section Scripts {
    <script>
        // Localized strings for JavaScript
        const L = {
                   colItemCode: '@Html.Raw(Localizer["CreateReceipt_ColItemCode"])',
                   colItemName: '@Html.Raw(Localizer["CreateReceipt_ColItemName"])',
                   colUom: '@Html.Raw(Localizer["CreateReceipt_ColUom"])',
                   colQuantity: '@Html.Raw(Localizer["CreateReceipt_ColQuantity"])',
                   colLocation: '@Html.Raw(Localizer["CreateReceipt_ColLocation"])',
                   colPalletCode: '@Html.Raw(Localizer["CreateReceipt_ColPalletCode"])',
                   colReference: '@Html.Raw(Localizer["CreateReceipt_ColReference"])',
                   colActions: '@Html.Raw(Localizer["CreateReceipt_ColActions"])',
                   noWarehouseFound: '@Html.Raw(Localizer["CreateReceipt_NoWarehouseFound"])',
                   noItemFound: '@Html.Raw(Localizer["CreateReceipt_NoItemFound"])',
                   searching: '@Html.Raw(Localizer["CreateReceipt_Searching"])',
                   clickToSearchItem: '@Html.Raw(Localizer["CreateReceipt_ClickToSearchItem"])',
                   loadingLocationMap: '@Html.Raw(Localizer["CreateReceipt_LoadingLocationMap"])',
                   locationLoadError: '@Html.Raw(Localizer["CreateReceipt_LocationLoadError"])',
                   noLocationData: '@Html.Raw(Localizer["CreateReceipt_NoLocationData"])',
                   locationEmpty: '@Html.Raw(Localizer["CreateReceipt_LocationEmpty"])',
                   searchingPallet: '@Html.Raw(Localizer["CreateReceipt_SearchingPallet"])',
                   noPalletFound: '@Html.Raw(Localizer["CreateReceipt_NoPalletFound"])',
                   select: '@Html.Raw(Localizer["Common_Select"])',
                   referenceBtn: '@Html.Raw(Localizer["CreateReceipt_ReferenceBtn"])',
                   orderDetailPrefix: '@Html.Raw(Localizer["CreateReceipt_OrderDetailPrefix"])',
                   deleteRowTitle: '@Html.Raw(Localizer["CreateReceipt_DeleteRowTitle"])',
                   validReceiptNo: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptNo"])',
                   validReceiptDate: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptDate"])',
                   validReceiptType: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptType"])',
                   validWarehouse: '@Html.Raw(Localizer["CreateReceipt_ValidWarehouse"])',
                   validAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidAtLeastOneItem"])',
                   saveSuccess: '@Html.Raw(Localizer["CreateReceipt_SaveSuccess"])',
                   saveFailed: '@Html.Raw(Localizer["CreateReceipt_SaveFailed"])',
                   connectionError: '@Html.Raw(Localizer["Common_ConnectionError"])',
                   validWhName: '@Html.Raw(Localizer["CreateReceipt_ValidWhName"])',
                   validWhCity: '@Html.Raw(Localizer["CreateReceipt_ValidWhCity"])',
                   validWhAddress: '@Html.Raw(Localizer["CreateReceipt_ValidWhAddress"])',
                   whSaveSuccess: '@Html.Raw(Localizer["CreateReceipt_WhSaveSuccess"])',
                   whSaveFailed: '@Html.Raw(Localizer["CreateReceipt_WhSaveFailed"])',
                   validSelectWhFirst: '@Html.Raw(Localizer["CreateReceipt_ValidSelectWhFirst"])',
                   palletGenerateError: '@Html.Raw(Localizer["CreateReceipt_PalletGenerateError"])',
                   palletNoResponse: '@Html.Raw(Localizer["CreateReceipt_PalletNoResponse"])',
                   palletCreatedAssigned: '@Html.Raw(Localizer["CreateReceipt_PalletCreatedAssigned"])',
                   palletCreated: '@Html.Raw(Localizer["CreateReceipt_PalletCreated"])',
                   validSelectAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidSelectAtLeastOneItem"])',
                   validWhContactTel: '@Html.Raw(Localizer["CreateReceipt_ValidWhContactTel"])',
                   validWhContactTel: '@Html.Raw(Localizer["CreateReceipt_ValidWhContactTel"])',
                   palletLocationConflict: '@Html.Raw(Localizer["CreateReceipt_PalletLocationConflict"])',
                   msgAddAtLeastOneItem : '@Html.Raw(Localizer["CreateReceipt_MsgAddAtLeastOneItem"])',
                   validSupplier: '@Html.Raw(Localizer["CreateReceipt_ValidSupplier"])',
                   validQtyPerItem: '@Html.Raw(Localizer["CreateReceipt_ValidQtyPerItem"])',      
                   validExpiryPerItem: '@Html.Raw(Localizer["CreateReceipt_ValidExpiryPerItem"])', 
                   validLocationLoadError: '@Html.Raw(Localizer["CreateReceipt_LocationLoadError"])',
                   connectionError: '@Html.Raw(Localizer["Common_ConnectionError"])',
                   noLocationData: '@Html.Raw(Localizer["CreateReceipt_NoLocationData"])',
                   searching: '@Html.Raw(Localizer["CreateReceipt_Searching"])',
                   msgCreateWarehouseFail: '@Html.Raw(Localizer["CreateWarehouseFail"])',                               
                   msgCreateWarehouseSuccess: '@Html.Raw(Localizer["CreateWarehouseSuccess"])',
               };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
         // init flat pickr for date input
         document.addEventListener('DOMContentLoaded', function() {
            let sevenDaysAgo = new Date();
            sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
            flatpickr("#receiptDate", {
                dateFormat: "d/m/Y",
                altInput: true,
                altFormat: "d/m/Y",
                defaultDate: "today",
                minDate: sevenDaysAgo,
                allowInput: true,
            });

            flatpickr("#expectedDeliveryDate", {
                   
                    dateFormat: "Y-m-d\\", 
                    altInput: true,              
                    altFormat: "d/m/Y",     
                    defaultDate: "today",
                    minDate: "today",
                    allowInput: true,
                });

            fetch('?handler=GenarationReceiptNo')
                .then(response => response.json())
                .then(result => {
                    const receiptNo = result?.receiptNo ?? result?.data?.receiptNo ?? result;
                    if (receiptNo) {
                        document.getElementById('receiptNumber').value = receiptNo;
                    }
                })
                .catch(error => console.error('Error generating receipt number:', error));
        });

        // util state function
        function debounce (fn , delay){
            let timer; 
            return function (...args) {
                clearTimeout(timer);
                timer = setTimeout(() => fn.apply(this, args), delay);
            };
        }

        // handle for warehouse search dropdown
        let warehouses = [];
        const searchInput = document.getElementById('warehouseSearch');
        const dropdown = document.getElementById('warehouseDropdown');
        const selectedWarehouseIdInput = document.getElementById('selectedWarehouseId');
        
        let currentAbortController = null;
        
        async function fetchWarehouses(keyword = '' , pageIndex = 1){           
            if (currentAbortController) {
                currentAbortController.abort(); 
            }
            currentAbortController = new AbortController();
            try
            {
               const keyWordParam = keyword?.trim()
                     ? `&keyWord=${encodeURIComponent(keyword.trim())}`
                     : ''; 

                const url = `?handler=SearchWareHouse${keyWordParam}&pageIndex=${pageIndex}`;          
                const response = await fetch(url , {
                        signal : currentAbortController.signal
                });
                if (!response.ok) return [];
                return await response.json();
            }catch (e) {
               if (e.name === 'AbortError') {
                   return null; 
               }
                console.error('Error fetching warehouses:', e);
                return [];
            }
        }


        function renderDropdown(data) {
            if(data === null){
                return;
            }
            if(!Array.isArray(data)){
                return
            }
            dropdown.innerHTML = '';
            if (data.length === 0) {
                dropdown.innerHTML = `<li class="px-4 py-2 text-gray-500 text-sm">${L.noWarehouseFound}</li>`;
                dropdown.classList.remove('hidden');
                return;
            }
            data.forEach(wh => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = `${wh.warehouseName}`
                li.onclick = () => {
                    searchInput.value = wh.warehouseName; 
                    selectedWarehouseIdInput.value = wh.id;
                    dropdown.classList.add('hidden');
                };
                dropdown.appendChild(li);
            });
             dropdown.classList.remove('hidden');
        }

        const debouncedSearch = debounce(async function () {
            const data = await fetchWarehouses(searchInput.value);
            renderDropdown(data);
        }, 300);    

        searchInput.addEventListener('input', debouncedSearch);
            
        searchInput.addEventListener('focus', async function () {
            if (!dropdown.classList.contains('hidden')) return;
            const data = await fetchWarehouses(this.value);
            renderDropdown(data);
        });

     
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });

        class FlatpickrCellEditor {
            init(params) {
                this.params = params;
                const today = new Date();
        
                const todayIso = toLocalIsoDate(today);
                const rawIso = toIsoDateOnly(params.value);
                this.selectedIso = rawIso || '';

                this.eInput = document.createElement('input');
                this.eInput.type = 'text';
                this.eInput.className = 'w-full h-full px-2 outline-none bg-transparent dark:text-gray-200';
                this.eInput.value = this.selectedIso ? toDisplayDate(this.selectedIso) : '';

                this.fp = flatpickr(this.eInput, {
                    dateFormat: "d/m/Y",
                    allowInput: false,
                    disableMobile: true,
                    minDate: today,
                    defaultDate: rawIso ? new Date(rawIso) : today,
    
                    onReady: function(selectedDates, dateStr, instance) {
                        if (instance.calendarContainer) {
                            instance.calendarContainer.classList.add('ag-custom-component-popup');
                        }
                    },
    
                    onChange: (selectedDates) => {
                    
        
                        if (selectedDates?.length) {
                            this.selectedIso = toLocalIsoDate(selectedDates[0]);
                            
                        }
        
                       
                        setTimeout(() => this.params.stopEditing(), 0);
                    }
                });
            }
            getGui() { 
                return this.eInput;
            }
            afterGuiAttached() {
                setTimeout(() => { this.eInput.focus(); this.fp.open(); }, 0);
            }
            getValue() {
                return this.selectedIso;
            }
            isPopup() { 
                return false; 
            }
            destroy() {
                this.fp?.destroy(); 
            }
        }

        function toLocalIsoDate(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        // global state
        let gridApi; 

        const columnDefs = [
            { 
                headerName: L.colItemCode, 
                field: "itemCode", 
                flex: 1.5, 
                editable: false, 
                cellClass: 'hover:bg-blue-50 transition-colors cursor-pointer',
                cellRenderer: function(params) {
                    const displayValue = params.value ? 
                        `<span class="font-medium text-blue-700">${params.value}</span>` : 
                        `<span class="text-gray-400 italic"></span>`;
                    
                    const iconColor = params.value ? 'text-blue-600' : 'text-gray-400';

                    return `
                          <div class="flex justify-between items-center w-full h-full" onclick="openItemSearchModal('${params.node.id}')" title="@Localizer["CreateReceipt_ClickToSearchItem"]">
                            <div class="truncate pr-2">${displayValue}</div>   
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-1 flex-shrink-0 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                             </svg>
                        </div>
                    `;
                }
            },
            { 
                headerName: L.colItemName, 
                field: "itemName", 
                flex: 2, 
                editable: false, 
                wrapText : true,
                autoHeight : true,
                cellClass: 'py-3 px-3 leading-tight'
            },
            { 
                headerName: L.colUom, 
                field: "uom", 
                flex: 1, 
                editable: false , 
                cellRenderer: function(params) {
                    return `<div class="flex items-center h-full w-full">${params.value || ''}</div>`;
                }
            },
            { 
                headerName: L.colQuantity,
                field: "qty", 
                flex: 1, 
                editable: true, 
                cellEditor: 'agNumberCellEditor' , 

                cellEditorParams: {
                    min: 0.001,   
                    step: 'any',  
                },

                valueParser: function(params) {
                    const num = parseFloat(params.newValue);
                    if (isNaN(num) || num <= 0) {
                        return null;
                    }
                    return num;
                },

                cellClass: 'bg-blue-50 border border-blue-100 cursor-text font-semibold text-blue-700',
                cellRenderer: function(params) {
                    const val = params.value !== undefined && params.value !== null ? params.value : '';
                    return `<div class="flex items-center h-full w-full">${val}</div>`;
                }
            },
            { 
                headerName: L.colLocation, 
                field: "location", 
                width: 150, 
                editable: false, 
                hide: true, 
                cellClass: 'hover:bg-yellow-100 transition-colors cursor-pointer',
                cellRenderer: function(params) {
                    const val = params.value || '<span class="text-gray-400 italic"></span>';
                    return `
                        <div class="flex justify-between items-center w-full h-full" onclick="openLocationModal('${params.node.id}')">
                            <span class="${params.value ? 'font-medium text-blue-700' : ''}">${val}</span>
                             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                 <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                 <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                             </svg>
                        </div>`;
                }
            },
            {
                headerName: L.colPalletCode,
                field: "pallet",
                width: 150,
                editable: false,
                hide: true,
                cellRenderer: function(params) {
                    const val = params.value || '';
                    return `<div class="flex items-center h-full w-full">
                                <span class="font-medium text-gray-700">${val}</span>
                            </div>`;
                }
            },
            {
                 headerName: "@Html.Raw(L["ExpiryDate"])",
                 field: "expiryDate",
                 width: 150,
                 editable: true,
                 cellDataType : false,
                 cellEditor: FlatpickrCellEditor,
                 valueFormatter: params => toDisplayDate(params.value),               
                  cellClass: 'expiry-date-cell bg-amber-50 border border-amber-100'
            },
            {
                headerName: L.colReference,
                field: "referenceCode",
                width: 140,
                editable: false, 
                cellRenderer: function(params) {
                  
                    if (params.value) {
                        return `<div class="flex items-center h-full">
                                    <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-semibold border border-gray-200">
                                        ${params.value}
                                    </span>
                                </div>`;
                    }
                    return ''; 
                }
            },
            {
                headerName: L.colActions,
                width: 100,
                sortable: false,
                filter: false,
                cellRenderer: function(params) {
                    return `
                         <button type="button" onclick="deleteRow('${params.node.id}')" class="text-red-500 hover:text-red-700 flex items-center justify-center w-full h-full" title="@Localizer["CreateReceipt_DeleteRowTitle"]">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>`;
                }
            }
        ];

        const rowData = [
            { id: "row-init"  ,itemCode: "", itemName: "", uom: "", qty: null }
        ];

        const gridOptions = {
            columnDefs: columnDefs,
            rowData: rowData,

            getRowId: params => params.data.id ,
            pagination: true,
            paginationPageSize: 20,

            singleClickEdit: true,
            stopEditingWhenCellsLoseFocus: true
        };

        function addRow() {
            const newRecord = { 
                id: Math.random().toString(36).substring(2, 9), 
                itemCode: "", 
                itemName: "", 
                uom: "", 
                qty: null , 
                expiryDate: null,
                referenceCode : ""
            };
            gridApi.applyTransaction({ add: [newRecord] });
        }

        function deleteRow(nodeId) {
            const rowNode = gridApi.getRowNode(nodeId);
            if(rowNode) {
                gridApi.applyTransaction({ remove: [rowNode.data] });
            }
            updateReferenceUI();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const gridDiv = document.querySelector('#myGrid');
            const isDark = document.documentElement.classList.contains('dark');
            if (isDark) {
                gridDiv.classList.remove('ag-theme-quartz');
                gridDiv.classList.add('ag-theme-quartz-dark');
            }   
            gridApi = agGrid.createGrid(gridDiv, gridOptions);
        });

         function formatText(template, ...args) {
            return template.replace(/\{(\d+)\}/g, (_, index) => args[index] ?? '');
       }

       function toDisplayDate(value) {
            const iso = toIsoDateOnly(value);
            if (!iso) return '';
            const [y, m, d] = iso.split('-');
            return `${d}/${m}/${y}`;
       }

       function toIsoDateOnly(value) {
            if (!value) return null;

            if (value instanceof Date && !isNaN(value.getTime())) {
                return toLocalIsoDate(value); 
            }

            const text = value.toString().trim();
            if (!text) return null;

            // yyyy-MM-dd
            if (/^\d{4}-\d{2}-\d{2}$/.test(text)) {
                return text;
            }

            // dd/MM/yyyy
            const vn = text.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (vn) {
                return `${vn[3]}-${vn[2]}-${vn[1]}`;
            }
            return null;
        }

         async function saveReceipt(isDraft = false) {

             const isStoredChecked = document.getElementById('isStored').checked;
             const receiptNumber = document.getElementById('receiptNumber').value.trim();
             const receiptDate = document.getElementById('receiptDate').value.trim();
             const warehouseId = document.getElementById('selectedWarehouseId').value.trim();
             const receiptType = document.getElementById('receiptType').value;
             const supplierId = document.getElementById('selectedSupplierId').value.trim();
             const description = document.getElementById('message')?.value?.trim() ?? '';
             const deliverer = document.getElementById('deliverer')?.value?.trim() ?? '';
             const invoiceNumber = document.getElementById('invoiceNumber')?.value?.trim() ?? '';
             const expectedDeliveryDate = document.getElementById('expectedDeliveryDate')?.value?.trim() ?? '';

             if (!receiptNumber) {
                  Notify.info(L.validReceiptNo);
                  return;
             }

             if (!receiptDate) {
                  Notify.info(L.validReceiptDate);
                  return;
             }
             if (!receiptType) {
                  Notify.info(L.validReceiptType);
                  return;
             }

             if (!warehouseId) {
                  Notify.info(L.validWarehouse);
                  return;
             }

              if (!supplierId) {
                 Notify.info(L.validSupplier);
                 return;
             }


             const details = [];
             const invalidExpiryRows = [];
             const invalidQtyRows = [];

             gridApi.forEachNode(node => {
                 const row = node.data;
                 if (!row.itemCode) return;

                  const qty = Number(row.qty);
                  if (!Number.isFinite(qty) || qty <= 0) {
                      invalidQtyRows.push(row.itemCode || row.itemName || node.id);
                      return;
                  }

                 const expiryIso = toIsoDateOnly(row.expiryDate ?? row.expireDate ?? row.expiredDate);

                 const detail = {
                      skuId: row.skuId || 0,
                      quantity: row.qty || 0,
                      skuUomId: row.skuUomId || 0,
                      locationId: isStoredChecked ? (parseInt(row.locationId) || 1) : 1,
                      locationName: (row.location || '').toString().trim(),
                      palletCode: isStoredChecked ? (row.pallet || null) : null,
                      expiryDate: expiryIso,
                      sourceNumber: row.referenceCode || null
                  };
                  details.push(detail);
             });


             if (invalidQtyRows.length > 0) {
                 Notify.info(formatText(L.validQtyPerItem, invalidQtyRows.join(', ')));
                 return;
             }

             if (details.length === 0) {
                 Notify.info(L.msgAddAtLeastOneItem);
                 return;
             }

             if (invalidExpiryRows.length > 0) {
                 Notify.info(formatText(L.validExpiryPerItem, invalidExpiryRows.join(', ')));
                 return;
             }

             if (isStoredChecked) {
                 const check = validatePalletLocationMapping(details);
                 if (!check.isValid) {
                     if (check.type === 'pallet-multi-location') {
                         Notify.info(formatText(
                             L.palletLocationConflict,
                             check.palletCode,
                             check.firstLocationName,
                             check.conflictLocationName
                         ));
                     } else {
                         Notify.info(formatText(
                             L.locationPalletConflict ,
                             check.locationName,
                             check.firstPalletCode,
                             check.conflictPalletCode
                         ));
                     }
                     return;
                 }
             }

             const parts = receiptDate.split('/');
             const isoDate = parts.length === 3
                  ? `${parts[2]}-${parts[1]}-${parts[0]}`
                  : null;


              const request = {
                  receiptNo: receiptNumber,
                  warehouseId: parseInt(warehouseId),
                  supplierId: parseInt(supplierId),
                  description: description,
                  type: receiptType, 
                  isStored: isStoredChecked,
                  createdDate: isoDate,
                  isDraft : isDraft,
                  deliverer: deliverer,
                  invoiceNumber: invoiceNumber ,
                  expectedDeliveryDate: expectedDeliveryDate,
                  details: details
              };

              try {
                  const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                  const response = await fetch('?', {
                      method: 'POST',
                      headers: {
                          'Content-Type': 'application/json',
                          'RequestVerificationToken': token
                      },
                      body: JSON.stringify(request)
                  });

                  const result = await response.json();

                  if (result.success) {
                      Notify.info('@Html.Raw(L["OperationSuccessful"])');
                    
                       window.location.href = `/Inbound/Receipt/Detail/${result.id}`;
                  } else {
                      Notify.info( '@Html.Raw(L["OperationFailed"])');
                  }
              } catch (error) {
                  console.error("Error saving receipt:", error);
                  Notify.info( '@Html.Raw(L["OperationFailed"])');
              }
         }


        function validatePalletLocationMapping(details) {
            const palletToLocationMap = new Map();
            const locationToPalletMap = new Map();

            for (const d of details) {
                const palletCode = (d.palletCode ?? '').toString().trim().toUpperCase();
                const locationId = Number(d.locationId ?? 0);
                const locationName = (d.locationName ?? '').toString().trim();

                if (!palletCode || locationId <= 0) continue;

             
                if (palletToLocationMap.has(palletCode)) {
                    const first = palletToLocationMap.get(palletCode);
                    if (first.locationId !== locationId) {
                        return {
                            isValid: false,
                            type: 'pallet-multi-location',
                            palletCode,
                            firstLocationId: first.locationId,
                            firstLocationName: first.locationName || first.locationId,
                            conflictLocationId: locationId,
                            conflictLocationName: locationName || locationId
                        };
                    }
                } else {
                    palletToLocationMap.set(palletCode, { locationId, locationName });
                }

               
                if (locationToPalletMap.has(locationId)) {
                    const first = locationToPalletMap.get(locationId);
                    if (first.palletCode !== palletCode) {
                        return {
                            isValid: false,
                            type: 'location-multi-pallet',
                            locationId,
                            locationName: first.locationName || locationName || locationId,
                            firstPalletCode: first.palletCode,
                            conflictPalletCode: palletCode
                        };
                    }
                } else {
                    locationToPalletMap.set(locationId, { palletCode, locationName });
                }
            }

            return { isValid: true };
        }

