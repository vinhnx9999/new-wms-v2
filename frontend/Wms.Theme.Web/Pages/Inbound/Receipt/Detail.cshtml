@page "/Inbound/Receipt/Detail/{id:int}"
@using WMSSolution.Shared.Enums
@model Wms.Theme.Web.Pages.Inbound.Receipt.DetailModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Detail"];
    var currentStatus = Model.Receipt.Status; 
}

@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
}

@Html.AntiForgeryToken()

<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div class="flex items-center justify-start mb-2 pb-2">
        @await Html.PartialAsync("_StatusPartialView", currentStatus)        
    </div>
    <div class="flex justify-end gap-3 mb-2 pb-2">
        <a href="/Inbound/Receipt/Index" class="px-6 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors font-medium">
            @Localizer["Common_Back"]
        </a>
        @if (currentStatus == (int)ReceiptStatus.DRAFT || (currentStatus == (int)ReceiptStatus.PROCESSING && Model.Receipt.Details != null && Model.Receipt.Details.Any(x => x.IsException)))
        {
            <a href="/Inbound/Receipt/Edit/@Model.Receipt.Id" class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium">
                @Localizer["Common_Edit"]
            </a>
        }

        @if (currentStatus != (int)ReceiptStatus.CANCELED)
        {
            <button type="button"
                    onclick="printInbound()"
                    class="flex items-center gap-2 px-6 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 shadow-md transition-all font-medium">
                <i class="fa-solid fa-print"></i> @Localizer["PrintReceipt"]
            </button>            
        }

        <button id="btnPrintQr" class="flex items-center gap-2 px-6 py-2 bg-green-600 text-white rounded-md hover:bg-green-700 shadow-md transition-all font-medium" onclick="handlePrintQrClick()">
            <i class="fa-solid fa-qrcode"></i> @L["QRCode"]
        </button>
        
        @if (currentStatus == (int)ReceiptStatus.COMPLETE && string.IsNullOrEmpty(Model.Receipt.SharingUrl))
        {
            <button onclick="shareInbound()">
                <i class="fa-solid fa-share-from-square"></i> @L["Share"]
            </button>
        }
    </div>
</div>

<label class="block text-xs font-medium text-gray-700 flex justify-end gap-3 mb-2 pb-2">
    @Html.Raw(Model.Receipt.SharingUrl)
</label>

<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">        
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptNumber"]
            </label>
            <input type="text" value="@Model.Receipt.ReceiptNo" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptDate"]
            </label>
            <input type="text" value="@(Model.Receipt.CreatedDate?.ToString("dd/MM/yyyy"))" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            @{
                string localizedTypeLabel = Model.Receipt.Type;
                switch (Model.Receipt.Type)
                {
                    case "PURCHASE": localizedTypeLabel = Localizer["CreateReceipt_TypePurchase"]; break;
                    case "RETURN": localizedTypeLabel = Localizer["CreateReceipt_TypeReturn"]; break;
                    case "TRANSFER": localizedTypeLabel = Localizer["CreateReceipt_TypeTransfer"]; break;
                    case "MISC": localizedTypeLabel = Localizer["CreateReceipt_TypeMisc"]; break;
                }
            }
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptType"]
            </label>
            <select disabled class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 appearance-none">
                <option value="@Model.Receipt.Type" selected>@localizedTypeLabel</option>
            </select>
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_Warehouse"]
            </label>
            <input type="text" value="@Model.Receipt.WarehouseName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
            <span class="text-xs text-gray-500 italic">@Model.Receipt.Address</span>
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
               @Html.Raw(Localizer["Supplier"])
            </label>
            <input type="text" value="@Model.Receipt.SupplierName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>
        <div>
            <div class="flex items-center h-full ">
                <input type="checkbox" disabled @(Model.Receipt.IsStored ? "checked" : "")
                       class="w-4 h-4 text-blue-600 border-gray-300 rounded bg-gray-50 cursor-not-allowed">
                <label class="ml-2 text-xs font-medium text-gray-700 cursor-not-allowed">
                    @Localizer["CreateReceipt_IsStored"]
                </label>
            </div>
        </div>
                
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(Localizer["InvoiceNumber"])
            </label>
            <input type="text" value="@Model.Receipt.InvoiceNumber" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>
          
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(Localizer["Deliverer"])
            </label>
            <input type="text" value="@Model.Receipt.Deliverer" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["ExpectedDeliveryDate"]
            </label>
            <input type="text" value="@(Model.Receipt.ExpectedDeliveryDate?.ToString("dd/MM/yyyy"))" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div class="md:col-span-3">
            <label class="block text-xs font-medium text-gray-700 mb-1">
               @Html.Raw(Localizer["Note"])
            </label>
            <textarea readonly rows="3"
                      class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none resize-none">@Model.Receipt.Description</textarea>
        </div>

    </div>
</div>

<div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold text-gray-800">@Localizer["CreateReceipt_ItemDetails"]</h2>
    </div>

<div id="myGrid" class="ag-theme-quartz" style="height: 400px; width: 100%;"></div>

@await Html.PartialAsync("Inbound/_ReceiptText" , Model)

@section Scripts {
    <script src="~/js/qrcodegen-v1.8.0-es6.js"></script>
    <script src="~/js/qr-print.js"></script>
    <script src="~/js/printReceipt.js"></script>
    <script>

        const detailData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Receipt.Details));
        const isStored = @Model.Receipt.IsStored.ToString().ToLower();

        const rowData = detailData.map(item => ({
            id: item.Id,       
            skuId: item.SkuId,
            itemCode : item.SkuCode,
            itemName: item.SkuName,
            uom: item.UnitName,
            qty: item.Quantity,
            location: item.LocationName,
            pallet: item.PalletCode,
            expiryDate: item.ExpiryDate,
            isException: item.IsException,
            referenceCode : item.SourceNumber
        }));

        const columnDefs = [
            { 
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColItemCode"])', 
                field: "itemCode", 
                flex: 1.5, 
                pinned : "left",
                editable: false, 
                cellClass: 'py-3 px-3 leading-tight font-medium text-gray-700' 
            },
            { 
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColItemName"])', 
                field: "itemName", 
                flex: 2, 
                editable: false, 
                wrapText: true,
                autoHeight: true,
                cellClass: 'py-3 px-3 leading-tight font-medium text-gray-700'
            },
            { 
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColUom"])', 
                field: "uom", 
                flex: 1, 
                editable: false 
            },
            { 
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColQuantity"])',
                field: "qty", 
                flex: 1, 
                editable: false,
                cellClass: 'font-semibold text-blue-700'
            },
            { 
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColLocation"])', 
                field: "location", 
                width: 150, 
                editable: false, 
                hide: !isStored 
            },
            {
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColPalletCode"])',
                field: "pallet",
                width: 150,
                editable: false,
                hide: true
            },
            {
                headerName: '@Html.Raw(Localizer["ExpiryDate"])',
                field: "expiryDate",
                width: 150,
                editable: false,
                valueFormatter: params => {
                    if (!params.value) return '';
                    const date = new Date(params.value);
                    return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
                }
            },
            {
                headerName: '@Html.Raw(Localizer["CreateReceipt_ColReference"])',
                field: "referenceCode",
                width: 140,
                editable: false, 
                cellRenderer: function(params) {
                  
                    if (params.value) {
                        return `<div class="flex items-center h-full">
                                    <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-semibold border border-gray-200">
                                        ${params.value}
                                    </span>
                                </div>`;
                    }
                    return ''; 
                }
            },
        ];

        const gridOptions = {
            columnDefs: columnDefs,
            rowData: rowData,
            getRowId: params => params.data.id,
            getRowClass: params => {
                if (params.data && params.data.isException) {
                   return '!bg-red-50 hover:!bg-red-100';
                }
                return ''; 
            },
            pagination: true,
            paginationPageSize: 20,
            suppressRowClickSelection: true,
            suppressCellFocus: true
        };

        document.addEventListener('DOMContentLoaded', function () {
            const gridDiv = document.querySelector('#myGrid');
            const isDark = document.documentElement.classList.contains('dark');
            if (isDark) {
                gridDiv.classList.remove('ag-theme-quartz');
                gridDiv.classList.add('ag-theme-quartz-dark');
            }   
            agGrid.createGrid(gridDiv, gridOptions);
        });


        function handlePrintQrClick() {
           
            const rowsWithPallet = rowData.filter(item => item.pallet && item.pallet.trim() !== '');

            if (rowsWithPallet.length === 0) {
                Notify.error('Không có mã Pallet nào để in!');
                return;
            }

         
            const uniquePalletsMap = new Map();
            rowsWithPallet.forEach(item => {
                if (!uniquePalletsMap.has(item.pallet)) {
                    uniquePalletsMap.set(item.pallet, item);
                }
            });
            const uniqueRows = Array.from(uniquePalletsMap.values());

           
            const qrDataToPrint = uniqueRows.map(item => ({
                content: item.pallet,
                title: item.pallet,
                desc1: "",
                desc2: ""
            }));

          
            const headerInfo = {
                title: "",
                subtitle: ""
            };

           
            if (typeof printQrCode === 'function') {
                printQrCode(qrDataToPrint, headerInfo);
            } else {
                console.error('Hàm printQrCode chưa được load!');
            }
        }

        async function shareInbound() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
             
            fetch(`?handler=ShareInbound`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                }
            })
            .then(response => response.json())
            .then(result => {
                if(result.success) {
                    Notify.info('@Html.Raw(L["OperationSuccessful"])');
                    setTimeout(() => {
                        location.reload();
                    }, 800);
                } else {
                    Notify.info(result.message || 'Failed to Share Inbound');
                }
            })
            .catch(error => {
                console.error('Error activating warehouse:', error);
                Notify.info('Connection error');
            });
        }
    </script>
}