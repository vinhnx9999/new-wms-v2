@page
@model Wms.Theme.Web.Pages.Inbound.Order.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@{
    ViewData["Title"] = "Lệnh nhập kho";
}

@Html.AntiForgeryToken()

<div class="px-6 pb-6" x-data="{ ...AlpineDataTable(orderConfig) }" @@datatable-reload.window="reload()">
    <!-- Search Bar -->
    <div class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-slate-200 dark:border-gray-700">
        <div class="flex items-end gap-2">
            <div class="flex-1 flex flex-col gap-1">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true"
                            xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text" x-model="filters.text" @@keydown.enter="reload()"
                        @@input.debounce.500ms="reload()" placeholder="Tìm kiếm..."
                        class="w-full pl-10 px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border border-slate-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:text-white">
                </div>
            </div>

            <a href="/Inbound/Order/Create" title="Thêm"
                class="px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-colors shadow-sm flex items-center justify-center">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
            </a>
        </div>
    </div>

    <partial name="Shared/Components/_AlpineDataTable" />
</div>

@section Scripts {
    <script src="~/js/components/alpine-datatable.js" asp-append-version="true"></script>
    <script>
        const orderConfig = {
            apiUrl: '?handler=DataTable',
            filters: { text: '' },
            columns: [
                {
                    title: 'Số lệnh nhập kho', field: 'orderNo', sortable: true, class: 'font-medium text-gray-900 dark:text-white',
                    render: (row) => {
                        let html = `<a href="/Inbound/Order/Detail/${row.id}" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 hover:underline" title="Chi tiết">${row.orderNo ?? ''}</a>`;
                        if (row.has_rejected_items) {
                            html += `<span class="ml-2 inline-flex items-center justify-center w-5 h-5 text-xs font-bold text-white bg-red-500 rounded-full" title="Có hàng bị từ chối">!</span>`;
                        }
                        return html;
                    }
                },
                { title: 'Ngày lập lệnh', field: 'createdDate', sortable: true },
                { title: 'Hạn nhập kho', field: 'etaDate', sortable: true },
                { title: 'Kho nhập', field: 'warehouse', sortable: false },
                { title: 'Người thực hiện', field: 'executor', sortable: true },
                { title: 'Tham chiếu', field: 'reference', sortable: true },
                { title: 'Loại lệnh', field: 'orderType', sortable: false, render: () => 'Inbound' },
                { title: 'Tình trạng', field: 'status', align: 'center', render: (row) => renderStatusBadge(row.status) },
                { title: '', field: null, sortable: false, class: 'text-right', render: (row) => renderActions(row) }
            ],
            options: { pageSize: 10 }
        };

        function renderStatusBadge(status) {
            const statusMap = {
                0: { text: 'Đợi xử lý', class: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300' },
                1: { text: 'Đang xử ly', class: 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200' },
                2: { text: 'Hoàn thành', class: 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300' },
                8: { text: 'Đã hủy', class: 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300' },
                99: { text: 'Không xác định', class: 'bg-slate-100 text-slate-800 dark:bg-slate-700 dark:text-slate-200' }
            };
            const s = statusMap[status] || statusMap[99];
            return `<span class="px-2 py-1 rounded text-xs font-semibold ${s.class}">${s.text}</span>`;
        }

        function renderActions(row) {
            const status = Number(row?.status);
            const hideDeleteForStatuses = [1, 2, 8, 99];
            const canDelete = !hideDeleteForStatuses.includes(status);
            if (!canDelete) return '';

            return `
                                    <div class="flex justify-end gap-2">
                                        <button type="button"
                                            class="p-1.5 rounded hover:bg-red-50 dark:hover:bg-red-900/20 text-red-600 dark:text-red-400"
                                            title="Xoá"
                                            onclick="deleteInboundOrder(${row.id})">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M9 7h6m2 0H7m3-3h4a1 1 0 011 1v1H9V5a1 1 0 011-1z"/>
                                            </svg>
                                        </button>
                                    </div>
                                `;
        }

        async function deleteInboundOrder(id) {
            if (!id || id <= 0) return;
            const ok = await Notify.confirm('Xác nhận', 'Bạn có chắc muốn xoá lệnh nhập kho này không?', 'Xoá');
            if (!ok) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            try {
                const res = await fetch('?handler=Delete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(id)
                });
                const result = await res.json();
                if (result?.success) {
                    if (typeof Notify !== 'undefined') Notify.success(result.message || 'Xoá thành công');
                    window.dispatchEvent(new Event('datatable-reload'));
                } else {
                    if (typeof Notify !== 'undefined') Notify.error(result?.message || 'Xoá thất bại');
                    else alert(result?.message || 'Xoá thất bại');
                }
            } catch (e) {
                if (typeof Notify !== 'undefined') Notify.error(e?.message || 'Có lỗi xảy ra');
                else alert(e?.message || 'Có lỗi xảy ra');
            }
        }
    </script>
}