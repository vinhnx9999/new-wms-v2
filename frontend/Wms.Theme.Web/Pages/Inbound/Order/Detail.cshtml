@page "/Inbound/Order/Detail/{id:int}"
@model Wms.Theme.Web.Pages.Inbound.Order.DetailModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@{
    ViewData["Title"] = L["InboundOrder"];
}

@Html.AntiForgeryToken()

<style>
    .timeline {
        position: relative;
    }

    .timeline-item {
        position: relative;
        display: flex;
        padding-bottom: 2rem;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    /* Vertical connector line */
    .timeline-item::after {
        content: "";
        position: absolute;
        left: 5.5px;
        top: 18px;
        /* Start below the dot */
        bottom: -6px;
        /* End above the next dot */
        width: 1.5px;
        background-color: #e2e8f0;
        z-index: 0;
    }

    .timeline-item:last-child::after {
        display: none;
    }

    .timeline-item-point {
        width: 12px;
        height: 12px;
        margin-top: 6px;
        flex-shrink: 0;
        position: relative;
        z-index: 10;
        border: 2px solid white;
        box-shadow: 0 0 0 1px #e2e8f0;
    }

    .timeline-item-content {
        flex: 1;
        padding-left: 1.5rem;
    }

    .timeline-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2px;
    }

    /* Dark mode support */
    .dark .timeline-item::after {
        background-color: #475569;
    }

    .dark .timeline-item-point {
        border-color: #1e293b;
        box-shadow: 0 0 0 1px #475569;
    }
</style>

<div class="grid grid-cols-12 gap-6">

    <div class="col-span-12 lg:col-span-9 bg-white dark:bg-navy-700 p-4 rounded-lg shadow-sm">
        <h2 class="font-bold text-gray-800 dark:text-navy-100 mb-4 border-b dark:border-navy-500 pb-2">@L["GeneralInfo"]
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["OwnerCode"]</label>
                    <input id="goodsOwnerName" type="text" value="@Model.Order.GoodsOwnerName" readonly
                        class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                </div>
                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["InboundWarehouse"] <span
                            class="text-red-500">*</span></label>
                    <select id="warehouseSelect" disabled data-adjustable="true"
                        class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                        <option value="@Model.Order.WareHouseId" selected>@Model.Order.WareHouseName</option>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["Executor"]</label>
                    <input id="creator" type="text" value="@Model.Order.Creator" readonly
                        class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                </div>
            </div>

            <div class="space-y-4">

                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["Description"]</label>
                    <input id="description" type="text" value="@L["InboundOrder"]" readonly data-adjustable="true"
                        class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                </div>
                <div class="input-group">
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["Reference"]</label>
                    <div class="relative">
                        <input id="reference" type="text" value="@Model.Order.AsnBatch" readonly
                            class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 pr-8 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                        <svg xmlns="http://www.w3.org/2000/svg"
                            class="h-4 w-4 absolute right-3 top-3 text-gray-400 dark:text-navy-300" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="space-y-4">
                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["InboundOrderNo"] <span
                            class="text-red-500">*</span></label>
                    <input id="asnNo" type="text" value="@Model.Order.AsnNo" readonly
                        class="w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                </div>
                <div>
                    <label
                        class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["OrderCreatedDate"]</label>
                    <div class="relative">
                        <input id="createTime" type="text"
                            value="@Model.Order.CreateTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")" readonly
                            class="datetime-picker w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                    </div>
                </div>
                <div>
                    <label class="block text-gray-700 dark:text-navy-200 font-medium mb-1">@L["InboundDeadline"]</label>
                    <div class="relative">
                        <input id="estimatedArrival" type="text"
                            value="@Model.Order.EstimatedArrivalTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")"
                            readonly
                            class="datetime-picker w-full border border-gray-300 dark:border-navy-500 rounded px-3 py-2 focus:outline-blue-500 bg-gray-100 dark:bg-navy-600 dark:text-navy-100 cursor-not-allowed">
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="col-span-12 lg:col-span-3 bg-white dark:bg-navy-700 p-4 rounded-lg shadow-sm h-full">
        <h2 class="font-bold text-gray-800 dark:text-navy-100 mb-4 border-b dark:border-navy-500 pb-2">@L["TrackStatus"]
        </h2>
        <ol class="timeline max-w-sm">
            <li class="timeline-item">
                <div class="timeline-item-point rounded-full bg-blue-600"></div>
                <div class="timeline-item-content">
                    <div class="timeline-item-header">
                        <p class="font-medium text-slate-700 dark:text-navy-100">@L["OrderCreated"]</p>
                        <span
                            class="text-xs text-slate-400 dark:text-navy-300">@Model.Order.CreateTime.ToLocalTime().ToString("dd/MM/yyyy                            HH:mm")</span>
                    </div>
                    <p class="text-xs text-slate-500 dark:text-navy-300">@Model.Order.Creator</p>
                </div>
            </li>
        </ol>
    </div>

</div>

<div class="p-6" x-data="orderDetailTableDetail()">
    <h3 class="font-bold text-lg text-gray-800 dark:text-navy-100 mb-4">@L["Goods"]</h3>

    <div class="overflow-x-auto border dark:border-navy-500 rounded-lg">
        <table class="w-full text-sm text-left text-gray-500 dark:text-navy-200">
            <thead class="text-xs text-gray-700 dark:text-navy-100 uppercase bg-gray-50 dark:bg-navy-800">
                <tr>
                    <th scope="col" class="px-2 py-2 w-12">#</th>
                    <th scope="col" class="px-2 py-2 w-48">@L["ItemCode"]</th>
                    <th scope="col" class="px-2 py-2 w-40">@L["ItemName"]</th>
                    <th scope="col" class="px-2 py-2 w-32">@L["SpecificationCode"]</th>
                    <th scope="col" class="px-2 py-2 w-28">@L["UOM"]</th>
                    <th scope="col" class="px-2 py-2 w-24">@L["QtyRequired"]</th>
                    <th scope="col" class="px-2 py-2 w-24">@L["QtyReceived"]</th>
                    <th scope="col" class="px-2 py-2 w-18 text-center">@L["MarkAsFull"]</th>
                    <th scope="col" class="px-2 py-2 w-28">@L["LotNumber"]</th>
                    <th scope="col" class="px-2 py-2 w-28">@L["Pallet"]</th>
                    <th scope="col" class="px-2 py-2 w-28 col-location">@L["Location"]</th>
                    <th scope="col" class="px-2 py-2 w-36">@L["ExpiryDate"]</th>
                    <th scope="col" class="px-2 py-2 w-20"></th>
                </tr>
            </thead>
            <template x-for="(item, index) in paginatedItems" :key="getRealIndex(index)">
                <tbody>
                    <tr
                        class="bg-white dark:bg-navy-700 border-b dark:border-navy-600 hover:bg-gray-50 dark:hover:bg-navy-600">
                        <td class="px-1 py-1">
                            <div class="flex items-center gap-1">
                                <span x-text="getRealIndex(index) + 1"></span>
                                <template x-if="!item.locationId || item.locationId === 0">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                        class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor"
                                        title="@L["NoLocation"]">
                                        <path fill-rule="evenodd"
                                            d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z"
                                            clip-rule="evenodd" />
                                    </svg>
                                </template>
                            </div>
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.skuCode" readonly
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.skuName" readonly
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" readonly
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.unit" readonly
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="number" x-model="item.qtyRequiredDecimal" readonly min="0"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 text-right cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="number" x-model="item.qtyReceivedDecimal" readonly min="0"
                                data-adjustable="true"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 text-right cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1 text-center">
                            <input type="checkbox" x-model="item.isFull" disabled data-adjustable="true"
                                class="w-4 h-4 text-blue-600 bg-gray-100 dark:bg-navy-600 border-gray-300 dark:border-navy-500 rounded focus:ring-blue-500 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.lotNo" readonly data-adjustable="true"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.palletCode" readonly
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                        </td>
                        <td class="px-1 py-1 col-location">
                            <input type="text" x-model="item.location" readonly data-adjustable="picker"
                                @@click="openLocationPicker(getRealIndex(index))"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed"
                                placeholder="@L["SelectLocation"]">
                        </td>
                        <td class="px-1 py-1">
                            <input type="text" x-model="item.expiryDate" readonly data-adjustable="true"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed"
                                placeholder="dd/mm/yyyy">
                        </td>
                        <td class="px-1 py-1 flex gap-1.5 justify-end">
                            <!-- Retry button: only show for rows with no location -->
                            <template x-if="!item.locationId || item.locationId === 0">
                                <button @@click="retryRow(getRealIndex(index))" type="button"
                                    class="font-medium hover:bg-gray-100 dark:hover:bg-navy-600 p-1 rounded text-yellow-600"
                                    title="@L["Retry"]">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                                    </svg>
                                </button>
                            </template>

                            <button @@click="toggleNote(getRealIndex(index))" type="button" disabled
                                data-adjustable="true"
                                class="font-medium hover:bg-gray-100 dark:hover:bg-navy-600 p-1 rounded"
                                :class="item.showNote ? 'text-blue-600' : 'text-gray-400 dark:text-navy-300'"
                                title="@L["AddNote"]">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                </svg>
                            </button>

                            <button type="button" disabled data-adjustable="true"
                                @@click="removeRow(getRealIndex(index))"
                                class="font-medium text-red-600 hover:underline">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                </svg>
                            </button>
                        </td>
                    </tr>
                    <tr class="bg-gray-50 dark:bg-navy-800 border-b dark:border-navy-600" x-show="item.showNote"
                        x-cloak>
                        <td class="px-2 py-1.5"></td>
                        <td class="px-2 py-1.5"></td>
                        <td class="px-2 py-1.5" colspan="11">
                            <input type="text" x-model="item.description" readonly data-adjustable="true"
                                class="bg-gray-100 dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded block w-full p-1.5 cursor-not-allowed"
                                placeholder="@L["EnterNote"]">
                        </td>
                    </tr>
                </tbody>
            </template>
            <tbody>
                <tr class="bg-gray-50 dark:bg-navy-800 font-bold text-gray-700 dark:text-navy-100">
                    <td colspan="5" class="px-4 py-2 text-right">@L["Total"]: <span x-text="items.length"></span></td>
                    <td class="px-4 py-2 text-right" x-text="totalQtyRequired()"></td>
                    <td class="px-4 py-2 text-right" x-text="totalQtyReceived()"></td>
                    <td colspan="4"></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-end mt-4 gap-2 text-sm text-gray-600 dark:text-navy-200">
        <span>@L["RowsPerPage"]</span>
        <select
            class="border border-gray-300 dark:border-navy-500 dark:bg-navy-600 dark:text-navy-100 rounded p-1 focus:outline-blue-500"
            x-model="pageSize" @@change="changePageSize($event.target.value)">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
        <span>
            <span x-text="startIndex"></span> - <span x-text="endIndex"></span>
            @L["Of"] <span x-text="items.length"></span>
        </span>
        <div class="flex gap-1">
            <button @@click="firstPage()" :disabled="currentPage === 1"
                class="p-1 px-2 border dark:border-navy-500 rounded hover:bg-gray-100 dark:hover:bg-navy-600 disabled:opacity-50">
                «
            </button>
            <button @@click="prevPage()" :disabled="currentPage === 1"
                class="p-1 px-2 border dark:border-navy-500 rounded hover:bg-gray-100 dark:hover:bg-navy-600 disabled:opacity-50">
                ‹
            </button>
            <button @@click="nextPage()" :disabled="currentPage === totalPages || totalPages === 0"
                class="p-1 px-2 border dark:border-navy-500 rounded hover:bg-gray-100 dark:hover:bg-navy-600 disabled:opacity-50">
                ›
            </button>
            <button @@click="lastPage()" :disabled="currentPage === totalPages || totalPages === 0"
                class="p-1 px-2 border dark:border-navy-500 rounded hover:bg-gray-100 dark:hover:bg-navy-600 disabled:opacity-50">
                »
            </button>
        </div>
    </div>
</div>
<div class="h-20"></div>

<div
    class="fixed bottom-0 left-0 right-0 bg-white dark:bg-navy-800 border-t border-gray-200 dark:border-navy-600 p-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] z-50">
    <div class="container mx-auto flex justify-end items-center gap-3">
        <a href="/Inbound/Order"
            class="px-4 py-2 border border-gray-300 dark:border-navy-500 rounded text-gray-700 dark:text-navy-200 hover:bg-gray-50 dark:hover:bg-navy-700 transition-colors font-medium">
            @L["Back"]
        </a>

        @if (Model.Order.AsnStatus == 0)
        {
            <button id="btnAdjustOrder" type="button" onclick="window.toggleAdjustOrder?.()"
                class="px-4 py-2 bg-gray-600 border border-gray-600 rounded text-white hover:bg-gray-700 transition-colors font-medium shadow-sm">
                @L["AdjustOrder"]
            </button>
        }
        <button id="btnSaveChanges" type="button" onclick="window.saveChanges?.()" style="display:none"
            class="px-4 py-2 bg-emerald-600 border border-emerald-600 rounded text-white hover:bg-emerald-700 transition-colors font-medium shadow-sm">
            @L["SaveChanges"]
        </button>
        @if (Model.Order.AsnStatus == 0)
        {
            <button id="btnCompleteOrder" type="button" onclick="window.submitOrderForm()"
                class="px-4 py-2 bg-blue-600 border border-blue-600 rounded text-white hover:bg-blue-700 transition-colors font-medium shadow-sm">
                @L["Completed"]
            </button>
        }
    </div>
</div>

<!-- Modal: choose location (shows only location name) -->
<div x-data="locationPickerModalDetail()">
    <template x-teleport="#x-teleport-target">
        <div class="fixed inset-0 z-[100] flex flex-col items-center justify-center overflow-hidden px-4 py-6 sm:px-5"
            x-show="showModal" role="dialog" @@keydown.window.escape="close()">
            <div class="absolute inset-0 bg-slate-900/60 transition-opacity duration-300" @@click="close()"
                x-show="showModal" x-transition:enter="ease-out" x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100" x-transition:leave="ease-in" x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"></div>

            <div class="relative w-full max-w-2xl origin-bottom rounded-lg bg-white pb-4 transition-all duration-300 dark:bg-navy-700"
                x-show="showModal" x-transition:enter="easy-out" x-transition:enter-start="opacity-0 scale-95"
                x-transition:enter-end="opacity-100 scale-100" x-transition:leave="easy-in"
                x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95">

                <div class="flex justify-between rounded-t-lg bg-slate-200 px-4 py-3 dark:bg-navy-800 sm:px-5">
                    <div class="flex items-center gap-3">
                        <h3 class="text-base font-medium text-slate-700 dark:text-navy-100"
                            x-text="mode === 'pallet' ? '@Html.Raw(L["SelectLocationByPallet"])' : '@Html.Raw(L["SelectLocation"])'">
                        </h3>
                        <template x-if="mode === 'pallet'">
                            <select x-model="activePalletId" @@change="setActivePallet(activePalletId)"
                                class="bg-white dark:bg-navy-600 border border-gray-300 dark:border-navy-500 text-gray-900 dark:text-navy-100 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block p-1.5 min-w-[180px]">
                                <template x-for="p in palletList" :key="p.id">
                                    <option :value="p.id" x-text="p.palletCode"></option>
                                </template>
                            </select>
                        </template>
                    </div>
                    <button @@click="close()"
                        class="btn -mr-1.5 size-7 rounded-full p-0 hover:bg-slate-300/20 focus:bg-slate-300/20 active:bg-slate-300/25 dark:hover:bg-navy-300/20 dark:focus:bg-navy-300/20 dark:active:bg-navy-300/25">
                        <svg xmlns="http://www.w3.org/2000/svg" class="size-4.5" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                <div class="mt-3 max-h-[420px] overflow-auto px-2 sm:px-3">
                    <template x-if="filteredLocations.length === 0">
                        <div class="px-4 py-6 text-sm text-slate-500 dark:text-navy-300">@L["NoLocationData"]</div>
                    </template>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                        <template x-for="(loc, idx) in filteredLocations" :key="idx">
                            <button type="button" @@click="choose(loc)"
                                :disabled="(() => { const id = getLocationId(loc); return id !== null && isTaken(id) && id !== selectedLocationId; })()"
                                class="w-full rounded border bg-white px-4 py-3 text-left shadow-sm focus:outline-none focus:ring-2 dark:bg-navy-700"
                                :class="(() => {
                                    const id = getLocationId(loc);
                                    const selected = (id !== null && id === selectedLocationId);
                                    const disabled = (id !== null && isTaken(id) && id !== selectedLocationId);
                                    if (selected) return 'border-red-500 bg-red-50 ring-red-200 dark:border-red-400 dark:bg-red-500/10';
                                    if (disabled) return 'border-red-300 bg-red-50 text-red-700 opacity-70 cursor-not-allowed ring-transparent dark:border-red-400 dark:bg-red-500/10';
                                    return 'border-slate-200 hover:border-slate-300 hover:bg-slate-50 ring-blue-500 dark:border-navy-600 dark:hover:bg-navy-600';
                                })()">
                                <div class="text-sm font-medium"
                                    :class="(() => { const id = getLocationId(loc); return (id !== null && id === selectedLocationId) ? 'text-red-700 dark:text-red-200' : 'text-slate-800 dark:text-navy-100'; })()"
                                    x-text="getLocationName(loc)"></div>
                            </button>
                        </template>
                    </div>
                </div>

                <template x-if="mode === 'pallet'">
                    <div class="mt-3 flex items-center justify-end gap-2 px-4 sm:px-5">
                        <a href="/Inbound/Order"
                            class="px-4 py-2 border border-gray-300 dark:border-navy-500 rounded text-gray-700 dark:text-navy-200 hover:bg-gray-50 dark:hover:bg-navy-700 transition-colors font-medium">
                            @L["Back"]
                        </a>
                        <button type="button" @@click="finish()" :disabled="!canFinish"
                            class="px-4 py-2 bg-blue-600 border border-blue-600 rounded text-white hover:bg-blue-700 transition-colors font-medium shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                            @L["Completed"]
                        </button>
                    </div>
                </template>
            </div>
        </div>
    </template>
</div>


@section Scripts
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
    <script>
        window.initFlatpickr = function (scope = document) {
            if (typeof flatpickr === 'undefined') return;
            // Initialize expiry-date pickers in a non-interactive state by default.
            // We keep the underlying value as ISO (Y-m-d) and display dd/MM via altInput.
            const inputs = (scope || document).querySelectorAll('input[placeholder*="dd/mm"]');
            inputs.forEach(el => {
                if (!el) return;

                const enabled = !!window.__detailAdjustMode;

                // Sync from current input value (ISO) -> flatpickr instance (keeps display dd/MM)
                const rawVal = String(el.value ?? '').trim();
                const iso = (typeof toIsoDateOnly === 'function') ? toIsoDateOnly(rawVal) : rawVal;

                if (el._flatpickr) {
                    try {
                        if (iso) el._flatpickr.setDate(iso, true, "Y-m-d");
                        else el._flatpickr.clear();
                        el._flatpickr.set('clickOpens', enabled);
                        el._flatpickr.set('allowInput', enabled);
                        if (el._flatpickr?.altInput) {
                            if (enabled) el._flatpickr.altInput.removeAttribute('readonly');
                            else el._flatpickr.altInput.setAttribute('readonly', 'readonly');
                        }
                    } catch { /* ignore */ }
                    return;
                }

                try {
                    const fp = flatpickr(el, {
                        dateFormat: "Y-m-d",
                        altInput: true,
                        altFormat: "d/m/Y",
                        altInputClass: el.className,
                        allowInput: enabled,
                        clickOpens: enabled,
                        defaultDate: iso || null
                    });
                    // Ensure altInput behaves like readonly until Adjust mode is enabled
                    if (fp?.altInput) {
                        if (enabled) fp.altInput.removeAttribute('readonly');
                        else fp.altInput.setAttribute('readonly', 'readonly');
                    }
                    if (iso) fp.setDate(iso, true, "Y-m-d");
                } catch { /* ignore */ }
            });
        };
        document.addEventListener("DOMContentLoaded", function () {
            window.initFlatpickr();
        });
    </script>
    <script>
        // Server data
        window.__orderDetail = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Order));

        // Master data
        let globalSkuUomList = [];
        let globalGoodLocationList = [];
        let globalWarehouseList = [];
        let globalPalletList = [];

        async function fetchData(url) {
            const response = await fetch(url);
            if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
            return await response.json();
        }

        function renderWarehouseOptions(data) {
            const select = document.getElementById('warehouseSelect');
            if (!select) return;

            const currentSelected = String(select.value || '').trim();
            let html = `<option value="">Chọn kho</option>`;
            (data || []).forEach(item => {
                const id = item.id ?? item.Id ?? '';
                const name = item.WarehouseName || item.warehouseName || item.warehouse_name || 'N/A';
                const isSelected = String(id) === currentSelected ? 'selected' : '';
                html += `<option value="${id}" ${isSelected}>${name}</option>`;
            });
            select.innerHTML = html;
            // restore selection if it existed
            if (currentSelected) select.value = currentSelected;
        }

        document.addEventListener("DOMContentLoaded", function () {
            Promise.all([
                fetchData('?handler=LoadSkuUom'),
                fetchData('?handler=LoadWarehouse'),
                fetchData('?handler=LoadPallets')
            ]).then(([uoms, warehouses, pallets]) => {
                globalSkuUomList = (uoms && uoms.data) ? uoms.data : [];
                // Lazy-load locations later (only when Adjust mode is ON)
                globalGoodLocationList = [];
                window.__goodLocations = [];
                globalWarehouseList = (warehouses && warehouses.data) ? warehouses.data : [];
                globalPalletList = (pallets && pallets.data)
                    ? (pallets.data || []).map(p => ({
                        id: Number(p?.id ?? p?.Id) || 0,
                        palletCode: p?.palletCode ?? p?.PalletCode ?? p?.pallet_code ?? ''
                    })).filter(p => p.id > 0 && p.palletCode)
                    : [];
                if (globalWarehouseList.length > 0) renderWarehouseOptions(globalWarehouseList);
                window.dispatchEvent(new CustomEvent('master-data-loaded'));
            }).catch(() => window.dispatchEvent(new CustomEvent('master-data-loaded')));
        });

        // ===== LOCATION PICKER MODAL (DETAIL) =====
        function locationPickerModalDetail() {
            return {
                showModal: false,
                keyword: '',
                mode: 'row', // 'row' | 'pallet'
                rowIndex: null,
                palletList: [], // [{id,palletCode}]
                palletIds: [],
                activePalletId: null,
                palletLocationMap: {}, // { [palletId]: { locationId, locationName } }
                action: null,
                selectedLocationId: null,
                selectedLocationName: '',
                takenLocationIds: [],
                locations: [],

                init() {
                    window.addEventListener('open-location-modal', (e) => {
                        const mode = e?.detail?.mode ?? 'row';
                        this.mode = (mode === 'pallet') ? 'pallet' : 'row';
                        this.rowIndex = e?.detail?.rowIndex ?? null;

                        if (this.mode === 'pallet') {
                            this.palletList = Array.isArray(e?.detail?.palletList) ? e.detail.palletList : [];
                            this.palletIds = Array.isArray(e?.detail?.palletIds) ? e.detail.palletIds : [];
                            this.palletLocationMap = (e?.detail?.palletLocationMap && typeof e.detail.palletLocationMap === 'object')
                                ? e.detail.palletLocationMap
                                : {};
                            this.action = e?.detail?.action ?? null;
                            const initialActive = e?.detail?.activePalletId ?? this.palletIds?.[0] ?? null;
                            this.activePalletId = initialActive;
                            if (this.activePalletId) this.setActivePallet(this.activePalletId);
                        } else {
                            this.selectedLocationId = e?.detail?.currentLocationId ?? null;
                            this.selectedLocationName = e?.detail?.currentLocationName ?? '';
                            this.takenLocationIds = Array.isArray(e?.detail?.takenLocationIds) ? e.detail.takenLocationIds : [];
                        }
                        this.keyword = '';
                        // Base list comes from available-for-pallet; may not include currently used locations.
                        const base = Array.isArray(window.__goodLocations) ? window.__goodLocations : [];
                        this.locations = base.slice();

                        // Merge currently-used locations from palletLocationMap so they can be highlighted.
                        if (this.mode === 'pallet') {
                            const existingIds = new Set((this.locations || [])
                                .map(l => Number(this.getLocationId(l)) || 0)
                                .filter(x => x > 0));
                            const entries = Object.entries(this.palletLocationMap || {});
                            for (const [, v] of entries) {
                                const locId = Number(v?.locationId) || 0;
                                const locName = String(v?.locationName || '').trim();
                                if (!(locId > 0) || !locName) continue;
                                if (existingIds.has(locId)) continue;
                                // create a compatible shape for getLocationId/getLocationName
                                this.locations.push({ id: locId, LocationName: locName });
                                existingIds.add(locId);
                            }
                        }
                        this.showModal = true;
                    });
                },

                close() {
                    this.showModal = false;
                    this.rowIndex = null;
                    this.mode = 'row';
                    this.palletList = [];
                    this.palletIds = [];
                    this.activePalletId = null;
                    this.palletLocationMap = {};
                    this.action = null;
                },

                setActivePallet(palletId) {
                    const pid = Number(palletId) || 0;
                    if (!(pid > 0)) return;
                    this.activePalletId = pid;

                    const current = this.palletLocationMap?.[pid] ?? null;
                    this.selectedLocationId = current?.locationId ?? null;
                    this.selectedLocationName = current?.locationName ?? '';

                    const taken = [];
                    const entries = Object.entries(this.palletLocationMap || {});
                    for (const [otherPidStr, v] of entries) {
                        const otherPid = Number(otherPidStr) || 0;
                        if (otherPid === pid) continue;
                        const locId = Number(v?.locationId) || 0;
                        if (locId > 0) taken.push(locId);
                    }
                    this.takenLocationIds = Array.from(new Set(taken));
                },

                get canFinish() {
                    if (this.mode !== 'pallet') return false;
                    const ids = Array.isArray(this.palletIds) ? this.palletIds : [];
                    if (ids.length === 0) return false;
                    return !ids.some(pid => !(Number(this.palletLocationMap?.[pid]?.locationId) > 0));
                },

                getLocationId(loc) {
                    if (!loc) return null;
                    const id = loc.id ?? loc.Id ?? null;
                    const n = Number(id);
                    return Number.isFinite(n) ? n : null;
                },

                getLocationName(loc) {
                    if (!loc) return '';
                    return (
                        loc.location_name ??
                        loc.locationName ??
                        loc.LocationName ??
                        loc.name ??
                        loc.Name ??
                        ''
                    );
                },

                isTaken(locId) {
                    if (locId === null || locId === undefined) return false;
                    return (this.takenLocationIds || []).includes(locId);
                },

                get filteredLocations() {
                    const kw = (this.keyword || '').trim().toLowerCase();
                    if (!kw) return this.locations;
                    return (this.locations || []).filter(l => this.getLocationName(l).toLowerCase().includes(kw));
                },

                choose(loc) {
                    const locId = this.getLocationId(loc);
                    const name = this.getLocationName(loc);
                    if (!name) return;
                    if (locId !== null && this.isTaken(locId) && locId !== this.selectedLocationId) return;

                    this.selectedLocationId = locId;
                    this.selectedLocationName = name;
                    if (this.mode === 'pallet') {
                        const pid = Number(this.activePalletId) || 0;
                        if (!(pid > 0)) return;
                        this.palletLocationMap = this.palletLocationMap || {};
                        this.palletLocationMap[pid] = { locationId: locId, locationName: name };
                        this.setActivePallet(pid);
                        return;
                    }

                    window.dispatchEvent(new CustomEvent('location-selected', {
                        detail: {
                            rowIndex: this.rowIndex,
                            locationId: locId,
                            locationName: name
                        }
                    }));
                    this.close();
                }
                ,
                finish() {
                    if (this.mode !== 'pallet') return;
                    if (!this.canFinish) {
                        if (typeof Notify !== 'undefined') Notify.error('Vui lòng chọn vị trí cho tất cả pallet trước khi hoàn thành.');
                        return;
                    }
                    window.dispatchEvent(new CustomEvent('pallet-locations-finished-detail', {
                        detail: { action: this.action, palletLocationMap: this.palletLocationMap }
                    }));
                    this.close();
                }
            };
        }

        function toIsoDateOnly(dateVal) {
            if (!dateVal) return '';
            const s = String(dateVal).trim();
            // If backend returns ISO datetime: 2026-01-09T00:00:00 -> 2026-01-09
            if (/^\d{4}-\d{2}-\d{2}/.test(s)) return s.substring(0, 10);
            // If already dd/MM/yyyy, normalize to yyyy-MM-dd
            if (/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(s)) {
                const [dd, mm, yyyy] = s.split('/');
                return `${yyyy}-${String(mm).padStart(2, '0')}-${String(dd).padStart(2, '0')}`;
            }
            const d = new Date(s);
            if (isNaN(d.getTime())) return '';
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const dd = String(d.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        function toIsoDateTimeStartOfDay(isoDate) {
            if (!isoDate) return null;
            const s = String(isoDate).trim();
            if (!s) return null;
            // already datetime-ish
            if (s.includes('T')) return s;
            // date-only
            if (/^\d{4}-\d{2}-\d{2}$/.test(s)) return `${s}T00:00:00`;
            return s; // fallback (let backend validate)
        }

        function orderDetailTableDetail() {
            return {
                dataLoaded: false,
                items: [],
                pageSize: 20,
                currentPage: 1,
                palletLocationMap: {}, // { [palletId]: { locationId, locationName } }
                __pendingUpdateAction: null,

                init() {
                    const order = window.__orderDetail || {};
                    const details = order.detailList || order.DetailList || [];
                    this.items = (details || []).map(d => {
                        const qtyReqDecimal = d.asn_qty_decimal ?? d.AsnQtyDecimal ?? 0;
                        const qtyRecDecimal = d.actual_qty_decimal ?? d.ActualQtyDecimal ?? 0;
                        const uomId = d.uom_id ?? d.UomId ?? 0;

                        return {
                            id: d.id ?? d.Id ?? 0,
                            asnmasterId: d.asnmaster_id ?? d.AsnmasterId ?? 0,
                            skuId: d.sku_id ?? d.SkuId ?? 0,
                            skuCode: d.sku_code ?? d.SkuCode ?? '',
                            skuName: d.sku_name ?? d.SkuName ?? '',
                            spuId: d.spu_id ?? d.SpuId ?? 0,
                            spuCode: d.spu_code ?? d.SpuCode ?? '',
                            spuName: d.spu_name ?? d.SpuName ?? '',
                            uomId: uomId,
                            unit: '',
                            qtyRequiredDecimal: qtyReqDecimal,
                            qtyReceivedDecimal: qtyRecDecimal,
                            isFull: qtyRecDecimal >= qtyReqDecimal && qtyReqDecimal > 0,
                            lotNo: d.batch_number ?? d.BatchNumber ?? '',
                            palletId: Number(d.pallet_id ?? d.PalletId ?? 0) || 0,
                            palletCode: '',
                            supplierId: d.supplier_id ?? d.SupplierId ?? 0,
                            supplierName: d.supplier_name ?? d.SupplierName ?? '',
                            weight: d.weight ?? d.Weight ?? 0,
                            volume: d.volume ?? d.Volume ?? 0,
                            price: d.price ?? d.Price ?? 0,
                            isValid: d.is_valid ?? d.IsValid ?? true,
                            locationId: Number(d.goods_location_id ?? d.GoodsLocationId ?? 0) || null,
                            // Prefer server-provided location name; fallback to lookup if missing
                            location: d.goods_location_name ?? d.GoodsLocationName ?? '',
                            // Store ISO date for flatpickr + backend payload
                            expiryDate: toIsoDateOnly(d.expiry_date ?? d.ExpiryDate),
                            description: d.description ?? d.Description ?? '',
                            showNote: ((d.description ?? d.Description ?? '') + '').trim().length > 0
                        };
                    });

                    // Ensure expiry date fields are formatted via flatpickr altInput (dd/MM) after Alpine renders.
                    this.$nextTick(() => window.initFlatpickr?.(document));

                    // Expose items for global toggleAdjustOrder (lazy-load locations)
                    window.__detailItems = this.items;

                    window.addEventListener('master-data-loaded', () => {
                        this.dataLoaded = true;
                        // map unit name by uomId if possible
                        this.items.forEach(item => {
                            if (!item.uomId) return;
                            const match = globalSkuUomList.find(u => (u.id || u.uomId) == item.uomId);
                            if (match) item.unit = match.unitName || '';
                        });

                        // map location name by locationId
                        this.items.forEach(item => {
                            if (!item.locationId) {
                                item.location = '';
                                return;
                            }
                            if ((item.location || '').trim().length > 0) return;
                            const match = globalGoodLocationList.find(l => (l.id ?? l.Id) == item.locationId);
                            item.location = match
                                ? (match.LocationName || match.locationName || match.location_name || '')
                                : String(item.locationId);
                        });

                        // map pallet code by palletId
                        this.items.forEach(item => {
                            if (!item.palletId) {
                                item.palletCode = '';
                                return;
                            }
                            const match = (globalPalletList || []).find(p => Number(p?.id) === Number(item.palletId));
                            item.palletCode = match ? (match.palletCode || '') : String(item.palletId);
                        });
                    });

                    if (globalSkuUomList.length > 0) {
                        this.dataLoaded = true;
                    }

                    window.addEventListener('location-selected', (e) => {
                        const idx = e?.detail?.rowIndex;
                        const locId = e?.detail?.locationId ?? null;
                        const name = e?.detail?.locationName;
                        if (idx === null || idx === undefined) return;
                        if (!this.items || !this.items[idx]) return;
                        this.items[idx].locationId = locId;
                        this.items[idx].location = name || '';
                    });

                    window.addEventListener('pallet-locations-finished-detail', async (e) => {
                        const action = e?.detail?.action ?? null;
                        const map = e?.detail?.palletLocationMap ?? null;
                        if (!action || !map) return;
                        await this.onPalletLocationsFinished(action, map);
                    });

                    // expose save handler
                    window.saveChanges = () => this.saveChanges();
                },

                buildPalletLocationPrefill(rows) {
                    const map = {};
                    const grouped = {};
                    (rows || []).forEach(r => {
                        const pid = Number(r?.palletId) || 0;
                        if (!(pid > 0)) return;
                        if (!grouped[pid]) grouped[pid] = [];
                        grouped[pid].push(r);
                    });
                    Object.keys(grouped).forEach(pidStr => {
                        const pid = Number(pidStr) || 0;
                        const groupRows = grouped[pid] || [];
                        const locIds = groupRows
                            .map(x => Number(x?.locationId) || 0)
                            .filter(x => x > 0);
                        const uniqueLocIds = Array.from(new Set(locIds));
                        if (uniqueLocIds.length === 1) {
                            const locId = uniqueLocIds[0];
                            const nameFromRow = (groupRows.find(x => Number(x?.locationId) === locId && x?.location)?.location) || '';
                            map[pid] = { locationId: locId, locationName: nameFromRow };
                        }
                    });
                    return map;
                },

                applyPalletLocationsToRows(rows) {
                    (rows || []).forEach(r => {
                        const pid = Number(r?.palletId) || 0;
                        if (!(pid > 0)) return;
                        const loc = this.palletLocationMap?.[pid];
                        if (!loc) return;
                        r.locationId = loc.locationId ?? null;
                        r.location = loc.locationName ?? r.location ?? '';
                    });
                },

                openLocationPicker(rowIndex) {
                    if (!window.__detailAdjustMode) return;
                    const current = this.items?.[rowIndex] ?? null;
                    const currentLocationId = current?.locationId ?? null;
                    const currentLocationName = current?.location ?? '';
                    const takenLocationIds = (this.items || [])
                        .map((x, i) => (i === rowIndex ? null : x?.locationId))
                        .filter(x => x !== null && x !== undefined);

                    window.dispatchEvent(new CustomEvent('open-location-modal', {
                        detail: {
                            rowIndex,
                            currentLocationId,
                            currentLocationName,
                            takenLocationIds
                        }
                    }));
                },

                async saveChanges() {
                    if (!window.__detailAdjustMode) return;

                    const btn = document.getElementById('btnSaveChanges');
                    if (btn) {
                        btn.disabled = true;
                        btn.textContent = 'Đang lưu...';
                    }

                    try {
                        // Step 1: choose locations by pallet (single modal) before calling Update
                        const rows = (this.items || []).filter(x => x && x.skuId);
                        const missingPallet = rows.filter(x => !(Number(x.palletId) > 0));
                        if (missingPallet.length > 0) {
                            Notify.error('Vui lòng chọn pallet cho tất cả các dòng có hàng hóa trước khi lưu thay đổi.');
                            return;
                        }

                        const seen = new Set();
                        const palletIds = [];
                        for (const r of rows) {
                            const pid = Number(r?.palletId) || 0;
                            if (!(pid > 0)) continue;
                            if (!seen.has(pid)) {
                                seen.add(pid);
                                palletIds.push(pid);
                            }
                        }
                        if (palletIds.length === 0) {
                            Notify.error('Không tìm thấy pallet hợp lệ để chọn vị trí.');
                            return;
                        }

                        this.palletLocationMap = this.buildPalletLocationPrefill(rows);

                        const palletIdSet = new Set(palletIds);
                        const palletListForPopup = (globalPalletList || [])
                            .filter(p => palletIdSet.has(Number(p?.id)))
                            .map(p => ({ id: Number(p?.id) || 0, palletCode: p?.palletCode || '' }))
                            .filter(p => p.id > 0 && p.palletCode);

                        // Open modal and wait for finish event
                        this.__pendingUpdateAction = 'Update';
                        window.dispatchEvent(new CustomEvent('open-location-modal', {
                            detail: {
                                mode: 'pallet',
                                action: 'Update',
                                palletIds,
                                palletList: palletListForPopup,
                                palletLocationMap: this.palletLocationMap || {},
                                activePalletId: palletIds?.[0] ?? null
                            }
                        }));
                        return;
                    } catch (err) {
                        Notify.error('Có lỗi xảy ra: ' + (err?.message || err));
                        return;
                    } finally {
                        // Button will be restored in onPalletLocationsFinished (after API) or if early return
                        if (btn) {
                            btn.disabled = false;
                            btn.textContent = 'Lưu thay đổi';
                        }
                    }
                },

                async onPalletLocationsFinished(action, palletLocationMap) {
                    if (!window.__detailAdjustMode) return;
                    if (action !== 'Update') return;
                    if (this.__pendingUpdateAction !== 'Update') return;

                    const btn = document.getElementById('btnSaveChanges');
                    if (btn) {
                        btn.disabled = true;
                        btn.textContent = 'Đang lưu...';
                    }

                    try {
                        this.palletLocationMap = palletLocationMap || {};
                        const rows = (this.items || []).filter(x => x && x.skuId);
                        this.applyPalletLocationsToRows(rows);

                        const missingLocAfter = rows.filter(x => !(Number(x.locationId) > 0));
                        if (missingLocAfter.length > 0) {
                            Notify.error('Vui lòng chọn vị trí cho tất cả pallet trước khi lưu thay đổi.');
                            return;
                        }

                        const order = window.__orderDetail || {};
                        const masterId = order.id ?? order.Id ?? 0;

                        const warehouseSelect = document.getElementById('warehouseSelect');
                        const warehouseIdRaw = String(warehouseSelect?.value ?? '').trim();
                        if (!warehouseIdRaw) {
                            Notify.error('Vui lòng chọn Kho nhập');
                            return;
                        }
                        const warehouseIdValue = Number.isFinite(Number(warehouseIdRaw)) ? Number(warehouseIdRaw) : warehouseIdRaw;
                        const warehouseName = String(warehouseSelect?.selectedOptions?.[0]?.textContent || '').trim();

                        const detailList = (this.items || []).map(item => {
                            const qtyReqDecimal = parseFloat(String(item.qtyRequiredDecimal)) || 0;
                            const qtyRecDecimal = parseFloat(String(item.qtyReceivedDecimal)) || 0;

                            // Backend expects DateTime (e.g. 2026-01-09T00:00:00)
                            const expiry = toIsoDateTimeStartOfDay(item.expiryDate);

                            return {
                                id: Number(item.id) || 0,
                                asnmaster_id: Number(item.asnmasterId) || Number(masterId) || 0,
                                spu_id: Number(item.spuId) || 0,
                                spu_code: item.spuCode || '',
                                spu_name: item.spuName || '',
                                sku_id: Number(item.skuId) || 0,
                                sku_code: item.skuCode || '',
                                sku_name: item.skuName || '',
                                uom_id: Number(item.uomId) || null,
                                asn_qty: Math.floor(qtyReqDecimal),
                                asn_qty_decimal: qtyReqDecimal,
                                actual_qty: Math.floor(qtyRecDecimal),
                                actual_qty_decimal: qtyRecDecimal,
                                supplier_id: Number(item.supplierId) || 0,
                                supplier_name: item.supplierName || '',
                                weight: Number(item.weight) || 0,
                                volume: Number(item.volume) || 0,
                                price: Number(item.price) || 0,
                                is_valid: !!item.isValid,
                                batch_number: item.lotNo || '',
                                description: item.description || '',
                                goods_location_id: Number(item.locationId) || 0,
                                pallet_id: Number(item.palletId) || 0,
                                expiry_date: expiry
                            };
                        });

                        const requestData = {
                            id: masterId,
                            asn_no: order.asn_no ?? order.AsnNo ?? '',
                            asn_batch: order.asn_batch ?? order.AsnBatch ?? '',
                            estimated_arrival_time: order.estimated_arrival_time ?? order.EstimatedArrivalTime ?? null,
                            asn_status: order.asn_status ?? order.AsnStatus ?? 0,
                            weight: order.weight ?? order.Weight ?? 0,
                            volume: order.volume ?? order.Volume ?? 0,
                            goods_owner_id: order.goods_owner_id ?? order.GoodsOwnerId ?? 0,
                            goods_owner_name: order.goods_owner_name ?? order.GoodsOwnerName ?? '',
                            warehouse_id: warehouseIdValue,
                            warehouse_name: warehouseName,
                            creator: order.creator ?? order.Creator ?? '',
                            create_time: order.create_time ?? order.CreateTime ?? null,
                            last_update_time: order.last_update_time ?? order.LastUpdateTime ?? null,
                            detailList: detailList
                        };

                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        const response = await fetch(`?handler=Update`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify(requestData)
                        });

                        const result = await response.json();
                        if (result.success) {
                            Notify.success(result.message || 'Lưu thay đổi thành công!');
                            if (result.redirectUrl) {
                                window.location.href = result.redirectUrl;
                                return;
                            }
                            // No redirect: exit Adjust mode so UI returns to view state (and notes are re-synced)
                            window.toggleAdjustOrder?.();
                            return;
                        }
                        Notify.error(result.message || 'Có lỗi xảy ra khi lưu thay đổi');
                    } finally {
                        this.__pendingUpdateAction = null;
                        if (btn) {
                            btn.disabled = false;
                            btn.textContent = 'Lưu thay đổi';
                        }
                    }
                },

                get totalPages() {
                    return Math.ceil(this.items.length / this.pageSize);
                },
                get startIndex() {
                    return (this.currentPage - 1) * this.pageSize + 1;
                },
                get endIndex() {
                    const end = this.currentPage * this.pageSize;
                    return Math.min(end, this.items.length);
                },
                goToPage(page) {
                    if (page >= 1 && page <= this.totalPages) this.currentPage = page;
                },
                nextPage() { this.goToPage(this.currentPage + 1); },
                prevPage() { this.goToPage(this.currentPage - 1); },
                firstPage() { this.goToPage(1); },
                lastPage() { this.goToPage(this.totalPages); },
                changePageSize(size) {
                    this.pageSize = parseInt(size);
                    this.currentPage = 1;
                },
                get paginatedItems() {
                    const start = (this.currentPage - 1) * this.pageSize;
                    const end = start + this.pageSize;
                    return this.items.slice(start, end);
                },
                getRealIndex(currentIndex) {
                    return (this.currentPage - 1) * this.pageSize + currentIndex;
                },
                removeRow(index) {
                    if (!Array.isArray(this.items)) return;
                    if (index < 0 || index >= this.items.length) return;
                    this.items.splice(index, 1);
                    if (this.currentPage > this.totalPages) {
                        this.currentPage = this.totalPages || 1;
                    }
                },
                totalQtyRequired() {
                    return this.items.reduce((sum, item) => sum + parseFloat(item.qtyRequiredDecimal || 0), 0).toFixed(2);
                },
                totalQtyReceived() {
                    return this.items.reduce((sum, item) => sum + parseFloat(item.qtyReceivedDecimal || 0), 0).toFixed(2);
                },
                toggleNote(index) {
                    if (!window.__detailAdjustMode) return;
                    if (!Array.isArray(this.items)) return;
                    if (index < 0 || index >= this.items.length) return;
                    this.items[index].showNote = !this.items[index].showNote;
                },

                async retryRow(rowIndex) {
                    const items = Array.isArray(this.items) ? this.items : [];
                    const item = items[rowIndex];

                    if (!item || !item.id) {
                        if (typeof Notify !== 'undefined') Notify.error('Invalid item');
                        return;
                    }

                    if (item.locationId && item.locationId > 0) {
                        if (typeof Notify !== 'undefined') Notify.info('Dòng này đã có vị trí');
                        return;
                    }

                    // Store detail ID and row index for retry
                    window.__retryDetailId = item.id;
                    window.__retryRowIndex = rowIndex;
                    window.__isRetrying = true;

                    try {
                        // Fetch locations
                        const response = await fetchData('?handler=GoodLocations&totalPalletNeed=1');
                        const locations = (response && response.data) ? response.data : (Array.isArray(response) ? response : []);
                        window.__goodLocations = locations;

                        // Get current taken locations (excluding this row)
                        const takenLocationIds = items
                            .map((x, i) => (i === rowIndex ? null : x?.locationId))
                            .filter(x => x !== null && x !== undefined && x > 0);

                        // Open location modal
                        window.dispatchEvent(new CustomEvent('open-location-modal', {
                            detail: {
                                mode: 'row',
                                rowIndex: null, // We'll handle via retry flag
                                currentLocationId: null,
                                currentLocationName: '',
                                takenLocationIds
                            }
                        }));
                    } catch (err) {
                        console.error('Error loading locations:', err);
                        if (typeof Notify !== 'undefined') {
                            Notify.error('@L["ErrorLoadingData"]: ' + (err?.message || err));
                        }
                        window.__isRetrying = false;
                    }
                }
            }
        }
    </script>
    <script>
        // ===== ADJUST MODE (ENABLE EDITING) =====
        window.__detailAdjustMode = false;

        function syncDetailNotesFromDescription() {
            try {
                const items = Array.isArray(window.__detailItems) ? window.__detailItems : [];
                for (const it of items) {
                    const hasDesc = String(it?.description ?? '').trim().length > 0;
                    it.showNote = hasDesc;
                }
            } catch { /* ignore */ }
        }

        function setEditableState(el, enabled) {
            const tag = (el.tagName || '').toLowerCase();

            // Cache original state once
            if (el.dataset._adjustInit !== '1') {
                el.dataset._adjustInit = '1';
                el.dataset._origReadonly = el.hasAttribute('readonly') ? '1' : '0';
                el.dataset._origDisabled = el.hasAttribute('disabled') ? '1' : '0';
            }

            const shouldRestoreReadonly = el.dataset._origReadonly === '1';
            const shouldRestoreDisabled = el.dataset._origDisabled === '1';

            if (enabled) {
                el.removeAttribute('readonly');
                el.removeAttribute('disabled');
                el.classList.remove('bg-gray-100', 'cursor-not-allowed');
                el.classList.add('bg-white');
                // allow pointer on inputs
                if (tag === 'input' || tag === 'select' || tag === 'textarea') {
                    el.classList.add('cursor-text');
                }
            } else {
                if (shouldRestoreReadonly) el.setAttribute('readonly', 'readonly');
                if (shouldRestoreDisabled) el.setAttribute('disabled', 'disabled');
                el.classList.remove('bg-white', 'cursor-text');
                el.classList.add('bg-gray-100', 'cursor-not-allowed');
            }
        }

        window.toggleAdjustOrder = function () {
            window.__detailAdjustMode = !window.__detailAdjustMode;

            // When exiting Adjust mode: only show notes that actually have description
            if (!window.__detailAdjustMode) {
                syncDetailNotesFromDescription();
            }

            const btn = document.getElementById('btnAdjustOrder');
            if (btn) {
                btn.textContent = window.__detailAdjustMode ? '@Html.Raw(L["CancelAdjust"])' : '@Html.Raw(L["AdjustOrder"])';
            }

            const btnSave = document.getElementById('btnSaveChanges');
            if (btnSave) {
                btnSave.style.display = window.__detailAdjustMode ? '' : 'none';
            }

            const btnComplete = document.getElementById('btnCompleteOrder');
            if (btnComplete) {
                btnComplete.style.display = window.__detailAdjustMode ? 'none' : '';
            }

            const editableEls = document.querySelectorAll('[data-adjustable="true"]');
            editableEls.forEach(el => setEditableState(el, window.__detailAdjustMode));

            // Location picker inputs: keep readonly, just unlock styling/click
            const pickerEls = document.querySelectorAll('[data-adjustable="picker"]');
            pickerEls.forEach(el => {
                if (window.__detailAdjustMode) {
                    el.classList.remove('bg-gray-100', 'cursor-not-allowed');
                    el.classList.add('bg-white', 'cursor-pointer');
                    el.setAttribute('readonly', 'readonly');
                } else {
                    el.classList.remove('bg-white', 'cursor-pointer');
                    el.classList.add('bg-gray-100', 'cursor-not-allowed');
                    el.setAttribute('readonly', 'readonly');
                }
            });

            // Hide Location column in Adjust mode (location picked via modal on Save)
            document.querySelectorAll('.col-location').forEach(el => {
                el.style.display = window.__detailAdjustMode ? 'none' : '';
            });

            // Lazy-load locations when entering Adjust mode
            if (window.__detailAdjustMode) {
                try {
                    const items = Array.isArray(window.__detailItems) ? window.__detailItems : [];
                    const seen = new Set();
                    for (const it of items) {
                        const pid = Number(it?.palletId) || 0;
                        if (pid > 0) seen.add(pid);
                    }
                    const totalPalletNeed = seen.size || 1;
                    fetchData(`?handler=GoodLocations&totalPalletNeed=${totalPalletNeed}`)
                        .then(goodLocations => {
                            globalGoodLocationList = Array.isArray(goodLocations)
                                ? goodLocations
                                : (goodLocations && goodLocations.data) ? goodLocations.data : [];
                            window.__goodLocations = globalGoodLocationList;
                        })
                        .catch(() => {
                            globalGoodLocationList = [];
                            window.__goodLocations = [];
                        });
                } catch {
                    globalGoodLocationList = [];
                    window.__goodLocations = [];
                }
            }

            // Enable/disable expiry-date pickers in Adjust mode
            if (typeof flatpickr !== 'undefined') {
                // Ensure initialized (non-interactive) at least once
                window.initFlatpickr?.(document);

                editableEls.forEach(el => {
                    if (!el || !el._flatpickr) return;
                    const fp = el._flatpickr;
                    try {
                        fp.set('clickOpens', window.__detailAdjustMode);
                        fp.set('allowInput', window.__detailAdjustMode);
                        if (fp.altInput) {
                            setEditableState(fp.altInput, window.__detailAdjustMode);
                        }
                        if (!window.__detailAdjustMode) fp.close();
                    } catch { /* ignore */ }
                });
            }
        };
    </script>
    <script>
        window.submitOrderForm = async function () {
            try {
                const order = window.__orderDetail || {};
                const id = Number(order.id ?? order.Id ?? 0) || 0;
                if (id <= 0) {
                    Notify.error('Invalid order id.');
                    return;
                }

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch(`?handler=Complete`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(id)
                });

                const result = await response.json();
                if (result?.success) {
                    Notify.success(result.message || 'Completed successfully.');
                    if (result.redirectUrl) {
                        window.location.href = result.redirectUrl;
                    }
                    return;
                }
                Notify.error(result?.message || 'Complete failed.');
            } catch (err) {
                Notify.error('Complete failed: ' + (err?.message || err));
            }
        };
    </script>
    <script>
        // ===== RETRY LOGIC =====
        window.__isRetrying = false;
        window.__retryLocationId = null;
        window.__retryLocationName = '';

        window.retry = async function () {
            const asnId = @Model.Id;
            if (!asnId || asnId <= 0) {
                Notify.error('Invalid ASN ID');
                return;
            }

            // Set retry flag
            window.__isRetrying = true;
            window.__retryLocationId = null;
            window.__retryLocationName = '';

            try {
                // Fetch good locations first (same as in adjust mode)
                const response = await fetchData('?handler=GoodLocations&totalPalletNeed=1');
                const locations = (response && response.data) ? response.data : (Array.isArray(response) ? response : []);

                // Store in global variable for modal to use
                window.__goodLocations = locations;

                // Dispatch event to open existing Alpine modal in 'row' mode
                window.dispatchEvent(new CustomEvent('open-location-modal', {
                    detail: {
                        mode: 'row',
                        rowIndex: null,
                        currentLocationId: null,
                        currentLocationName: '',
                        takenLocationIds: []
                    }
                }));
            } catch (err) {
                console.error('Error loading locations:', err);
                Notify.error('@L["ErrorLoadingData"]: ' + (err?.message || err));
                window.__isRetrying = false;
            }
        };

        // Listen for location selection from the Alpine modal (for retry)
        window.addEventListener('location-selected', async (e) => {
            if (!window.__isRetrying) return;

            const locationId = e?.detail?.locationId;
            const locationName = e?.detail?.locationName || '';

            if (!locationId) {
                Notify.error('Invalid location selected');
                window.__isRetrying = false;
                return;
            }

            // Get detail ID (not master ID)
            const detailId = window.__retryDetailId;
            if (!detailId || detailId <= 0) {
                Notify.error('Invalid detail ID');
                window.__isRetrying = false;
                return;
            }

            // Get pallet code from the specific row
            const items = Array.isArray(window.__detailItems) ? window.__detailItems : [];
            const rowIndex = window.__retryRowIndex ?? -1;
            let palletCode = '';

            if (rowIndex >= 0 && rowIndex < items.length) {
                palletCode = items[rowIndex]?.palletCode || '';
            }

            const payload = {
                asn_id: detailId,  // ← Now using detail row ID instead of master ID
                new_location_id: locationId,
                pallet_code: palletCode || ''
            };

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch(`?handler=Retry`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                if (result?.success) {
                    Notify.success(result.message || '@L["RetrySuccess"]');

                    // Update the row's location in UI
                    if (rowIndex >= 0 && rowIndex < items.length) {
                        items[rowIndex].locationId = locationId;
                        items[rowIndex].location = locationName;
                    }

                    // Reload page to show updated status
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    Notify.error(result?.message || '@L["RetryFailed"]');
                }
            } catch (err) {
                console.error('Retry error:', err);
                Notify.error('@L["RetryFailed"]: ' + (err?.message || err));
            } finally {
                window.__isRetrying = false;
                window.__retryDetailId = null;
                window.__retryRowIndex = null;
            }
        });
    </script>
}