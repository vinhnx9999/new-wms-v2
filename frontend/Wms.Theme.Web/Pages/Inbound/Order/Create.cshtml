@page "/Inbound/Order/Create"
@model Wms.Theme.Web.Pages.Inbound.Order.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@{
    ViewData["Title"] = L["CreateInboundOrder"];
}

@Html.AntiForgeryToken()

<style>
    .timeline {
        position: relative;
    }

    .timeline-item {
        position: relative;
        display: flex;
        padding-bottom: 2rem;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    /* Vertical connector line */
    .timeline-item::after {
        content: "";
        position: absolute;
        left: 5.5px;
        top: 18px;
        /* Start below the dot */
        bottom: -6px;
        /* End above the next dot */
        width: 1.5px;
        background-color: #e2e8f0;
        z-index: 0;
    }

    .timeline-item:last-child::after {
        display: none;
    }

    .timeline-item-point {
        width: 12px;
        height: 12px;
        margin-top: 6px;
        flex-shrink: 0;
        position: relative;
        z-index: 10;
        border: 2px solid white;
        box-shadow: 0 0 0 1px #e2e8f0;
    }

    .timeline-item-content {
        flex: 1;
        padding-left: 1.5rem;
    }

    .timeline-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2px;
    }
</style>

<div class="grid grid-cols-12 gap-6">

    <div class="col-span-12 lg:col-span-9 bg-white p-4 rounded-lg shadow-sm">
        <h2 class="font-bold text-gray-800 mb-4 border-b pb-2">Thông tin chung</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

            <div class="space-y-4">
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Mã đối tượng</label>
                    <select id="goodsOwnerSelect"
                            class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500 bg-white">
                        <option value="">Đang tải...</option>
                    </select>
                </div>
                <div>
                    <label class="block text-gray-700 font-medium mb-1">Kho nhập <span
                        class="text-red-500">*</span></label>
                        <select id="warehouseSelect"
                                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500 bg-white">
                            <option value="">Đang tải...</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Người thực hiện</label>
                        <input id="creator" type="text" value="@Model.Creator"
                               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500">
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Diễn giải</label>
                        <input id="description" type="text" value="Lệnh nhập kho hàng hóa"
                               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500">
                    </div>
                    <div class="input-group">
                        <label class="block text-gray-700 font-medium mb-1">Tham chiếu</label>
                        <div class="relative">
                            <input id="reference" type="text"
                                   class="w-full border border-gray-300 rounded px-3 py-2 pr-8 focus:outline-blue-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute right-3 top-3 text-gray-400"
                                 fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                    </div>
                </div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Số lệnh nhập kho <span
                            class="text-red-500">*</span></label>
                            <input id="asnNo" type="text" value="@Model.AsnNo"
                                   class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500">
                        </div>
                        <div>
                            <label class="block text-gray-700 font-medium mb-1">Ngày lập lệnh</label>
                            <div class="relative">
                                <input id="createTime" type="text" value="@Model.CurrentDate"
                                       class="datetime-picker w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500">
                            </div>
                        </div>
                        <div class="hidden">
                            <label class="block text-gray-700 font-medium mb-1">Hạn nhập kho</label>
                            <div class="relative">
                                <input id="estimatedArrival" type="text" value="@Model.CurrentDate"
                                       class="datetime-picker w-full border border-gray-300 rounded px-3 py-2 focus:outline-blue-500">
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-span-12 lg:col-span-3 bg-white p-4 rounded-lg shadow-sm h-full">
                <h2 class="font-bold text-gray-800 mb-4 border-b pb-2">Theo dõi tình trạng</h2>
                <!-- TODO:  update soon -->
            </div>

        </div>

        <div class="p-6" x-data="orderDetailTable()">
            <h3 class="font-bold text-lg text-gray-800 mb-4">Hàng hóa</h3>

            <!-- Search Bar -->
            <div class="mb-4">
                <div class="relative w-full max-w-sm">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none"
                             viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text"
                           class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full pl-10 p-2.5"
                           placeholder="Tìm kiếm..." required>
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto border rounded-lg">
                <table class="w-full text-sm text-left text-gray-500">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                        <tr>
                            <th scope="col" class="px-2 py-2 w-12">#</th>
                            <th scope="col" class="px-2 py-2 w-48">Mã hàng</th>
                            <th scope="col" class="px-2 py-2 w-40">Tên hàng</th>
                            <th scope="col" class="px-2 py-2 w-32">Mã quy cách</th>
                            <th scope="col" class="px-2 py-2 w-28">ĐVT</th>
                            <th scope="col" class="px-2 py-2 w-24">SL yêu cầu</th>
                            <th scope="col" class="px-2 py-2 w-24">SL thực nhập</th>
                            <th scope="col" class="px-2 py-2 w-18 text-center">Đánh dấu đủ</th>
                            <th scope="col" class="px-2 py-2 w-28">Số lô</th>
                            <th scope="col" class="px-2 py-2 w-28">Pallet</th>
                            <th scope="col" class="px-2 py-2 w-36">Hạn sử dụng</th>
                            <th scope="col" class="px-2 py-2 w-20"></th>
                        </tr>
                    </thead>
                    <template x-for="(item, index) in paginatedItems" :key="getRealIndex(index)">
                        <tbody>
                            <tr class="bg-white border-b hover:bg-gray-50">
                                <td class="px-1 py-1" x-text="getRealIndex(index) + 1"></td>
                                <td class="px-1 py-1">
                                    <select x-model="item.skuId"
                                        @@change="onSkuChange(getRealIndex(index), $event.target.value)"
                                            class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5">
                                        <option value="">Chọn hàng hóa</option>
                                        <template x-for="sku in skuOptions" :key="sku.sku_id">
                                            <option :value="sku.sku_id" x-text="sku.sku_code + ' - ' + sku.sku_name"></option>
                                        </template>
                                    </select>
                                </td>
                                <td class="px-1 py-1">
                                    <input type="text" x-model="item.skuName" readonly
                                           class="bg-gray-100 border border-gray-300 text-gray-900 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                                </td>
                                <td class="px-1 py-1">
                                    <input type="text"
                                           class="bg-gray-100 border border-gray-300 text-gray-900 text-sm rounded block w-full p-1.5 cursor-not-allowed">
                                </td>
                                <td class="px-1 py-1">
                                    <select x-model="item.unit" @@change="onUomChange(getRealIndex(index), item.unit)"
                                            class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5">
                                        <option value="">Đơn vị</option>
                                        <template x-for="uom in getUomOptions(item.skuId)" :key="uom.unitName">
                                            <option :value="uom.unitName" x-text="uom.unitName"
                                                    :selected="item.unit === uom.unitName"></option>
                                        </template>
                                    </select>
                                </td>
                                <td class="px-1 py-1">
                                    <input type="number" x-model="item.qtyRequiredDecimal" min="0" step="0.01"
                                           class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5 text-right">
                                </td>
                                <td class="px-1 py-1">
                                    <input type="number" x-model="item.qtyReceivedDecimal" min="0" step="0.01"
                                           class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5 text-right">
                                </td>
                                <td class="px-1 py-1 text-center">
                                    <input type="checkbox" x-model="item.isFull" @@change="toggleFull(index)"
                                           class="w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500">
                                </td>
                                <td class="px-1 py-1">
                                    <input type="text" x-model="item.lotNo"
                                           class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5">
                                </td>
                                <!-- hidden field -->
                                <!-- waiting for my flow to implement -->
                                <td class="px-1 py-1" hidden>
                                    <input type="text" x-model="item.location" readonly
                                    @@click="openLocationPicker(getRealIndex(index))"
                                           class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5 cursor-pointer"
                                           placeholder="Chọn vị trí">
                                </td>

                                <!-- Pallet column - Dropdown with Search + Teleport -->
                                <td class="px-1 py-1">
                                    <div x-data="palletDropdown(getRealIndex(index))" class="relative">
                                        <!-- Trigger Button -->
                                        <button type="button" x-ref="triggerBtn" @@click="toggle()"
                                                class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 flex items-center justify-between w-full p-1.5"
                                                :class="item.palletCode ? 'text-blue-600 font-medium' : 'text-gray-400'">
                                            <span x-text="item.palletCode || 'Chọn pallet...'" class="truncate"></span>
                                            <template x-if="item.isGeneratingPallet">
                                                <svg class="animate-spin h-4 w-4 text-blue-500 ml-1"
                                                     xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor"
                                                            stroke-width="4"></circle>
                                                    <path class="opacity-75" fill="currentColor"
                                                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                                                    </path>
                                                </svg>
                                            </template>
                                            <template x-if="!item.isGeneratingPallet">
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     class="h-4 w-4 transition-transform duration-200 text-gray-400"
                                                     :class="isShowPopper && 'rotate-180'" fill="none" viewBox="0 0 24 24"
                                                     stroke="currentColor" stroke-width="2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                                </svg>
                                            </template>
                                        </button>
                                        <input type="hidden" x-model="item.palletId">

                                        <!-- Teleported Dropdown Popper -->
                                        <template x-teleport="#x-teleport-target">
                                            <div x-show="isShowPopper" x-ref="popperRoot" @@click.outside="closePopper($event)"
                                                 x-transition:enter="transition ease-out duration-150"
                                                 x-transition:enter-start="opacity-0 scale-95"
                                                 x-transition:enter-end="opacity-100 scale-100"
                                                 x-transition:leave="transition ease-in duration-100"
                                                 x-transition:leave-start="opacity-100 scale-100"
                                                 x-transition:leave-end="opacity-0 scale-95" :style="popperStyle"
                                                 class="fixed z-[9999] w-64 rounded-md border border-slate-200 bg-white shadow-lg dark:border-navy-600 dark:bg-navy-700"
                                                 style="min-width: 250px;">

                                                <!-- Search Input -->
                                                <div class="p-2 border-b border-slate-150 dark:border-navy-600">
                                                    <div class="relative">
                                                        <input type="text" x-model="searchKeyword" x-ref="searchInput"
                                                        @@input.debounce.300ms="search()"
                                                        @@keydown.escape="isShowPopper = false"
                                                               class="form-input w-full border border-slate-200 bg-transparent px-3 py-1.5 pl-8 text-sm placeholder:text-slate-400/70 rounded focus:border-blue-500 dark:border-navy-600"
                                                               placeholder="Tìm mã pallet...">
                                                        <div
                                                            class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-2.5 text-slate-400">
                                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none"
                                                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                                            </svg>
                                                        </div>
                                                        <template x-if="isLoading">
                                                            <div class="absolute inset-y-0 right-0 flex items-center pr-2">
                                                                <svg class="animate-spin h-4 w-4 text-blue-500"
                                                                     xmlns="http://www.w3.org/2000/svg" fill="none"
                                                                     viewBox="0 0 24 24">
                                                                    <circle class="opacity-25" cx="12" cy="12" r="10"
                                                                            stroke="currentColor" stroke-width="4"></circle>
                                                                    <path class="opacity-75" fill="currentColor"
                                                                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                                                </svg>
                                                            </div>
                                                        </template>
                                                    </div>
                                                </div>

                                                <!-- Pallet List -->
                                                <ul class="max-h-48 overflow-y-auto py-1">
                                                    <template x-if="pallets.length === 0 && !isLoading">
                                                        <li class="px-3 py-2 text-sm text-slate-500 text-center">
                                                            <span
                                                            x-text="searchKeyword ? 'Không tìm thấy' : 'Nhập để tìm kiếm'"></span>
                                                        </li>
                                                    </template>
                                                    <template x-for="pallet in pallets" :key="pallet.pallet_code">
                                                        <li>
                                                            <button type="button" @@click="selectPallet(pallet)"
                                                                    :disabled="isUsedByOtherRow(pallet)"
                                                                    class="flex items-center justify-between w-full px-3 py-2 text-sm transition-all outline-none"
                                                                    :class="isUsedByOtherRow(pallet)
                                                                ? 'text-red-400 bg-red-50 cursor-not-allowed opacity-60'
                                                                : (item.palletCode === pallet.pallet_code
                                                                ? 'bg-blue-50 text-blue-700'
                                                                : 'text-slate-700 hover:bg-slate-100 dark:text-navy-100 dark:hover:bg-navy-600')">
                                                                <div class="flex flex-col items-start">
                                                                    <span class="font-medium"
                                                                          x-text="pallet.pallet_code"></span>
                                                                    <span class="text-xs text-slate-400"
                                                                          x-text="formatDate(pallet.create_time)"></span>
                                                                </div>
                                                                <template x-if="item.palletCode === pallet.pallet_code">
                                                                    <svg xmlns="http://www.w3.org/2000/svg"
                                                                         class="h-4 w-4 text-blue-600" fill="none"
                                                                         viewBox="0 0 24 24" stroke="currentColor"
                                                                         stroke-width="2">
                                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                                              d="M5 13l4 4L19 7" />
                                                                    </svg>
                                                                </template>
                                                                <template x-if="isUsedByOtherRow(pallet)">
                                                                    <span class="text-xs text-red-400">Đã dùng</span>
                                                                </template>
                                                            </button>
                                                        </li>
                                                    </template>
                                                </ul>

                                                <!-- Pagination Footer -->
                                                <template x-if="totalPages > 1">
                                                    <div
                                                        class="flex items-center justify-between px-3 py-2 border-t border-slate-150 text-xs text-slate-500 dark:border-navy-600">
                                                        <span x-text="`${pageIndex}/${totalPages}`"></span>
                                                        <div class="flex gap-1">
                                                            <button type="button" @@click="prevPage()"
                                                                    :disabled="pageIndex <= 1"
                                                                    class="px-2 py-0.5 border rounded hover:bg-slate-100 disabled:opacity-50">
                                                                ←
                                                            </button>
                                                            <button type="button" @@click="nextPage()"
                                                                    :disabled="pageIndex >= totalPages"
                                                                    class="px-2 py-0.5 border rounded hover:bg-slate-100 disabled:opacity-50">
                                                                →
                                                            </button>
                                                        </div>
                                                    </div>
                                                </template>
                                            </div>
                                        </template>
                                    </div>
                                </td>
                                <td class="px-1 py-1">
                                    <input type="text" x-model="item.expiryDate" x-init="flatpickr($el, { 
                                    dateFormat: 'Y-m-d', 
                                    altInput: true, 
                                    altFormat: 'd/m/Y',
                                    allowInput: true 
                                    })"
                                           class="date-picker bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5"
                                           placeholder="dd/mm/yyyy">
                                </td>
                                <td class="px-1 py-1 flex gap-1.5">
                                    <button @@click="toggleNote(getRealIndex(index))" type="button"
                                        class="font-medium hover:bg-gray-100 p-1 rounded"
                                        :class="item.showNote ? 'text-blue-600' : 'text-gray-400'" title="Thêm ghi chú">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                             stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                                        </svg>
                                    </button>
                                    <button @@click="removeRow(getRealIndex(index))" type="button"
                                        class="font-medium text-red-600 hover:underline">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                             stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                            <tr x-show="item.showNote" class="bg-gray-50 border-b">
                                <td class="px-2 py-1.5"></td>
                                <td class="px-2 py-1.5"></td>
                                <td class="px-2 py-1.5" colspan="10">
                                    <input type="text" x-model="item.description" placeholder="Nhập ghi chú..."
                                           class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block w-full p-1.5">
                                </td>
                                <td colspan="9"></td>
                            </tr>
                        </tbody>
                    </template>
                    <tbody>
                        <tr class="bg-gray-50 font-bold text-gray-700">
                            <td colspan="5" class="px-4 py-2 text-right">Tổng số: <span x-text="items.length"></span></td>
                            <td class="px-4 py-2 text-right" x-text="totalQtyRequired()"></td>
                            <td class="px-4 py-2 text-right" x-text="totalQtyReceived()"></td>
                            <td colspan="4"></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination & Page Size -->
            <div class="flex items-center justify-end mt-4 gap-2 text-sm text-gray-600">
                <span>Số dòng/trang</span>
                <select class="border border-gray-300 rounded p-1 focus:outline-blue-500" x-model="pageSize"
                    @@change="changePageSize($event.target.value)">
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span>
                    <span x-text="startIndex"></span> - <span x-text="endIndex"></span>
                    của <span x-text="items.length"></span>
                </span>
                <div class="flex gap-1">
                    <button @@click="firstPage()" :disabled="currentPage === 1"
                        class="p-1 px-2 border rounded hover:bg-gray-100 disabled:opacity-50">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                            <path fill-rule="evenodd"
                                  d="M15.79 14.77a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L11.832 10l3.938 3.71a.75.75 0 0 1 .02 1.06Zm-6 0a.75.75 0 0 1-1.06.02l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 1 1 1.04 1.08L5.832 10l3.938 3.71a.75.75 0 0 1 .02 1.06Z"
                                  clip-rule="evenodd" />
                        </svg>
                    </button>
                    <button @@click="prevPage()" :disabled="currentPage === 1"
                        class="p-1 px-2 border rounded hover:bg-gray-100 disabled:opacity-50">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                            <path fill-rule="evenodd"
