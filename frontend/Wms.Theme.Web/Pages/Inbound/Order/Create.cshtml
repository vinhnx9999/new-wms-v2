                <button @@click="clearAll()" type="button"
                    class="flex items-center gap-1 px-3 py-1.5 text-gray-700 border border-gray-300 rounded hover:bg-gray-50 font-medium text-sm transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                         stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    Xóa hết dòng
                </button>
            </div>
        </div>

        <div class="h-20"></div>

        <div
            class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 p-4 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] z-50">
            <div class="container mx-auto flex justify-end items-center gap-3">

                <button type="button" onclick="window.saveDraftForm()"
                        class="px-4 py-2 border border-blue-600 rounded text-blue-600 hover:bg-blue-50 transition-colors font-medium">
                    Lưu tạm
                </button>

                <button type="button" onclick="window.submitOrderForm()"
                        class="px-4 py-2 bg-blue-600 border border-blue-600 rounded text-white hover:bg-blue-700 transition-colors font-medium shadow-sm">
                    Hoàn thành
                </button>

            </div>
        </div>


        <!-- Modal: choose location (shows only location name) -->
        <div x-data="locationPickerModal()">
            <template x-teleport="#x-teleport-target">
                <div class="fixed inset-0 z-[100] flex flex-col items-center justify-center overflow-hidden px-4 py-6 sm:px-5"
                     x-show="showModal" role="dialog" @@keydown.window.escape="close()">
                    <div class="absolute inset-0 bg-slate-900/60 transition-opacity duration-300" @@click="close()"
                         x-show="showModal" x-transition:enter="ease-out" x-transition:enter-start="opacity-0"
                         x-transition:enter-end="opacity-100" x-transition:leave="ease-in" x-transition:leave-start="opacity-100"
                         x-transition:leave-end="opacity-0"></div>

                    <div class="relative w-full max-w-2xl origin-bottom rounded-lg bg-white pb-4 transition-all duration-300 dark:bg-navy-700"
                         x-show="showModal" x-transition:enter="easy-out" x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100" x-transition:leave="easy-in"
                         x-transition:leave-start="opacity-100 scale-100" x-transition:leave-end="opacity-0 scale-95">

                        <div class="flex justify-between rounded-t-lg bg-slate-200 px-4 py-3 dark:bg-navy-800 sm:px-5">
                            <div class="flex items-center gap-3">
                                <h3 class="text-base font-medium text-slate-700 dark:text-navy-100"
                                    x-text="mode === 'pallet' ? 'Chọn vị trí theo pallet' : 'Chọn vị trí'">
                                </h3>
                                <template x-if="mode === 'pallet'">
                                    <select x-model="activePalletCode" @@change="setActivePallet(activePalletCode)"
                                            class="bg-white border border-gray-300 text-gray-900 text-sm rounded focus:ring-blue-500 focus:border-blue-500 block p-1.5 min-w-[180px]">
                                        <template x-for="p in palletList" :key="p.palletCode">
                                            <option :value="p.palletCode" x-text="p.palletCode"></option>
                                        </template>
                                    </select>
                                </template>
                            </div>
                            <button @@click="close()"
                                class="btn -mr-1.5 size-7 rounded-full p-0 hover:bg-slate-300/20 focus:bg-slate-300/20 active:bg-slate-300/25 dark:hover:bg-navy-300/20 dark:focus:bg-navy-300/20 dark:active:bg-navy-300/25">
                                <svg xmlns="http://www.w3.org/2000/svg" class="size-4.5" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>

                        <div class="mt-3 max-h-[420px] overflow-auto px-2 sm:px-3">
                            <template x-if="filteredLocations.length === 0">
                                <div class="px-4 py-6 text-sm text-slate-500">Không có dữ liệu vị trí.</div>
                            </template>

                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                                <template x-for="(loc, idx) in filteredLocations" :key="idx">
                                    <button type="button" @@click="choose(loc)"
                                            :disabled="(() => { const id = getLocationId(loc); return id !== null && isTaken(id) && id !== selectedLocationId; })()"
                                            class="w-full rounded border bg-white px-4 py-3 text-left shadow-sm focus:outline-none focus:ring-2 dark:bg-navy-700"
                                            :class="(() => {
                                        const id = getLocationId(loc);
                                        const selected = (id !== null && id === selectedLocationId);
                                        const disabled = (id !== null && isTaken(id) && id !== selectedLocationId);
                                        if (selected) return 'border-red-500 bg-red-50 ring-red-200 dark:border-red-400 dark:bg-red-500/10';
                                        if (disabled) return 'border-red-300 bg-red-50 text-red-700 opacity-70 cursor-not-allowed ring-transparent dark:border-red-400 dark:bg-red-500/10';
                                        return 'border-slate-200 hover:border-slate-300 hover:bg-slate-50 ring-blue-500 dark:border-navy-600 dark:hover:bg-navy-600';
                                        })()">
                                        <div class="text-sm font-medium"
                                             :class="(() => { const id = getLocationId(loc); return (id !== null && id === selectedLocationId) ? 'text-red-700 dark:text-red-200' : 'text-slate-800 dark:text-navy-100'; })()"
                                             x-text="getLocationName(loc)"></div>
                                    </button>
                                </template>
                            </div>
                        </div>
                        <template x-if="mode === 'pallet'">
                            <div class="mt-3 flex items-center justify-end gap-2 px-4 sm:px-5">
                                <button type="button" @@click="close()"
                                        class="px-4 py-2 border border-gray-300 rounded text-gray-700 hover:bg-gray-50 transition-colors font-medium">
                                    Hủy
                                </button>
                                <button type="button" @@click="finish()" :disabled="!canFinish"
                                        class="px-4 py-2 bg-blue-600 border border-blue-600 rounded text-white hover:bg-blue-700 transition-colors font-medium shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">
                                    Hoàn thành
                                </button>
                            </div>
                        </template>
                    </div>
                </div>
            </template>
        </div>


        @section Scripts
        {
            <script src="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.js"></script>
            <script>
                // ===== FLATPICKR INITIALIZATION =====
                window.initFlatpickr = function (scope = document) {
                if (typeof flatpickr === 'undefined') return;
                const datetimeInputs = scope.querySelectorAll('.datetime-picker');
                if (datetimeInputs.length > 0) {
                flatpickr(datetimeInputs, { dateFormat: "d/m/Y H:i", enableTime: true, time_24hr: true, allowInput: true, defaultDate: new Date() });
                }
                const dateInputs = scope.querySelectorAll('.date-picker');
                if (dateInputs.length > 0) {
                flatpickr(dateInputs, { dateFormat: "d/m/Y", allowInput: true });
                }
                };
                document.addEventListener("DOMContentLoaded", function () { window.initFlatpickr(); });
            </script>
            <script>
                // ===== GLOBAL VARIABLES =====
                let globalSkuList = [];
                let globalSkuUomList = [];
                let globalGoodsOwnerList = [];
                let globalSupplierList = [];
                let globalWarehouseList = [];
                let globalGoodLocationList = [];

                // ===== HELPER FUNCTIONS =====
                async function fetchData(url) {
                const response = await fetch(url);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                return await response.json();
                }

                async function postData(url, data) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(data)
                });
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                return await response.json();
                }

                function renderGoodsOwnerOptions(data) {
                const select = document.getElementById('goodsOwnerSelect');
                if (!select) return;
                let html = `<option value="">Chọn đối tượng</option>`;
                data.forEach(item => { html += `<option value="${item.id}" data-name="${item.goods_owner_name}">${item.goods_owner_name}</option>`; });
                select.innerHTML = html;
                }

                function renderSupplierOptions(data) {
                const select = document.getElementById('supplierSelect');
                if (!select) return;
                let html = `<option value="">Chọn nhà cung cấp</option>`;
                data.forEach(item => { html += `<option value="${item.id}">${item.supplier_name}</option>`; });
                select.innerHTML = html;
                }

                function renderWarehouseOptions(data) {
                const select = document.getElementById('warehouseSelect');
                if (!select) return;
                let html = `<option value="">Chọn kho</option>`;
                data.forEach(item => {
                const name = item.WarehouseName || item.warehouseName || item.warehouse_name || 'N/A';
                html += `<option value="${item.id}">${name}</option>`;
                });
                select.innerHTML = html;
                }

                // ===== DOMContentLoaded =====
                document.addEventListener("DOMContentLoaded", function () {
                Promise.all([
                fetchData('?handler=LoadGoodsOwner'),
                fetchData('?handler=LoadSkuSelect'),
                fetchData('?handler=LoadSupplier'),
                fetchData('?handler=LoadSkuUom'),
                fetchData('?handler=LoadWarehouse'),
                ]).then(([owners, skus, suppliers, uoms, warehouses]) => {
                globalGoodsOwnerList = (owners?.data) || [];
                globalSkuList = (skus?.data) || [];
                globalSupplierList = (suppliers?.data) || [];
                globalSkuUomList = (uoms?.data) || [];
                globalWarehouseList = (warehouses?.data) || [];
                globalGoodLocationList = [];
                window.__goodLocations = [];

                if (globalGoodsOwnerList.length > 0) renderGoodsOwnerOptions(globalGoodsOwnerList);
                if (globalSupplierList.length > 0) renderSupplierOptions(globalSupplierList);
                if (globalWarehouseList.length > 0) renderWarehouseOptions(globalWarehouseList);

                window.dispatchEvent(new CustomEvent('master-data-loaded'));
                }).catch(err => {
                console.error('Error loading master data:', err);
                if (typeof Notify !== 'undefined') Notify.error('Không thể tải dữ liệu.');
                });
                });

                // ===== PALLET DROPDOWN COMPONENT =====
                // ===== PALLET DROPDOWN COMPONENT =====
                function palletDropdown(rowIndex) {
                return {
                rowIndex: rowIndex,
                isShowPopper: false,
                searchKeyword: '',
                pallets: [],
                pageIndex: 1,
                pageSize: 10,
                total: 0,
                totalPages: 0,
                isLoading: false,
                popperPosition: { top: 0, left: 0 },


                getItem() {
                const items = Alpine.store('orderItems') || [];
                return items[this.rowIndex] || {};
                },

                get item() {
                return this.getItem();
                },

                get popperStyle() {
                return `top: ${this.popperPosition.top}px; left: ${this.popperPosition.left}px;`;
                },

                updatePopperPosition() {
                const btn = this.$refs.triggerBtn;
                if (!btn) return;
                const rect = btn.getBoundingClientRect();
                const dropdownHeight = 280; // estimated max height
                const dropdownWidth = 250;

                // Check if dropdown would go below viewport
                const spaceBelow = window.innerHeight - rect.bottom;
                const spaceAbove = rect.top;

                let top, left;

                if (spaceBelow >= dropdownHeight || spaceBelow >= spaceAbove) {
                // Show below
                top = rect.bottom + 4;
                } else {
                // Show above
                top = rect.top - dropdownHeight - 4;
                }

                // Horizontal positioning
                left = rect.left;
                if (left + dropdownWidth > window.innerWidth) {
                left = window.innerWidth - dropdownWidth - 10;
                }

                this.popperPosition = { top, left };
                },

                async toggle() {
                this.isShowPopper = !this.isShowPopper;
                if (this.isShowPopper) {
                this.searchKeyword = '';
                this.pageIndex = 1;
                this.updatePopperPosition();
                await this.search();
                // Focus search input after opening
                this.$nextTick(() => {
                const searchInput = document.querySelector('#x-teleport-target input[placeholder="Tìm mã pallet..."]');
                if (searchInput) searchInput.focus();
                });
                }
                },

                closePopper(event) {
                // Check if click is on the trigger button (to avoid double toggle)
                const btn = this.$refs.triggerBtn;
                if (btn && btn.contains(event.target)) return;
                this.isShowPopper = false;
                },

                async search() {
                this.isLoading = true;
                try {
                const searchObjects = [];
                if (this.searchKeyword.trim()) {
                // Match C# SearchObject model: PascalCase + Operator enum (6 = Contains)
                searchObjects.push({
                Label: 'PalletCode',
                Name: 'PalletCode',
                Operator: 6,
                Value: this.searchKeyword.trim(),
                Text: this.searchKeyword.trim()
                });
                }
                const result = await postData('?handler=SearchPallets', { pageIndex: this.pageIndex, pageSize: this.pageSize, searchObjects: searchObjects });
                if (result.success && result.data) {
                this.pallets = result.data.rows || [];
                this.total = result.data.total || 0;
                this.totalPages = result.data.totalPages || 0;
                } else {
                this.pallets = []; this.total = 0; this.totalPages = 0;
                }
                } catch (err) { console.error('Search pallets error:', err); this.pallets = []; }
                finally { this.isLoading = false; }
                },

                async prevPage() { if (this.pageIndex > 1) { this.pageIndex--; await this.search(); } },
                async nextPage() { if (this.pageIndex < this.totalPages) { this.pageIndex++; await this.search(); } },

                isUsedByOtherRow(pallet) {
                const code = pallet?.pallet_code || '';
                if (!code) return false;
                const currentItem = this.getItem();
                if (currentItem && code === currentItem.palletCode) return false;
                const items = Alpine.store('orderItems') || [];
                return items.some((x, i) => i !== this.rowIndex && x?.palletCode === code);
                },

                selectPallet(pallet) {
                if (this.isUsedByOtherRow(pallet)) return;
                const currentItem = this.getItem();
                if (currentItem) {
                currentItem.palletCode = pallet.pallet_code || '';
                currentItem.palletId = pallet.id || 0;
                }
                this.isShowPopper = false;
                },

                formatDate(dateStr) {
                if (!dateStr) return '';
                try { return new Date(dateStr).toLocaleDateString('vi-VN'); } catch { return dateStr; }
                }
                };
                }

                // ===== LOCATION PICKER MODAL =====
                function locationPickerModal() {
                return {
                showModal: false, keyword: '', mode: 'row', isWizard: false, rowIndex: null,
                palletId: null, palletCode: '', palletList: [], palletCodes: [], activePalletCode: null,
                palletLocationMap: {}, action: null, selectedLocationId: null, selectedLocationName: '',
                takenLocationIds: [], locations: [],


                init() {
                window.addEventListener('open-location-modal', (e) => {
                this.mode = (e?.detail?.mode === 'pallet') ? 'pallet' : 'row';
                this.isWizard = Boolean(e?.detail?.isWizard);
                this.rowIndex = e?.detail?.rowIndex ?? null;
                this.palletList = Array.isArray(e?.detail?.palletList) ? e.detail.palletList : [];
                // Use palletCodes instead of palletIds for consistent string-based keys
                this.palletCodes = this.palletList.map(p => p.palletCode).filter(Boolean);
                this.palletLocationMap = (typeof e?.detail?.palletLocationMap === 'object') ? e.detail.palletLocationMap : {};
                this.action = e?.detail?.action ?? null;
                // Set initial active pallet by code
                this.activePalletCode = this.palletCodes?.[0] ?? null;
                if (this.mode === 'pallet' && this.activePalletCode) {
                this.setActivePallet(this.activePalletCode);
                } else {
                this.palletCode = e?.detail?.palletCode ?? '';
                this.selectedLocationId = e?.detail?.currentLocationId ?? null;
                this.selectedLocationName = e?.detail?.currentLocationName ?? '';
                this.takenLocationIds = Array.isArray(e?.detail?.takenLocationIds) ? e.detail.takenLocationIds : [];
                }
                this.keyword = '';
                this.locations = Array.isArray(window.__goodLocations) ? window.__goodLocations : [];
                this.showModal = true;
                });
                },

                close() {
                this.showModal = false; this.rowIndex = null; this.palletId = null; this.palletCode = '';
                this.palletList = []; this.palletCodes = []; this.activePalletCode = null;
                this.palletLocationMap = {}; this.action = null; this.mode = 'row'; this.isWizard = false;
                },

                setActivePallet(palletCode) {
                if (!palletCode) return;
                this.activePalletCode = palletCode;
                this.palletCode = palletCode;
                const p = (this.palletList || []).find(x => x?.palletCode === palletCode);
                this.palletId = p?.id || 0;
                // Get current location for this pallet from map (keyed by palletCode)
                const current = this.palletLocationMap?.[palletCode] ?? null;
                this.selectedLocationId = current?.locationId ?? null;
                this.selectedLocationName = current?.locationName ?? '';
                // Build taken list from other pallets
                const taken = [];
                for (const [k, v] of Object.entries(this.palletLocationMap || {})) {
                if (k !== palletCode && Number(v?.locationId) > 0) {
                taken.push(Number(v.locationId));
                }
                }
                this.takenLocationIds = [...new Set(taken)];
                },

                get canFinish() {
                if (this.mode !== 'pallet' || !this.palletCodes?.length) return false;
                // Check all pallets have locations assigned
                return !this.palletCodes.some(code => !(Number(this.palletLocationMap?.[code]?.locationId) > 0));
                },

                getLocationId(loc) { const n = Number(loc?.id ?? loc?.Id); return Number.isFinite(n) ? n : null; },
                getLocationName(loc) { return loc?.location_name ?? loc?.locationName ?? loc?.LocationName ?? loc?.name ?? ''; },
                isTaken(locId) { return locId != null && this.takenLocationIds.includes(locId); },
                get filteredLocations() {
                const kw = (this.keyword || '').trim().toLowerCase();
                return kw ? this.locations.filter(l => this.getLocationName(l).toLowerCase().includes(kw)) : this.locations;
                },

                choose(loc) {
                const locId = this.getLocationId(loc), name = this.getLocationName(loc);
                if (!name || (locId != null && this.isTaken(locId) && locId !== this.selectedLocationId)) return;
                this.selectedLocationId = locId;
                this.selectedLocationName = name;
                if (this.mode === 'pallet') {
                const code = this.activePalletCode;
                if (!code) return;
                // Store by palletCode (string) key
                this.palletLocationMap[code] = { locationId: locId, locationName: name };
                // Refresh state for current pallet
                this.setActivePallet(code);
                } else {
                window.dispatchEvent(new CustomEvent('location-selected', { detail: { rowIndex: this.rowIndex, locationId: locId, locationName: name } }));
                this.close();
                }
                },

                finish() {
                if (this.mode !== 'pallet' || !this.canFinish) {
                Notify?.error('Vui lòng chọn vị trí cho tất cả pallet.');
                return;
                }
                window.dispatchEvent(new CustomEvent('pallet-locations-finished', {
                detail: { action: this.action, palletLocationMap: this.palletLocationMap }
                }));
                this.close();
                }
                };
                }

                // ===== ORDER DETAIL TABLE =====
                function orderDetailTable() {
                return {
                dataLoaded: false, palletLocationMap: {}, items: [], pageSize: 20, currentPage: 1,

                createItem(palletId = 0, palletCode = '') {
                return {
                skuId: '', skuCode: '', skuName: '', spuId: 0, spuCode: '', spuName: '',
                uomId: 0, uomCode: '', unit: '', qtyRequired: 1, qtyRequiredDecimal: 1.00,
                qtyReceived: 0, qtyReceivedDecimal: 0.00, isFull: false, lotNo: '',
                locationId: null, location: '', palletId: palletId, palletCode: palletCode,
                expiryDate: '', description: '', showNote: false, isGeneratingPallet: false
                };
                },

                init() {
                this.items = [];
                Alpine.store('orderItems', this.items);
                this.$watch('items', (v) => Alpine.store('orderItems', v));

                window.addEventListener('master-data-loaded', () => { this.dataLoaded = true; });
                window.addEventListener('location-selected', (e) => {
                const idx = e?.detail?.rowIndex; if (idx == null || !this.items?.[idx]) return;
                this.items[idx].locationId = e.detail.locationId ?? null;
                this.items[idx].location = e.detail.locationName ?? '';
                });
                window.addEventListener('pallet-locations-finished', async (e) => {
                if (e?.detail?.action && e?.detail?.palletLocationMap) await this.onPalletLocationsFinished(e.detail.action, e.detail.palletLocationMap);
                });
                if (globalSkuList.length > 0) this.dataLoaded = true;
                window.saveDraftForm = () => this.prepareLocationsThenSubmit('Draft');
                window.submitOrderForm = () => this.prepareLocationsThenSubmit('Submit');
                },

                async addRow() {
                const newItem = this.createItem();
                newItem.isGeneratingPallet = true;
                this.items.push(newItem);
                const newIndex = this.items.length - 1;
                try {
                const result = await postData('?handler=GeneratePalletCode', {});
                if (result.success && result.data) {
                // JSON returns: { id, pallet_code } (snake_case from C# JsonPropertyName)
                this.items[newIndex].palletId = result.data.id || 0;
                this.items[newIndex].palletCode = result.data.pallet_code || '';
                }
                } catch (err) { console.error('Error generating pallet:', err); }
                finally { if (this.items[newIndex]) this.items[newIndex].isGeneratingPallet = false; }
                },

                buildPalletLocationPrefill(rows) {
                const map = {}, grouped = {};
                (rows || []).forEach(r => { const c = r?.palletCode; if (c) { grouped[c] = grouped[c] || []; grouped[c].push(r); } });
                Object.keys(grouped).forEach(c => {
                const locs = [...new Set(grouped[c].map(x => Number(x?.locationId) || 0).filter(x => x > 0))];
                if (locs.length === 1) map[c] = { locationId: locs[0], locationName: grouped[c].find(x => Number(x?.locationId) === locs[0])?.location || '' };
                });
                return map;
                },

                applyPalletLocationsToRows(rows) {
                (rows || []).forEach(r => {
                const loc = this.palletLocationMap?.[r?.palletCode];
                if (loc) { r.locationId = loc.locationId; r.location = loc.locationName; }
                });
                },

                async prepareLocationsThenSubmit(action) {
                try {
                const rows = this.items.filter(x => x?.skuId);
                if (rows.some(x => !x.palletCode)) { Notify.error('Vui lòng chọn pallet cho tất cả dòng hàng hóa.'); return; }
                const palletCodes = [...new Set(rows.map(r => r.palletCode).filter(Boolean))];
                if (!palletCodes.length) { Notify.error('Vui lòng chọn pallet hợp lệ.'); return; }

                this.palletLocationMap = this.buildPalletLocationPrefill(rows);
                const palletList = palletCodes.map(c => ({ id: rows.find(r => r.palletCode === c)?.palletId || 0, palletCode: c }));
                const goodLocations = await fetchData(`?handler=GoodLocations&totalPalletNeed=${palletCodes.length}`);
                window.__goodLocations = Array.isArray(goodLocations) ? goodLocations : (goodLocations?.data || []);
                const palletIds = palletCodes.map(c => rows.find(r => r.palletCode === c)?.palletId || c);

                window.dispatchEvent(new CustomEvent('open-location-modal', {
                detail: { mode: 'pallet', isWizard: true, action, palletIds, palletList, palletLocationMap: this.palletLocationMap, activePalletId: palletIds[0] }
                }));
                } catch (err) { Notify.error('Có lỗi: ' + (err?.message || 'Unknown')); }
                },

                async onPalletLocationsFinished(action, map) {
                try {
                this.palletLocationMap = map || {};
                const rows = this.items.filter(x => x?.skuId);
                this.applyPalletLocationsToRows(rows);
                if (rows.some(x => !(Number(x.locationId) > 0))) { Notify.error('Vui lòng chọn vị trí cho tất cả pallet.'); return; }
                await this.submitForm(action);
                } catch (err) { Notify.error('Có lỗi: ' + (err?.message || 'Unknown')); }
                },

                get skuOptions() { return globalSkuList; },
                getUomOptions(skuId) { return skuId ? globalSkuUomList.filter(u => u.skuId == skuId) : []; },

                get totalPages() { return Math.ceil(this.items.length / this.pageSize); },
                get startIndex() { return this.items.length ? (this.currentPage - 1) * this.pageSize + 1 : 0; },
                get endIndex() { return Math.min(this.currentPage * this.pageSize, this.items.length); },
                get paginatedItems() { const s = (this.currentPage - 1) * this.pageSize; return this.items.slice(s, s + this.pageSize); },
                getRealIndex(i) { return (this.currentPage - 1) * this.pageSize + i; },

                goToPage(p) { if (p >= 1 && p <= this.totalPages) this.currentPage = p; },
                nextPage() { this.goToPage(this.currentPage + 1); },
                prevPage() { this.goToPage(this.currentPage - 1); },
                firstPage() { this.goToPage(1); },
                lastPage() { this.goToPage(this.totalPages); },
                changePageSize(s) { this.pageSize = parseInt(s); this.currentPage = 1; },

                removeRow(i) { this.items.splice(i, 1); },
                clearAll() { this.items = []; },

                toggleFull(index) {
                const item = this.items[this.getRealIndex(index)];
                if (item.isFull) { item.qtyReceivedDecimal = item.qtyRequiredDecimal; item.qtyReceived = Math.floor(item.qtyRequiredDecimal); }
                else { item.qtyReceivedDecimal = 0; item.qtyReceived = 0; }
                },

                onSkuChange(index, skuId) {
                const sku = globalSkuList.find(s => s.sku_id == skuId), item = this.items[index];
                if (sku) {
                Object.assign(item, { skuId: sku.sku_id, skuCode: sku.sku_code || '', skuName: sku.sku_name || '', spuId: sku.spu_id || 0, spuCode: sku.spu_code || '', spuName: sku.spu_name || '' });
                const uom = globalSkuUomList.find(u => u.skuId == sku.sku_id && (u.unitName === sku.unit || u.isBase));
                item.uomId = uom?.id || 0; item.unit = uom?.unitName || sku.unit || '';
                } else { Object.assign(item, { skuId: '', skuCode: '', skuName: '', spuId: 0, spuCode: '', spuName: '', unit: '', uomId: 0 }); }
                },

                onUomChange(index, unitName) {
                const item = this.items[index], uom = globalSkuUomList.find(u => u.skuId == item.skuId && u.unitName === unitName);
                item.uomId = uom?.id || 0; item.unit = uom?.unitName || '';
                },

                totalQtyRequired() { return this.items.reduce((s, i) => s + parseFloat(i.qtyRequiredDecimal || 0), 0).toFixed(2); },
                totalQtyReceived() { return this.items.reduce((s, i) => s + parseFloat(i.qtyReceivedDecimal || 0), 0).toFixed(2); },
                toggleNote(i) { this.items[i].showNote = !this.items[i].showNote; },

                async submitForm(action) {
                try {
                const indexUrl = '@Url.Page("/Inbound/Order/Index")';
                if (this.items.some(i => i.skuId && (!i.spuCode || !i.spuName))) { Notify.error('Một số hàng thiếu thông tin SKU.'); return; }
                if (action === 'Submit' && this.items.some(i => i.skuId && !(Number(i.locationId) > 0))) { Notify.error('Vui lòng chọn Vị trí.'); return; }
                const asnNo = document.getElementById('asnNo')?.value, ws = document.getElementById('warehouseSelect');
                if (!asnNo) { Notify.error('Vui lòng nhập Số lệnh nhập kho'); return; }
                if (!ws?.value) { Notify.error('Vui lòng chọn Kho nhập'); return; }

                const requestData = {
                asn_no: asnNo,
                goods_owner_id: parseInt(document.getElementById('goodsOwnerSelect')?.value) || 0,
                goods_owner_name: document.getElementById('goodsOwnerSelect')?.selectedOptions[0]?.dataset.name || '',
                warehouse_id: Number(ws.value) || ws.value,
                warehouse_name: ws.selectedOptions[0]?.textContent?.trim() || '',
                estimated_arrival_time: document.getElementById('estimatedArrival')?.value || '',
                detailList: this.items.map(item => ({
                sku_id: parseInt(item.skuId) || 0, sku_code: item.skuCode, sku_name: item.skuName,
                spu_id: parseInt(item.spuId) || 0, spu_code: item.spuCode, spu_name: item.spuName,
                uom_id: parseInt(item.uomId) || null,
                asn_qty: Math.floor(parseFloat(item.qtyRequiredDecimal) || 0), asn_qty_decimal: parseFloat(item.qtyRequiredDecimal) || 0,
                actual_qty: Math.floor(parseFloat(item.qtyReceivedDecimal) || 0), actual_qty_decimal: parseFloat(item.qtyReceivedDecimal) || 0,
                is_valid: true, batch_number: item.lotNo || '',
                goods_location_id: Number(item.locationId) || 0, pallet_id: Number(item.palletId) || 0, pallet_code: item.palletCode || '',
                expiry_date: item.expiryDate || null, description: item.description || ''
                }))
                };

                const result = await postData(`?handler=${action}`, requestData);
                if (result.success) { Notify.success(result.message || 'Thành công!'); window.location.href = result.redirectUrl || indexUrl; }
                else { Notify.error(result.message || 'Có lỗi xảy ra'); }
                } catch (error) { Notify.error('Có lỗi: ' + error.message); }
                }
                };
                }
            </script>
        }