@using Microsoft.Extensions.Localization
@using Wms.Theme.Web
@inject IStringLocalizer<SharedResource> L

<div x-data="deliveryTab()" x-init="init()" class="space-y-4">
    <!-- Filter & Actions -->
    <div class="flex flex-col sm:flex-row justify-end items-end gap-4 mb-4">
        <!-- Search Input -->
        @* <div class="w-full sm:w-96">
            <div class="relative">
                <input type="text" x-model="tableConfig.filters.text" @@keydown.enter="reloadData()"
                    class="w-full pl-3 pr-10 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                    placeholder="@L["SearchPlaceholder"]...">
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>
        </div> *@

        <!-- Buttons -->
        <div class="flex gap-2">
            <button @@click="exportExcel()" title="@L["ExportExcel"]"
                class="w-20 py-2.5 bg-white border border-gray-300 text-green-600 text-base rounded-lg shadow-sm hover:bg-gray-50 hover:text-green-700 focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200 flex justify-center items-center">
                <i class="fa-solid fa-file-excel"></i>
            </button>
            <button @@click="openConfirmModal()" title="@L["Confirm"]"
                class="w-20 py-2.5 bg-blue-600 text-white text-base rounded-lg shadow-md hover:bg-blue-700 hover:shadow-lg focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 flex justify-center items-center">
                <i class="fa-solid fa-check"></i>
            </button>
        </div>
    </div>

    <!-- Data Table -->
    <div x-data="AlpineDataTable(tableConfig)" x-init="init()">
        <partial name="Shared/Components/_AlpineDataTable" />
    </div>

    <!-- Confirm Modal -->
    <template x-teleport="body">
        <div x-show="showConfirmModal" style="display: none;"
            class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-[9999] flex items-center justify-center">
            <div class="relative p-5 border w-full max-w-3xl shadow-lg rounded-md bg-white dark:bg-gray-800 dark:border-gray-700"
                @@click.away="showConfirmModal = false">
                <div class="mt-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white text-center">
                        @L["ConfirmTransport"]</h3>
                    <div class="mt-4 px-4 py-3">
                        <!-- Shared Arrival Date -->
                        <div class="mb-4">
                            <label
                                class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">@L["ArrivalTime"]</label>
                            <input type="text" x-ref="arrivalDatePicker" x-model="arrivalDate"
                                placeholder="dd/mm/yyyy HH:mm"
                                class="w-full sm:w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-1 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
                        </div>
                        <!-- Selected Items Table -->
                        <div class="overflow-x-auto max-h-80">
                            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                                <thead class="bg-gray-50 dark:bg-gray-700 sticky top-0">
                                    <tr>
                                        <th
                                            class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                                            @L["ASNNumber"]</th>
                                        <th
                                            class="px-3 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                                            @L["SkuName"]</th>
                                        <th
                                            class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                                            @L["OriginalQty"]</th>
                                        <th
                                            class="px-3 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase">
                                            @L["InputQty"]</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                                    <template x-for="(item, index) in selectedItems" :key="item.Id">
                                        <tr>
                                            <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-900 dark:text-white"
                                                x-text="item.AsnNo"></td>
                                            <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300"
                                                x-text="item.SkuName"></td>
                                            <td class="px-3 py-2 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300 text-right"
                                                x-text="GlobalFormatNumber(item.originalQty)"></td>
                                            <td class="px-3 py-2 whitespace-nowrap text-right">
                                                <input type="number" min="1" :max="item.originalQty"
                                                    x-model.number="item.inputQty" @@input="validateQty(item)"
                                                    class="w-24 px-2 py-1 border rounded-md text-right focus:ring-1 focus:ring-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:text-white"
                                                    :class="{ 'border-red-500': item.error, 'border-yellow-500': item.warning && !item.error }">
                                                <p x-show="item.error" class="text-xs text-red-500 mt-1"
                                                    x-text="item.error"></p>
                                                <p x-show="item.warning && !item.error"
                                                    class="text-xs text-yellow-600 mt-1" x-text="item.warning"></p>
                                            </td>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="items-center px-4 py-3 flex gap-3 justify-end">
                        <button @@click="showConfirmModal = false"
                            class="px-4 py-2 bg-gray-100 text-gray-700 text-base font-medium rounded-md shadow-sm hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:bg-gray-700 dark:text-gray-300 dark:hover:bg-gray-600">
                            @L["Cancel"]
                        </button>
                        <button @@click="submitConfirm()" :disabled="isSubmitting || hasValidationError"
                            class="px-4 py-2 bg-blue-600 text-white text-base font-medium rounded-md shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-300 disabled:opacity-50 disabled:cursor-not-allowed">
                            <span x-show="!isSubmitting">@L["Confirm"]</span>
                            <span x-show="isSubmitting">@L["Processing"]...</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </template>
</div>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('deliveryTab', () => ({
            // State
            showConfirmModal: false,
            selectedCount: 0,
            arrivalDate: '',
            selectedItems: [], // Array of selected items with editable quantities
            isSubmitting: false,

            /**
             * Computed property to check if any item has a validation error.
             * @@returns {boolean} True if any item has an error.
             */
            get hasValidationError() {
                return this.selectedItems.some(item => item.error);
            },

            // Configuration for AlpineDataTable
            tableConfig: {
                apiUrl: '?handler=DataTable&handlerName=DeliveryTable',
                columns: [
                    { title: '@Html.Raw(L["ASNNumber"])', data: 'AsnNo' ,
                        render: (row) => `<a href="/Inbound/ASN/Detail/${row.Id}" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 p-1 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded transition-colors" title="@Html.Raw(L["Detail"])">
                          ${row.AsnNo}
                     </a>`
                    },
                    { title: '@Html.Raw(L["Supplier"])', data: 'SupplierName' },
                    { title: '@Html.Raw(L["Status"])', data: 'StatusBadge', render: (item) => item.StatusBadge },
                    { title: '@Html.Raw(L["ETA"])', data: 'EstimatedArrivalTime', render: (item) => GlobalFormatDate(item.EstimatedArrivalTime) },
                    { title: '@Html.Raw(L["GoodsOwnerName"])', data: 'GoodsOwnerName' },
                    { title: '@Html.Raw(L["Price"])', data: 'Price', render: (item) => GlobalFormatCurrency(item.Price) },
                    { title: '@Html.Raw(L["SkuCode"])', data: 'SkuCode' },
                    { title: '@Html.Raw(L["SkuName"])', data: 'SkuName' },
                    { title: '@Html.Raw(L["AsnQty"])', data: 'AsnQty', align: 'right', render: (item) => GlobalFormatNumber(item.AsnQty) },
                ],
                filters: {
                    text: ''
                }
            },

            init() {
                this.setDefaultDate();
                // Listen for custom events from the table renderers
                window.addEventListener('delivery-action', (e) => {
                    this.handleAction(e.detail.action, e.detail.id);
                });

                // Listen for tab changes
                window.addEventListener('tab-changed', (e) => {
                    if (e.detail.tab === 'delivery') {
                        this.reloadData();
                    }
                });
            },

            handleAction(action, id) {
                console.log('Action received:', action, id);
            },

            // Actions
            /**
             * Opens the confirmation modal and populates selectedItems from the table.
             */
            openConfirmModal() {
                const tableEl = this.$root.querySelector('[x-data^="AlpineDataTable"]');
                if (tableEl && tableEl._x_dataStack) {
                    const tableData = tableEl._x_dataStack[0];
                    const selected = tableData.selectedRows;

                    if (!selected || selected.length === 0) {
                        Notify.warning('@Html.Raw(L["PleaseSelectAtLeastOneRow"])');
                        return;
                    }

                    // Populate selectedItems with data from selected rows
                    this.selectedItems = selected.map(row => ({
                        Id: row.Id,
                        AsnNo: row.AsnNo,
                        SkuName: row.SkuName,
                        originalQty: row.AsnQty,
                        inputQty: row.AsnQty, // Default to original quantity
                        error: null,
                        warning: null
                    }));

                    this.selectedCount = selected.length;
                    this.showConfirmModal = true;

                    // Initialize Flatpickr after modal is shown
                    this.$nextTick(() => {
                        this.initArrivalDatePicker();
                    });
                }
            },

            /**
             * Initializes Flatpickr for the arrival date picker.
             */
            initArrivalDatePicker() {
                const el = this.$refs.arrivalDatePicker;
                if (el && typeof flatpickr !== 'undefined') {
                    // Destroy existing instance if any
                    if (el._flatpickr) {
                        el._flatpickr.destroy();
                    }
                    flatpickr(el, {
                        dateFormat: 'd/m/Y H:i',
                        enableTime: true,
                        time_24hr: true,
                        allowInput: true,
                        minDate: 'today',
                        defaultDate: new Date(),
                        static: true, // Keeps calendar inline, prevents click.away issue
                        onChange: (selectedDates, dateStr) => {
                            this.arrivalDate = dateStr;
                        }
                    });
                }
            },

            /**
             * Validates quantity input for a single item.
             * @@param {object} item - The item to validate.
             */
            validateQty(item) {

                item.error = null;
                item.warning = null;

                if (item.inputQty > item.originalQty) {
                    item.error = '@Html.Raw(L["QtyExceedsOriginal"])';
                } else if (item.inputQty < item.originalQty && item.inputQty > 0) {
                    item.warning = '@Html.Raw(L["QtyLessThanOriginal"])';
                } else if (item.inputQty <= 0) {
                    item.error = '@Html.Raw(L["QtyMustBePositive"])';
                }
            },

            /**
             * Sets the default arrival date to current datetime.
             */
            setDefaultDate() {
                const now = new Date();
                const day = String(now.getDate()).padStart(2, '0');
                const month = String(now.getMonth() + 1).padStart(2, '0');
                const year = now.getFullYear();
                const hours = String(now.getHours()).padStart(2, '0');
                const minutes = String(now.getMinutes()).padStart(2, '0');
                this.arrivalDate = `${day}/${month}/${year} ${hours}:${minutes}`;
            },

            /**
             * Submits the confirmation data to the backend.
             */
            async submitConfirm() {
                if (!this.arrivalDate) {
                    Notify.warning('@Html.Raw(L["PleaseSelectTime"])');
                    return;
                }

                // Re-validate all items before submission
                this.selectedItems.forEach(item => this.validateQty(item));
                if (this.hasValidationError) {
                    Notify.error('@Html.Raw(L["PleaseFixValidationErrors"])');
                    return;
                }

                const tableEl = this.$root.querySelector('[x-data^="AlpineDataTable"]');
                const tableData = tableEl._x_dataStack[0];

                this.isSubmitting = true;
                const payload = this.selectedItems.map(item => ({
                    id: item.Id,
                    arrival_time: this.arrivalDate,
                    input_qty: item.inputQty
                }));

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    const response = await fetch('?handler=Confirm', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        const errorText = await response.text();
                        console.error('Confirm API Error:', response.status, errorText);
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }

                    const result = await response.json();
                    if (result.success) {
                        Notify.success(result.message);
                        this.showConfirmModal = false;

                        // Reload tab counts
                        const processPageEl = document.querySelector('[x-data^="processPage"]');
                        if (processPageEl && processPageEl._x_dataStack) {
                            const processPage = processPageEl._x_dataStack[0];
                            if (processPage.loadTabCounts) {
                                processPage.loadTabCounts();
                            }
                        }

                        // Reload table data - use fetchData instead of refresh
                        tableData.fetchData(tableData.pagination.pageIndex);
                    } else {
                        Notify.error(result.message);
                    }
                } catch (e) {
                    console.error('Confirm submission error:', e);
                    Notify.error('@Html.Raw(L["SystemError"])');
                } finally {
                    this.isSubmitting = false;
                }
            },

            exportExcel() {
                const tableEl = this.$root.querySelector('[x-data^="AlpineDataTable"]');
                if (!tableEl || !tableEl._x_dataStack) return;

                const tableData = tableEl._x_dataStack[0];
                const selected = tableData.selectedRows;

                // Check if any rows are selected
                if (!selected || selected.length === 0) {
                    Notify.warning('@Html.Raw(L["PleaseSelectAtLeastOneRow"])');
                    return;
                }

                if (typeof XLSX === 'undefined') {
                    Notify.error('XLSX library not loaded');
                    return;
                }

                try {
                    // Map status codes to text (Sync with backend GetStatusBadge logic)
                    const statusMap = {
                        0: '@Html.Raw(L["New"])',
                        1: '@Html.Raw(L["Delivery"])',
                        2: '@Html.Raw(L["Unload"])',
                        3: '@Html.Raw(L["Putaway"])',
                        4: '@Html.Raw(L["WaitingRobot"])',
                        5: '@Html.Raw(L["Completed"])',
                        8: '@Html.Raw(L["Cancelled"])'
                    };

                    // Prepare data for Excel
                    const exportData = selected.map((item, index) => ({
                        '@Html.Raw(L["STT"])': index + 1,
                        '@Html.Raw(L["ASNNumber"])': item.AsnNo || '',
                        '@Html.Raw(L["Supplier"])': item.SupplierName || '',
                        '@Html.Raw(L["Status"])': statusMap[item.AsnStatus] || item.AsnStatus || '',
                        '@Html.Raw(L["ETA"])': item.EstimatedArrivalTime ? new Date(item.EstimatedArrivalTime).toLocaleDateString() : '',
                        '@Html.Raw(L["GoodsOwnerName"])': item.GoodsOwnerName || '',
                        '@Html.Raw(L["Price"])': parseFloat(item.Price || 0),
                        '@Html.Raw(L["SkuCode"])': item.SkuCode || '',
                        '@Html.Raw(L["SkuName"])': item.SkuName || '',
                        '@Html.Raw(L["AsnQty"])': parseFloat(item.AsnQty || 0)
                    }));

                    // Create worksheet
                    const worksheet = XLSX.utils.json_to_sheet(exportData);

                    // Set column widths
                    worksheet['!cols'] = [
                        { wch: 8 },  // STT
                        { wch: 20 }, // ASNNumber
                        { wch: 30 }, // Supplier
                        { wch: 15 }, // Status
                        { wch: 15 }, // ETA
                        { wch: 25 }, // GoodsOwnerName
                        { wch: 12 }, // Price
                        { wch: 20 }, // SkuCode
                        { wch: 35 }, // SkuName
                        { wch: 12 }  // AsnQty
                    ];

                    // Create workbook
                    const workbook = XLSX.utils.book_new();
                    XLSX.utils.book_append_sheet(workbook, worksheet, "Delivery");

                    // Generate filename
                    const timestamp = new Date().getTime();
                    const filename = `Delivery_Export_${timestamp}.xlsx`;

                    // Download file
                    XLSX.writeFile(workbook, filename, { bookType: 'xlsx', compression: true });

                    Notify.success('@Html.Raw(L["ExportSuccess"])');
                } catch (error) {
                    console.error('Export error:', error);
                    Notify.error('@Html.Raw(L["ExportFailed"])');
                }
            },

            reloadData() {
                // Reload tab counts
                const processPageEl = document.querySelector('[x-data^="processPage"]');
                if (processPageEl && processPageEl._x_dataStack) {
                    const processPage = processPageEl._x_dataStack[0];
                    if (processPage.loadTabCounts) {
                        processPage.loadTabCounts();
                    }
                }

                // Reload table
                const tableEl = this.$root.querySelector('[x-data^="AlpineDataTable"]');
                if (tableEl && tableEl._x_dataStack) {
                    const tableData = tableEl._x_dataStack[0];
                    // Sync filters from parent config to table component
                    tableData.filters = { ...this.tableConfig.filters };
                    tableData.fetchData(1); // Reset to page 1 on search/reload
                }
            }
        }));
    });

</script>