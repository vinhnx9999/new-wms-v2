@page "/PurchaseOrder/Create"
@model Wms.Theme.Web.Pages.PurchaseOrder.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@{
    ViewData["Title"] = L["CreatePO"];
}
@Html.AntiForgeryToken()

<div class="overflow-y-auto flex flex-col mx-auto p-2 space-y-2 bỏ" style="height: 80vh;">
    <form method="post" id="po-create-form" class="flex flex-col flex-1 min-h-0" onsubmit="return submitPoForm(event)">
        
        <div class="flex-none bg-white dark:bg-gray-800 rounded-lg shadow-sm mb-2 border">
            <div class="p-3 grid grid-cols-1 md:grid-cols-4 gap-3">
                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["PONumber"]
                    </label>
                    <input asp-for="CreateRequest.PoNo" type="text" id="poNo"
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white"
                           placeholder="" />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["CreateReceipt_ReceiptDate"] <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="orderDatePicker" required
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white"
                           placeholder="dd/mm/yyyy" />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["ExpectedDate"]
                    </label>
                    <input asp-for="CreateRequest.ExpectedDeliveryDate" type="text" id="expectedDeliveryDatePicker"
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white"
                           placeholder="dd/mm/yyyy" />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["ShippingAmount"]
                    </label>
                    <input asp-for="@Model.CreateRequest.ShippingAmount" type="number" min="0" step="0.01" id="shippingAmount"
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white" />
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["PaymentTerm"]
                    </label>
                    <select asp-for="CreateRequest.PaymentTerm" id="paymentTerm"
                            class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white border-none ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-blue-600">
                        <option value="Advance Payment">Advance Payment (Thanh toán trước)</option>
                        <option value="Due on Receipt">Due on Receipt (Thanh toán ngay khi nhận hóa đơn)</option>
                        <option value="COD">COD (Thanh toán khi nhận hàng)</option>
                        <option value="Net 15">Net 15 (Thanh toán trong vòng 15 ngày)</option>
                        <option value="Net 30">Net 30 (Thanh toán trong vòng 30 ngày)</option>
                        <option value="Net 45">Net 45 (Thanh toán trong vòng 45 ngày)</option>
                        <option value="Net 60">Net 60 (Thanh toán trong vòng 60 ngày)</option>
                        <option value="EOM">EOM (Thanh toán vào cuối tháng)</option>
                    </select>
                </div>

                <div>
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["BuyerName"]
                    </label>
                    <input asp-for="CreateRequest.BuyerName" type="text" id="buyerName"
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white" />
                </div>

               

                <div class="md:col-span-2">
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["BuyerAddress"]
                    </label>
                    <input asp-for="CreateRequest.BuyerAddress" type="text" id="buyerAddress"
                           class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white" />
                </div>

                <div class="md:col-span-4">
                    <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
                        @L["Description"]
                    </label>
                    <textarea asp-for="CreateRequest.Description" id="description" rows="2"
                              class="bg-gray-50 text-gray-900 text-sm rounded-md block w-full px-2 py-1.5 dark:bg-gray-700 dark:text-white"></textarea>
                </div>
            </div>

            <input type="hidden" asp-for="CreateRequest.SupplierId" id="selectedSupplierId" />
            <input type="hidden" asp-for="CreateRequest.SupplierName" id="selectedSupplierName" />
        </div>

        <div class="flex-none flex items-center justify-end px-3 py-2 bg-gray-50 dark:bg-gray-900/50 rounded-t-lg">
            <button type="button"
                    onclick="addGridRow()"
                    class="text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-md text-xs px-3 py-1.5">
                @L["AddItem"]
            </button>
        </div>

        <div id="poDetailsGrid" class="ag-theme-quartz w-full" style="height: 430px;"></div>

        <div class="flex-none flex items-center justify-end gap-2 w-full mt-2">
            <a href="/PurchaseOrder"
               class="px-3 py-1.5 text-xs font-medium text-gray-700 bg-white rounded-md hover:bg-gray-50 w-full md:w-auto text-center">
                @L["Cancel"]
            </a>
            <button type="submit"
                    class="px-4 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 w-full md:w-auto">
                @L["CreatePO"]
            </button>
        </div>
    </form>
</div>

@await Html.PartialAsync("Inbound/_SkuSearchModal")
@await Html.PartialAsync("Inbound/_SupplierSearchModal")

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        let gridApi;

        // ===== util =====
        function debounce(fn, delay) {
            let timer;
            return function (...args) {
                clearTimeout(timer);
                timer = setTimeout(() => fn.apply(this, args), delay);
            };
        }

        function toLocalIsoDate(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function toIsoDateOnly(value) {
            if (!value) return null;
            if (value instanceof Date && !isNaN(value.getTime())) return toLocalIsoDate(value);

            const text = value.toString().trim();
            if (!text) return null;

            if (/^\d{4}-\d{2}-\d{2}$/.test(text)) return text;

            const vn = text.match(/^(\d{2})\/(\d{2})\/(\d{4})$/);
            if (vn) return `${vn[3]}-${vn[2]}-${vn[1]}`;
            return null;
        }

        function toDisplayDate(value) {
            const iso = toIsoDateOnly(value);
            if (!iso) return '';
            const [y, m, d] = iso.split('-');
            return `${d}/${m}/${y}`;
        }

        // ===== init =====
        document.addEventListener("DOMContentLoaded", function () {
            flatpickr("#orderDatePicker", {
                dateFormat: "d/m/Y",
                defaultDate: "today",
                allowInput: true
            });

            flatpickr("#expectedDeliveryDatePicker", {
                dateFormat: "d/m/Y",
                defaultDate: "today",
                minDate: "today",
                allowInput: true
            });

            initAgGrid();
            addGridRow();

            initSkuObserver();
            initSupplierObserver();
        });

        // ===== grid =====
        function initAgGrid() {
            class FlatpickrCellEditor {
                init(params) {
                    this.params = params;
                    const today = new Date();
                    const rawIso = toIsoDateOnly(params.value);
                    this.selectedIso = rawIso || '';

                    this.eInput = document.createElement('input');
                    this.eInput.type = 'text';
                    this.eInput.className = 'w-full h-full px-1 outline-none bg-transparent';
                    this.eInput.value = this.selectedIso ? toDisplayDate(this.selectedIso) : '';

                    this.fp = flatpickr(this.eInput, {
                        dateFormat: "d/m/Y",
                        allowInput: false,
                        disableMobile: true,
                        minDate: today,
                        defaultDate: rawIso ? new Date(rawIso) : today,
                        onReady: function (_sd, _ds, instance) {
                            if (instance.calendarContainer) {
                                instance.calendarContainer.classList.add('ag-custom-component-popup');
                            }
                        },
                        onChange: (selectedDates) => {
                            if (selectedDates?.length) {
                                this.selectedIso = toLocalIsoDate(selectedDates[0]);
                            }
                            setTimeout(() => this.params.stopEditing(), 0);
                        }
                    });
                }
                getGui() { return this.eInput; }
                afterGuiAttached() { setTimeout(() => { this.eInput.focus(); this.fp.open(); }, 0); }
                getValue() { return this.selectedIso; }
                isPopup() { return false; }
                destroy() { this.fp?.destroy(); }
            }

            const columnDefs = [
                {
                    headerName: "SkuCode",
                    field: "itemCode",
                    flex: 1.5,
                    editable: false,
                    cellClass: 'hover:bg-blue-50 transition-colors cursor-pointer',
                    cellRenderer: function (params) {
                        const displayValue = params.value
                            ? `<span class="font-medium text-blue-700">${params.value}</span>`
                            : `<span class="text-gray-400 italic"></span>`;

                        return `
                            <div class="flex justify-between items-center w-full h-full" onclick="openItemSearchModal('${params.node.id}')" title="Click to search item">
                                <div class="truncate pr-2">${displayValue}</div>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-1 flex-shrink-0 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                        `;
                    }
                },
                {
                    headerName: 'Sku name',
                    field: "itemName",
                    flex: 2,
                    editable: false,
                    wrapText: true,
                    autoHeight: true,
                    cellClass: 'py-3 px-3 leading-tight'
                },
                {
                    headerName: 'Đơn vị tính',
                    field: "uom",
                    flex: 1,
                    editable: false,
                    cellRenderer: function (params) {
                        return `<div class="flex items-center h-full w-full">${params.value || ''}</div>`;
                    }
                },
                {
                    headerName: 'Supplier',
                    field: 'supplierName',
                    flex: 1.5,
                    editable: false,
                    cellClass: 'hover:bg-indigo-50 transition-colors cursor-pointer',
                    cellRenderer: function (params) {
                        const text = params.value
                            ? `<span class="font-medium text-indigo-700">${params.value}</span>`
                            : `<span class="text-gray-400 italic"></span>`;

                        return `
                            <div class="flex justify-between items-center w-full h-full"
                                 onclick="openSupplierModalForRow('${params.node.id}')"
                                 title="Click to search supplier">
                                <div class="truncate pr-2">${text}</div>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mt-1 flex-shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                </svg>
                            </div>
                        `;
                    }
                },
                {
                    headerName: 'Số lượng',
                    field: "qty",
                    flex: 1,
                    editable: true,
                    cellEditor: 'agNumberCellEditor',
                    cellEditorParams: { min: 0.001, step: 'any' },
                    valueParser: function (params) {
                        const num = parseFloat(params.newValue);
                        if (isNaN(num) || num <= 0) return null;
                        return num;
                    },
                    cellClass: 'bg-blue-50 border border-blue-100 cursor-text font-semibold text-blue-700',
                    cellRenderer: function (params) {
                        const val = params.value !== undefined && params.value !== null ? params.value : '';
                        return `<div class="flex items-center h-full w-full">${val}</div>`;
                    }
                },
                {
                    headerName: "@Html.Raw(L["ExpiryDate"])",
                    field: "expiryDate",
                    width: 150,
                    editable: true,
                    cellDataType: false,
                    cellEditor: FlatpickrCellEditor,
                    valueFormatter: params => toDisplayDate(params.value),
                    cellClass: 'expiry-date-cell bg-amber-50 border border-amber-100'
                },
                {
                    headerName: '@Html.Raw(L["Price"])',
                    field: "unitPrice",
                    flex: 1,
                    editable: true,
                    cellEditor: 'agNumberCellEditor',
                    cellEditorParams: {
                        min: 0,
                        step: '0.01'
                    },
                    valueParser: function (params) {
                        if (params.newValue === '' || params.newValue == null) return null;
                        const num = parseFloat(params.newValue);
                        if (isNaN(num) || num < 0) return null;
                        return num;
                    },
                    valueFormatter: function (params) {
                        if (params.value == null || params.value === '') return '';
                        return Number(params.value).toFixed(2);
                    },
                    cellClass: 'bg-emerald-50 border border-emerald-100 cursor-text font-semibold text-emerald-700',
                    cellRenderer: function (params) {
                        const val = params.value !== undefined && params.value !== null ? Number(params.value).toFixed(2) : '';
                        return `<div class="flex items-center h-full w-full">${val}</div>`;
                    }
                },
                {
                    headerName: "Thao tác",
                    width: 100,
                    sortable: false,
                    filter: false,
                    cellRenderer: function (params) {
                        return `
                            <button type="button" onclick="deleteRow('${params.node.id}')" class="text-red-500 hover:text-red-700 flex items-center justify-center w-full h-full">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>`;
                    }
                }
            ];

            const gridOptions = {
                columnDefs,
                rowData: [],
                getRowId: params => params.data.id,
                pagination: true,
                paginationPageSize: 20,
                singleClickEdit: true,
                stopEditingWhenCellsLoseFocus: true
            };

            const gridDiv = document.querySelector('#poDetailsGrid');
            gridApi = agGrid.createGrid(gridDiv, gridOptions);
        }

        function addGridRow() {
            const row = {
                id: Math.random().toString(36).substring(2, 9),
                supplierId: '',
                supplierName: '',
                itemCode: '',
                skuId: 0,
                skuName: '',
                spuId: 0,
                spuName: '',
                qtyOrdered: 1,
                qtyReceived: 0,
                unitPrice: null,
                unitPrice: 0,
                skuUomId: 0,
                expiryDate: null // fixed key
            };
            gridApi?.applyTransaction({ add: [row] });
        }

        function deleteRow(nodeId) {
            const rowNode = gridApi?.getRowNode(nodeId);
            if (rowNode) {
                gridApi.applyTransaction({ remove: [rowNode.data] });
            }
        }

        // ===== SKU modal + infinite =====
        const itemSearchModal = document.getElementById('itemSearchModal');
        const itemSearchInput = document.getElementById('itemSearchInput');
        const itemSearchResultBody = document.getElementById('itemSearchResultBody');
        const skuScrollContainer = document.getElementById('scrollContainer');
        const skuScrollAnchor = document.getElementById('scroll-anchor');
        const skuLoadingIndicator = document.getElementById('loading-indicator');

        let currentRowIdForItemSearch = null;
        let itemSearchAbortController = null;
        let skuCurrentPage = 1;
        const skuPageSize = 20;
        let skuIsFetching = false;
        let skuHasMoreData = true;
        let skuObserver = null;

        async function fetchSkuItems(keyword = '', pageIndex = 1) {
            if (itemSearchAbortController) itemSearchAbortController.abort();
            itemSearchAbortController = new AbortController();

            try {
                const supplierRaw = document.getElementById('selectedSupplierId').value?.trim();
                const supplierParam = supplierRaw ? `&supplierId=${encodeURIComponent(supplierRaw)}` : '';
                const keywordParam = keyword?.trim() ? `&keyWord=${encodeURIComponent(keyword.trim())}` : '';
                const url = `?handler=SearchSku${supplierParam}${keywordParam}&pageIndex=${pageIndex}&pageSize=${skuPageSize}`;

                const response = await fetch(url, { signal: itemSearchAbortController.signal });
                if (!response.ok) return null;
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') return null;
                console.error('Error fetching SKU items:', e);
                return [];
            }
        }

        function showItemSearchLoading() {
            itemSearchResultBody.innerHTML = `
                <tr>
                    <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                        <div class="flex justify-center items-center gap-2">
                            <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            @Html.Raw(L["Loading"])
                        </div>
                    </td>
                </tr>`;
        }

        function renderItemTable(data, isAppend = false) {
            if (!isAppend) itemSearchResultBody.innerHTML = '';

            if (!Array.isArray(data) || data.length === 0) {
                if (!isAppend) {
                    itemSearchResultBody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">No item found</td></tr>`;
                }
                skuHasMoreData = false;
                skuScrollAnchor?.classList.add('hidden');
                return;
            }

            if (data.length < skuPageSize) {
                skuHasMoreData = false;
                skuScrollAnchor?.classList.add('hidden');
            } else {
                skuHasMoreData = true;
                skuScrollAnchor?.classList.remove('hidden');
            }

            data.forEach(item => {
                const skuId = item.skuId ?? item.SkuId ?? 0;
                const skuCode = item.skuCode ?? item.SkuCode ?? '';
                const skuName = item.skuName ?? item.SkuName ?? '';
                const unitName = item.unitName ?? item.UnitName ?? '';
                const supplierId = item.supplierId ?? item.SupplierId ?? null;
                const supplierName = item.supplierName ?? item.SupplierName ?? '';
                const skuUomId = item.skuUomId ?? item.SkuUomId ?? 0;

                const tr = document.createElement('tr');
                tr.className = 'hover:bg-blue-50 transition-colors cursor-pointer';
                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm font-medium text-gray-900">${skuCode}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${skuName}</td>
                    <td class="px-6 py-3 text-sm text-gray-500">${unitName}</td>
                    <td class="px-6 py-3 text-sm text-blue-600 font-medium">${supplierName}</td>`;
                tr.onclick = () => selectItem({ skuId, skuCode, skuName, unitName, supplierId, supplierName, skuUomId });
                itemSearchResultBody.appendChild(tr);
            });
        }

        async function openItemSearchModal(rowNodeId) {
            currentRowIdForItemSearch = rowNodeId;
            skuCurrentPage = 1;
            skuHasMoreData = true;
            skuIsFetching = true;

            itemSearchInput.value = '';
            if (skuScrollContainer) skuScrollContainer.scrollTop = 0;
            showItemSearchLoading();

            itemSearchModal.classList.remove('hidden');
            setTimeout(() => itemSearchInput.focus(), 100);

            const data = await fetchSkuItems('', skuCurrentPage);
            renderItemTable(data, false);
            skuIsFetching = false;
        }

        function closeItemSearchModal() {
            itemSearchModal.classList.add('hidden');
            currentRowIdForItemSearch = null;

            if (itemSearchAbortController) {
                itemSearchAbortController.abort();
                itemSearchAbortController = null;
            }
        }

        function initSkuObserver() {
            if (!skuScrollContainer || !skuScrollAnchor) return;

            skuObserver = new IntersectionObserver(async (entries) => {
                const target = entries[0];
                if (target.isIntersecting && !skuIsFetching && skuHasMoreData) {
                    skuIsFetching = true;
                    skuLoadingIndicator?.classList.remove('hidden');

                    skuCurrentPage++;
                    const keyword = itemSearchInput.value;
                    const data = await fetchSkuItems(keyword, skuCurrentPage);
                    if (data !== null) renderItemTable(data, true);

                    skuLoadingIndicator?.classList.add('hidden');
                    skuIsFetching = false;
                }
            }, {
                root: skuScrollContainer,
                rootMargin: '0px 0px 100px 0px',
                threshold: 0
            });

            skuObserver.observe(skuScrollAnchor);
        }

        itemSearchInput.addEventListener('input', debounce(async function () {
            skuCurrentPage = 1;
            skuHasMoreData = true;
            skuIsFetching = true;
            showItemSearchLoading();

            const data = await fetchSkuItems(itemSearchInput.value, skuCurrentPage);
            if (data !== null) renderItemTable(data, false);

            skuIsFetching = false;
        }, 300));

        function selectItem(item) {
            if (!currentRowIdForItemSearch) return;

            const rowId = currentRowIdForItemSearch;
            const selectedSupplierIdInput = document.getElementById('selectedSupplierId');
            const selectedSupplierNameInput = document.getElementById('selectedSupplierName');

            const headerSupplierId = parseInt(selectedSupplierIdInput.value || '0', 10);
            const rowSupplierId = parseInt(item.supplierId || '0', 10);

            if (headerSupplierId > 0 && rowSupplierId > 0 && headerSupplierId !== rowSupplierId) {
                Notify.info('Selected SKU belongs to another supplier.');
                return;
            }

            if (headerSupplierId === 0 && rowSupplierId > 0) {
                selectedSupplierIdInput.value = rowSupplierId.toString();
                selectedSupplierNameInput.value = item.supplierName ?? '';
            }

            const rowNode = gridApi?.getRowNode(rowId);
            if (rowNode) {
                rowNode.setDataValue('itemCode', item.skuCode ?? '');
                rowNode.setDataValue('itemName', item.skuName ?? '');
                rowNode.setDataValue('uom', item.unitName ?? '');
                rowNode.data.skuId = parseInt(item.skuId || 0, 10);
                rowNode.data.skuUomId = parseInt(item.skuUomId || 0, 10);
                rowNode.data.supplierId = rowSupplierId || null;
                rowNode.setDataValue('supplierName', item.supplierName ?? '');
            }

            closeItemSearchModal();

            const selected = gridApi?.getRowNode(rowId);
            const hasSupplier = !!selected?.data?.supplierId;
            if (!hasSupplier) {
                openSupplierModalForRow(rowId);
            }
        }

        // ===== Supplier modal + infinite =====
        const supplierSearchModal = document.getElementById('supplierSearchModal');
        const supplierModalSearchInput = document.getElementById('supplierModalSearchInput');
        const supplierSearchResultBody = document.getElementById('supplierSearchResultBody');
        const supplierScrollContainer = document.getElementById('supplierScrollContainer');
        const supplierScrollAnchor = document.getElementById('supplier-scroll-anchor');
        const supplierLoadingIndicator = document.getElementById('supplier-loading-indicator');

        let currentRowIdForSupplierSearch = null;
        let supplierSearchAbortController = null;
        let supplierCurrentPage = 1;
        const supplierPageSize = 20;
        let supplierIsFetching = false;
        let supplierHasMoreData = true;
        let supplierObserver = null;

        async function fetchSuppliers(keyword = '', pageIndex = 1) {
            if (supplierSearchAbortController) supplierSearchAbortController.abort();
            supplierSearchAbortController = new AbortController();

            try {
                const keywordParam = keyword?.trim() ? `&keyword=${encodeURIComponent(keyword.trim())}` : '';
                const url = `?handler=SearchSupplier${keywordParam}&pageIndex=${pageIndex}&pageSize=${supplierPageSize}`;

                const response = await fetch(url, { signal: supplierSearchAbortController.signal });
                if (!response.ok) return null;
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') return null;
                console.error('Error fetching suppliers:', e);
                return [];
            }
        }

        function showSupplierSearchLoading() {
            supplierSearchResultBody.innerHTML = `
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                        <div class="flex justify-center items-center gap-2">
                            <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                            </svg>
                            @Html.Raw(L["Loading"])
                        </div>
                    </td>
                </tr>`;
        }

        function renderSupplierTable(data, isAppend = false) {
            if (!isAppend) supplierSearchResultBody.innerHTML = '';

            if (!Array.isArray(data) || data.length === 0) {
                if (!isAppend) {
                    supplierSearchResultBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">No supplier found</td></tr>`;
                }
                supplierHasMoreData = false;
                supplierScrollAnchor?.classList.add('hidden');
                return;
            }

            if (data.length < supplierPageSize) {
                supplierHasMoreData = false;
                supplierScrollAnchor?.classList.add('hidden');
            } else {
                supplierHasMoreData = true;
                supplierScrollAnchor?.classList.remove('hidden');
            }

            data.forEach(supplier => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
                tr.onclick = () => selectSupplierForRow(supplier.id, supplier.supplierName ?? '');

                tr.innerHTML = `
                    <td class="px-6 py-3 text-sm text-gray-900">${supplier.supplierName ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${supplier.address ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${supplier.city ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${supplier.email ?? ''}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${supplier.contactTel ?? ''}</td>
                `;
                supplierSearchResultBody.appendChild(tr);
            });
        }

        async function openSupplierModalForRow(rowNodeId) {
            if (!rowNodeId) return;

            currentRowIdForSupplierSearch = rowNodeId;
            supplierCurrentPage = 1;
            supplierHasMoreData = true;
            supplierIsFetching = true;

            supplierModalSearchInput.value = '';
            if (supplierScrollContainer) supplierScrollContainer.scrollTop = 0;
            showSupplierSearchLoading();

            supplierSearchModal.classList.remove('hidden');
            setTimeout(() => supplierModalSearchInput.focus(), 100);

            const data = await fetchSuppliers('', supplierCurrentPage);
            renderSupplierTable(data, false);
            supplierIsFetching = false;
        }

        function closeSupplierModal() {
            supplierSearchModal.classList.add('hidden');
            currentRowIdForSupplierSearch = null;

            if (supplierSearchAbortController) {
                supplierSearchAbortController.abort();
                supplierSearchAbortController = null;
            }
        }

        function initSupplierObserver() {
            if (!supplierScrollContainer || !supplierScrollAnchor) return;

            supplierObserver = new IntersectionObserver(async (entries) => {
                const target = entries[0];
                if (target.isIntersecting && !supplierIsFetching && supplierHasMoreData) {
                    supplierIsFetching = true;
                    supplierLoadingIndicator?.classList.remove('hidden');

                    supplierCurrentPage++;
                    const keyword = supplierModalSearchInput.value;
                    const data = await fetchSuppliers(keyword, supplierCurrentPage);
                    if (data !== null) renderSupplierTable(data, true);

                    supplierLoadingIndicator?.classList.add('hidden');
                    supplierIsFetching = false;
                }
            }, {
                root: supplierScrollContainer,
                rootMargin: '0px 0px 100px 0px',
                threshold: 0
            });

            supplierObserver.observe(supplierScrollAnchor);
        }

        supplierModalSearchInput.addEventListener('input', debounce(async function () {
            supplierCurrentPage = 1;
            supplierHasMoreData = true;
            supplierIsFetching = true;
            showSupplierSearchLoading();

            const data = await fetchSuppliers(supplierModalSearchInput.value, supplierCurrentPage);
            if (data !== null) renderSupplierTable(data, false);

            supplierIsFetching = false;
        }, 300));

        function selectSupplierForRow(supplierId, supplierName) {
            if (currentRowIdForSupplierSearch == null) return;

            const rowNode = gridApi?.getRowNode(currentRowIdForSupplierSearch);
            if (!rowNode) return;

            rowNode.data.supplierId = parseInt(supplierId || 0, 10);
            rowNode.setDataValue('supplierName', supplierName ?? '');
            closeSupplierModal();
        }


        async function submitPoForm(event) {
            event.preventDefault();

            const poNo = document.getElementById('poNo')?.value?.trim() ?? '';
            const orderDateText = document.getElementById('orderDatePicker')?.value?.trim() ?? '';
            const expectedDeliveryDateText = document.getElementById('expectedDeliveryDatePicker')?.value?.trim() ?? '';
            const shippingAmountText = document.getElementById('shippingAmount')?.value?.trim() ?? '';
            const paymentTerm = document.getElementById('paymentTerm')?.value ?? null;
            const buyerName = document.getElementById('buyerName')?.value?.trim() ?? '';
            const buyerAddress = document.getElementById('buyerAddress')?.value?.trim() ?? '';
            const description = document.getElementById('description')?.value?.trim() ?? '';

            const supplierIdText = document.getElementById('selectedSupplierId')?.value?.trim() ?? '';
            const supplierName = document.getElementById('selectedSupplierName')?.value?.trim() ?? '';

            const orderDateIso = toIsoDateOnly(orderDateText);
            if (!orderDateIso) {
                Notify.info('@Html.Raw(L["CreateReceipt_ValidReceiptDate"])');
                return false;
            }

            let supplierId = parseInt(supplierIdText || '0', 10);

            const details = [];
            const invalidRows = [];
            const supplierMissingRows = [];

            gridApi?.forEachNode(node => {
                const row = node.data ?? {};
                const skuId = parseInt(row.skuId || 0, 10);
                const qty = Number(row.qty ?? row.qtyOrdered ?? 0);

                // bỏ qua dòng trống
                if (!skuId) return;

                if (!Number.isFinite(qty) || qty <= 0) {
                    invalidRows.push(row.itemCode || row.itemName || node.id);
                    return;
                }

                const detailSupplierId = parseInt(row.supplierId || supplierId || 0, 10);
                if (!detailSupplierId) {
                    supplierMissingRows.push(row.itemCode || row.itemName || node.id);
                    return;
                }

                details.push({
                    skuId: skuId,
                    skuName: row.itemName ?? null,
                    skuCode: row.itemCode ?? null,
                    supplierId: detailSupplierId,
                    qty: qty,
                    unitPrice: row.unitPrice != null ? Number(row.unitPrice) : null,
                    expiryDate: toIsoDateOnly(row.expiryDate ?? row.expireDate ?? row.expiredDate),
                    skuUomId: parseInt(row.skuUomId || 0, 10)
                });
            });

            if (invalidRows.length > 0) {
                Notify.info(`Qty invalid: ${invalidRows.join(', ')}`);
                return false;
            }

            if (supplierMissingRows.length > 0) {
                Notify.info(`Missing supplier: ${supplierMissingRows.join(', ')}`);
                return false;
            }

            if (details.length === 0) {
                Notify.info('@Html.Raw(L["CreateReceipt_MsgAddAtLeastOneItem"])');
                return false;
            }

            // fallback supplier từ detail đầu tiên nếu header chưa có
            if (!supplierId) {
                supplierId = parseInt(details[0]?.supplierId || 0, 10);
            }

            if (!supplierId) {
                Notify.info('@Html.Raw(L["CreateReceipt_ValidSupplier"])');
                return false;
            }

            const request = {
                poNo: poNo,
                supplierId: supplierId,
                supplierName: supplierName || null,
                orderDate: orderDateIso,
                expectedDeliveryDate: toIsoDateOnly(expectedDeliveryDateText),
                description: description || null,
                buyerName: buyerName || null,
                buyerAddress: buyerAddress || null,
                paymentTerm: paymentTerm || null,
                shippingAmount: shippingAmountText === '' ? null : Number(shippingAmountText),
                details: details
            };

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('?', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(request)
                });

                const result = await response.json();

                if (result?.success) {
                    Notify.info(result.message ?? '@Html.Raw(L["OperationSuccessful"])');
                    window.location.href = result.redirectUrl ?? '/PurchaseOrder';
                    return false;
                }

                Notify.info(result?.message ?? '@Html.Raw(L["OperationFailed"])');
                return false;
            } catch (error) {
                console.error('submitPoForm error:', error);
                Notify.info('@Html.Raw(L["OperationFailed"])');
                return false;
            }
        }

  </script>
}