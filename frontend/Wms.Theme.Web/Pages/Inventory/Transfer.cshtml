@page
@model Wms.Theme.Web.Pages.Inventory.TransferModel
@{
    ViewData["Title"] = L["TransferList"];
}

@Html.AntiForgeryToken()
<div class="p-6 bg-gray-50 min-h-screen">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">@Html.Raw(L["TransferList"])</h1>
        <a href="/Inventory/Transfer/Create"
            class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg flex items-center gap-2 shadow-sm transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            @Html.Raw(L["NewTransfer"])
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-200 flex items-center">
            <div class="p-3 rounded-lg bg-yellow-100 text-yellow-600 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">@Html.Raw(L["Pending"])</p>
                <p class="text-3xl font-bold text-gray-800">@(Model.DashboardStats?.Pending ?? 0)</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-200 flex items-center">
            <div class="p-3 rounded-lg bg-blue-100 text-blue-600 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">@Html.Raw(L["InProgress"])</p>
                <p class="text-3xl font-bold text-gray-800">@(Model.DashboardStats?.InProgress ?? 0)</p>
            </div>
        </div>

        <div class="bg-white p-5 rounded-lg shadow-sm border border-gray-200 flex items-center">
            <div class="p-3 rounded-lg bg-green-100 text-green-600 mr-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium text-gray-500">@Html.Raw(L["CompletedToday"])</p>
                <p class="text-3xl font-bold text-gray-800">@(Model.DashboardStats?.CompletedToday ?? 0)</p>
            </div>
        </div>
    </div>

    <div x-data="AlpineDataTable(tableConfig)" x-cloak>
        <partial name="Shared/Components/_AlpineDataTable" />
    </div>

</div>

@section Scripts {
    <script src="~/js/components/alpine-datatable.js"></script>
    <script>
        const tableConfig = {
            apiUrl: '?handler=TableData',
            columns: [
                {
                    title: '@Html.Raw(L["JobCode"])',
                    field: 'job_code',
                    class: 'text-sm text-gray-700 dark:text-gray-300',
                    render: (item) => `<a href="/Inventory/Transfer/Detail/${item.id}" class="font-medium text-blue-600 hover:underline cursor-pointer">${item.job_code}</a>`
                },
                {
                    title: '@Html.Raw(L["Status"])',
                    field: 'move_status',
                    align: 'center',
                    class: 'text-sm text-gray-700 dark:text-gray-300',
                    render: (item) => {

                        if (item.move_status == 1) {
                            return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
                                            @Html.Raw(L["Completed"])
                                        </span>`;
                        } else {
                            return `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300">
                                            @Html.Raw(L["Pending"])
                                        </span>`;
                        }
                    }
                },
                {
                    title: '@Html.Raw(L["SKU"])',
                    field: 'sku_code',
                    class: 'text-sm text-gray-700 dark:text-gray-300'
                },
                {
                    title: '@Html.Raw(L["ItemName"])',
                    field: 'sku_name',
                    class: 'text-sm text-gray-700 dark:text-gray-300 truncate max-w-xs'
                },
                {
                    title: '@Html.Raw(L["FromLocation"])',
                    field: 'orig_goods_location_name',
                    class: 'text-sm text-gray-700 dark:text-gray-300'
                },
                {
                    title: '@Html.Raw(L["ToLocation"])',
                    field: 'dest_googs_location_name',
                    class: 'text-sm text-gray-700 dark:text-gray-300'
                },
                {
                    title: '@Html.Raw(L["Qty"])',
                    field: 'qty',
                    align: 'right',
                    class: 'text-sm text-gray-700 dark:text-gray-300',
                    render: (item) => item.qty ? item.qty.toLocaleString() : '0'
                },
                {
                    title: '@Html.Raw(L["CreatedBy"])',
                    field: 'creator',
                    class: 'text-sm text-gray-700 dark:text-gray-300'
                },
                {
                    title: '@Html.Raw(L["CreatedDate"])',
                    field: 'create_time',
                    class: 'text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap',
                    render: (item) => {
                        if (!item.create_time || item.create_time.startsWith('0001')) return '-';
                        const date = new Date(item.create_time);
                        return date.toLocaleString('vi-VN', {
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                        });
                    }
                },
                {
                    title: '@Html.Raw(L["Actions"])',
                    align: 'center',
                    class: 'text-sm text-gray-700 dark:text-gray-300',
                    render: (item) => `
                            <div class="flex items-center justify-center gap-2">
                                    <a href="/Inventory/Transfer/Detail/${item.id}" class="text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300" title="@Html.Raw(L["View"])">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                </a>
                                <button onclick="deleteStockMove('${item.id}')" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" title="@Html.Raw(L["Delete"])">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </div>
                        `
                }
            ],
            filters: {
                status: () => document.getElementById('filterStatus')?.value || '',
                source: () => document.getElementById('filterSource')?.value || '',
                dest: () => document.getElementById('filterDest')?.value || '',
                date: () => document.getElementById('filterDate')?.value || ''
            }
        };



        async function deleteStockMove(id) {
            // ... (keep existing delete logic)
            const isConfirmed = await Notify.confirm(
                '@Html.Raw(L["ConfirmDelete"])', // "Xác nhận xóa lệnh?"
                '@Html.Raw(L["DeleteConfirmationAndUndo"])', // "Bạn có chắc chắn..."
                '@Html.Raw(L["Delete"])'
            );

            if (isConfirmed) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                fetch(`?handler=RemoveStockMove&id=${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            Notify.success(data.message);
                            // Reload table
                            const el = document.querySelector('[x-data^="AlpineDataTable"]');
                            if (el) el.__x.$data.reload();
                        } else {
                            Notify.error(data.message);
                        }
                    })
                    .catch(e => Notify.error("Error"));
            }
        }
    </script>
}