@page
@model Wms.Theme.Web.Pages.Inventory.SearchModel
@{
    ViewData["Title"] = L["InventorySearch"];
    var role = TempData.Peek("UserRole")?.ToString();
}

@if (role != "Admin" && role != "Operator")
{
    <div class="flex items-end gap-2"></div>
}
else
{
    <div class="mb-6 p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-slate-200 dark:border-gray-700">
        <div class="flex flex-col md:flex-row items-end justify-between gap-4">
        
            <div class="flex-1 flex flex-col gap-1 w-full md:max-w-md">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                        <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z" />
                        </svg>
                    </div>
                    <input type="text" id="searchInput" placeholder="@L["SearchInventoryPlaceholder"]"
                           class="w-full pl-10 px-3 py-2 text-sm bg-gray-50 dark:bg-gray-900 border border-slate-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:text-white">
                </div>
            </div>

            <div class="flex flex-wrap gap-2">
                <button onclick="exportSelectedRows('excel')"
                        class="px-3 py-2 bg-white dark:bg-gray-700 border border-slate-200 dark:border-gray-600 text-slate-600 dark:text-slate-300 hover:text-emerald-700 dark:hover:text-emerald-400 hover:border-emerald-200 hover:bg-emerald-50 rounded-lg transition-colors shadow-sm flex items-center justify-center"
                        title="@L["ExportExcel"]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                    </svg>
                </button>
                <button onclick="exportSelectedRows('pdf')"
                        class="px-3 py-2 bg-white dark:bg-gray-700 border border-slate-200 dark:border-gray-600 text-slate-600 dark:text-slate-300 hover:text-red-700 dark:hover:text-red-400 hover:border-red-200 hover:bg-red-50 rounded-lg transition-colors shadow-sm flex items-center justify-center"
                        title="@L["ExportPDF"]">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                </button>
                <button onclick="printLabels()"
                        class="px-3 py-2 bg-slate-800 dark:bg-slate-700 text-white text-sm font-medium rounded-lg hover:bg-slate-900 dark:hover:bg-slate-600 focus:ring-4 focus:ring-slate-300 transition-colors shadow-sm flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                    </svg>
                    @L["PrintLabels"]
                </button>
            </div>
        </div>
    </div>

    <div id="inventoryGrid" class="ag-theme-quartz" style="height: calc(100vh - 220px); width: 100%;"></div>

    <div id="detailModal" style="display: none;" class="fixed inset-0 z-[100] overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">

        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75 transition-opacity" onclick="closeDetailModal()"></div>

        <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0 pointer-events-none">
            <div class="relative transform overflow-hidden rounded-2xl bg-white dark:bg-gray-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-7xl border border-slate-200 dark:border-gray-700 pointer-events-auto">

                <div class="px-6 py-4 border-b border-slate-200 dark:border-gray-700 flex justify-between items-center bg-slate-50 dark:bg-gray-700/50">
                    <h3 class="text-lg font-semibold leading-6 text-slate-900 dark:text-white" id="modal-title">@L["StockDetails"]</h3>
                    <button type="button" onclick="closeDetailModal()" class="text-slate-400 hover:text-slate-500 focus:outline-none">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <div class="px-6 py-6 max-h-[70vh] overflow-auto">

                    <div id="detailLoadingSpinner" class="flex justify-center py-10">
                        <svg class="animate-spin h-8 w-8 text-blue-600 dark:text-blue-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>

                    <div id="detailTableContainer" style="display: none;">
                        <table class="min-w-full divide-y divide-slate-200 dark:divide-gray-700">
                            <thead class="bg-slate-50 dark:bg-gray-700/50">
                                <tr>
                                    <th scope="col" class="px-3 py-3.5 text-left text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["Warehouse"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-left text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["Location"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-left text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["SkuCode"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-left text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["ItemName"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["PalletCode"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["PutawayDate"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-center text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["ExpiryDate"]</th>
                                    <th scope="col" class="px-3 py-3.5 text-right text-xs font-semibold text-slate-900 dark:text-white uppercase tracking-wider">@L["Qty"]</th>
                                </tr>
                            </thead>
                            <tbody id="detailTableBody" class="divide-y divide-slate-200 dark:divide-gray-700 bg-white dark:bg-gray-800">
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="bg-slate-50 dark:bg-gray-700/50 px-6 py-4 sm:flex sm:flex-row-reverse border-t border-slate-200 dark:border-gray-700 rounded-b-2xl">
                    <button type="button" onclick="closeDetailModal()" class="mt-3 inline-flex w-full justify-center rounded-xl bg-white dark:bg-gray-700 px-3 py-2 text-sm font-semibold text-slate-900 dark:text-white shadow-sm ring-1 ring-inset ring-slate-300 dark:ring-gray-600 hover:bg-slate-50 dark:hover:bg-gray-600 sm:mt-0 sm:w-auto transition-colors">@L["Close"]</button>
                </div>
            </div>
        </div>
    </div>

    <div id="print-label-area" class="hidden print:grid print:grid-cols-2 print:gap-4 print:p-0"></div>

}

@section Scripts {
    <script>
        let gridApi = null;

        // UTILS
        function debounce(func, wait) {
            let timeout;
            return function (...args) {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, args), wait);
            };
        }

        function formatNumber(num) {
            return num ? num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",") : "0";
        }

        function formatDate(dateStr) {
            if (!dateStr || dateStr.startsWith('0001')) return '-';
            const d = new Date(dateStr);
            return d.toLocaleDateString('vi-VN');
        }

        function initGrid() {
            const columnDefs = [
               
                {
                    headerName: '@Html.Raw(L["SkuCode"])',
                    field: 'sku_code',
                    width: 180, 
                    cellRenderer: params => {
                        if (!params.data) return `<span class="text-gray-400 italic text-sm"><i class="fas fa-spinner fa-spin"></i></span>`;
                        return `<button onclick="viewDetail('${params.data.id}')" class="font-medium text-blue-600 dark:text-blue-400 hover:underline cursor-pointer" title="${params.value}">${params.value}</button>`;
                    }
                },
                {
                    headerName: '@Html.Raw(L["ItemName"])',
                    field: 'sku_name',
                    flex: 1, 
                    minWidth: 300,
                    cellRenderer: params => {
                        if (!params.data) return '';
                        const catName = params.data.category_name || params.data.spu_code || '';
                        return `<div class="truncate text-slate-800 dark:text-slate-200 font-medium" title="${params.value}">${params.value}</div>
                                <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">${catName}</div>`;
                    }
                },
                {
                    headerName: '@Html.Raw(L["Unit"])',
                    field: 'unit',
                    width: 120,
                    cellClass: 'text-left text-slate-600 dark:text-slate-400'
                },
                {
                    headerName: '@Html.Raw(L["Quantity"])',
                    field: 'qty_available',
                    width: 140,
                    cellClass: 'text-left font-semibold text-slate-800 dark:text-white',
                    valueFormatter: params => formatNumber(params.value)
                },
            ];

            const dataSource = {
                getRows: async (params) => {
                    const pageSize = 20;
                    const pageIndex = Math.floor(params.startRow / pageSize) + 1;
                    const keyword = document.getElementById('searchInput').value.trim();

                    try {
                        const url = `?handler=TableData&pageIndex=${pageIndex}&pageSize=${pageSize}&pKeyword=${encodeURIComponent(keyword)}`;
                        const response = await fetch(url);
                        
                        if (!response.ok) throw new Error('Lỗi máy chủ');
                        
                        const result = await response.json();
                        let rows = result.data || result.rows || [];
                        let totals = result.totals || 0;
                        params.successCallback(rows, totals);
                    } catch (error) {
                        console.error('Lỗi Data:', error);
                        params.failCallback();
                    }
                }
            };

            const gridOptions = {
                columnDefs: columnDefs,
                rowModelType: 'infinite',
                rowSelection: 'multiple',
                pagination: true,
                paginationPageSize: 20,
                cacheBlockSize: 20,
                overlayLoadingTemplate: '<span>@Html.Raw(L["Loading"])</span>',
                overlayNoRowsTemplate: '<span class="text-gray-500">@Html.Raw(L["NoDataFound"])</span>',
            };

            const gridDiv = document.querySelector('#inventoryGrid');
            if (document.documentElement.classList.contains('dark')) {
                gridDiv.classList.replace('ag-theme-quartz', 'ag-theme-quartz-dark');
            }
            gridApi = agGrid.createGrid(gridDiv, gridOptions);
            gridApi.setGridOption('datasource', dataSource);
        }

        function reloadGrid() {
            if (gridApi) {
                const ds = gridApi.getGridOption('datasource');
                gridApi.setGridOption('datasource', ds);
            }
        }

        // DOM EVENT LISTENERS
        document.addEventListener('DOMContentLoaded', function () {
            initGrid();

            // Gắn sự kiện Debounce cho ô tìm kiếm
            const searchInput = document.getElementById('searchInput');
            if (searchInput) {
                searchInput.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        reloadGrid();
                    }
                });
                searchInput.addEventListener('input', debounce(function () {
                    reloadGrid();
                }, 500));
            }
        });

        // MODAL LOGIC
        async function viewDetail(id) {
            const modal = document.getElementById('detailModal');
            const spinner = document.getElementById('detailLoadingSpinner');
            const tableContainer = document.getElementById('detailTableContainer');
            const tbody = document.getElementById('detailTableBody');

            // Reset modal state
            modal.style.display = 'block';
            spinner.style.display = 'flex';
            tableContainer.style.display = 'none';
            tbody.innerHTML = '';

            try {
                const res = await fetch(`?handler=StockDetail&skuId=${id}`);
                const json = await res.json();
                if (json.status) {
                    const data = json.data || [];
                    if (data.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="8" class="px-3 py-8 text-center text-sm text-slate-500 dark:text-slate-400">@Html.Raw(L["NoDetailData"])</td></tr>`;
                    } else {
                        data.forEach(d => {
                            let badgeClass = 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300';
                            if (d.is_expired) badgeClass = 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400';
                            else if (d.is_soon_expired) badgeClass = 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400';

                            tbody.innerHTML += `
                                <tr class="hover:bg-slate-50 dark:hover:bg-gray-700 transition-colors">
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-700 dark:text-slate-300">${d.warehouse_name || ''}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-slate-600 dark:text-slate-400">${d.location_name || ''}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-blue-600 dark:text-blue-400 font-medium">${d.sku_code || ''}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-700 dark:text-slate-300 max-w-[150px] truncate" title="${d.sku_name || ''}">${d.sku_name || ''}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-center font-mono text-slate-600 dark:text-slate-400">${d.pallet_code || '-'}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-center text-slate-600 dark:text-slate-400">${formatDate(d.putaway_date)}</td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-center">
                                        <span class="px-2 py-1 rounded-full text-xs font-medium ${badgeClass}">${formatDate(d.expiry_date)}</span>
                                    </td>
                                    <td class="whitespace-nowrap px-3 py-4 text-sm text-right font-bold text-slate-800 dark:text-white">${formatNumber(d.qty_available)}</td>
                                </tr>
                            `;
                        });
                    }
                }
            } catch (e) {
                console.error(e);
                if (typeof Notify !== 'undefined') Notify.error("@Html.Raw(L["ErrorLoadingDetails"])");
            } finally {
                spinner.style.display = 'none';
                tableContainer.style.display = 'block';
            }
        }

        function closeDetailModal() {
            document.getElementById('detailModal').style.display = 'none';
        }

        // EXPORT LOGIC
        function getCheckedRows() {
            return gridApi ? gridApi.getSelectedRows() : [];
        }

        function exportSelectedRows(type) {
            const selected = getCheckedRows();
            if (selected.length === 0) { Notify.warning("@Html.Raw(L["PleaseSelectAtLeastOneRow"])"); return; }

            const dataExport = selected.map(r => ({
                '@Html.Raw(L["SkuCode"])': r.sku_code,
                '@Html.Raw(L["ItemName"])': r.sku_name,
                '@Html.Raw(L["WarehouseName"])': r.warehouse_name,
                '@Html.Raw(L["LocationName"])': r.location_name,
                '@Html.Raw(L["SeriesNumber"])': r.series_number || '',
                '@Html.Raw(L["ExpiryDate"])': formatDate(r.expiry_date),
                '@Html.Raw(L["Quantity"])': r.qty
            }));

            if (type === 'excel') {
                const ws = XLSX.utils.json_to_sheet(dataExport);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "Inventory");
                XLSX.writeFile(wb, `Inventory_${new Date().toISOString().slice(0, 10)}.xlsx`);
            } else if (type === 'pdf') {
                if (typeof window.jspdf === 'undefined') return;
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF();
                const body = dataExport.map(Object.values);
                doc.text("Inventory Export", 14, 15);
                doc.autoTable({ head: [Object.keys(dataExport[0])], body: body, startY: 20 });
                doc.save(`Inventory_${new Date().toISOString().slice(0, 10)}.pdf`);
            }
        }

        function printLabels() {
            const selected = getCheckedRows();
            if (selected.length === 0) { Notify.warning("@Html.Raw(L["NoRowsSelected"])"); return; }

            const printArea = document.getElementById('print-label-area');
            printArea.innerHTML = '';

            selected.forEach((item, i) => {
                const el = document.createElement('div');
                el.className = 'border border-black p-2 flex flex-col items-center justify-center text-center h-[150px] break-inside-avoid';
                el.innerHTML = `<div class="text-xs font-bold mb-1 truncate w-full">${item.sku_name}</div>
                      <svg id="bc-${i}"></svg>
                      <div class="text-sm font-mono mt-1">${item.sku_code}</div>
                      <div class="text-[10px]">Lot: ${item.series_number || '-'} | Exp: ${formatDate(item.expiry_date)}</div>
                `;
                printArea.appendChild(el);
                try {
                    JsBarcode(`#bc-${i}`, item.sku_code, { format: "CODE128", width: 1.5, height: 40, displayValue: false });
                } catch (e) { }
            });
            window.print();
        }
    </script>
}

@section Styles {
    <style>
        @@media print {
            body * {
                visibility: hidden;
            }

            #print-label-area,
            #print-label-area * {
                visibility: visible;
            }

            #print-label-area {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }
        }
    </style>
}