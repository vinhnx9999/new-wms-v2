@page
@model Wms.Theme.Web.Pages.Inventory.Adjustment.DetailModel
@using Microsoft.Extensions.Localization
@using Wms.Theme.Web.Util
@inject IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["InventoryAdjustmentDetail"];

    string GetStatusClass(bool status) => status
    ? "bg-green-100 text-green-700 border-green-200 dark:bg-green-900/40 dark:text-green-300 dark:border-green-800"
            : "bg-yellow-100 text-yellow-600 border-yellow-200 dark:bg-yellow-900/40 dark:text-yellow-300 dark:border-yellow-800";

    string GetStatusLabel(bool status) => status ? L["Accepted"] : L["Pending"];
}

@Html.AntiForgeryToken()

<div class="max-w-7xl mx-auto space-y-6 pb-10" x-data="adjustmentDetail(@Model.StockModel?.id)">

    <div
        class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden transition-colors duration-200">
        <div
            class="px-6 py-5 border-b border-gray-100 dark:border-gray-700 flex flex-col md:flex-row justify-between items-start md:items-center bg-gray-50/50 dark:bg-gray-800/50 gap-4">
            <div>
                <div class="flex items-center gap-3 mb-1">
                    <span
                        class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider border border-gray-300 dark:border-gray-600 px-2 py-0.5 rounded">@Html.Raw(L["TicketCode"])</span>

                    <div class="flex items-center gap-2">
                        <h1 class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight font-mono">
                            @Model.StockModel?.job_code
                        </h1>
                        @if (!Model.StockModel.process_status)
                        {
                            <button @@click="openEditModal()" type="button"
                                class="text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors p-1 rounded-md hover:bg-gray-200 dark:hover:bg-gray-700"
                                title="@Html.Raw(L["Edit"])">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                    </path>
                                </svg>
                            </button>
                        }
                    </div>
                </div>

                <div class="flex items-center gap-2 mt-2">
                    <span
                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border @GetStatusClass(Model.StockModel.process_status)">
                        <svg class="w-3 h-3 mr-1.5" fill="currentColor" viewBox="0 0 8 8">
                            <circle cx="4" cy="4" r="3" />
                        </svg>
                        @Html.Raw(GetStatusLabel(Model.StockModel.process_status))
                    </span>

                    @if (Model.StockModel.adjust_status)
                    {
                        <span
                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-200 dark:bg-blue-900/40 dark:text-blue-300 dark:border-blue-800">
                            <svg class="w-3 h-3 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            @Html.Raw(L["StockDeducted"])
                        </span>
                    }
                </div>
            </div>

            <div class="flex gap-2">
                @if (!Model.StockModel.process_status)
                {
                    <button @@click="confirmProcess()"
                        class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-600 text-white text-sm font-medium rounded-lg shadow-sm transition-colors focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-900">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        @Html.Raw(L["ConfirmAndAdjust"])
                    </button>
                }
                else
                {
                    <span
                        class="inline-flex items-center px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 text-sm font-medium rounded-lg border border-gray-200 dark:border-gray-600 cursor-not-allowed">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                            </path>
                        </svg>
                        @Html.Raw(L["Locked"])
                    </span>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 px-6 py-5">
            @* <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["JobType"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @(Model.StockModel.job_type == 2 ? Html.Raw(L["Adjustment"] + " / " + L["StockCount"]) :
                                        Html.Raw(L["Inbound"]))
                </div>
            </div> *@
            <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["Creator"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @(Model.StockModel.creator)
                </div>
            </div>
            <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["CreatedDate"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @(Model.StockModel.create_time.Year > 2000 ? Model.StockModel.create_time.Convert2LocalTime() : "-")
                </div>
            </div>
            <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["LastProcessor"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @(string.IsNullOrEmpty(Model.StockModel.processor) ? "-" : Model.StockModel.processor)
                </div>
            </div>
            <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["ProcessedDate"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @(Model.StockModel.process_time?.Year > 2000 ? Model.StockModel.process_time?.Convert2LocalTime() : "-")
                </div>
            </div>
            @* <div>
                <label
                    class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">@Html.Raw(L["LastUpdated"])</label>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">
                    @Model.StockModel.last_update_time.Convert2LocalTime()
                </div>
            </div> *@
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div
            class="flex flex-col h-full bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-red-100 dark:border-red-900/40 overflow-hidden">
            <div
                class="px-5 py-3 bg-red-50 dark:bg-red-900/20 border-b border-red-100 dark:border-red-900/40 flex justify-between items-center">
                <h3 class="font-bold text-red-800 dark:text-red-300 flex items-center gap-2">
                    <span
                        class="w-6 h-6 rounded-full bg-red-200 dark:bg-red-800 flex items-center justify-center text-red-700 dark:text-red-200 text-xs"><i
                            class="fas fa-minus"></i></span>
                    @Html.Raw(L["StockSourceDecrease"])
                </h3>
                <span
                    class="bg-white dark:bg-gray-700 text-red-700 dark:text-red-300 text-xs font-bold px-2.5 py-1 rounded-md shadow-sm border border-red-100 dark:border-red-900/40">
                    @Model.StockModel.source_detail_list.Count @Html.Raw(L["Lines"])
                </span>
            </div>
            <div class="flex-1 overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead
                        class="bg-gray-50 dark:bg-gray-700/50 text-gray-500 dark:text-gray-400 font-medium border-b border-gray-100 dark:border-gray-700">
                        <tr>
                            <th class="px-4 py-2.5">@Html.Raw(L["LocationName"])</th>
                            <th class="px-4 py-2.5">@Html.Raw(L["SKU"]) / @Html.Raw(L["Name"])</th>
                            <th class="px-4 py-2.5">@Html.Raw(L["LotBatch"]) / @Html.Raw(L["Date"])</th>
                            <th class="px-4 py-2.5 text-right">@Html.Raw(L["Qty"])</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-gray-700/50">
                        @if (Model.StockModel.source_detail_list.Any())
                        {
                            foreach (var item in Model.StockModel.source_detail_list)
                            {
                                <tr class="group hover:bg-red-50/40 dark:hover:bg-red-900/10 transition-colors">
                                    <td class="px-4 py-3 font-medium text-gray-800 dark:text-gray-200">@item.location_name</td>
                                    <td class="px-4 py-3">
                                        <div class="font-bold text-blue-600 dark:text-blue-400 group-hover:underline">
                                            @item.sku_code</div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[150px]"
                                            title="@item.spu_name">@item.spu_name</div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="text-xs font-mono text-gray-600 dark:text-gray-400">@item.series_number
                                        </div>
                                        <div class="text-[10px] text-gray-400 dark:text-gray-500">
                                            @item.expiry_date.Convert2LocalDate()
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-right font-bold text-red-600 dark:text-red-400 tabular-nums">
                                        -@item.qty.FormatPrice()
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4"
                                    class="px-4 py-8 text-center text-gray-400 dark:text-gray-500 italic text-xs">
                                    @Html.Raw(L["NoDecreaseData"])</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div
            class="flex flex-col h-full bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-green-100 dark:border-green-900/40 overflow-hidden">
            <div
                class="px-5 py-3 bg-green-50 dark:bg-green-900/20 border-b border-green-100 dark:border-green-900/40 flex justify-between items-center">
                <h3 class="font-bold text-green-800 dark:text-green-300 flex items-center gap-2">
                    <span
                        class="w-6 h-6 rounded-full bg-green-200 dark:bg-green-800 flex items-center justify-center text-green-700 dark:text-green-200 text-xs"><i
                            class="fas fa-plus"></i></span>
                    @Html.Raw(L["StockDestinationIncrease"])
                </h3>
                <span
                    class="bg-white dark:bg-gray-700 text-green-700 dark:text-green-300 text-xs font-bold px-2.5 py-1 rounded-md shadow-sm border border-green-100 dark:border-green-900/40">
                    @Model.StockModel.target_detail_list.Count @Html.Raw(L["Lines"])
                </span>
            </div>
            <div class="flex-1 overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead
                        class="bg-gray-50 dark:bg-gray-700/50 text-gray-500 dark:text-gray-400 font-medium border-b border-gray-100 dark:border-gray-700">
                        <tr>
                            <th class="px-4 py-2.5">@Html.Raw(L["LocationName"])</th>
                            <th class="px-4 py-2.5">@Html.Raw(L["SKU"]) / @Html.Raw(L["Name"])</th>
                            <th class="px-4 py-2.5">@Html.Raw(L["LotBatch"]) / @Html.Raw(L["Date"])</th>
                            <th class="px-4 py-2.5 text-right">@Html.Raw(L["Qty"])</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-gray-700/50">
                        @if (Model.StockModel.target_detail_list.Any())
                        {
                            foreach (var item in Model.StockModel.target_detail_list)
                            {
                                <tr class="group hover:bg-green-50/40 dark:hover:bg-green-900/10 transition-colors">
                                    <td class="px-4 py-3 font-medium text-gray-800 dark:text-gray-200">@item.location_name</td>
                                    <td class="px-4 py-3">
                                        <div class="font-bold text-blue-600 dark:text-blue-400 group-hover:underline">
                                            @item.sku_code</div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[150px]"
                                            title="@item.spu_name">@item.spu_name</div>
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="text-xs font-mono text-gray-600 dark:text-gray-400">@item.series_number
                                        </div>
                                        <div class="text-[10px] text-gray-400 dark:text-gray-500">
                                            @item.expiry_date.Convert2LocalDate()
                                        </div>
                                    </td>
                                    <td class="px-4 py-3 text-right font-bold text-green-600 dark:text-green-400 tabular-nums">
                                        +@item.qty.FormatPrice()
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4"
                                    class="px-4 py-8 text-center text-gray-400 dark:text-gray-500 italic text-xs">
                                    @Html.Raw(L["NoIncreaseData"])</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="flex items-center justify-end pt-6 border-t border-gray-200 dark:border-gray-700 gap-4">

        <a href="/Inventory/Adjustment"
            class="px-6 py-2.5 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors shadow-sm flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18">
                </path>
            </svg>
            @Html.Raw(L["BackToList"])
        </a>

        @if (Model.StockModel.process_status && !Model.StockModel.adjust_status)
        {
            <button @@click="approveAdjust()"
                class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg shadow-sm transition-colors flex items-center gap-2 focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                @Html.Raw(L["ConfirmChanges"])
            </button>
        }
    </div>

    <!-- Edit Modal -->
    <div x-show="isEditModalOpen" style="display: none;" class="fixed inset-0 z-50 overflow-y-auto"
        aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div x-show="isEditModalOpen" x-transition:enter="ease-out duration-300"
                x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
                x-transition:leave="ease-in duration-200" x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0" class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"
                @@click="closeEditModal()"></div>

            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

            <div x-show="isEditModalOpen" x-transition:enter="ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                x-transition:leave="ease-in duration-200"
                x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-gray-200 dark:border-gray-700">
                <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                            <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white" id="modal-title">
                                @Html.Raw(L["EditTicketInfo"])
                            </h3>
                            <div class="mt-4 space-y-4">

                                <div>
                                    <label
                                        class="block text-sm font-medium text-gray-700 dark:text-gray-300">@Html.Raw(L["TicketCode"])</label>
                                    <input type="text" x-model="editForm.job_code" readonly
                                        class="mt-1 block w-full bg-gray-100 dark:bg-gray-700 border-gray-300 dark:border-gray-600 rounded-md shadow-sm sm:text-sm p-2 cursor-not-allowed text-gray-500 dark:text-gray-400">
                                </div>

                                <div>
                                    <label
                                        class="block text-sm font-medium text-gray-700 dark:text-gray-300">@Html.Raw(L["JobType"])</label>
                                    <select x-model="editForm.job_type"
                                        class="mt-1 block w-full border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border">
                                        <option :value="true">@Html.Raw(L["Adjustment"]) / @Html.Raw(L["StockCount"])
                                        </option>
                                        <option :value="false">@Html.Raw(L["Inbound"]) / @Html.Raw(L["Other"])</option>
                                    </select>
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div>
                                        <label
                                            class="block text-sm font-medium text-gray-700 dark:text-gray-300">@Html.Raw(L["LastProcessor"])</label>
                                        <input type="text" x-model="editForm.processor"
                                            class="mt-1 block w-full border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border">
                                    </div>

                                    <div>
                                        <label
                                            class="block text-sm font-medium text-gray-700 dark:text-gray-300">@Html.Raw(L["ProcessedDate"])</label>
                                        <input type="datetime-local" x-model="editForm.process_time"
                                            class="mt-1 block w-full border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm p-2 border">
                                    </div>
                                </div>

                                <div class="flex items-center mt-4" style="display:none">
                                    <input id="edit_process_status" type="checkbox" x-model="editForm.process_status"
                                        class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 dark:border-gray-600 rounded bg-gray-50 dark:bg-gray-700">
                                    <label for="edit_process_status"
                                        class="ml-2 block text-sm text-gray-900 dark:text-white">
                                        @Html.Raw(L["ProcessFinished"])
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div
                    class="bg-gray-50 dark:bg-gray-700/50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200 dark:border-gray-700">
                    <button type="button" @@click="submitUpdate()"
                        class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 hover:bg-blue-700 text-base font-medium text-white focus:outline-none sm:ml-3 sm:w-auto sm:text-sm">
                        @Html.Raw(L["Save"])
                    </button>                    
                    <button type="button" @@click="closeEditModal()"
                        class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                        @Html.Raw(L["Cancel"])
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('adjustmentDetail', (id) => ({
                id: id,
                isEditModalOpen: false,
                editForm: {
                    id: 0,
                    job_code: '',
                    job_type: true,
                    processor: '',
                    process_time: '',
                    process_status: false
                },
                init() {
                    // Init logic
                },
                openEditModal() {
                    this.editForm = {
                        id: @Model.StockModel.id,
                        job_code: '@Model.StockModel.job_code',
                        job_type: @(Model.StockModel.job_type.ToString().ToLower()),
                        processor: '@Model.StockModel.processor',
                        process_time: '@(Model.StockModel.process_time?.Year > 2000 ? Model.StockModel.process_time?.ToString("yyyy-MM-ddTHH:mm") : "")',
                        process_status: @(Model.StockModel.process_status.ToString().ToLower())
                        };
                    this.isEditModalOpen = true;
                },
                closeEditModal() {
                    this.isEditModalOpen = false;
                },
                async confirmProcess() {
                    const isConfirmed = await Notify.confirm(
                        "@Html.Raw(L["ConfirmAdjustmentQuestion"])",
                        "@Html.Raw(L["AdjustmentWarning"])"
                    );

                    if (!isConfirmed) return;

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const response = await fetch(`?handler=ApproveProcess&id=${this.id}`, {
                            method: 'POST',
                            headers: { 'RequestVerificationToken': token }
                        });

                        const result = await response.json();

                        if (result.success) {
                            Notify.success("@Html.Raw(L["AdjustmentSuccess"])");
                            this.closeEditModal();
                            setTimeout(() => window.location.reload(), 100);
                        } else {
                            Notify.error(result.message || "@Html.Raw(L["ErrorOccurred"])");
                        }
                    } catch (error) {
                        Notify.error("@Html.Raw(L["ErrorSystem"])");
                    }
                },
                async submitUpdate() {
                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                        const form = this.editForm;
                        const payload = {
                            id: parseInt(form.id),
                            job_code: form.job_code,
                            job_type: form.job_type === true || form.job_type === 'true',
                            processor: form.processor,
                            process_time: form.process_time ? new Date(form.process_time).toISOString() : new Date().toISOString(),
                            process_status: form.process_status
                        };

                        const response = await fetch('?handler=UpdateProcess', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify(payload)
                        });

                        const result = await response.json();

                        if (result.success) {
                            Notify.success(result.message);
                            this.closeEditModal();
                            setTimeout(() => window.location.reload(), 100);
                        } else {
                            Notify.error(result.message || "@Html.Raw(L["ErrorOccurred"])");
                        }
                    } catch (error) {
                        Notify.error("@Html.Raw(L["ErrorSystem"])");
                    }
                },
                async approveAdjust() {
                    const isConfirmed = await Notify.confirm(
                        "@Html.Raw(L["ConfirmApprovalQuestion"])",
                        "@Html.Raw(L["ConfirmApprovalMessage"])"
                    );

                    if (!isConfirmed) return;

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const response = await fetch(`?handler=ApproveAdjust&id=${this.id}`, {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': token
                            }
                        });
                        const result = await response.json();
                        if (result.success) {
                            Notify.success(result.message);
                            setTimeout(() => window.location.reload(), 100);
                        } else {
                            Notify.error(result.message || "@Html.Raw(L["ErrorOccurred"])");
                        }
                    } catch (error) {
                        Notify.error("@Html.Raw(L["ErrorSystem"])");
                    }
                }
            }));
        });
    </script>
}