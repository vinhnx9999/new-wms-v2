@page 
@model Wms.Theme.Web.Pages.Inventory.Adjustment.EditModel
@{
    ViewData["Title"] = $"Sửa phiếu điều chỉnh #{Model.Input.Id}";
}

<form method="post" class="space-y-6">
    <input type="hidden" asp-for="Input.Id" />

    <div class="bg-white shadow-sm rounded-lg p-6 border border-gray-100">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold text-gray-800">
                Sửa phiếu điều chỉnh <span class="text-blue-600">#@Model.Input.Id</span>
            </h2>
            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 rounded-full text-xs font-semibold">Đang sửa (Pending)</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Kho</label>
                <select asp-for="Input.WarehouseId" asp-items="Model.Warehouses"
                        class="block w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-sm bg-gray-50">
                </select>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Lý do</label>
                <select asp-for="Input.Reason" asp-items="Model.Reasons"
                        class="block w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-sm bg-white">
                </select>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1">Ghi chú</label>
            <textarea asp-for="Input.Note" rows="3"
                      class="block w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 text-sm"
                      placeholder="Nhập ghi chú..."></textarea>
        </div>
    </div>

    <div class="bg-white shadow-sm rounded-lg p-6 border border-gray-100">
        <h3 class="text-lg font-bold text-gray-800 mb-4">Chi tiết điều chỉnh</h3>

        <div class="overflow-x-auto">
            <table class="w-full min-w-[800px]">
                <thead>
                    <tr class="bg-gray-100 border-b border-gray-200">
                        <th class="text-left py-3 px-4 text-xs font-bold text-gray-600 uppercase w-12 text-center">#</th>
                        <th class="text-left py-3 px-4 text-xs font-bold text-gray-600 uppercase w-1/4">SKU/Sản phẩm</th>
                        <th class="text-left py-3 px-4 text-xs font-bold text-gray-600 uppercase w-1/6">Vị trí/Bin</th>
                        <th class="text-left py-3 px-4 text-xs font-bold text-gray-600 uppercase w-1/6">Lô/Lot</th>
                        <th class="text-right py-3 px-4 text-xs font-bold text-gray-600 uppercase w-24">Tồn hệ thống</th>
                        <th class="text-left py-3 px-4 text-xs font-bold text-gray-600 uppercase w-32">Tồn thực tế</th>
                        <th class="text-right py-3 px-4 text-xs font-bold text-gray-600 uppercase w-32">Chênh lệch</th>
                        <th class="w-10"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100" id="tableBody">
                    @for (int i = 0; i < Model.Input.Items.Count; i++)
                    {
                        var item = Model.Input.Items[i];
                        var delta = (item.ActualQty ?? 0) - item.SystemQty;
                        var deltaColor = delta < 0 ? "text-red-600 font-bold" : (delta > 0 ? "text-green-600 font-bold" : "text-gray-500");
                        var deltaPrefix = delta > 0 ? " +" : " ";
                        var displayText = delta == 0 ? "0" : $"{deltaPrefix}{delta}";

                        <tr>
                            <td class="p-2 align-middle text-center text-gray-500 text-sm">@(i + 1)</td>

                            <td class="p-2 align-top">
                                <input asp-for="Input.Items[i].Sku" readonly
                                       class="w-full pl-3 pr-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-600 focus:outline-none" />
                            </td>

                            <td class="p-2 align-top">
                                <input asp-for="Input.Items[i].Bin" readonly
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-600 focus:outline-none" />
                            </td>

                            <td class="p-2 align-top">
                                <input asp-for="Input.Items[i].Lot" readonly
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-gray-50 text-gray-600 focus:outline-none" />
                            </td>

                            <td class="p-2 align-middle text-right text-sm text-gray-700 sys-qty px-4 font-medium">
                                <input type="hidden" asp-for="Input.Items[i].SystemQty" />
                                @item.SystemQty
                            </td>

                            <td class="p-2 align-top">
                                <input type="number" asp-for="Input.Items[i].ActualQty"
                                       class="w-full py-2 px-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm actual-qty font-medium"
                                       oninput="calculateRow(this)" />
                            </td>

                            <td class="p-2 align-middle text-right text-sm delta-cell px-4 @deltaColor">
                                @displayText
                            </td>

                            <td class="p-2 align-middle text-center">
                                <button type="button" class="text-gray-400 hover:text-red-500 transition">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="flex items-center justify-end pt-4 border-t border-gray-200 mt-6">
        <a href="/Inventory/Adjustment"
           class="flex items-center gap-2 px-4 py-2 text-red-600 hover:text-red-800 hover:bg-red-50 rounded-lg text-sm font-medium transition">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Hủy bỏ thay đổi
        </a>

        <div class="flex gap-3">
            <button type="submit" class="flex items-center gap-2 px-6 py-2 bg-blue-700 hover:bg-blue-800 text-white rounded-lg text-sm font-medium transition shadow-md">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Cập nhật phiếu
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function calculateRow(input) {
            const row = input.closest('tr');

            const sysQty = parseInt(row.querySelector('.sys-qty').innerText.trim()) || 0;
            const actualQtyVal = input.value;
            const deltaCell = row.querySelector('.delta-cell');

            if (actualQtyVal === '') {
                deltaCell.innerText = '-';
                deltaCell.className = "p-2 align-middle text-right text-sm delta-cell px-4 text-gray-400";
                return;
            }

            const actualQty = parseInt(actualQtyVal);
            const delta = actualQty - sysQty;

            let displayText = delta > 0 ? `+${delta}` : `${delta}`;
            if (delta === 0) displayText = "0";

            deltaCell.innerText = displayText;

            // Reset classes & add logic color
            deltaCell.className = "p-2 align-middle text-right text-sm delta-cell px-4 font-bold";
            if (delta > 0) {
                deltaCell.classList.add('text-green-600');
            } else if (delta < 0) {
                deltaCell.classList.add('text-red-600');
            } else {
                deltaCell.classList.add('text-gray-500');
            }
        }
    </script>
}