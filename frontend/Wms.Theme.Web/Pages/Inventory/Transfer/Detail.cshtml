@page "{id:int}"
@model Wms.Theme.Web.Pages.Inventory.Transfer.DetailModel
@{
    ViewData["Title"] = L["TransferDetail"];
    var item = Model.StockMoveModel;
    string statusText = "";
    string statusClass = "";
    switch (item.move_status)
    {
        case 0:
            statusText = L["InProgress"];
            statusClass = "bg-gray-100 text-gray-800 border-gray-200 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600";
            break;
        case 1:
            statusText = L["Completed"];
            statusClass = "bg-green-100 text-green-800 border-green-200 dark:bg-green-900 dark:text-green-300 dark:border-green-800";
            break;
        default:
            statusText = "Unknown";
            statusClass = "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300";
            break;
    }
}

@Html.AntiForgeryToken()
<div class="max-w-7xl mx-auto p-4 md:p-6 pb-32 min-h-screen bg-gray-50 dark:bg-gray-900">

    <div class="flex flex-col md:flex-row md:items-center justify-between mb-6 gap-4">
        <div>
            <div class="flex items-center gap-3">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white">@Html.Raw(L["TransferDetail"]): <span
                        class="font-mono text-blue-700 dark:text-blue-400">@item.job_code</span></h2>
                <span class="px-3 py-1 rounded-full text-xs font-bold border @statusClass">
                    @statusText
                </span>
            </div>
            <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">
                @Html.Raw(L["CreatedDate"]): <span
                    class="font-medium text-gray-700 dark:text-gray-300">@item.create_time.ToString("dd/MM/yyyy                    HH:mm")</span>
                <span class="mx-2">|</span>
                @Html.Raw(L["CreatedBy"]): <span
                    class="font-medium text-gray-700 dark:text-gray-300">@item.creator</span>
            </p>
        </div>
        <div class="flex gap-3">
            <button onclick="history.back()"
                class="flex items-center justify-center text-gray-700 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white font-medium px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                @Html.Raw(L["Back"])
            </button>

        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-1 space-y-6">
            <div
                class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div
                    class="bg-indigo-50 dark:bg-indigo-900/30 px-5 py-4 border-b border-indigo-100 dark:border-indigo-800 flex items-center">
                    <span
                        class="bg-indigo-100 dark:bg-indigo-900 text-indigo-600 dark:text-indigo-300 p-2 rounded-lg mr-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </span>
                    <h3 class="font-bold text-indigo-900 dark:text-indigo-100">@Html.Raw(L["ProductInfo"])</h3>
                </div>

                <div class="p-6 space-y-5">
                    <div>
                        <label
                            class="block text-xs font-semibold text-gray-400 uppercase mb-1">@Html.Raw(L["Product"])</label>
                        <div class="text-base font-bold text-gray-900 dark:text-white">@item.sku_name</div>
                        <div class="text-sm text-gray-500 font-mono mt-1">@item.sku_code</div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 border-t border-gray-100 dark:border-gray-700 pt-4">
                        <div>
                            <label
                                class="block text-xs font-semibold text-gray-400 uppercase mb-1">@Html.Raw(L["Lot"])</label>
                            <div class="text-sm font-medium text-gray-800 dark:text-gray-200 font-mono">
                                @(string.IsNullOrEmpty(item.series_number) ? "---" : item.series_number)</div>
                        </div>
                        <div>
                            <label
                                class="block text-xs font-semibold text-gray-400 uppercase mb-1">@Html.Raw(L["ExpiryDate"])</label>
                            <div class="text-sm font-medium text-gray-800 dark:text-gray-200">
                                @(item.expiry_date.Year == 1 ? "---" : item.expiry_date.ToString("dd/MM/yyyy"))
                            </div>
                        </div>
                        <div>
                            <label
                                class="block text-xs font-semibold text-gray-400 uppercase mb-1">@Html.Raw(L["PutawayDate"])</label>
                            <div class="text-sm font-medium text-gray-800 dark:text-gray-200">
                                @(item.putaway_date.Year == 1 ? "---" : item.putaway_date.ToString("dd/MM/yyyy"))
                            </div>
                        </div>
                        <div>
                            <label
                                class="block text-xs font-semibold text-gray-400 uppercase mb-1">@Html.Raw(L["Price"])</label>
                            <div class="text-sm font-medium text-gray-800 dark:text-gray-200">@item.price.ToString("N0")
                            </div>
                        </div>
                    </div>

                    <div
                        class="bg-yellow-50 dark:bg-yellow-900/30 rounded-lg p-4 border border-yellow-100 dark:border-yellow-800 text-center mt-4">
                        <label
                            class="block text-xs font-bold text-yellow-600 dark:text-yellow-400 uppercase mb-1">@Html.Raw(L["TransferQty"])</label>
                        <div class="text-3xl font-bold text-yellow-700 dark:text-yellow-300">@item.qty.ToString("N0")
                            <span
                                class="text-sm font-medium text-yellow-600 dark:text-yellow-500">@Html.Raw(L["Unit"])</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2 space-y-6">
            <div
                class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
                <div
                    class="bg-gray-50 dark:bg-gray-700/50 px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center">
                    <span class="bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 p-2 rounded-lg mr-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                        </svg>
                    </span>
                    <h3 class="font-bold text-gray-800 dark:text-white">@Html.Raw(L["RouteDetail"])</h3>
                </div>

                <div class="p-6 relative">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                        <div
                            class="hidden md:block absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-10 bg-white dark:bg-gray-700 rounded-full p-2 shadow-md border border-gray-200 dark:border-gray-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 dark:text-gray-300"
                                fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </div>

                        <div
                            class="bg-red-50 dark:bg-red-900/20 p-6 rounded-xl border border-red-100 dark:border-red-800 relative overflow-hidden">
                            <div class="absolute top-0 right-0 p-2 opacity-10">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-red-600"
                                    fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                                </svg>
                            </div>
                            <div class="relative z-10">
                                <div class="flex items-center mb-4">

                                    <h4
                                        class="font-bold text-red-800 dark:text-red-300 uppercase tracking-wide text-sm">
                                        @Html.Raw(L["SourceLocation"])</h4>
                                </div>

                                <div class="space-y-4">
                                    <div>
                                        <label
                                            class="block text-xs font-semibold text-red-400 uppercase mb-1">@Html.Raw(L["SourceWarehouse"])</label>
                                        <div class="text-base font-medium text-gray-800 dark:text-gray-200">
                                            @item.orig_goods_warehouse</div>
                                    </div>
                                    <div class="border-t border-red-200/50 dark:border-red-800/50 pt-3">
                                        <label
                                            class="block text-xs font-semibold text-red-400 uppercase mb-1">@Html.Raw(L["OldLocation"])</label>
                                        <div class="text-2xl font-bold font-mono text-gray-900 dark:text-white">
                                            @item.orig_goods_location_name</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div
                            class="bg-green-50 dark:bg-green-900/20 p-6 rounded-xl border border-green-100 dark:border-green-800 relative overflow-hidden">
                            <div class="absolute top-0 right-0 p-2 opacity-10">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-green-600"
                                    fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M5 10l7-7m0 0l7 7m-7-7v18" />
                                </svg>
                            </div>
                            <div class="relative z-10 md:pl-4">
                                <div class="flex items-center mb-4">

                                    <h4
                                        class="font-bold text-green-800 dark:text-green-300 uppercase tracking-wide text-sm">
                                        @Html.Raw(L["DestLocation"])</h4>
                                </div>

                                <div class="space-y-4">
                                    <div>
                                        <label
                                            class="block text-xs font-semibold text-green-500 uppercase mb-1">@Html.Raw(L["DestWarehouse"])</label>
                                        <div class="text-base font-medium text-gray-800 dark:text-gray-200">
                                            @item.dest_googs_warehouse</div>
                                    </div>
                                    <div class="border-t border-green-200/50 dark:border-green-800/50 pt-3">
                                        <label
                                            class="block text-xs font-semibold text-green-500 uppercase mb-1">@Html.Raw(L["NewLocation"])</label>
                                        <div class="text-2xl font-bold font-mono text-gray-900 dark:text-white">
                                            @item.dest_googs_location_name</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
                <h4
                    class="text-sm font-bold text-gray-700 dark:text-gray-300 mb-3 border-b border-gray-200 dark:border-gray-700 pb-2">
                    @Html.Raw(L["SystemLog"])</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">@Html.Raw(L["LastUpdateBy"]):</span>
                        <span
                            class="text-gray-800 dark:text-white font-medium ml-1">@(string.IsNullOrEmpty(item.handler)
                                                        ? "---" : item.handler)</span>
                    </div>
                    <div>
                        <span class="text-gray-500 dark:text-gray-400">@Html.Raw(L["LastUpdateTime"]):</span>
                        <span class="text-gray-800 dark:text-white font-medium ml-1">@(item.last_update_time.Year == 1 ?
                                                        "---" : item.last_update_time.ToString("dd/MM/yyyy HH:mm"))</span>
                    </div>
                </div>
            </div>
            @if (item.move_status < 1)
            {
                <div class="mt-6 flex justify-end">
                    <button type="button" onclick="confirmStockMove(@item.id)"
                        class="inline-flex items-center px-6 py-3 border border-transparent text-base font-bold rounded-lg shadow-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all dark:focus:ring-offset-gray-900">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24"
                            stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        @Html.Raw(L["ConfirmComplete"])
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmStockMove(id) {
            // 1. Hỏi xác nhận người dùng
            Notify.confirm(
                '@Html.Raw(L["ConfirmCompleteQuestion"])',
                '@Html.Raw(L["ConfirmCompleteWarning"])',
                '@Html.Raw(L["ConfirmNow"])'
            ).then((isConfirmed) => {
                if (isConfirmed) {
                    // 2. Lấy Token chống giả mạo
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    // 3. Gọi Backend
                    // Handler=Confirm sẽ map vào hàm OnPostConfirm
                    fetch(`?handler=Confirm&id=${id}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        }
                    })
                        .then(response => {
                            if (!response.ok) throw new Error('Network response was not ok');
                            return response.json();
                        })
                        .then(data => {
                            // --- ĐIỂM SỬA QUAN TRỌNG ---
                            // Backend trả về: { status: true, msg: "..." }
                            if (data.status) {
                                Notify.success(data.msg);
                                // Đợi 1 giây rồi load lại trang để cập nhật trạng thái mới
                                setTimeout(() => location.reload(), 1000);
                            } else {
                                Notify.error(data.msg || '@Html.Raw(L["ErrorOccurred"])');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            Notify.error('@Html.Raw(L["ConnectionError"])');
                        });
                }
            });
        }
    </script>
}