        async function saveNewGateway() {
            const gatewayName = newGatewayNameInput.value.trim();

            if (!gatewayName) {
                Notify.info('Vui lòng nhập tên cổng xuất');
                return;
            }

            if (!selectedWarehouseId) {
                Notify.info('Vui lòng chọn kho xuất trước');
                return;
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('?handler=QuickOutboundGateway', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        gatewayName: gatewayName,
                        warehouseId: Number(selectedWarehouseId)
