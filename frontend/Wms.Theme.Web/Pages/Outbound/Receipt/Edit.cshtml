         async function fetchPallets(keyword = '', pageIndex = 1) {
             if (palletSearchAbortController) {
                 palletSearchAbortController.abort();
             }
             palletSearchAbortController = new AbortController();
             try {
                 const keyWordParam = keyword?.trim()
                     ? `&keyword=${encodeURIComponent(keyword.trim())}`
                     : '';
                 const url = `?handler=SearchPallet${keyWordParam}&pageIndex=${pageIndex}`;
                 const response = await fetch(url, {
                     signal: palletSearchAbortController.signal
                 });
                 if (!response.ok) return null;
                 return await response.json();
             } catch (e) {
                 if (e.name === 'AbortError') return null;
                 console.error('Error fetching pallets:', e);
                 return [];
             }
         }

