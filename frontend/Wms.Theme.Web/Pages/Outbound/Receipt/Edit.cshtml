@page "{id:int}"
@model Wms.Theme.Web.Pages.Outbound.Receipt.EditModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Edit"];
    var currentStatus = Model.Receipt.Status;
}

@{
    Dictionary<int, string> palletStatus = new Dictionary<int, string>
    {
        { 1, Localizer["CreateReceipt_PalletStatusAvailable"] },
        { 2, Localizer["CreateReceipt_PalletStatusOccupied"] },
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
}

@Html.AntiForgeryToken()
<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <div class="flex items-center justify-start mb-2 pb-2">
        @await Html.PartialAsync("_StatusPartialView", currentStatus)
    </div>
    <div class="flex justify-end gap-3 mb-2 pb-2">
    <a href="/Outbound/Receipt/Detail/@Model.Receipt.Id"
           class="inline-block px-6 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors font-medium text-center">
        @Localizer["Common_Cancel"]
    </a>
   
    @if (Model.Receipt.Status == 0) 
    {
        <button type="button" onclick="saveReceipt(false)" 
                class="px-6 py-2 bg-blue-50 text-blue-700 border border-blue-200 rounded-md hover:bg-blue-100 transition-colors font-medium">
             @Html.Raw(Localizer["Save_Draft"])
        </button>

        <button type="button" onclick="saveReceipt(true)" 
                class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium flex items-center gap-2">
           @Html.Raw(Localizer["CreateReceipt_Save"])
        </button>
    }
</div>
</div>

<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">

        <div>
            <label for="receiptNumber" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptNumber"] <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   id="receiptNumber"
                   name="receiptNumber"
                   value="@Model.Receipt.ReceiptNo"
                   readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
        </div>

        <div>
            <label for="receiptDate" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptDate"] <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   id="receiptDate"
                   name="receiptDate"
                   value="@Model.Receipt.ReceiptDate?.ToString("dd/MM/yyyy")"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="issueType" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateOutboundReceipt_IssueType"]<span class="text-red-500">*</span>
            </label>
            <select id="issueType"
                    name="issueType"
                    class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
                <option value="SALES" selected="@(Model.Receipt.Type == "SALES")">@Localizer["CreateOutboundReceipt_IssueTypeSales"]</option>
                <option value="RETURN" selected="@(Model.Receipt.Type == "RETURN")">@Localizer["CreateOutboundReceipt_IssueTypeReturnSupplier"]</option>
                <option value="SCRAP" selected="@(Model.Receipt.Type == "SCRAP")">@Localizer["CreateOutboundReceipt_IssueTypeScrap"]</option>
                <option value="MISC" selected="@(Model.Receipt.Type == "MISC")">@Localizer["CreateOutboundReceipt_IssueTypeMisc"]</option>
            </select>
        </div>

        <div class="md:col-span-2">
            <label for="customerSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateOutboundReceipt_Customer"]  <span class="text-red-500">*</span>
            </label>
            <div class="flex">
                <div class="relative flex-1">
                    <input type="text"
                           id="customerSearch"
                           name="customerSearch"
                           autocomplete="off"
                           value="@Model.Receipt.CustomerName"
                           placeholder="@Localizer["CreateOutboundReceipt_CustomerSearchPlaceholder"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                    <ul id="customerDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto [&::-webkit-scrollbar]:w-1.5">
                    </ul>
                </div>
                <button type="button"
                        title="Tạo nhanh khách hàng"
                        onclick="openCustomerModal()"
                        class="px-2 py-1.5 bg-gray-50 border border-gray-300 border-l-0 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>
        <div>
            <label for="consignee" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["Consignee"]
            </label>
            <input type="text"
                   id="consignee"
                   name="consignee"
                   value="@Model.Receipt.Consignee"
                   placeholder="Người nhận hàng"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
        </div>
        <div class="md:col-span-2">
            <label for="warehouseSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateOutboundReceipt_Warehouse"] <span class="text-red-500">*</span> @Model.Receipt.WarehouseAddress
            </label>
            <div class="relative">
                <input type="text"
                       id="warehouseSearch"
                       autocomplete="off"
                       value="@Model.Receipt.WarehouseName"
                       placeholder="@Localizer["CreateOutboundReceipt_WarehouseSearchPlaceholder"]"
                       class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                <ul id="warehouseDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto [&::-webkit-scrollbar]:w-1.5">
                </ul>
            </div>
        </div>

        <div>
            <label for="gatewaySearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateOutboundReceipt_Gateway"]  <span class="text-red-500">*</span>
            </label>
            <div class="flex">
                <div class="relative flex-1">
                    <input type="text"
                           id="gatewaySearch"
                           name="gatewaySearch"
                           autocomplete="off"
                           value="@Model.Receipt.OutboundGatewayName"
                           placeholder="@Localizer["CreateOutboundReceipt_GatewaySearchPlaceholder"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                    <ul id="gatewayDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto">
                    </ul>
                </div>
                <button type="button"
                        title="Tạo nhanh cửa xuất"
                        onclick="openGatewayModal()"
                        class="px-2 py-1.5 bg-gray-50 border border-gray-300 border-l-0 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>

        <div>
            <label for="exportDate" class="block text-xs font-medium text-gray-700 mb-1">
                Thời gian dự kiến xuất hàng @Model.Receipt.ExpectedShipDate?.ToString("dd/MM/yyyy HH:mm")
            </label>
            <input type="text"
                   id="exportDate"
                   name="exportDate"
                   placeholder="dd/mm/yyyy HH:mm"
                   value="@Model.Receipt.ExpectedShipDate"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="pickingDate" class="block text-xs font-medium text-gray-700 mb-1">
                Thời gian bắt đầu picking @Model.Receipt.StartPickingTime?.ToString("dd/MM/yyyy HH:mm")
            </label>
            <input type="text"
                   id="pickingDate"
                   name="pickingDate"
                   placeholder="dd/mm/yyyy HH:mm"                  
                   value="@Model.Receipt.StartPickingTime"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div class="md:col-span-3">
            <label for="message" class="block mb-1 text-xs font-medium text-gray-700">
                @Localizer["AddNote"]
            </label>
            <textarea id="message"
                      name="message"
                      rows="2"
                      placeholder="@Localizer["EnterNote"]"
                      class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white resize-y">@Model.Receipt.Description</textarea>
        </div>

    </div>
</div>

<div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold text-gray-800">@Localizer["CreateOutboundReceipt_DetailHeader"]</h2>
    <button type="button" onclick="addRow()" class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 shadow-sm transition-colors flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
        @Localizer["CreateOutboundReceipt_AddRow"]
    </button>
</div>

<div id="myGrid" class="ag-theme-quartz" style="height: 400px; width: 100%;"></div>



<!-- Customer modal popup -->
@await Html.PartialAsync("Outbound/_CustomerModal")

<!--Outbound Gateway Modal-->
@await Html.PartialAsync("Outbound/_GatewayModal")

<!--Item search mo-->
@await Html.PartialAsync("Outbound/_SkuModal")

<!--Modal locations-->
@await Html.PartialAsync("Outbound/_LocationModal")

<!--Location Modal-->
@await Html.PartialAsync("Outbound/_OrderSearchModal")

<!--Pallet Modal-->
@await Html.PartialAsync("Outbound/_PalletModal")

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // Localized strings for JavaScript
        const L = {
                   colItemCode: '@Html.Raw(Localizer["CreateReceipt_ColItemCode"])',
                   colItemName: '@Html.Raw(Localizer["CreateReceipt_ColItemName"])',
                   colUom: '@Html.Raw(Localizer["CreateReceipt_ColUom"])',
                   colQuantity: '@Html.Raw(Localizer["CreateReceipt_ColQuantity"])',
                   colLocation: '@Html.Raw(Localizer["CreateReceipt_ColLocation"])',
                   colPalletCode: '@Html.Raw(Localizer["CreateReceipt_ColPalletCode"])',
                   colReference: '@Html.Raw(Localizer["CreateReceipt_ColReference"])',
                   colActions: '@Html.Raw(Localizer["CreateReceipt_ColActions"])',
                   noWarehouseFound: '@Html.Raw(Localizer["CreateReceipt_NoWarehouseFound"])',
                   noItemFound: '@Html.Raw(Localizer["CreateReceipt_NoItemFound"])',
                   searching: '@Html.Raw(Localizer["CreateReceipt_Searching"])',
                   clickToSearchItem: '@Html.Raw(Localizer["CreateReceipt_ClickToSearchItem"])',
                   loadingLocationMap: '@Html.Raw(Localizer["CreateReceipt_LoadingLocationMap"])',
                   locationLoadError: '@Html.Raw(Localizer["CreateReceipt_LocationLoadError"])',
                   noLocationData: '@Html.Raw(Localizer["CreateReceipt_NoLocationData"])',
                   locationEmpty: '@Html.Raw(Localizer["CreateReceipt_LocationEmpty"])',
                   searchingPallet: '@Html.Raw(Localizer["CreateReceipt_SearchingPallet"])',
                   noPalletFound: '@Html.Raw(Localizer["CreateReceipt_NoPalletFound"])',
                   select: '@Html.Raw(Localizer["Common_Select"])',
                   referenceBtn: '@Html.Raw(Localizer["CreateReceipt_ReferenceBtn"])',
                   orderDetailPrefix: '@Html.Raw(Localizer["CreateReceipt_OrderDetailPrefix"])',
                   deleteRowTitle: '@Html.Raw(Localizer["CreateReceipt_DeleteRowTitle"])',
                   validReceiptNo: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptNo"])',
                   validReceiptDate: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptDate"])',
                   validReceiptType: '@Html.Raw(Localizer["CreateReceipt_ValidReceiptType"])',
                   validWarehouse: '@Html.Raw(Localizer["CreateOutboundReceipt_SelectWarehouseFirst"])',
                   validAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidAtLeastOneItem"])',
                   saveSuccess: '@Html.Raw(Localizer["CreateOutboundReceipt_SaveSuccess"])',
                   saveFailed: '@Html.Raw(Localizer["CreateOutboundReceipt_SaveFailed"])',
                   connectionError: '@Html.Raw(Localizer["Common_ConnectionError"])',
                   validWhName: '@Html.Raw(Localizer["CreateReceipt_ValidWhName"])',
                   validWhCity: '@Html.Raw(Localizer["CreateReceipt_ValidWhCity"])',
                   validWhAddress: '@Html.Raw(Localizer["CreateReceipt_ValidWhAddress"])',
                   whSaveSuccess: '@Html.Raw(Localizer["CreateReceipt_WhSaveSuccess"])',
                   whSaveFailed: '@Html.Raw(Localizer["CreateReceipt_WhSaveFailed"])',
                   validSelectWhFirst: '@Html.Raw(Localizer["CreateReceipt_ValidSelectWhFirst"])',
                   palletGenerateError: '@Html.Raw(Localizer["CreateReceipt_PalletGenerateError"])',
                   palletNoResponse: '@Html.Raw(Localizer["CreateReceipt_PalletNoResponse"])',
                   palletCreatedAssigned: '@Html.Raw(Localizer["CreateReceipt_PalletCreatedAssigned"])',
                   palletCreated: '@Html.Raw(Localizer["CreateReceipt_PalletCreated"])',
                   validSelectAtLeastOneItem: '@Html.Raw(Localizer["CreateReceipt_ValidSelectAtLeastOneItem"])',
                   validWhContactTel: '@Html.Raw(Localizer["CreateReceipt_ValidWhContactTel"])',
                   validOutboundGateway : '@Html.Raw(Localizer["CreateOutboundReceipt_ValidWhOutboundGateway"])',
                   msgSearchingItems: '@Html.Raw(Localizer["CreateOutboundReceipt_SearchingItems"])',
                   noCustomerFound: '@Html.Raw(Localizer["CreateOutboundReceipt_NoCustomerFound"])',
                   noGatewayFound: '@Html.Raw(Localizer["CreateOutboundReceipt_NoGatewayFound"])',
                   selectItemBeforeLocation: '@Html.Raw(Localizer["CreateOutboundReceipt_SelectItemBeforeLocation"])',
                   validCustomerCodeAndName: '@Html.Raw(Localizer["CreateOutboundReceipt_ValidCustomerCodeAndName"])',
                   customerCodeExists: '@Html.Raw(Localizer["CreateOutboundReceipt_CustomerCodeExists"])',
                   customerAddedSuccess: '@Html.Raw(Localizer["CreateOutboundReceipt_CustomerAddedSuccess"])',
                   selectWarehouseFirst: '@Html.Raw(Localizer["CreateOutboundReceipt_SelectWarehouseFirst"])',
                   availableQtyAtLocation: '@Html.Raw(Localizer["CreateOutboundReceipt_AvailableQtyAtLocation"])',
                   virtualLocation :  '@Html.Raw(Localizer["VirtualLocation"])'
               };
    </script>
    <script>

        const receiptId = @Model.Receipt.Id;
        let selectedWarehouseId = @Model.Receipt.WarehouseId;
        let selectedCustomerId = @Model.Receipt.CustomerId;
        let selectedGatewayId = @Model.Receipt.OutboundGatewayId;
         // init flat pickr for date input
         document.addEventListener('DOMContentLoaded', function() {
            flatpickr("#receiptDate", {
                dateFormat: "d/m/Y",
                altInput: true,
                altFormat: "d/m/Y",
                defaultDate: "today",
                minDate: "today",
                allowInput: true,
            });

            flatpickr("#pickingDate", {
                dateFormat: "d/m/Y H:i",
                altInput: true,
                time_24hr: true,
                enableTime: true,
                altFormat: "d/m/Y H:i",
                defaultDate: "today",
                minDate: "today",
                allowInput: true,
            });

            flatpickr("#exportDate", {
                dateFormat: "d/m/Y H:i",
                altInput: true,
                time_24hr: true,
                enableTime: true,
                altFormat: "d/m/Y H:i",
                defaultDate: "today",
                minDate: "today",
                allowInput: true,
            });

             fetch('?handler=GenarationReceiptNo')
                .then(response => response.json())
                .then(result => {
                    const receiptNo = result?.receiptNo ?? result?.data?.receiptNo ?? result;
                    if (receiptNo) {
                        document.getElementById('receiptNumber').value = receiptNo;
                    }
                })
                .catch(error => console.error('Error generating receipt number:', error));
        });


        function debounce (fn , delay){
            let timer;
            return function (...args) {
                clearTimeout(timer);
                timer = setTimeout(() => fn.apply(this, args), delay);
            };
        }

        const searchInput = document.getElementById('warehouseSearch');
        const dropdown = document.getElementById('warehouseDropdown');
        
        let currentAbortController = null;

        async function fetchWarehouses(keyword = '' , pageIndex = 1)
        {
            if (currentAbortController) {
                currentAbortController.abort();
            }
            currentAbortController = new AbortController();
            try
            {
               const keyWordParam = keyword?.trim()
                     ? `&keyWord=${encodeURIComponent(keyword.trim())}`
                     : '';

               const url = `?handler=SearchWareHouse${keyWordParam}&pageIndex=${pageIndex}`;
               const response = await fetch(url , {
                        signal : currentAbortController.signal
               });
               if (!response.ok) {
                   return [];
               }
               return await response.json();
            } catch (e) {
               if (e.name === 'AbortError') {
                   return null;
               }
                console.error('Error fetching warehouses:', e);
                return [];
            }
        }


        function renderDropdown(data) {
            if(data === null){
                return;
            }
            if(!Array.isArray(data)){
                return
            }
            dropdown.innerHTML = '';
            if (data.length === 0) {
                dropdown.innerHTML = `<li class="px-4 py-2 text-gray-500 text-sm">${L.noWarehouseFound}</li>`;
                dropdown.classList.remove('hidden');
                return;
            }
            data.forEach(wh => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = `${wh.warehouseName}`
                li.onclick = () => {
                    searchInput.value = wh.warehouseName;
                    selectedWarehouseId = wh.id;
                    dropdown.classList.add('hidden');

                    gatewaySearchInput.value = "";
                    selectedGatewayId = null;
                };
                dropdown.appendChild(li);
            });
             dropdown.classList.remove('hidden');
        }

        const debouncedSearch = debounce(async function () {
            const data = await fetchWarehouses(searchInput.value);
            renderDropdown(data);
        }, 300);

        searchInput.addEventListener('input', debouncedSearch);

        searchInput.addEventListener('focus', async function () {
            if (!dropdown.classList.contains('hidden')) return; 
            const data = await fetchWarehouses(this.value);
            renderDropdown(data);
        });


        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });

        // customer handling searching and dropdown
        const customerSearchInput = document.getElementById('customerSearch');
        const customerDropdown = document.getElementById('customerDropdown');
        let customerAbortController = null;

        async function fetchCustomers(keyword = '' , pageIndex = 1) {
           if (customerAbortController) {
                customerAbortController.abort();
            }
            customerAbortController = new AbortController();
            try {
                const keyWordParam = keyword?.trim()
                    ? `&keyWord=${encodeURIComponent(keyword.trim())}`
                    : '';

                const url = `?handler=SearchCustomer${keyWordParam}&pageIndex=${pageIndex}`;
                const response = await fetch(url, {
                    signal: customerAbortController.signal
                });
                if (!response.ok) return [];
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') {
                    return null;
                }
                console.error('Error fetching customers:', e);
                return [];
            }
        }
        
         function renderCustomerDropdown(data) {
            if (data === null) {
                return;
            }
            if (!Array.isArray(data)) {
                return;
            }
            customerDropdown.innerHTML = '';
            if (data.length === 0) {
                customerDropdown.innerHTML = `<li class="px-4 py-2 text-gray-500 text-sm">${L.noCustomerFound}</li>`;
                customerDropdown.classList.remove('hidden');
                return;
            }
            data.forEach(cus => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = `${cus.customerName}`;
                li.onclick = () => {
                    customerSearchInput.value = cus.customerName;
                    selectedCustomerId = cus.id;
                    customerDropdown.classList.add('hidden');
                };
                customerDropdown.appendChild(li);
            });
            customerDropdown.classList.remove('hidden');
         }

         const debouncedCustomerSearch = debounce(async function () {
            const data = await fetchCustomers(customerSearchInput.value);
            renderCustomerDropdown(data);
         }, 300);

         customerSearchInput.addEventListener('input', function () {
            selectedCustomerId = null;
            debouncedCustomerSearch();
         });

         customerSearchInput.addEventListener('focus', async function () {
            if (!customerDropdown.classList.contains('hidden')) return;
            const data = await fetchCustomers(this.value);
            renderCustomerDropdown(data);
         });

         document.addEventListener('click', function (e) {
            if (!customerSearchInput.contains(e.target) && !customerDropdown.contains(e.target)) {
                customerDropdown.classList.add('hidden');
            }
         });


        // handle customer modal
        const customerModal = document.getElementById('customerModal');
        const newCusNameInput = document.getElementById('newCusName');
        const newCusCityInput = document.getElementById('newCusCity');
        const newCusAddressInput = document.getElementById('newCusAddress');
        const newCusManagerInput = document.getElementById('newCusManager');
        const newCusEmailInput = document.getElementById('newCusEmail');
        const newCusContactTelInput = document.getElementById('newCusContactTel');
                
         function openCustomerModal() {
            newCusNameInput.value = '';
            newCusCityInput.value = '';
            newCusAddressInput.value = '';
            newCusManagerInput.value = '';
            newCusEmailInput.value = '';
            newCusContactTelInput.value = '';

            customerModal.classList.remove('hidden');
            setTimeout(() => newCusNameInput.focus(), 100);
         }

         function closeCustomerModal() {
            customerModal.classList.add('hidden');
         }

         async function saveNewCustomer() {
            const name = newCusNameInput.value.trim();
            const city = newCusCityInput.value.trim();
            const address = newCusAddressInput.value.trim();
            const manager = newCusManagerInput.value.trim();
            const email = newCusEmailInput.value.trim();
            const contactTel = newCusContactTelInput.value.trim();

               if (!name) {
                    Notify.info(L.validCustomerCodeAndName);
                    return;
               }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch('?handler=AddCustomer', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                     body: JSON.stringify({
                         id: 0,
                         customerName: name,
                         city: city,
                         address: address,
                         manager: manager,
                         email: email,
                         contactTel: contactTel
                     })
                });

                const result = await response.json();

                if (!response.ok || !result?.success) {
                     Notify.info(result?.message || L.saveFailed);
                     return;
                 }

                selectedCustomerId = Number(result.id || 0);
                customerSearchInput.value = result.customerName ?? name;
                customerDropdown.classList.add('hidden');

                closeCustomerModal();
                Notify.info(result?.message || L.customerAddedSuccess);

            } catch (e) {
                console.error('saveNewCustomer error:', e);
                Notify.info(L.connectionError);
            }
        }

         const gatewaySearchInput = document.getElementById('gatewaySearch');
         const gatewayDropdown = document.getElementById('gatewayDropdown');
         let gatewayAbortController = null;

         async function fetchGateways(keyword = '', pageIndex = 1) {
            if (!selectedWarehouseId) {
                return null;
            }

            if (gatewayAbortController) {
                gatewayAbortController.abort();
            }
            gatewayAbortController = new AbortController();

            try {
                const keyWordParam = keyword?.trim()
                    ? `&keyWord=${encodeURIComponent(keyword.trim())}`
                    : '';

                const url = `?handler=SearchOutboundGateway${keyWordParam}&warehouseId=${selectedWarehouseId}&pageIndex=${pageIndex}`;
                const response = await fetch(url, {
                    signal: gatewayAbortController.signal
                });

                if (!response.ok) {
                    return [];
                }
                return await response.json();
            } catch (e) {
                if (e.name === 'AbortError') {
                    return null;
                }
                console.error('Error fetching gateways:', e);
                return [];
            }
         }


         function renderGatewayDropdown(data) {
            if (data === null) {
                return;
            }
            if (!Array.isArray(data)) {
                return;
            }
            gatewayDropdown.innerHTML = '';
            if (data.length === 0) {
                gatewayDropdown.innerHTML = `<li class="px-4 py-2 text-gray-500 text-sm">${L.noGatewayFound}</li>`;
                gatewayDropdown.classList.remove('hidden');
                return;
            }
            data.forEach(gw => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = gw.gatewayName;
                li.onclick = () => {
                    gatewaySearchInput.value = gw.gatewayName;
                    selectedGatewayId = gw.id;
                    gatewayDropdown.classList.add('hidden');
                };
                gatewayDropdown.appendChild(li);
            });
            gatewayDropdown.classList.remove('hidden');
         }

         const debouncedGatewaySearch = debounce(async function () {
            const data = await fetchGateways(gatewaySearchInput.value);
            renderGatewayDropdown(data);
         }, 300);

         gatewaySearchInput.addEventListener('input', function () {
            selectedGatewayId = null;
            debouncedGatewaySearch();
         });

         gatewaySearchInput.addEventListener('focus', async function () {
            if (!selectedWarehouseId) {
                Notify.info(L.selectWarehouseFirst);
                gatewayDropdown.classList.remove('hidden');
                return;
            }
            if (!gatewayDropdown.classList.contains('hidden')) return;
            const data = await fetchGateways(this.value);
            renderGatewayDropdown(data);
         });

