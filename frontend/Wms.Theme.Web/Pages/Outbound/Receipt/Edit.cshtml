            tip.id = 'loc-floating-tooltip';
            tip.innerHTML = `
                <div style="font-weight:700;color:#1d4ed8;font-size:13px;border-bottom:1px solid #e5e7eb;padding-bottom:6px;margin-bottom:6px;">${palletCode}</div>
