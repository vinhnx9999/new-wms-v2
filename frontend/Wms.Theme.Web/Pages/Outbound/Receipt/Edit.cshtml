         function renderPalletTable(response) {
             palletSearchResultBody.innerHTML = '';

             const data = response?.data?.rows ?? response?.rows ?? response;
             if (!Array.isArray(data) || data.length === 0) {
                 palletSearchResultBody.innerHTML = `
                     <tr>
                         <td colspan="3" class="px-6 py-4 text-center text-gray-500">
                              ${L.noPalletFound}
                         </td>
                     </tr>`;
                 return;
             }

             data.forEach(pallet => {
                 const statusText = palletStatusMap[pallet.palletStatus] ?? `Status ${pallet.palletStatus}`;
                 const isAvailable = pallet.palletStatus === 1;
                 const statusClass = isAvailable
                     ? 'bg-green-100 text-green-700'
                     : 'bg-yellow-100 text-yellow-700';

                 const formattedDate = pallet.createTime
                         ? new Date(pallet.createTime).toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' })
                         : '';

                 const tr = document.createElement('tr');
                 tr.className = "hover:bg-blue-50 transition-colors cursor-pointer";
                 tr.onclick = () => selectPallet(pallet.palletCode);
                 tr.innerHTML = `
                     <td class="hidden">${pallet.id}</td>
                     <td class="px-6 py-3 text-sm font-bold text-blue-700">${pallet.palletCode}</td>
                     <td class="px-6 py-3 text-sm text-gray-600">${formattedDate}</td>
                     <td class="px-6 py-3">
                         <span class="px-2 py-1 text-xs font-semibold rounded ${statusClass}">${statusText}</span>
                     </td>
                 `;
                 palletSearchResultBody.appendChild(tr);
             });
         }

         const debouncedPalletSearch = debounce(async function () {
