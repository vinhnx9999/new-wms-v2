        function parseTimeOfDMYToIso(dateStr) {
            if (!dateStr) return null;

            let partsTime = dateStr.split(' ');
            
            if(partsTime.length === 2) {
                const datePart = partsTime[0].trim();
                const timePart = partsTime[1].trim();
                const timeParts = timePart.split(':');

                if (timeParts.length !== 2) return null;
                const [hh, min] = timeParts.map(Number);
                if (Number.isNaN(hh) || Number.isNaN(min)) return null;
                const dateIso = parseDdMmYyyyToIso(datePart);
                if (!dateIso) return null;
                const dt = new Date(dateIso);
                dt.setHours(hh, min, 0, 0);
                if (Number.isNaN(dt.getTime())) return null;
                return dt.toISOString();
            }

            const parts = dateStr.split('/');
            if (parts.length === 3) {
                const [dd, mm, yyyy] = parts.map(Number);
                if (!dd || !mm || !yyyy) return null;
                const dt = new Date(yyyy, mm - 1, dd);
                if (Number.isNaN(dt.getTime())) return null;
                return dt.toISOString();
            }
            
            if (parts.length === 5) {
                const [dd, mm, yyyy, hh, min] = parts.map(Number);
                if (!dd || !mm || !yyyy) return null;
                const dt = new Date(yyyy, mm - 1, dd, hh, min, 0);
                if (Number.isNaN(dt.getTime())) return null;
                return dt.toISOString();
            }

            return null;
        }

        function parseDdMmYyyyToIso(dateStr) {
            if (!dateStr) return null;
            const parts = dateStr.split('/');
            if (parts.length !== 3) return null;

            const [dd, mm, yyyy] = parts.map(Number);
            if (!dd || !mm || !yyyy) return null;

            const dt = new Date(yyyy, mm - 1, dd);
            if (Number.isNaN(dt.getTime())) return null;

            return dt.toISOString();
        }

        async function saveReceipt(isDraft = false) 
        {
            try {
                gridApi.stopEditing();

                const receiptNo = document.getElementById('receiptNumber')?.value?.trim();
                const receiptDateText = document.getElementById('receiptDate')?.value?.trim();
                const issueType = document.getElementById('issueType')?.value;
                const outboundGatewayId = Number(selectedGatewayId || 0);
                const description = document.getElementById('message')?.value?.trim();
                const consignee = document.getElementById('consignee')?.value?.trim();
                const exportDate = document.getElementById('exportDate')?.value?.trim();
                const pickingDate = document.getElementById('pickingDate')?.value?.trim();

                if (!receiptNo) return Notify.info(L.validReceiptNo);
                if (!receiptDateText) return Notify.info(L.validReceiptDate);
                if (!issueType) return Notify.info(L.validReceiptType);
                if (!selectedWarehouseId) return Notify.info(L.validWarehouse);
                if(!outboundGatewayId) return Notify.info(L.validOutboundGateway)

                const details = [];
                gridApi.forEachNode(node => {
                    const d = node.data;
                    if (!d?.skuId) return;
                    if (!d?.qty || d.qty <= 0) return;

                    details.push({
                        id: isNaN(d.id) ? 0 : Number(d.id),
                        skuId: Number(d.skuId),
                        quantity: Number(d.qty),
                        skuUomId: Number(d.skuUomId || 0),
                        locationId: d.locationId ? Number(d.locationId) : null,
                        palletCode: d.pallet ? String(d.pallet) : null,
                        dispatchId: null 
                    });
                });

                if (details.length === 0) return Notify.info(L.validAtLeastOneItem);

                const payload = {
                    receiptNo: receiptNo,
                    warehouseId: Number(selectedWarehouseId),
                    outboundGatewayId: Number(selectedGatewayId || 0),
                    customerId: Number(selectedCustomerId || 0),
                    type: issueType,
                    expectedShipDate: parseTimeOfDMYToIso(exportDate),
                    startPickingTime: parseTimeOfDMYToIso(pickingDate),
                    receiptDate: parseDdMmYyyyToIso(receiptDateText),
                    description : description,
                    isUpgradeStatus : isDraft,
                    consignee: consignee,
                    details: details
                };

                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                const response = await fetch(`?handler=UpdateReceipt&id=@Model.Receipt.Id`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (!response.ok || !result?.success) {
                    Notify.info(result?.message || L.saveFailed);
                    return;
                }

                Notify.info(`${L.saveSuccess}`);
                // optionally redirect:
                window.location.href = '/Outbound/Receipt/Index';
            } catch (error) {
                console.error('saveReceipt error:', error);
                Notify.info(L.connectionError);
            }
        }


