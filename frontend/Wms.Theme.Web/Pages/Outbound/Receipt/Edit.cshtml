         async function quickCreatePalletCode() {
             try {
                 const response = await fetch('?handler=GeneratePalletCode');
                 if (!response.ok) {
                       Notify.info(L.palletGenerateError);
                     return;
                 }
                 const result = await response.json();
                 const newCode = result?.palletCode ?? result?.data?.palletCode;

                 if (!newCode) {
                     Notify.info(L.palletNoResponse);
                     return;
                 }

                 if (currentRowIdForPallet) {
                     const rowNode = gridApi.getRowNode(currentRowIdForPallet);
                     if (rowNode) {
                         rowNode.setDataValue('pallet', newCode);
                         rowNode.data.palletSource = 'manual';
                     }
                     closePalletSearchModal();
                     Notify.info(`${L.palletCreatedAssigned} ${newCode}`);
                 } else {
                     showPalletSearchLoading();
                     const data = await fetchPallets('');
                     renderPalletTable(data);
                     Notify.info(`${L.palletCreated} ${newCode}`);
                 }
                 } catch (error) {
                     console.error('Error generating pallet code:', error);
                     Notify.info(L.connectionError);
                 }
         }
    
