                     </td>
                     <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-700">${item.warehouseName ?? ''}</td>
                     <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-900 text-right font-mono">
                         ${(item.totalStock ?? 0)}
                     </td>
        
                     <td class="px-6 py-3 whitespace-nowrap text-sm font-bold text-right font-mono ">
                         ${(item.availableQty ?? 0)}
                     </td>
                 `;
                 itemSearchResultBody.appendChild(tr);
             });
          }

          function showItemSearchLoading(){
                itemSearchResultBody.innerHTML = `
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-gray-500">
                            <div class="flex justify-center items-center gap-2">
                                <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg"
                                    fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10"
                                            stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor"
                                        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                               @Html.Raw(L["Loading"])
                            </div>
                        </td>
                    </tr>`;
          }

         const scrollContainer = document.getElementById('scrollContainer');
         const scrollAnchor = document.getElementById('scroll-anchor');
         const loadingIndicator = document.getElementById('loading-indicator');
         const observerOptions = {
            root: scrollContainer,
            rootMargin: '0px 0px 100px 0px', 
            threshold: 0
         };

         const infiniteScrollObserver = new IntersectionObserver(async (entries) => {
            const target = entries[0];
    
          
            if (target.isIntersecting && !isFetching && hasMoreData) {
                isFetching = true;
                loadingIndicator.classList.remove('hidden');

                currentPage++;
              
                const keyword = itemSearchInput.value;

                const data = await fetchSkuItems(keyword, currentPage);
        
                if (data !== null) {
                    renderItemTable(data, true);
                }

                loadingIndicator.classList.add('hidden');
                isFetching = false;
            }
        }, observerOptions);

        
         infiniteScrollObserver.observe(scrollAnchor);

         const debouncedSkuSearch = debounce(async function () {
             isFetching = true;

             currentPage = 1;
             hasMoreData = true;
             showItemSearchLoading();
             
             try {
                 const keyword = itemSearchInput.value;
                 const data = await fetchSkuItems(keyword, currentPage);
                 if (data !== null) {
                    renderItemTable(data, false); 
                 }
             }
             finally {
                 isFetching = false;
             }
         }, 300);

         itemSearchInput.addEventListener('input', debouncedSkuSearch);

         function selectItem(skuId, code, name, uom , skuUomId , warehouseId, warehouseName) {
             if (!currentRowIdForItemSearch) return;

              if (warehouseId && warehouseName) {
                selectedWarehouseId = parseInt(warehouseId);
        
             
                const whInput = document.getElementById('warehouseSearch');
                if (whInput) {
                    whInput.value = warehouseName;
                }

                selectedGatewayId = null;
                const gatewayInput = document.getElementById('gatewaySearch');
                if(gatewayInput) gatewayInput.value = "";
            }

             const rowNode = gridApi.getRowNode(currentRowIdForItemSearch);
             if (rowNode) {
             
                 rowNode.setDataValue('availableQty', null); 
                 rowNode.setDataValue('qty', null);       
                 rowNode.setDataValue('location', '');      
                 rowNode.data.locationId = null;           
                 rowNode.setDataValue('pallet', '');        
                 rowNode.data.palletSource = null;

                 rowNode.setDataValue('itemCode', code);
                 rowNode.setDataValue('itemName', name);
                 rowNode.setDataValue('uom', uom);
                 rowNode.data.skuId = parseInt(skuId) || 0;
                 rowNode.data.skuUomId = parseInt(skuUomId) || 0;
               
             }
             closeItemSearchModal();
         }

         // Handle for Location Modal
        const locationSearchModal = document.getElementById('locationSearchModal');
        const locationGridContainer = document.getElementById('locationGridContainer');
        let currentRowIdForLocation = null;
        let locationFetchAbortController = null;

         function openLocationModal(rowNodeId) {
           
            const rowNode = gridApi.getRowNode(rowNodeId);
            const skuId = rowNode?.data?.skuId ?? 0;

            currentRowIdForLocation = rowNodeId;
            locationSearchModal.classList.remove('hidden');
            fetchLocationsFromServer(selectedWarehouseId, skuId);
        }

        function closeLocationModal() {
             hideLocationTooltip();
             locationSearchModal.classList.add('hidden');
             currentRowIdForLocation = null;
             if (locationFetchAbortController) {
                 locationFetchAbortController.abort();
                 locationFetchAbortController = null;
             }
        }

        async function fetchLocationsFromServer(warehouseId , skuId) {
            locationGridContainer.innerHTML = `
                <div class="col-span-full text-center text-gray-500 py-8 flex justify-center items-center gap-2">
                    <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        ${L.loadingLocationMap}
                </div>`;

            if(locationFetchAbortController) {
                locationFetchAbortController.abort();
            }

            locationFetchAbortController = new AbortController();
            try {
                    const url = `?handler=SearchLocationWithPallet&warehouseId=${encodeURIComponent(warehouseId)}&skuId=${encodeURIComponent(skuId)}`;
                    const response = await fetch(url, {
                        signal: locationFetchAbortController.signal
                    });

                    if (!response.ok){
                        locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">Lỗi tải dữ liệu vị trí.</div>`;
                        return;
                    }

                    const data = await response.json();

                    const mapped = (data ?? []).map(item => {
                        const hasPallet = item.palletCode && item.palletCode !== '';
                        const hasItems = (item.items && item.items.length > 0) || (item.currentQuantity > 0) || (item.availableQuantity > 0);

                        let status;
                        if (hasPallet) {
                            status = 'has-pallet';
                        } else if (hasItems) {
                            status = 'buffer';
                        } else {
                            status = 'empty';
                        }

                        return {
                            locationId: item.goodLocationId,
                            locCode: item.goodLocationName,
                            palletCode: item.palletCode || '',
                            items: item.items ?? [],
                            status: status,
                            availableQty: item.availableQuantity ?? 0,
                            qty: item.currentQuantity ?? 0,
                            isVirtual: item.virtualLocation ?? false,
                            skuId : item.skuId ?? 0,
                            itemCode: item.skuCode ?? '',
                            itemName: item.skuName ?? '',
                            stockName: item.warehouseName ?? ''
                        };
                    });

                    renderLocationBlocks(mapped);
            } catch (e) {
                if (e.name === 'AbortError') return;
                console.error('Error fetching locations:', e);
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-red-500 py-8">Lỗi kết nối, vui lòng thử lại.</div>`;
            }
        }

          function renderLocationBlocks(data) {
            locationGridContainer.innerHTML = '';

            if(!data || data.length === 0) {
                locationGridContainer.innerHTML = `<div class="col-span-full text-center text-gray-500 py-8">Không có dữ liệu vị trí từ Server.</div>`;
                return;
            }

            data.forEach(item => {
                const isEmpty = item.status === 'empty';
                const hasPallet = item.status === 'has-pallet';
                const isBuffer = item.status === 'buffer';

                const baseClass = "border-2 rounded-lg p-3 text-center transition-all duration-200 flex flex-col justify-center items-center relative cursor-pointer ";

                let styleClass;
                if (isEmpty) {
                    styleClass = "border-green-400 bg-green-50 hover:bg-green-100 hover:shadow-md hover:-translate-y-1 h-24";
                } else if (hasPallet) {
                    styleClass = "border-blue-400 bg-blue-50 hover:bg-blue-100 hover:shadow-md hover:-translate-y-1 h-24";
                } else if (isBuffer) {
                    styleClass = "border-yellow-400 bg-yellow-50 hover:bg-yellow-100 hover:shadow-md hover:-translate-y-1 h-24";
                } else {
                    styleClass = "border-gray-200 bg-gray-100 opacity-60 cursor-not-allowed h-24";
                }

                const block = document.createElement('div');
                block.className = baseClass + styleClass + " group";
               
                if (isEmpty || hasPallet || isBuffer) {
                   block.onclick = () => selectLocation(
                                            item.locationId, 
                                            item.locCode, 
                                            item.palletCode, 
                                            item.items, 
                                            item.skuId, 
                                            item.itemCode, 
                                            item.itemName, 
                                            item.availableQty, 
                                            item.qty
                                        );
                }

                 if ((hasPallet || isBuffer) && item.items && item.items.length > 0) {
                    const tipItems = item.items;
                    const tipLabel = hasPallet ? item.palletCode : L.virtualLocation;
                    block.addEventListener('mouseenter', e => showLocationTooltip(e, tipLabel, tipItems));
                    block.addEventListener('mouseleave', hideLocationTooltip);
                }

                let dotColor, nameColor, subColor, label;

                if(item.isVirtual) {
                    dotColor = 'bg-yellow-500';
                    nameColor = 'text-yellow-700';
                    subColor = 'text-yellow-600';
                    label = L.virtualLocation;
                }
                else if (isEmpty) {
                    dotColor = 'bg-green-500';
                    nameColor = 'text-green-700';
                    subColor = 'text-green-600';
                    label = 'Trống';
                } else if (hasPallet) {
                    dotColor = 'bg-blue-500';
                    nameColor = 'text-blue-700';
                    subColor = 'text-blue-600';
                    label = item.palletCode;
                } else {
