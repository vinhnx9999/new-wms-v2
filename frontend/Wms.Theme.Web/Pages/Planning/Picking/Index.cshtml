@page
@model Wms.Theme.Web.Pages.Planning.Picking.IndexModel
@{
    ViewData["Title"] = @L["PickingList"];
    var hasRows = Model.PickingList != null && Model.PickingList.Any();
}
@Html.AntiForgeryToken()
<div id="gridPicking" style="height: calc(100vh - 240px); width:100%;" class="ag-theme-alpine"></div>
@if (hasRows)
{
    <div class="flex justify-end gap-3 mt-3 mb-2">
        <button type="button" onclick="getSelectedData()" class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium">
            @L["Save"]
        </button>
    </div>
}

<script>
    const columnDefs = [
        { headerName: '@Html.Raw(L["ReceiptNo"])', field: "ReceiptNo", sortable: true, filter: true,
            cellRenderer: params => {
                if (!params.data) return '';
                let title = params.data.IsOverdue ? "Overdue" : ""
                let cssRow = params.data.IsOverdue ? 
                    "text-orange-600 dark:text-orange-400 text-red-700"
                    : "text-gray-700 dark:text-gray-500";
              
                return `<a title="${title}" href="/Outbound/Receipt/Detail/${params.data.ReceiptId}" class="hover:underline font-bold ${cssRow}">${params.value || ''}</a>`;

            }
        },
        { headerName: '@Html.Raw(L["SKU"])', field: "SkuCode", sortable: true, filter: true },
        { headerName: '@Html.Raw(L["SkuName"])', field: "SkuName", sortable: true, filter: true },
        {
                headerName: '@Html.Raw(L["TotalQuantity"])',
                field: "Quantity",
                width: 120,
                cellClass: 'text-right font-semibold text-blue-700',
        },
        { headerName: '@Html.Raw(L["Unit"])', field: "UnitName", sortable: true, filter: true },
        { headerName: '@Html.Raw(L["Location"])', field: "LocationName", sortable: true, filter: true },
        { headerName: '@Html.Raw(L["ExpectedShipDate"])', field: "StartPickingTimer", sortable: true, filter: true},        
    ];

    // Serialize Razor model into JSON
    const rowData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PickingList));
    const gridOptions = {
        columnDefs: columnDefs,
        rowData: rowData,
        pagination: true,
        defaultColDef: {
          resizable: true,
          flex: 1
        },
        rowSelection: {
          mode: "multiRow",
        },
    };

    let gridApi;

    document.addEventListener('DOMContentLoaded', () => {
         const gridDiv = document.querySelector('#gridPicking');
         gridApi = agGrid.createGrid(gridDiv, gridOptions);
    });
        
    async function getSelectedData() {
      const selectedRows = gridApi.getSelectedRows();
      
      if((selectedRows?? []).length < 1) {
          Notify.warning('@Html.Raw(L["PleaseSelectAtLeastOneRow"])');
          return;
      }       

      try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('?handler=AddPicking', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                     body: JSON.stringify({ PickingList: selectedRows ?? [] })

                });

                const result = await response.json();

                 if (!response.ok || !result?.success) {
                     Notify.error('@Html.Raw(L["OperationFailed"])');
                     return;
                 }

                 Notify.success('@Html.Raw(L["OperationSuccessful"])');

            } catch (e) {
                console.error('savePlanning Picking error:', e);
                Notify.error('@Html.Raw(L["OperationFailed"])');
            }
    }

    
</script>