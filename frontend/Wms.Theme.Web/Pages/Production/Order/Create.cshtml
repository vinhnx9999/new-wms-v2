@page
@model Wms.Theme.Web.Pages.Production.Order.CreateModel
@{
}

<h2 class="text-lg font-semibold text-gray-800 mb-4 pb-2">Thông tin Lệnh Sản Xuất</h2>
<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6">  
    <div class="flex flex-col gap-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label for="receiptNumber" class="block text-sm font-medium text-gray-700 mb-1">
                    Mã Lệnh <span class="text-red-500">*</span>
                </label>
                <input type="text" 
                       id="receiptNumber" 
                       name="receiptNumber" 
                       placeholder="PN-2023-001"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
            </div>

            <div>
                <label for="receiptDate" class="block text-sm font-medium text-gray-700 mb-1">
                    Ngày tạo lệnh <span class="text-red-500">*</span>
                </label>
                <input type="text"
                       id="receiptDate"
                       name="receiptDate"
                       placeholder="dd/mm/yyyy"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
            </div>
        </div>
        <div> 
            <label for="warehouseSearch" class="block text-sm font-medium text-gray-700 mb-1">
                Kho Sản Xuất <span class="text-red-500">*</span>
            </label>
            <div class="flex">
                <div class="relative flex-1">
                    <input type="text" 
                           id="warehouseSearch" 
                           autocomplete="off"
                           placeholder="Tìm kiếm kho"
                           class="w-full px-4 py-2 border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                    
                    <ul id="warehouseDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto">
                    </ul>
                </div>

            </div>
        </div>
           <div>
            <label for="transferNote" class="block text-sm font-medium text-gray-700 mb-1">
                Ghi chú
            </label>
            <textarea id="transferNote"
                      name="transferNote"
                      rows="3"
                      placeholder="Nhập ghi chú sản xuất"
                      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors resize-y"></textarea>
        </div>  

    </div>
</div>

<h2 class="text-lg font-semibold text-gray-800 mb-4 pb-2">Thành phẩm dự kiến</h2>
<div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 mb-6">
    <div class="flex flex-col gap-5">

        <div>
            <label for="productSearch" class="block text-sm font-medium text-gray-700 mb-1">
                Thành phẩm cần sản xuất <span class="text-red-500">*</span>
            </label>
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text"
                       id="productSearch"
                       name="productSearch"
                       readonly
                       onclick="openItemSearchModal('HEADER')"
                       placeholder="Nhấn để tìm và chọn thành phẩm..."
                       class="w-full pl-10 px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white cursor-pointer hover:bg-gray-50">
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            <div>
                <label for="targetQuantity" class="block text-sm font-medium text-gray-700 mb-1">
                    Số lượng mục tiêu <span class="text-red-500">*</span>
                </label>
                <input type="number"
                       id="targetQuantity"
                       name="targetQuantity"
                       min="1"
                       placeholder="0"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
            </div>

            <div>
                <label for="uom" class="block text-sm font-medium text-gray-700 mb-1">
                    Đơn vị tính
                </label>
                <input type="text"
                       id="uom"
                       name="uom"
                       readonly
                       placeholder="VD: Pallet, Thùng..."
                       class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-50 text-gray-500 focus:outline-none cursor-not-allowed">
            </div>

            <div class="flex flex-col">
                <label for="bomVersion" class="block text-sm font-medium text-gray-700 mb-1">
                    Phiên bản định mức (BOM)
                </label>
                <div class="flex gap-2">
                    <div class="flex-1">
                        <select id="bomVersion"
                                name="bomVersion"
                                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
                            <option value="">Chọn BOM</option>
                        </select>
                    </div>

                    <div class="relative group">
                        <button type="button"
                                onclick="openQuickCreateBom()"
                                class="p-2.5 bg-gray-100 text-gray-600 border border-gray-300 rounded-md hover:bg-blue-50 hover:text-blue-600 hover:border-blue-300 transition-all focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                            </svg>
                        </button>

                        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover:block w-max px-2 py-1 bg-gray-800 text-white text-xs rounded shadow-lg">
                            Tạo nhanh BOM mới
                            <div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-gray-800"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex justify-end mt-2 pt-4 border-t border-gray-100">
            <button type="button"
                    id="btnLoadBom"
                    class="flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors shadow-sm disabled:bg-gray-400 disabled:cursor-not-allowed">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path>
                </svg>
                Tính Toán & Nạp Vật Tư
            </button>
        </div>

    </div>
</div>

<div class="flex justify-between items-center mb-4 mt-6">
    <h2 class="text-md font-semibold text-gray-700">Chi tiết nguyên vật liệu xuất kho</h2>
    <div class="flex gap-2">
        <button type="button" 
                onclick="openItemSearchModal('GRID')"
                class="flex items-center gap-2 px-3 py-1.5 bg-white border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition-all text-sm font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Thêm vật tư ngoài BOM
        </button>
    </div>
</div>

<div id="myGrid" class="ag-theme-quartz" style="height: 400px; width: 100%;"></div>

<div class="flex justify-end gap-3 mt-6 border-t pt-4">
    <button type="button" class="px-6 py-2 border border-gray-300 rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors font-medium">
        Hủy bỏ
    </button>
    <button type="button" onclick="saveReceipt()" class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 shadow-md transition-colors font-medium">
        Lưu phiếu nhập
    </button>
</div>



<!-- Modal Add Warehouse -->
<div id="warehouseModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 transform transition-all">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">Thêm kho nhập mới</h3>
            <button type="button" onclick="closeWarehouseModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        
        <div class="px-6 py-4 space-y-4">
            <div>
                <label for="newWhCode" class="block text-sm font-medium text-gray-700 mb-1">Mã kho <span class="text-red-500">*</span></label>
                <input type="text" id="newWhCode" placeholder="VD: WH05" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label for="newWhName" class="block text-sm font-medium text-gray-700 mb-1">Tên kho <span class="text-red-500">*</span></label>
                <input type="text" id="newWhName" placeholder="VD: Kho Vật Tư Phụ" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
        </div>
        
        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3 bg-gray-50 rounded-b-lg">
            <button type="button" onclick="closeWarehouseModal()" class="px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                Hủy
            </button>
            <button type="button" onclick="saveNewWarehouse()" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-sm transition-colors">
                Lưu kho
            </button>
        </div>
    </div>
</div>

<!--Modal search Sku Item-->
<div id="itemSearchModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl mx-4 transform transition-all flex flex-col" style="max-height: 90vh;">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">Tìm kiếm & Chọn hàng hóa</h3>
            <button type="button" onclick="closeItemSearchModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        
        <div class="px-6 py-4 flex flex-col flex-1 overflow-hidden">
            <div class="mb-4 relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                    </svg>
                </div>
                <input type="text" id="itemSearchInput" 
                       placeholder="Gõ mã hàng hoặc tên hàng hóa để tìm kiếm" 
                       class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="flex-1 overflow-y-auto border border-gray-200 rounded-md">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50 sticky top-0">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mã Hàng</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tên Hàng Hóa</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ĐVT</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nhà Cung Cấp</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itemSearchResultBody" class="bg-white divide-y divide-gray-200">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>



<div id="quickCreateBomModal" class="fixed inset-0 z-40 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl mx-4 transform transition-all flex flex-col" style="max-height: 90vh;">
        
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200 bg-gray-50 rounded-t-lg">
            <h3 class="text-lg font-semibold text-gray-800">Tạo nhanh Định mức (BOM)</h3>
            <button type="button" onclick="closeQuickCreateBom()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        
        <div class="px-6 py-4 flex-1 overflow-y-auto">
            <div class="grid grid-cols-2 gap-5 mb-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Thành phẩm đích</label>
                    <input type="text" id="newBomProduct" readonly class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-600 cursor-not-allowed">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tên phiên bản BOM mới <span class="text-red-500">*</span></label>
                    <input type="text" id="newBomName" placeholder="VD: BOM Sản xuất Tháng 5..." class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>

            <div class="flex justify-between items-center mb-2">
                <label class="block text-sm font-medium text-gray-700">Công thức Nguyên Vật Liệu</label>
                <button type="button" onclick="openItemSearchModal('QUICK_BOM')" class="px-3 py-1.5 bg-blue-50 text-blue-700 border border-blue-100 rounded hover:bg-blue-100 transition-colors text-sm font-medium flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Thêm nguyên liệu
                </button>
            </div>
            
            <div class="border border-gray-200 rounded-md overflow-hidden">
                <table class="w-full text-sm text-left">
                    <thead class="bg-gray-50 text-gray-600 border-b">
                        <tr>
                            <th class="px-4 py-2 font-medium">Mã VT</th>
                            <th class="px-4 py-2 font-medium">Tên vật tư</th>
                            <th class="px-4 py-2 font-medium text-center">ĐVT</th>
                            <th class="px-4 py-2 font-medium w-32">SL Định mức / 1 SP</th>
                            <th class="px-4 py-2 font-medium text-center w-16">Xóa</th>
                        </tr>
                    </thead>
                    <tbody id="quickBomMaterialsBody" class="divide-y divide-gray-100">
                        <tr id="quickBomEmptyState">
                            <td colspan="5" class="px-4 py-8 text-center text-gray-500">Chưa có vật tư nào. Nhấn "Thêm nguyên liệu" để bắt đầu.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3 bg-gray-50 rounded-b-lg">
            <button type="button" onclick="closeQuickCreateBom()" class="px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                Hủy
            </button>
            <button type="button" onclick="saveQuickBom()" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-sm transition-colors">
                Lưu & Chọn BOM
            </button>
        </div>
    </div>
</div>
@section Scripts{

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        
        // init flat pickr for date input
        document.addEventListener('DOMContentLoaded', function() {
            flatpickr("#receiptDate", {
                dateFormat: "d/m/Y",
                altInput: true,
                altFormat: "d/m/Y",
                defaultDate: "today",
                minDate: "today",
                allowInput: true,
            });
        });
    

        // mock data for warehouses
        const warehouses = [
            { id: "WH01", name: "Kho Tổng Miền Bắc" },
            { id: "WH02", name: "Kho Trung Chuyển Hà Nội" },    
            { id: "WH03", name: "Kho Tổng Miền Nam" },
            { id: "WH04", name: "Kho Hàng Lỗi (Defect)" }
        ];

        // mock data for products
        const mockProducts = [
            { itemCode: 'SP-001', itemName: 'Pallet Gỗ Xuất Khẩu', uom: 'Pallet', supplierName: 'Xưởng Gỗ A', availableQty: 50, boms: [{ id: 'BOM-01', name: 'BOM Tiêu chuẩn' }] },
            { itemCode: 'SP-002', itemName: 'Thùng Carton Đóng Hàng', uom: 'Thùng', supplierName: 'Bao Bì B', availableQty: 120, boms: [{ id: 'BOM-02', name: 'BOM Loại A' }, { id: 'BOM-03', name: 'BOM Loại B' }] },
            { itemCode: 'SP-003', itemName: 'Kệ sắt V lỗ', uom: 'Bộ', supplierName: 'Xưởng Cơ Khí', availableQty: 10, boms: [] },
            // Thêm vài nguyên liệu để test nút "Thêm vật tư ngoài BOM"
            { itemCode: 'RM-001', itemName: 'Gỗ thông tấm', uom: 'm3', supplierName: 'Xưởng Gỗ A', availableQty: 300, boms: [] },
            { itemCode: 'RM-002', itemName: 'Đinh vít 5 phân', uom: 'Cái', supplierName: 'Nhà máy C', availableQty: 5000, boms: [] },
            { itemCode: 'RM-009', itemName: 'Băng keo trong', uom: 'Cuộn', supplierName: 'Nhà máy C', availableQty: 150, boms: [] }
        ];

        const mockBomDetails = {
            'BOM-01': [
                { itemCode: 'RM-001', itemName: 'Gỗ thông tấm', uom: 'm3', qtyPerUnit: 0.05, availableQty: 100 }, // Thêm tồn kho 100
                { itemCode: 'RM-002', itemName: 'Đinh vít 5 phân', uom: 'Cái', qtyPerUnit: 20, availableQty: 5000 }, // Thêm tồn kho 5000
                { itemCode: 'RM-003', itemName: 'Sơn bóng PU', uom: 'Lít', qtyPerUnit: 0.2, availableQty: 50 } // Thêm tồn kho 50
            ],
            'BOM-02': [
                { itemCode: 'RM-004', itemName: 'Giấy Kraft cuộn', uom: 'kg', qtyPerUnit: 1.5, availableQty: 200 },
                { itemCode: 'RM-005', itemName: 'Keo dán công nghiệp', uom: 'kg', qtyPerUnit: 0.1, availableQty: 15 }
            ],
            'BOM-03': [
                { itemCode: 'RM-004', itemName: 'Giấy Kraft cuộn', uom: 'kg', qtyPerUnit: 1.2, availableQty: 200 },
                { itemCode: 'RM-006', itemName: 'Mực in đen', uom: 'ml', qtyPerUnit: 5, availableQty: 0 } // Cố tình để 0 để test màu đỏ
            ]
        };

        const searchInput = document.getElementById('warehouseSearch');
        const dropdown = document.getElementById('warehouseDropdown');

        // Render dropdown items based on filtered data
        function renderDropdown(data) {
            dropdown.innerHTML = '';
            if (data.length === 0) {
                dropdown.innerHTML = '<li class="px-4 py-2 text-gray-500 text-sm">Không tìm thấy kho...</li>';
                return;
            }
            data.forEach(wh => {
                const li = document.createElement('li');
                li.className = "px-4 py-2 hover:bg-blue-50 cursor-pointer text-sm border-b last:border-b-0";
                li.textContent = `${wh.id} - ${wh.name}`;
                li.onclick = () => {
                    searchInput.value = wh.name; 
                    dropdown.classList.add('hidden'); 
                };
                dropdown.appendChild(li);
            });
        }

        searchInput.addEventListener('input', function() {
            const keyword = this.value.toLowerCase();
            const filtered = warehouses.filter(w => 
                w.name.toLowerCase().includes(keyword) || w.id.toLowerCase().includes(keyword)
            );
            renderDropdown(filtered);
            dropdown.classList.remove('hidden');
        });

       
        searchInput.addEventListener('focus', function() {
            renderDropdown(warehouses);
            dropdown.classList.remove('hidden');
        });

     
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.classList.add('hidden');
            }
        });


        // handle for SEARCH SKU
        let currentTargetForSearch = null;
        let selectedHeaderProduct = null;

        const itemSearchModal = document.getElementById('itemSearchModal');
        const itemSearchInput = document.getElementById('itemSearchInput');
        const itemSearchResultBody = document.getElementById('itemSearchResultBody');

        function openItemSearchModal(target) {
            currentTargetForSearch = target; 
            itemSearchInput.value = '';
            renderItemTable(mockProducts);
            itemSearchModal.classList.remove('hidden');
            setTimeout(() => itemSearchInput.focus(), 100);
        }

        function closeItemSearchModal() {
            itemSearchModal.classList.add('hidden');
            currentRowIdForItemSearch = null;
        }

        function renderItemTable(data) {
            itemSearchResultBody.innerHTML = '';
            if(data.length === 0) {
                itemSearchResultBody.innerHTML = `<tr><td colspan="5" class="px-6 py-4 text-center text-gray-500">Không tìm thấy hàng hóa nào phù hợp.</td></tr>`;
                return;
            }

            data.forEach(item => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-blue-50 transition-colors";
                tr.innerHTML = `
                    <td class="px-6 py-3 whitespace-nowrap text-sm font-medium text-gray-900">${item.itemCode}</td>
                    <td class="px-6 py-3 text-sm text-gray-700">${item.itemName}</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-500">${item.uom}</td>
                    <td class="px-6 py-3 whitespace-nowrap text-sm text-blue-600 font-medium">${item.supplierName}</td>
                    <td class="px-6 py-3 whitespace-nowrap text-right text-sm font-medium">
                        <button type="button" onclick="selectItem('${item.itemCode}', '${item.itemName}', '${item.uom}')" class="bg-blue-100 text-blue-700 px-3 py-1 rounded hover:bg-blue-200">
                            Chọn
                        </button>
                    </td>
                `;
                itemSearchResultBody.appendChild(tr);
            });
        }

        itemSearchInput.addEventListener('input', function() {
            const keyword = this.value.toLowerCase();
            const filtered = mockProducts.filter(p => 
                p.itemCode.toLowerCase().includes(keyword) || 
                p.itemName.toLowerCase().includes(keyword) ||
                p.supplierName.toLowerCase().includes(keyword)
            );
            renderItemTable(filtered);
        });

       function selectItem(itemCode) {
            if (!currentTargetForSearch) return;

            const item = mockProducts.find(p => p.itemCode === itemCode);

            if (!item) return;
            if (currentTargetForSearch === 'HEADER') {
                selectedHeaderProduct = item; 
        
                document.getElementById('productSearch').value = `${item.itemCode} - ${item.itemName}`;
        
                document.getElementById('uom').value = item.uom;
        
                const bomSelect = document.getElementById('bomVersion');
                bomSelect.innerHTML = '<option value="">Chọn BOM </option>'; 
        
                if (item.boms && item.boms.length > 0) {
                    item.boms.forEach(b => {
                        bomSelect.innerHTML += `<option value="${b.id}">${b.name}</option>`;
                    });
                    if (item.boms.length === 1) {
                        bomSelect.value = item.boms[0].id;
                    }
                } else {
                    bomSelect.innerHTML = '<option value="">SP Không có BOM</option>';
                }
            } 
            else if (currentTargetForSearch === 'GRID') {
                    const newItem = {
                        id: Math.random().toString(36).substr(2, 9),
                        itemCode: item.itemCode,
                        itemName: item.itemName,
                        uom: item.uom,
                        availableQty: item.availableQty || 0,
                        qty: 1, 
                        location: "",
                        pallet: ""
                    };

                gridApi.applyTransaction({ add: [newItem] });

                gridApi.ensureIndexVisible(gridApi.getDisplayedRowCount() - 1);
            }
            else if (currentTargetForSearch === 'QUICK_BOM') {
                const tbody = document.getElementById('quickBomMaterialsBody');
                const emptyState = document.getElementById('quickBomEmptyState');
                
                // Chống thêm trùng vật tư
                if (document.querySelector(`.quick-bom-row[data-code="${item.itemCode}"]`)) {
                    alert("Vật tư này đã có trong danh sách BOM!");
                    closeItemSearchModal();
                    return;
                }

                if (emptyState) emptyState.remove();

                const tr = document.createElement('tr');
                tr.className = "quick-bom-row hover:bg-gray-50 border-b";
                tr.dataset.code = item.itemCode;
                tr.innerHTML = `
                    <td class="px-4 py-3 font-medium text-blue-600">${item.itemCode}</td>
                    <td class="px-4 py-3 text-gray-700">${item.itemName}</td>
                    <td class="px-4 py-3 text-center text-gray-500">${item.uom}</td>
                    <td class="px-4 py-3">
                        <input type="number" min="0.001" step="any" placeholder="Nhập SL" class="bom-qty-input w-full px-2 py-1.5 border border-gray-300 rounded text-right focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </td>
                    <td class="px-4 py-3 text-center">
                        <button type="button" onclick="this.closest('tr').remove(); checkEmptyQuickBom();" class="text-red-500 hover:text-red-700">
                            <svg class="w-5 h-5 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            }
    
            closeItemSearchModal();
       }

        // global state
        let gridApi; 
        const columnDefs = [
            { 
                headerName: "Mã Hàng", 
                field: "itemCode", 
                flex: 1.5, 
                editable: false, 
                cellClass: 'hover:bg-blue-50 transition-colors cursor-pointer',
                cellRenderer: function(params) {
                    const displayValue = params.value ? params.value : '';
                    return `
                        <div class="flex items-center w-full h-full">
                            <div class="truncate pr-2">${displayValue}</div>   
                        </div>
                    `;
                }
            },
            { 
                headerName: "Tên Hàng Hóa", 
                field: "itemName", 
                flex: 2, 
                editable: false, 
                wrapText : true,
                autoHeight : true,
                cellClass: 'py-3 px-3 leading-tight'
            },
            { 
                headerName: "ĐVT", 
                field: "uom", 
                flex: 1, 
                editable: false , 
                cellRenderer: function(params) {
                    return `<div class="flex items-center h-full w-full">${params.value || ''}</div>`;
                }
            },
            { 
                headerName: "SL Khả dụng", 
                field: "availableQty", 
                flex: 1,
                type: 'numericColumn',
                cellClass: 'text-right font-medium text-green-600 bg-gray-50', // Màu xanh, nền xám nhẹ để báo hiệu chỉ đọc
                valueFormatter: params => params.value ? params.value.toLocaleString() : '0'
            },
            { 
                headerName: "Số lượng", 
                field: "qty", 
                flex: 1, 
                editable: true, 
                cellEditor: 'agNumberCellEditor' , 

                cellEditorParams: {
                    min: 0.001,   
                    step: 'any',  
                },

                valueParser: function(params) {
                    const num = parseFloat(params.newValue);
                    if (isNaN(num) || num <= 0) {
                        return null;
                    }
                    return num;
                },

                cellClass: 'bg-blue-50 border border-blue-100 cursor-text font-semibold text-blue-700',
                cellRenderer: function(params) {
                    const val = params.value !== undefined && params.value !== null ? params.value : '';
                    return `<div class="flex items-center h-full w-full">${val}</div>`;
                }
            },
            { 
                headerName: "Vị trí", 
                field: "location", 
                width: 150, 
                editable: false, 
                hide: true, 
                cellClass: 'hover:bg-yellow-100 transition-colors cursor-pointer',
                cellRenderer: function(params) {
                    const val = params.value || '<span class="text-gray-400 italic"></span>';
                    return `
                        <div class="flex justify-between items-center w-full h-full" onclick="openLocationModal('${params.node.id}')">
                            <span class="${params.value ? 'font-medium text-blue-700' : ''}">${val}</span>
                             <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                 <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                 <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                             </svg>
                        </div>`;
                }
            },
            {
                headerName: "Mã Pallet",
                field: "pallet",
                width: 150,
                editable: false,
                hide: true,
                cellRenderer: function(params) {
                    const val = params.value || '';
                    return `<div class="flex items-center h-full w-full">
                                <span class="font-medium text-gray-700">${val}</span>
                            </div>`;
                }
            },
            {
                headerName: "Thao tác",
                width: 100,
                sortable: false,
                filter: false,
                cellRenderer: function(params) {
                    return `
                        <button type="button" onclick="deleteRow('${params.node.id}')" class="text-red-500 hover:text-red-700 flex items-center justify-center w-full h-full" title="Xóa dòng này">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>`;
                }
            }
        ];

        const rowData = [
            { id: "row-init"  ,itemCode: "", itemName: "", uom: "", qty: null }
        ];

        const gridOptions = {
            columnDefs: columnDefs,
            rowData: rowData,

            getRowId: params => params.data.id ,
            pagination: true,
            paginationPageSize: 20,

            singleClickEdit: true,
            stopEditingWhenCellsLoseFocus: true
        };

        function addRow() {
            const newRecord = { 
                id: Math.random().toString(36).substr(2, 9), 
                itemCode: "", 
                itemName: "", 
                availableQty: 0,
                uom: "", 
                qty: null , 
                referenceCode : ""
            };
            gridApi.applyTransaction({ add: [newRecord] });
        }

        function deleteRow(nodeId) {
            const rowNode = gridApi.getRowNode(nodeId);
            if(rowNode) {
                gridApi.applyTransaction({ remove: [rowNode.data] });
            }
        }

        function loadBomToGrid() {
            const targetQty = parseFloat(document.getElementById('targetQuantity').value);
            const bomId = document.getElementById('bomVersion').value;

            if (!selectedHeaderProduct) {
                Notify.info("Vui lòng chọn thành phẩm trước!");
                return;
            }
            if (!targetQty || targetQty <= 0) {
                Notify.info("Vui lòng nhập số lượng mục tiêu hợp lệ!");
                document.getElementById('targetQuantity').focus();
                return;
            }
            if (!bomId) {
                Notify.info("Vui lòng chọn phiên bản BOM!");
                return;
            }
            
            const materials = mockBomDetails[bomId];
            
            if (!materials || materials.length === 0) {
                Notify.info("Không tìm thấy thông tin định mức cho BOM này!");
                return;
            }

            const rowDataToLoad = materials.map(m => {
                return {
                    id: Math.random().toString(36).substr(2, 9),
                    itemCode: m.itemCode,
                    itemName: m.itemName,
                    uom: m.uom,
                    availableQty: m.availableQty || 0,
                    qty: m.qtyPerUnit * targetQty, 
                    location: "", 
                    pallet: ""
                };
            });

            gridApi.setGridOption('rowData', rowDataToLoad);

            // Thông báo cho user
            console.log(`Đã nạp ${rowDataToLoad.length} nguyên liệu từ ${bomId}`);
        }


        document.addEventListener('DOMContentLoaded', function () {
            const gridDiv = document.querySelector('#myGrid');
            gridApi = agGrid.createGrid(gridDiv, gridOptions);

            // Gán sự kiện nạp BOM
            document.getElementById('btnLoadBom').addEventListener('click', loadBomToGrid);
        });

        function openQuickCreateBom() {
            if (!selectedHeaderProduct) {
                alert("Vui lòng chọn Thành phẩm cần sản xuất trước khi tạo BOM!");
                return;
            }
            
            // Gán sẵn tên thành phẩm vào readonly input
            document.getElementById('newBomProduct').value = `${selectedHeaderProduct.itemCode} - ${selectedHeaderProduct.itemName}`;
            document.getElementById('newBomName').value = '';
            
            // Reset lại bảng vật tư
            document.getElementById('quickBomMaterialsBody').innerHTML = `
                <tr id="quickBomEmptyState">
                    <td colspan="5" class="px-4 py-8 text-center text-gray-500">Chưa có vật tư nào. Nhấn "Thêm nguyên liệu" để bắt đầu.</td>
                </tr>`;
            
            document.getElementById('quickCreateBomModal').classList.remove('hidden');
        }

        function closeQuickCreateBom() {
            document.getElementById('quickCreateBomModal').classList.add('hidden');
        }

        function checkEmptyQuickBom() {
            const tbody = document.getElementById('quickBomMaterialsBody');
            if (tbody.querySelectorAll('.quick-bom-row').length === 0) {
                tbody.innerHTML = `<tr id="quickBomEmptyState"><td colspan="5" class="px-4 py-8 text-center text-gray-500">Chưa có vật tư nào. Nhấn "Thêm nguyên liệu" để bắt đầu.</td></tr>`;
            }
        }

        function saveQuickBom() {
            const bomName = document.getElementById('newBomName').value.trim();
            if (!bomName) return alert("Vui lòng nhập tên phiên bản BOM!");

            const rows = document.querySelectorAll('.quick-bom-row');
            if (rows.length === 0) return alert("Một BOM phải có ít nhất 1 nguyên vật liệu!");

            // Tạo ID ảo cho BOM mới (thực tế sẽ lấy từ API trả về)
            const newBomId = 'BOM-NEW-' + Math.random().toString(36).substr(2, 5).toUpperCase();
            const newBomMaterials = [];
            let hasInvalidQty = false;

            // Quét qua các dòng vật tư vừa thêm
            rows.forEach(row => {
                const code = row.dataset.code;
                const name = row.cells[1].innerText;
                const uom = row.cells[2].innerText;
                const qtyInput = row.querySelector('.bom-qty-input');
                const qty = parseFloat(qtyInput.value);

                if (!qty || qty <= 0) {
                    hasInvalidQty = true;
                    qtyInput.classList.add('border-red-500', 'bg-red-50');
                } else {
                    qtyInput.classList.remove('border-red-500', 'bg-red-50');
                    
                    // Tìm số lượng khả dụng từ DB để đưa vào BOM cache
                    const sourceItem = mockProducts.find(p => p.itemCode === code);
                    
                    newBomMaterials.push({
                        itemCode: code,
                        itemName: name,
                        uom: uom,
                        qtyPerUnit: qty,
                        availableQty: sourceItem ? (sourceItem.availableQty || 0) : 0
                    });
                }
            });

            if (hasInvalidQty) return alert("Vui lòng nhập số lượng định mức lớn hơn 0!");

            // 1. Lưu vào Mock Data giả lập
            mockBomDetails[newBomId] = newBomMaterials;
            if (!selectedHeaderProduct.boms) selectedHeaderProduct.boms = [];
            selectedHeaderProduct.boms.push({ id: newBomId, name: bomName });

            // 2. Cập nhật thẻ Select (Dropdown) trên giao diện chính
            const bomSelect = document.getElementById('bomVersion');
            const option = document.createElement('option');
            option.value = newBomId;
            option.textContent = bomName;
            bomSelect.appendChild(option);
            
            // Tự động chọn luôn BOM vừa tạo
            bomSelect.value = newBomId; 

            // Đóng Modal
            closeQuickCreateBom();
            
            // NẾU CÓ THƯ VIỆN THÔNG BÁO: Notify.success(`Đã tạo BOM ${bomName}`);
            Notify.info(`Đã tạo nhanh BOM: ${bomName}`);
        }
        
    </script>
}
