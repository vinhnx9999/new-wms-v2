@page
@model Wms.Theme.Web.Pages.System.AuditLogModel

@{
    ViewData["Title"] = L["AuditLog"];
}

<div class="space-y-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">@L["AuditLog"]</h1>
            <p class="mt-1 text-gray-600 dark:text-gray-300">@L["UserActionsAndSystemEvents"]</p>
        </div>
        <div class="flex gap-3">
            <a href="#" class="btn btn-ghost">@L["Export"]</a>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-gray-900">@L["Logs"]</h3>
            <div class="flex items-center gap-3">
                <input type="text" placeholder="@L["SearchEventPlaceholder"]" class="input" />
                <a href="#" class="btn btn-secondary">@L["Filter"]</a>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-200">
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">@L["Time"]</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">@L["User"]</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">@L["Action"]</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-700 uppercase tracking-wider">@L["Details"]</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <tr>
                        <td colspan="4" class="px-6 py-10 text-center text-gray-500">@L["NoLogsRecorded"]</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
