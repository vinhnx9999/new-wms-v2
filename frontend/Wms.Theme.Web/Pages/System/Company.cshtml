@page
@model Wms.Theme.Web.Pages.System.CompanyModel

@{
    ViewData["Title"] = L["Company"];
}

<div class="space-y-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">@L["CompanySettings"]</h1>
            <p class="mt-1 text-gray-600 dark:text-gray-300">@L["OrganizationDetailsPreferences"]</p>
        </div>
        <div class="flex gap-3">
            <a href="#" class="btn btn-primary">@L["Save"]</a>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">@L["CompanyLabel"]</h3>
        </div>
        <div class="p-6 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="label">@L["CompanyName"]</label>
                    <input type="text" class="input" placeholder="Acme Inc." />
                </div>
                <div>
                    <label class="label">@L["Address"]</label>
                    <input type="text" class="input" placeholder="@L["AddressPlaceholder"]" />
                </div>
            </div>
        </div>
    </div>
</div>
