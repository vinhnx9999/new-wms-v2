@page "/Orders/{id}"
@using WMSSolution.Shared
@model Wms.Theme.Web.Pages.Orders.IndexModel
@{
    ViewData["Title"] = L["Orders"];
    Layout = "_AuthLayout";
    var versionApp = SystemDefine.SystemVersion;
}

@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
    <script src="~/lib/ag-grid/ag-grid-community.min.js"></script>
}

<div class="grid grid-cols-2 md:grid-cols-2 gap-3">
    <div class="max-w-full py-2">
        <img src="~/img/logo.png"
             alt="Logo"
             style="margin-left: 0px;"
             class="max-w-[150px] w-full h-auto block mx-auto antialiased" />
    </div>    
    <div class="flex justify-end gap-3 mb-2 pb-2 mt-2 mr-2">
        <div class="grid grid-cols-1">
            <div>
                <span style="color: #666;">@L["AlreadyHasAccount"]</span>
                <a href="/Auth/Index">@L["LoginHere"]</a>
            </div>
            <div>
                <span class="icon" aria-hidden="true">
                    <i class="fa fa-copyright" aria-hidden="true"></i>
                </span>
                <span class="menu-label"> @versionApp</span>
            </div>
        </div>
    </div>
</div>

<div class="flex justify-center bg-white p-4 rounded-lg shadow-sm border border-gray-200">        
    <h1>@L["InboundReceipt"]</h1> 
</div>

<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @L["CreateReceipt_ReceiptNumber"]
            </label>
            <input type="text" value="@Model.Receipt.ReceiptNo" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @L["CreateReceipt_ReceiptDate"]
            </label>
            <input type="text" value="@(Model.Receipt.CreatedDate?.ToString("dd/MM/yyyy"))" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            @{
                string localizedTypeLabel = Model.Receipt.Type;
                switch (Model.Receipt.Type.ToUpper())
                {                   
                    case "RETURN": localizedTypeLabel = L["CreateReceipt_TypeReturn"]; break;
                    case "TRANSFER": localizedTypeLabel = L["CreateReceipt_TypeTransfer"]; break;
                    case "MISC": localizedTypeLabel = L["CreateReceipt_TypeMisc"]; break;
                    case "PURCHASE": localizedTypeLabel = L["CreateReceipt_TypePurchase"]; break;
                }
            }
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @L["CreateReceipt_ReceiptType"]
            </label>
            <select disabled class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 appearance-none">
                <option value="@Model.Receipt.Type" selected>@localizedTypeLabel</option>
            </select>
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @L["CreateReceipt_Warehouse"]
            </label>
            <input type="text" value="@Model.Receipt.WarehouseName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
            <span class="text-xs text-gray-500 italic">@Model.Receipt.Address</span>
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(L["Supplier"])
            </label>
            <input type="text" value="@Model.Receipt.SupplierName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>              
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(L["InvoiceNumber"])
            </label>
            <input type="text" value="@Model.Receipt.InvoiceNumber" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

          
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(L["Deliverer"])
            </label>
            <input type="text" value="@Model.Receipt.Deliverer" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>


        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @L["ExpectedDeliveryDate"]
            </label>
            <input type="text" value="@(Model.Receipt.ExpectedDeliveryDate?.ToString("dd/MM/yyyy"))" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div class="md:col-span-3">
            <label class="block text-xs font-medium text-gray-700 mb-1">
                @Html.Raw(L["Note"])
            </label>
            <textarea readonly rows="3"
                      class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none resize-none">@Model.Receipt.Description</textarea>
        </div>

    </div>
</div>

<div class="flex justify-between items-center mb-2">
    <h2 class="text-lg font-semibold text-gray-800">@L["CreateReceipt_ItemDetails"]</h2>
</div>

<div id="gridOrders" class="ag-theme-quartz" style="height: 400px; width: 100%;"></div>

@section Scripts {
    <script src="~/js/qrcodegen-v1.8.0-es6.js"></script>
    <script src="~/js/qr-print.js"></script>
    <script src="~/js/printReceipt.js"></script>
            
    <script>
             
        function handlePrintQrClick() {
           
            const rowsWithPallet = rowData.filter(item => item.pallet && item.pallet.trim() !== '');

            if (rowsWithPallet.length === 0) {
                Notify.error('Không có mã Pallet nào để in!');
                return;
            }
         
            const uniquePalletsMap = new Map();
            rowsWithPallet.forEach(item => {
                if (!uniquePalletsMap.has(item.pallet)) {
                    uniquePalletsMap.set(item.pallet, item);
                }
            });
            const uniqueRows = Array.from(uniquePalletsMap.values());

           
            const qrDataToPrint = uniqueRows.map(item => ({
                content: item.pallet,
                title: item.pallet,
                desc1: "",
                desc2: ""
            }));

          
            const headerInfo = {
                title: "",
                subtitle: ""
            };

           
            if (typeof printQrCode === 'function') {
                printQrCode(qrDataToPrint, headerInfo);
            } else {
                console.error('Hàm printQrCode chưa được load!');
            }
        }

        const columnDefs = [
                {
                    headerName: '@Html.Raw(L["CreateReceipt_ColItemCode"])',
                    field: "SkuCode",
                    flex: 1.5,
                    pinned : "left",
                    cellClass: 'py-3 px-3 leading-tight font-medium text-gray-700'
                },
                {
                    headerName: '@Html.Raw(L["CreateReceipt_ColItemName"])',
                    field: "SkuName",
                    flex: 2,
                    wrapText: true,
                    autoHeight: true,
                    cellClass: 'py-3 px-3 leading-tight font-medium text-gray-700'
                },
                {
                    headerName: '@Html.Raw(L["CreateReceipt_ColUom"])',
                    field: "UnitName",
                    flex: 1
                },
                {
                    headerName: '@Html.Raw(L["CreateReceipt_ColQuantity"])',
                    field: "Quantity",
                    flex: 1,
                    cellClass: 'font-semibold text-blue-700'
                },
                {
                    headerName: '@Html.Raw(L["ExpiryDate"])',
                    field: "ExpiryDate",
                    width: 150,
                    editable: false,
                    valueFormatter: params => {
                    if (!params.value) return '';
                    const date = new Date(params.value);
                    return date.toLocaleDateString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric' });
                    }
                }
                
        ];

        const detailData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Receipt.Details));
                 
        console.log("detailData", detailData);

        const gridOptions = {
            columnDefs: columnDefs,
            rowData: detailData,
            pagination: true,
            defaultColDef: {
              resizable: true,
              flex: 1
            }
        };
            
        let gridApi;            
        document.addEventListener('DOMContentLoaded', () => {                
            const gridDiv = document.querySelector('#gridOrders');                
            gridApi = agGrid.createGrid(gridDiv, gridOptions);            
        });

    </script>    
}