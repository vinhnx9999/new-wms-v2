@page
@model Wms.Theme.Web.Pages.Setting.Supplier.CreateModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Create"];
}

<div class="mx-auto py-8 px-2">
    

    <form method="post" class="bg-white shadow-md rounded-lg overflow-hidden border border-gray-200">
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="md:col-span-2">
                    <label asp-for="AddSupplierRequest.SupplierName" class="block text-sm font-semibold text-gray-700 mb-1">Tên nhà cung cấp <span class="text-red-500">*</span></label>
                    <input asp-for="AddSupplierRequest.SupplierName"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="Nhập tên nhà cung cấp..." required />
                    <span asp-validation-for="AddSupplierRequest.SupplierName" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div>
                    <label asp-for="AddSupplierRequest.Manager" class="block text-sm font-semibold text-gray-700 mb-1">Người quản lý</label>
                    <input asp-for="AddSupplierRequest.Manager"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="Tên người đại diện" />
                </div>

                <div>
                    <label asp-for="AddSupplierRequest.ContactTel" class="block text-sm font-semibold text-gray-700 mb-1">Số điện thoại</label>
                    <input asp-for="AddSupplierRequest.ContactTel"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="090x xxx xxx" />
                </div>

                <div>
                    <label asp-for="AddSupplierRequest.Email" class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
                    <input asp-for="AddSupplierRequest.Email" type="email"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="example@domain.com" />
                </div>

                <div>
                    <label asp-for="AddSupplierRequest.City" class="block text-sm font-semibold text-gray-700 mb-1">Thành phố <span class="text-red-500">*</span></label>
                    <input asp-for="AddSupplierRequest.City"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="Ví dụ: TP. Hồ Chí Minh" required />
                    <span asp-validation-for="AddSupplierRequest.City" class="text-xs text-red-500 mt-1"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="AddSupplierRequest.Address" class="block text-sm font-semibold text-gray-700 mb-1">Địa chỉ cụ thể <span class="text-red-500">*</span></label>
                    <input asp-for="AddSupplierRequest.Address"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
                           placeholder="Số nhà, tên đường, phường/xã..." required />
                    <span asp-validation-for="AddSupplierRequest.Address" class="text-xs text-red-500 mt-1"></span>
                </div>

            </div>
        </div>

        <div class="bg-gray-50 px-6 py-4 flex items-center justify-end gap-3 border-t border-gray-200">
            <a href="./Index" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                Hủy bỏ
            </a>
            <button type="submit" class="px-6 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition-all">
                Lưu thông tin
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}