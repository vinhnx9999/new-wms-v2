@page
@model Wms.Theme.Web.Pages.Setting.Supplier.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
@{
    ViewData["Title"] = @L["ListSupplier"];
}

<div class="container p-3">
    <div class="flex items-start justify-between">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100">@L["ListSupplier"]</h2>
        </div>
        <div class="flex gap-3">
            @* <a href="Supplier/Create" class="btn btn-primary">@L["Common_AddNew"]</a> *@
            <form id="excelFormSupplier" asp-action="Setting/Supplier/ImportExcel" enctype="multipart/form-data" method="post">
                <input type="file" name="excelFile" accept=".xlsx,.xls" class="hidden" id="excelUploadSupplier" />
                <label for="excelUploadSupplier" class="btn btn-secondary cursor-pointer">
                    @L["Common_ImportExcel"]
                </label>
            </form>
            <button id="downloadBtnSupplier" class="btn btn-primary" 
                    title="@Html.Raw(L["GetTemplate"])">
                 <span class="hidden sm:inline">@Html.Raw(L["GetTemplate"])</span>
            </button>
        </div>
    </div>
</div>

<!-- Loading spinner -->
<div id="loadingOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%;
    background-color:rgba(0,0,0,0.4); z-index:9998;">
</div>

<div id="loadingSpinner" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%, -50%); z-index:9999;">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">@Html.Raw(Localizer["Loading"])</span>
    </div>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
        <div id="supplierGrid" class="ag-theme-quartz" style="height: 500px; width: 100%;"></div>
    </div>
</div>

<script>    
    document.getElementById("excelUploadSupplier").addEventListener("change", function () {           
        // Hiện loading
        document.getElementById("loadingSpinner").style.display = "block";
        document.getElementById("loadingOverlay").style.display = "block";

        const form = document.getElementById("excelFormSupplier");
        const formData = new FormData(form);

        fetch('?handler=ImportExcel', {
            method: "POST",
            body: formData
        })
        .then(response => {
            
            document.getElementById("loadingOverlay").style.display = "none";
            document.getElementById("loadingSpinner").style.display = "none";

            if (response.ok) {
                Notify.info('@Html.Raw(Localizer["OperationSuccessful"])');
                setTimeout(() => {
                    location.reload();
                }, 1000);
            } else {
                Notify.info('@Html.Raw(Localizer["Retry"])');
            }
        })
        .catch(error => {
            document.getElementById("loadingSpinner").style.display = "none";
            document.getElementById("loadingOverlay").style.display = "none";
            console.error("Lỗi:", error);
            Notify.error('Connection error');
        });

    });

    const rowData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Suppliers, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

    const columnDefs = [
        { 
            field: "supplier_name",
            headerName: '@Html.Raw(L["Supplier"])',
            flex: 1  ,
            editable: true,
        },
        { 
            field: "address",
            headerName: '@Html.Raw(L["Address"])',
            flex: 2 ,
            editable: true,

        },
        { 
            field: "taxNumber",
            headerName: '@Html.Raw(L["Tax"])',
            width: 150 ,
            editable: true,
        },
        {
            headerName: "",
            field: "Id",
            width: 70,
            pinned: 'right',
            cellRenderer: (params) => {
                const btnDelete = document.createElement("button");
                btnDelete.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                `;
                btnDelete.title = '@Html.Raw(L["Remove"])';
                btnDelete.addEventListener("click", () => {
                    params.api.applyTransaction({ remove: [params.node.data] });
                    deleteSupplier(params.data.id)
                });

                return btnDelete;
            },
       },
    ];

    const gridOptions = {
        columnDefs: columnDefs,
        rowData: rowData,
        // pagination: true,
        // paginationPageSize: 10,
        // paginationPageSizeSelector: [10, 20, 50],
        singleClickEdit: true, 
        stopEditingWhenCellsLoseFocus: true,
        defaultColDef: {
            sortable: true,
            filter: true,
            resizable: true,
        },
        
        onCellValueChanged: async function(event) {
            if (event.oldValue === event.newValue) return;

            const id = event.data.id;        
    
            const url = `?handler=UpdateSuplier&id=${id}`;

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token 
                    },
                    body: JSON.stringify(event.data)
                });

                if (!response.ok) {
                    throw new Error('@Html.Raw(L["ConnectionError"])');
                }

                const result = await response.json();

                if (result.success) {
                    Notify.success('@Html.Raw(L["OperationSuccessful"])');
                } else {
                    Notify.error('@Html.Raw(L["OperationFailed"])');
              
                   
                    event.data[event.colDef.field] = event.oldValue;
                    event.api.refreshCells({ rowNodes: [event.node], columns: [event.colDef.field] });
                }
            } catch (error) {
                console.error(error);
                Notify.error("Có lỗi xảy ra trong quá trình lưu");
         
                event.data[event.colDef.field] = event.oldValue;
                event.api.refreshCells({ rowNodes: [event.node], columns: [event.colDef.field] });
            }
        }
    };

    document.addEventListener('DOMContentLoaded', function () {
        const gridDiv = document.querySelector('#supplierGrid');
        agGrid.createGrid(gridDiv, gridOptions);
    });

    function deleteSupplier(supplierId) {
        let payload = {
            ChainId: supplierId
        };
        postData('?handler=DeleteSupplier', payload)
            .then((result) => {
                isLoading = false;
                if (!result.success) {
                    Notify.error('@Html.Raw(L["OperationFailed"])');
                } else {
                    console.log("delete Supplier", result);
                    Notify.success( '@Html.Raw(L["OperationSuccessful"])');
                }
            })
            .catch((err) => {
                console.log("[ERROR] delete Supplier", err);
                isLoading = false;
                Notify.error('@Html.Raw(L["OperationFailed"])');
            });
    }

    async function postData(url, data) {
        if(!data) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const response = await fetch(url,
            {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(data)
            }
        );

        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        return await response.json();
    }

        
    document.getElementById("downloadBtnSupplier").addEventListener("click", async () => {
        try {
            const response = await fetch('?handler=DownloadTemplate');
            if (!response.ok) {
                throw new Error("Không thể tải file");
            }

            const blob = await response.blob();
            const url = window.URL.createObjectURL(blob);

            const a = document.createElement("a");
            a.href = url;
            a.download = "TemplateSupplier.xlsx"; 
            document.body.appendChild(a);
            a.click();
            a.remove();

            window.URL.revokeObjectURL(url);
        } catch (err) {
            alert(err.message);
        }
    });

</script>