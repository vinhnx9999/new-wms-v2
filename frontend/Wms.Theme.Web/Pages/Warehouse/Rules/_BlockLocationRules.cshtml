@model IEnumerable<int>
<div class="space-y-3">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 lg:grid-cols-10 gap-2 p-4">
        @foreach (var number in Model)
        {
            if (@number % 10 == 0 && @number / 10 == 3)
            {
                <div class="w-12 h-12 bg-teal-300 rounded-lg flex items-center justify-center text-white font-bold"
                     title="Location @number">
                    @number
                </div>
            }
            else if (@number % 10 == 0)
            {
                <div class="w-12 h-12 bg-gray-200 rounded-lg flex items-center justify-center text-white font-bold"
                     title="Location @number">
                    @number
                </div>
            }
            else
            {
                <div class="w-12 h-12 bg-blue-500 rounded-lg flex items-center justify-center text-white font-bold"
                     title="Location @number">
                    @number
                </div>
            }
        }
    </div>
</div>
    
