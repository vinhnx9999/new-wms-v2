@using Wms.Theme.Web.Model.Sku
@model IEnumerable<SkuSafetyStockDto>

@Html.AntiForgeryToken()

<div id="gridSafetyStockConfig" style="height: calc(90vh - 240px); width:100%;" class="ag-theme-alpine"></div>

<script>
    const columnSafetyDefs = [
        { headerName: '@Html.Raw(L["SKU"])',
            pinned : "left",
            field: "SkuCode",
            sortable: true,
            filter: true
        },
        {
            headerName: '@Html.Raw(L["SkuName"])',
            flex: 2,
            field: "SkuName",
            sortable: true,
            filter: true
        },
        {
            headerName: '@Html.Raw(L["SafetyStock"])',
            field: "SafetyStockQty",
            width: 120,
            editable: true,
            cellClass: 'text-right font-semibold text-blue-700',
        },
        {
            headerName: "",
            field: "Id",
            width: 70,
            pinned: 'right',
            cellRenderer: (params) => {
                const btnDelete = document.createElement("button");
                btnDelete.innerHTML =`<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                      </svg>`;
                btnDelete.title = "@Html.Raw(L["Remove"])";
                btnDelete.addEventListener("click", () => {
                    params.api.applyTransaction({ remove: [params.node.data] });
                    deleteSafetyStockQty(params.data.Id)
                });

                return btnDelete;
            },
       },
    ]
     
    let rowSafetyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    const gridSafetyOptions = {
        columnDefs: columnSafetyDefs,
        rowData: rowSafetyData,
        pagination: true,
        defaultColDef: {
          resizable: true,
          flex: 1
        },
        onCellValueChanged: function(event) {
             postData('?handler=UpdateSafetyData', event.data)
                .then((result) => {
                    Notify.info('@Html.Raw(L["OperationSuccessful"])');
             });
        }
    };

    let gridApi;

    document.addEventListener('DOMContentLoaded', () => {
         const gridDiv = document.querySelector('#gridSafetyStockConfig');
         gridApi = agGrid.createGrid(gridDiv, gridSafetyOptions);
    });

    async function deleteSafetyStockQty(id) {

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const formData = new FormData();
            formData.append("skuSafetyId", id);
            formData.append("__RequestVerificationToken", tokenInput.value);

            const response = await fetch(`?handler=DeleteSafetyData`,
                    {
                       method: 'POST',
                       body: formData
                    }
                );
        
                const result = await response.json();
                if (result.success) {
                    Notify.info('@Html.Raw(L["OperationSuccessful"])');
                    setTimeout(() => {
                        location.reload();
                    }, 500);
                } else {
                    Notify.error(result.message ?? '@Html.Raw(L["ErrorConnectingToServer"])');
                }
    }
        
</script>