@page "/SalesOrders/{id}"
@using WMSSolution.Shared
@model Wms.Theme.Web.Pages.SalesOrders.IndexModel
@{
    ViewData["Title"] = L["SalesOrders"];
    Layout = "_AuthLayout";
    var versionApp = SystemDefine.SystemVersion;
}

@section Styles {
    <link rel="stylesheet" href="~/css/darkmode.css" />
    <script src="~/lib/ag-grid/ag-grid-community.min.js"></script>
}

<div class="grid grid-cols-2 md:grid-cols-2 gap-3">
    <div class="max-w-full py-2">
        <img src="~/img/logo.png"
             alt="Logo"
             style="margin-left: 0px;"
             class="max-w-[150px] w-full h-auto block mx-auto antialiased" />
    </div>
    <div class="flex justify-end gap-3 mb-2 pb-2 mt-2 mr-2">
        <div class="grid grid-cols-1">
            <div>
                <span style="color: #666;">@L["AlreadyHasAccount"]</span>
                <a href="/Auth/Index">@L["LoginHere"]</a>
            </div>
            <div>
                <span class="icon" aria-hidden="true">
                    <i class="fa fa-copyright" aria-hidden="true"></i>
                </span>
                <span class="menu-label"> @versionApp</span>
            </div>
        </div>
    </div>
</div>

<div class="flex justify-center bg-white p-4 rounded-lg shadow-sm border border-gray-200">
    <h1>@L["OutboundReceipt"]</h1>
</div>

<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">        
        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateReceipt_ReceiptNumber"]</label>
            <input type="text" value="@Model.Receipt.ReceiptNo" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateReceipt_ReceiptDate"]</label>
            <input type="text" value="@Model.Receipt.StrReceiptDate" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>
        
        <div>
            @{
                string localizedTypeLabel = Model.Receipt.Type;
                switch (Model.Receipt.Type)
                {
                    case "SALES": localizedTypeLabel = L["CreateOutboundReceipt_IssueTypeSales"]; break;
                    case "RETURN": localizedTypeLabel = L["CreateOutboundReceipt_IssueTypeReturnSupplier"]; break;
                    case "SCRAP": localizedTypeLabel = L["CreateOutboundReceipt_IssueTypeScrap"]; break;
                    case "MISC": localizedTypeLabel = L["CreateOutboundReceipt_IssueTypeMisc"]; break;
                }
            }
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateOutboundReceipt_IssueType"]</label>
            <select disabled class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 appearance-none">
                <option value="@Model.Receipt.Type" selected>@localizedTypeLabel</option>
            </select>
        </div>

        <div class="md:col-span-2">
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateOutboundReceipt_Customer"]</label>
            <input type="text" value="@Model.Receipt.CustomerName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label for="consignee" class="block text-xs font-medium text-gray-700 mb-1">
                @L["Consignee"]
            </label>
            <input type="text"
                   id="consignee"
                   name="consignee"
                   value="@Model.Receipt.Consignee"
                   readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
        </div>

        <div class="md:col-span-2">
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateOutboundReceipt_Warehouse"]</label>
            <input type="text" value="@Model.Receipt.WarehouseName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">@L["CreateOutboundReceipt_Gateway"]</label>
            <input type="text" value="@Model.Receipt.OutboundGatewayName" readonly
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none">
        </div>

        <div>
            <label class="block text-xs font-medium text-gray-700 mb-1">@Model.Receipt.WarehouseAddress</label>
        </div>
        <div>
            <label for="exportDate" class="block text-xs font-medium text-gray-700 mb-1">
                @(Model.Receipt.ExpectedShipDate == null ? "" : $"Thời gian dự kiến xuất hàng {Model.Receipt.ExpectedShipDate?.ToString("dd/MM/yyyy HH:mm")}")
            </label>
        </div>
        <div>
            <label for="pickingDate" class="block text-xs font-medium text-gray-700 mb-1">
                @(Model.Receipt.StartPickingTime == null ? "" : $"Thời gian bắt đầu picking {Model.Receipt.StartPickingTime?.ToString("dd/MM/yyyy HH:mm")}")
            </label>
        </div>
        <div class="md:col-span-3">
            <label class="block text-xs font-medium text-gray-700 mb-1">Ghi chú</label>
            <textarea readonly rows="3"
                      class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md bg-gray-50 focus:outline-none resize-none">@Model.Receipt.Description</textarea>
        </div>

    </div>
</div>

<div id="gridSalesOrders" class="ag-theme-quartz" style="max-height: calc(90vh - 260px); height: 260px; width: 100%;"></div>
      


<script>       
    const rowData = @Html.Raw(Json.Serialize(Model.Receipt.Details));
    const gridOptions = {
         columnDefs: [
            {
                field: "skuCode",
                headerName: '@Html.Raw(L["SkuCode"])',
                flex: 1,
                pinned : "left",
                minWidth: 120
            },
            {
                field: "skuName",
                headerName: '@Html.Raw(L["SkuName"])',
                flex: 3,          
                minWidth: 250
            },
            {
                field: "unitName",
                headerName: '@Html.Raw(L["Unit"])',
                flex: 1,     
                minWidth: 80
            },
            {
                field: "quantity",
                headerName: '@Html.Raw(L["Quantity"])',
                flex: 1,
                minWidth: 50,
            },
            {
                field: "palletCode",
                headerName: '@Html.Raw(L["PalletCode"])',
                flex: 1,        
                minWidth: 180
            }
        ],
            rowData: rowData,
            defaultColDef: {
                sortable: true,
                filter: true,
                editable: false
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
         const gridDiv = document.querySelector('#gridSalesOrders');
             const gridApi = agGrid.createGrid(gridDiv, gridOptions);         
        });
</script>