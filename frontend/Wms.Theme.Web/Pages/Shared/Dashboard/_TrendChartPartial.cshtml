@model Wms.Theme.Web.Pages.Dashboard.DashboardInfo
@{
    var dataDates = Model.Inbound7Dates;
    var dataValues = Model.Inbound7DateValues;
    bool hasRows = dataDates.Any();
}

<!-- Inbound trend full width -->
<div class="bg-dashboard-card rounded-xl border border-slate-700/70 ring-1 ring-white/10 bg-slate-900/70 p-6 shadow-2xl backdrop-blur">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-semibold tracking-tight">Xu hướng Nhập kho</h2>
            <p class="text-[11px] uppercase tracking-wider text-slate-400">Số phiếu nhập theo ngày</p>
        </div>
        <div class="text-[11px] text-slate-400">7 ngày gần nhất</div>
    </div>
    <div class="mt-3 h-72">
        <canvas id="inboundTrendChart" aria-label="Biểu đồ xu hướng nhập kho" role="img"></canvas>
    </div>
</div>

@section Scripts { 
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.5/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var inboundCanvas = document.getElementById('inboundTrendChart');
                if (inboundCanvas) {
                    var ic = inboundCanvas.getContext('2d');
                    let labelCharts = ['2026-04-01', '2026-04-02', '2026-04-03', '2026-04-04', '2026-04-05', '2026-04-06', '2026-04-07'];

                    var inboundGradient = ic.createLinearGradient(0, 0, 0, inboundCanvas.offsetHeight);
                    inboundGradient.addColorStop(0, 'rgba(56, 189, 248, 0.28)');
                    inboundGradient.addColorStop(1, 'rgba(56, 189, 248, 0.02)');

                    let dataInbound = {
                            labels: dataDates ?? labelCharts,
                            datasets: [{
                                label: 'Số phiếu nhập',
                                data: dataValues ?? [12, 18, 14, 26, 21, 17, 28],
                                borderColor: '#22d3ee',
                                backgroundColor: inboundGradient,
                                tension: 0.35,
                                fill: true,
                                pointBackgroundColor: '#22d3ee'
                            }]
                        };

                console.log("dataInbound", dataInbound);

                    new Chart(ic, {
                        type: 'line',
                        data: dataInbound,
                        options: chartOptions
                    });
                }
        });
</script>
        
}

