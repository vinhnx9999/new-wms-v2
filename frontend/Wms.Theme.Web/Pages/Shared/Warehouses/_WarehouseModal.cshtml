@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
@Html.AntiForgeryToken()

<div id="warehouseModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    
        <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 transform transition-all">
            <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-800">@L["CreateReceipt_AddNewWarehouse"]</h3>
                <button type="button" onclick="closeWarehouseModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <div class="px-6 py-4 space-y-4">
                <div>
                    <label for="newWhName" class="block text-sm font-medium text-gray-700 mb-1">
                        @L["CreateReceipt_WarehouseName"] <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="newWhName" maxlength="32"
                           placeholder="VD: Kho Vật Tư Phụ"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="newWhCity" class="block text-sm font-medium text-gray-700 mb-1">
                            @L["CreateReceipt_City"] <span class="text-red-500">*</span>
                        </label>
                        <input type="text" id="newWhCity" maxlength="128"
                               placeholder="VD: Hồ Chí Minh"
                               class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label for="newWhContactTel" class="block text-sm font-medium text-gray-700 mb-1">
                            @L["CreateReceipt_Phone"]
                        </label>
                        <input type="text" id="newWhContactTel" maxlength="64"
                               placeholder="VD: 028-1234-5678"
                               class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
                <div>
                    <label for="newWhAddress" class="block text-sm font-medium text-gray-700 mb-1">
                        @L["CreateReceipt_Address"] <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="newWhAddress" maxlength="256"
                           placeholder="VD: 123 Nguyễn Văn Linh, Quận 7"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div class="grid grid-cols-2 gap-4 hidden">
                    <div>
                        <label for="newWhManager" class="block text-sm font-medium text-gray-700 mb-1">
                            @L["CreateReceipt_WarehouseManager"]
                        </label>
                        <input type="text" id="newWhManager" maxlength="64"
                               placeholder="VD: Nguyễn Văn A"
                               class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                    <div>
                        <label for="newWhEmail" class="block text-sm font-medium text-gray-700 mb-1">
                            @L["CreateReceipt_Email"]
                        </label>
                        <input type="text" id="newWhEmail" maxlength="128"
                               placeholder="VD: kho@company.com"
                               class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>
            </div>

            <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3 bg-gray-50 rounded-b-lg">
                <button type="button" onclick="closeWarehouseModal()" class="px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                    @L["Common_Cancel"]
                </button>
            <button type="button" onclick="saveNewWarehouse()"
                        class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-sm transition-colors">
                    @L["CreateReceipt_SaveWarehouse"]
                </button>
            </div>
        </div>
</div>