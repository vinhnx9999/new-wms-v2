@using Wms.Theme.Web.Util
@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="~/img/warehouse-icon.svg" />
    <title>@ViewData["Title"] - @L["AppTitle"]</title>
    <script>
        // Apply saved theme ASAP to avoid FOUC
        (function () {
            try {
                var saved = localStorage.getItem('theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                if (saved === 'dark' || (!saved && prefersDark)) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }

                // Apply saved sidebar state
                var savedSidebar = localStorage.getItem('sidebar-state');
                if (savedSidebar === 'collapsed') {
                    document.body.classList.add('collapsed-sidebar');
                }
            } catch (e) { /* no-op */ }
        })();
    </script>
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <!-- Font Awesome Free (local) -->
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/toast.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/form-validation.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/bulk-operations.css" asp-append-version="true" />
    <!-- Tailwind compiled CSS last to avoid unintended overrides -->
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
    <!--Select 2 -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <!--alpine.js-->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <!--cdnjs cdn -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flatpickr/4.6.13/themes/airbnb.min.css">
</head>

@await RenderSectionAsync("Styles", required: false)
<body>
    <div class="layout-container">   
        @await Html.PartialAsync("_MyMenu")
        <!-- Main Content -->
        <div class="main-content flex-1 flex flex-col min-w-0 overflow-hidden bg-gray-50">
            <!-- Header -->
            <header class="header bg-white shadow-sm z-10 p-4 flex justify-between items-center">
                <nav class="flex pl-6" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-1 md:space-x-3">
                        @{
                            var rPath = Context.Request.Path.Value ?? "";
                            var path = rPath.Trim('/');

                            var segments = path.Split('/').Where(x => !string.IsNullOrEmpty(x)).ToArray();

                            if (segments.Length == 0 || (segments.Length == 1 && 
                                segments[0].Equals("Dashboard", StringComparison.OrdinalIgnoreCase)))
                            {
                                <li class="inline-flex items-center">
                                    <span class="inline-flex items-center text-sm font-medium text-gray-700 dark:text-gray-400">
                                        <i class="fa-solid fa-house mr-2"></i>
                                        @L["Dashboard"]
                                    </span>
                                </li>
                            }
                            else
                            {
                                string accumulatedPath = "";

                                for (int i = 0; i < segments.Length; i++)
                                {
                                    var segment = segments[i];
                                    accumulatedPath += "/" + segment;
                                    var displayName = segment;
                                        
                                    if (segment.All(char.IsDigit))
                                    {
                                        continue;
                                    }
                                    bool isLast = (i == segments.Length - 1);

                                    if (displayName == "WarehouseInventory")
                                    {
                                        displayName = "InOutStock";
                                    }

                                    if (accumulatedPath == "/Warehouse") accumulatedPath = "/Warehouse/List";                                    

                                    <li>
                                        <div class="flex items-center">

                                            @if (i > 0)
                                            {
                                                <i class="fa-solid fa-chevron-right text-gray-400 mx-1 text-xs"></i>
                                            }

                                            @if (isLast || accumulatedPath == "/Warehouse/List/Detail")
                                            {
                                                <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">
                                                    @L[displayName]
                                                </span>
                                            }
                                            else
                                            {
                                                <span href="@accumulatedPath"
                                                    class="ml-1 text-sm font-medium text-gray-700 hover:text-blue-600 md:ml-2 dark:text-gray-400 dark:hover:text-white">
                                                    @L[displayName]
                                                </span>
                                            }
                                        </div>
                                    </li>
                                }
                            }
                        }
                    </ol>
                </nav>
                @await Html.PartialAsync("_MyUserControls")
            </header>

            <!-- Content Area -->
            <main class="content flex-1 overflow-y-auto p-4 md:p-6 overflow-x-hidden">
                <!-- Toast Notifications -->
                @await Html.PartialAsync("_Toast")
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Alpine Teleport target (required for x-teleport) -->
    <div id="x-teleport-target"></div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <!-- jsPDF library for PDF export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script src="~/js/form-validation.js"></script>
    <script src="~/js/bulk-operations.js"></script>
    <script src="~/js/excel-export.js"></script>
    <script src="~/js/qrcodegen-v1.8.0-es6.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <link href="~/lib/sweetalert2/sweetalert2.css" rel="stylesheet" />
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/js/notification.js"></script>
    <script src="~/js/datatable-helpers.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <!-- Global Formatters -->
    <script src="~/js/formatters/format-currency.js" asp-append-version="true"></script>
    <script src="~/js/formatters/format-number.js" asp-append-version="true"></script>
    <script src="~/js/formatters/format-date.js" asp-append-version="true"></script>
    <script src="~/js/components/alpine-datatable.js?v=3" asp-append-version="true"></script>
    <!--Ag grid-->
    <script src="~/lib/ag-grid/ag-grid-community.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Theme init
            var root = document.documentElement;
            var themeToggleBtn = document.getElementById('theme-toggle');
            var themeToggleIcon = document.getElementById('theme-toggle-icon');

            function updateIcon() {
                if (root.classList.contains('dark')) {
                    themeToggleIcon.classList.remove('fa-moon');
                    themeToggleIcon.classList.add('fa-sun');
                } else {
                    themeToggleIcon.classList.remove('fa-sun');
                    themeToggleIcon.classList.add('fa-moon');
                }
            }
            updateIcon();

            themeToggleBtn.addEventListener('click', function () {
                root.classList.toggle('dark');
                if (root.classList.contains('dark')) {
                    localStorage.setItem('theme', 'dark');
                } else {
                    localStorage.setItem('theme', 'light');
                }
                updateIcon();
            });

            // Sidebar Toggle Logic
            const sidebarToggleBtn = document.getElementById('sidebar-toggle');
            if (sidebarToggleBtn) {
                sidebarToggleBtn.addEventListener('click', function () {
                    document.body.classList.toggle('collapsed-sidebar');
                    if (document.body.classList.contains('collapsed-sidebar')) {
                        localStorage.setItem('sidebar-state', 'collapsed');
                    } else {
                        localStorage.setItem('sidebar-state', 'expanded');
                    }
                });
            }

            var sidebarState = localStorage.getItem('sidebar-state');
            if (sidebarState === 'collapsed') {
                document.body.classList.add('collapsed-sidebar');
            }

            // Sidebar Submenu Logic
            var menu = document.querySelector('.sidebar-menu');
            if (!menu) return;

            var child = menu.firstElementChild;
            while (child) {
                if (child.classList && child.classList.contains('menu-title')) {
                    var group = document.createElement('li');
                    group.className = 'menu-group';

                    var titleText = child.innerText.trim(); // Use innerText to get visual text
                    var iconEl = child.querySelector('i');
                    var iconHtml = iconEl ? iconEl.outerHTML : '<i class="fa-solid fa-folder"></i>';

                    var toggle = document.createElement('button');
                    toggle.className = 'submenu-toggle';

                    toggle.innerHTML = '<span class="icon">' + iconHtml + '</span>' +
                        '<span class="menu-label">' + titleText + '</span>' +
                        '<span class="caret"><i class="fa-solid fa-chevron-right"></i></span>';

                    var submenu = document.createElement('ul');
                    submenu.className = 'submenu';

                    var next = child.nextElementSibling;
                    while (next && !(next.classList && next.classList.contains('menu-title'))) {
                        var toMove = next;
                        next = next.nextElementSibling;
                        submenu.appendChild(toMove);
                    }

                    group.appendChild(toggle);
                    group.appendChild(submenu);

                    var replaceTarget = child;
                    child = next;
                    menu.replaceChild(group, replaceTarget);

                    toggle.addEventListener('click', function (e) {
                        e.preventDefault();
                        this.parentNode.classList.toggle('open');
                    });

                    continue;
                }
                child = child.nextElementSibling;
            }

            var activeLinks = menu.querySelectorAll('a.active');
            for (var i = 0; i < activeLinks.length; i++) {
                var p = activeLinks[i].parentElement;
                while (p && p !== menu && !p.classList.contains('menu-group')) {
                    p = p.parentElement;
                }
                if (p && p.classList.contains('menu-group')) {
                    p.classList.add('open');
                    p.classList.add('active-group'); // Add this line
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>