@model int
    
@{        
    var isCancelled = Model == 4;
    var draftClass = (Model == 0 && !isCancelled) ? "text-blue-600 border-blue-600" : "text-gray-500 border-gray-300";
    var newClass = (Model == 1 && !isCancelled) ? "text-blue-600 border-blue-600" : "text-gray-500 border-gray-300";
    var processingClass = (Model == 2 && !isCancelled) ? "text-blue-600 border-blue-600" : "text-gray-500 border-gray-300";
    var completedClass = (Model == 3) ? "text-blue-600 border-blue-600" : "text-gray-500 border-gray-300";        
    var cancelClass = isCancelled ? "text-red-600 border-red-600" : "text-gray-500 border-gray-300";   
}

    <li class="flex items-center after:content-[''] after:w-16 after:h-1 after:border-b after:border-4 after:inline-block after:ms-4 after:rounded-full @draftClass">
    <div class="shrink-0 px-4 py-2 text-sm font-medium rounded-lg bg-gray-50 @(Model == 0 ? "ring-2 ring-blue-500 bg-blue-50" : "")">
            @L["Status_Draft"]
        </div>
    </li>

    <li class="flex items-center after:content-[''] after:w-16 after:h-1 after:border-b after:border-4 after:inline-block after:ms-4 after:rounded-full @newClass">
    <div class="shrink-0 px-4 py-2 text-sm font-medium rounded-lg bg-gray-50 @(Model == 1 ? "ring-2 ring-blue-500 bg-blue-50" : "")">
            @L["Status_Confirmed"]
        </div>
    </li>

    <li class="flex items-center after:content-[''] after:w-16 after:h-1 after:border-b after:border-4 after:inline-block after:ms-4 after:rounded-full @processingClass">
    <div class="shrink-0 px-4 py-2 text-sm font-medium rounded-lg bg-gray-50 @(Model == 2 ? "ring-2 ring-blue-500 bg-blue-50" : "")">
            @L["Status_Picking"]
        </div>
    </li>

    <li class="flex items-center @completedClass">
    <div class="shrink-0 px-4 py-2 text-sm font-medium rounded-lg bg-gray-50 @(Model == 3 ? "ring-2 ring-blue-500 bg-blue-50" : "")">
            @L["Status_Completed"]
        </div>
    </li>