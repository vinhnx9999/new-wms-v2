@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer

<div class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 mb-4 mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">        
        <div>
            <label for="receiptNumber" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptNumber"] <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   id="receiptNumber"
                   name="receiptNumber"
                   placeholder="PN-2023-001"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
        </div>

        <div>
            <label for="receiptDate" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptDate"] <span class="text-red-500">*</span>
            </label>
            <input type="text"
                   id="receiptDate"
                   name="receiptDate"
                   placeholder="dd/mm/yyyy"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="receiptType" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_ReceiptType"] <span class="text-red-500">*</span>
            </label>
            <select id="receiptType"
                    name="receiptType"
                    class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
                <option value="PURCHASE">@Localizer["CreateReceipt_TypePurchase"]</option>
                <option value="RETURN">@Localizer["CreateReceipt_TypeReturn"]</option>
                <option value="TRANSFER">@Localizer["CreateReceipt_TypeTransfer"]</option>
                <option value="MISC">@Localizer["CreateReceipt_TypeMisc"]</option>
            </select>
        </div>

        <div>
            <label for="warehouseSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["CreateReceipt_Warehouse"] <span class="text-red-500">*</span>
            </label>
            <div class="flex">
                <div class="relative flex-1">
                    <input type="text"
                           id="warehouseSearch"
                           autocomplete="off"
                           spellcheck="false"
                           placeholder="@Localizer["CreateReceipt_SearchWarehouse"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">

                    <input type="hidden" id="selectedWarehouseId" name="selectedWarehouseId" />
                    <ul id="warehouseDropdown" class="absolute z-10 w-full bg-white border border-gray-300 rounded-md mt-1 hidden shadow-lg max-h-48 overflow-y-auto [&::-webkit-scrollbar]:w-1.5">
                    </ul>
                </div>

                <button type="button"
                        title="@Localizer["CreateReceipt_AddWarehouse"]"
                        onclick="openWarehouseModal()"
                        class="px-2 py-1.5 bg-gray-50 border border-gray-300 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>
        </div>

        <div class="relative">
            <label for="supplierSearch" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["Supplier"] <span class="text-red-500">*</span>
            </label>

            <div class="flex">
                <div class="relative flex-1 cursor-pointer" onclick="openSupplierModal()">
                    <input type="text"
                           id="supplierSearch"
                           readonly
                           placeholder="@Localizer["SelectSupplier"]"
                           class="w-full px-3 py-1.5 text-sm border border-gray-300 border-r-0 rounded-l-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white cursor-pointer pr-10">
            
                   
                </div>

                <button type="button"
                        title="@Localizer["AddNew"]"
                        onclick="event.stopPropagation(); openSupplierAddModal();"
                        class="px-2 py-1.5 bg-gray-50 border border-gray-300 rounded-r-md text-gray-600 hover:bg-gray-200 hover:text-blue-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                </button>
            </div>

            <input type="hidden" id="selectedSupplierId" name="supplierId">
        </div>

        <div class="flex flex-col justify-end pb-2">
            <label class="block text-xs font-medium opacity-0 mb-1 select-none">&nbsp;</label>
            <div class="flex items-center h-[34px]">
                <input id="isStored"
                       name="isStored"
                       type="checkbox"
                       class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500 cursor-pointer">
                <label for="isStored" class="ml-2 text-sm font-medium text-gray-700 cursor-pointer select-none">
                    @Localizer["CreateReceipt_IsStored"]
                </label>
            </div>
        </div>

        <div>
            <label for="deliverer" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["Deliverer"]
            </label>
            <input type="text"
                   id="deliverer"
                   name="deliverer"
                   placeholder=""
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="invoiceNumber" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["InvoiceNumber"]
            </label>
            <input type="text"
                   id="invoiceNumber"
                   name="invoiceNumber"
                   placeholder=""
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>

        <div>
            <label for="expectedDeliveryDate" class="block text-xs font-medium text-gray-700 mb-1">
                @Localizer["ExpectedDeliveryDate"] <span class="text-red-500"></span>
            </label>
            <input type="text"
                   id="expectedDeliveryDate"
                   name="expectedDeliveryDate"
                   placeholder="dd/mm/yyyy"
                   class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
        </div>
 

        <div class="md:col-span-3">
            <label for="message" class="block mb-1 text-xs font-medium text-gray-700">
                @Localizer["AddNote"]
            </label>
            <textarea id="message"
                      name="message"
                      rows="2"
                      placeholder="@Localizer["EnterNote"]"
                      class="w-full px-3 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white resize-y"></textarea>
        </div>

        <div class="md:col-span-3">
            <label class="block text-xs font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_Reference"]</label>
            <div class="flex items-stretch">
                <div id="referenceOrderContainer"
                     onclick="openOrderModal()"
                     class="flex-1 px-3 py-1.5 border border-gray-300 border-r-0 rounded-l-md bg-gray-50 flex flex-wrap gap-2 items-center cursor-pointer focus-within:ring-2 focus-within:ring-blue-500 transition-all">
                    <span id="refPlaceholder" class="text-gray-400 text-sm italic leading-5">@Localizer["CreateReceipt_ReferencePlaceholder"]</span>
                </div>

                <button type="button"
                        onclick="openOrderModal()"
                        class="px-3 bg-blue-50 border border-blue-200 border-l-0 rounded-r-md text-blue-600 hover:bg-blue-100 transition-colors flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>
            </div>
        </div>

    </div>
</div>