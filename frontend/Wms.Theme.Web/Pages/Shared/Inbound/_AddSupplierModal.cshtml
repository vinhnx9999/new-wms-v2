@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> L
<div id="supplierAddModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 transform transition-all flex flex-col">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">Thêm Nhà Cung Cấp Mới</h3>
            <button type="button" onclick="closeSupplierAddModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-6 py-4 space-y-4">
            <div>
                <label for="newSupplierName" class="block text-sm font-medium text-gray-700 mb-1">
                    Tên nhà cung cấp <span class="text-red-500">*</span>
                </label>
                <input type="text" id="newSupplierName"
                       placeholder="Nhập tên nhà cung cấp"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="newSupplierCity" class="block text-sm font-medium text-gray-700 mb-1">
                        Thành phố <span class="text-red-500">*</span>
                    </label>
                    <input type="text" id="newSupplierCity"
                           placeholder="VD: Cần Thơ"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label for="newSupplierTel" class="block text-sm font-medium text-gray-700 mb-1">
                        Số điện thoại
                    </label>
                    <input type="text" id="newSupplierTel"
                           placeholder="VD: 090..."
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>

            <div>
                <label for="newSupplierAddress" class="block text-sm font-medium text-gray-700 mb-1">
                    Địa chỉ <span class="text-red-500">*</span>
                </label>
                <input type="text" id="newSupplierAddress"
                       placeholder="Số nhà, tên đường"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="newSupplierManager" class="block text-sm font-medium text-gray-700 mb-1">
                        Người liên hệ
                    </label>
                    <input type="text" id="newSupplierManager"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label for="newSupplierEmail" class="block text-sm font-medium text-gray-700 mb-1">
                        Email
                    </label>
                    <input type="email" id="newSupplierEmail"
                           class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                </div>
            </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3 bg-gray-50 rounded-b-lg">
            <button type="button" onclick="closeSupplierAddModal()"
                    class="px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                @L["Common_Cancel"]
            </button>
            <button type="button" onclick="saveSupplier()"
                    class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-sm transition-colors">
                Lưu dữ liệu
            </button>
        </div>
    </div>
</div>