@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer
<div id="orderSearchModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-4xl mx-4 transform transition-all flex flex-col" style="max-height: 90vh;">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
            <div>
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["CreateReceipt_SelectInboundOrder"]</h3>
            
            </div>
            <button type="button" onclick="closeOrderModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-6 py-4 flex flex-col flex-1 overflow-hidden bg-gray-50">
            <div class="mb-4">
                <input type="text" id="orderSearchInput" placeholder="@Localizer["CreateReceipt_InboundOrderPlaceholder"]" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="flex-1 overflow-y-auto border border-gray-200 rounded-md bg-white">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50 sticky top-0">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">@Localizer["CreateReceipt_ColOrderCode"]</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">@Localizer["CreateReceipt_ColExpectedDate"]</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">@Localizer["CreateReceipt_ColSupplierName"]</th>
                            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">@Localizer["CreateReceipt_ColActions"]</th>
                        </tr>
                    </thead>
                    <tbody id="orderSearchResultBody" class="bg-white divide-y divide-gray-200">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!--Modal Select Details Inbound Order-->
<div id="orderItemSelectionModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-3xl mx-4 transform transition-all flex flex-col" style="max-height: 90vh;">

        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200 bg-gray-50 rounded-t-lg">
            <div>
                <h3 class="text-lg font-bold text-gray-800" id="selectionModalTitle">@Localizer["CreateReceipt_OrderDetailTitle"]</h3>
                <p class="text-sm text-gray-500 mt-1">@Localizer["CreateReceipt_OrderDetailHint"]</p>
            </div>
            <button type="button" onclick="closeOrderItemSelectionModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none bg-white rounded-full p-1 hover:bg-gray-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-6 py-4 flex flex-col flex-1 overflow-hidden">
            <div class="flex-1 overflow-y-auto border border-gray-200 rounded-md shadow-sm">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-blue-50 sticky top-0 z-10">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left w-12">
                                <input type="checkbox" id="selectAllItems" onchange="toggleAllItems(this)" class="w-4 h-4 text-blue-600 rounded border-gray-300 cursor-pointer">
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["CreateReceipt_ColItemCode"]</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["CreateReceipt_ColItemName"]</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["CreateReceipt_ColUom"]</th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-700 uppercase">@Localizer["CreateReceipt_ColExpectedQty"]</th>
                        </tr>
                    </thead>
                    <tbody id="orderItemSelectionBody" class="bg-white divide-y divide-gray-200">
                    </tbody>
                </table>
            </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-200 flex justify-between items-center bg-gray-50 rounded-b-lg">
            <div class="text-sm text-gray-600 font-medium">
                @Localizer["CreateReceipt_SelectedCount"] <span id="selectedItemsCount" class="text-blue-600 font-bold text-lg">0</span> @Localizer["CreateReceipt_ItemsUnit"]
            </div>
            <div class="flex gap-3">
                <button type="button" onclick="closeOrderItemSelectionModal()" class="px-5 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-100 font-medium">
                    @Localizer["Common_Dismiss"]
                </button>
                <button type="button" onclick="confirmSelectedItems()" class="px-5 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-md flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    @Localizer["CreateReceipt_ConfirmAddToReceipt"]
                </button>
            </div>
        </div>
    </div>
</div>