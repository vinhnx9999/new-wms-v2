@using WMSSolution.Shared

<!-- Sidebar -->
@{
    string Active(string path, bool exactMatch = false)
    {
        var currentPath = Context.Request.Path.Value ?? "";

        if (exactMatch)
        {
            return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        }

        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
}

