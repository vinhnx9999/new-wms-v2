@model Wms.Theme.Web.Pages.Outbound.Receipt.DetailModel

<div id="printTemplate" class="hidden print:block print:w-full print:p-10 print:bg-white print:text-black font-sans">
   
        @if (Model?.Receipt != null)
        {
            @* --- HEADER --- *@
            <div class="flex justify-between items-start">
                <div class="w-[60%] text-left text-sm leading-tight">
                    <b class="uppercase block">
                        @(string.IsNullOrEmpty(Model.CompanyInfo.CompanyName) ? "CÔNG TY TNHH SX – TM – DV – KT DUY PHÁT" : Model.CompanyInfo.CompanyName)                   
                    </b>
                    <span class="text-xs">Địa chỉ: 
                        @(string.IsNullOrEmpty(Model.CompanyInfo.Address) ? "106/6 Ngô Tất Tố, Phường Thạnh Mỹ Tây, TP Hồ Chí Minh, Việt Nam" : Model.CompanyInfo.Address)                    
                    </span>
                </div>
                <div class="w-[40%] text-center text-xs leading-tight">
                    <b class="text-sm block">Mẫu số: 01 - VT</b>
                    <i class="block">(Ban hành theo Thông tư số 133/2016/TT-BTC<br />Ngày 26/08/2016 của Bộ Tài chính)</i>
                </div>
            </div>

            @* --- TITLE --- *@
            <div class="text-center mt-8">
                <h1 class="text-2xl font-bold uppercase">PHIẾU XUẤT KHO</h1>
                <div class="flex justify-center gap-24 mt-2 text-sm">
                    <span>Số: <b class="font-bold">@Model.Receipt.ReceiptNo</b></span>
                </div>
                <p class="italic text-sm">
                Ngày @(Model.Receipt.ReceiptDate?.Day ?? DateTime.Now.Day)
                tháng @(Model.Receipt.ReceiptDate?.Month ?? DateTime.Now.Month)
                năm @(Model.Receipt.ReceiptDate?.Year ?? DateTime.Now.Year)
                </p>
            </div>

        @* --- GENERAL INFO --- *@
        <div class="mt-6 space-y-1 text-sm">
            <p>- Họ và tên người nhận hàng: 
                <b class="font-bold"> 
                    @(string.IsNullOrEmpty(Model.Receipt.Consignee) ? "................................................................" : Model.Receipt.Consignee)
                </b>
            </p>
            <p>- Lý do xuất: <b class="font-bold">@(string.IsNullOrEmpty(Model.Receipt.Description) ? "................................................................" : Model.Receipt.Description)</b></p>
            <p>- Xuất tại kho: <b class="font-bold">@Model.Receipt.WarehouseName</b></p>
            <p>- Địa chỉ: <b class="font-bold">@Model.Receipt.WarehouseAddress</b></p>
            <p>- Khách hàng: <b class="font-bold">@Model.Receipt.CustomerName</b></p>
            @if (!string.IsNullOrEmpty(Model.Receipt.OutboundGatewayName))
            {
                <p>- Cửa xuất: <b class="font-bold">@Model.Receipt.OutboundGatewayName</b></p>
            }
        </div>

        @* --- TABLE --- *@
        <table class="w-full border-collapse border border-black mt-4 text-sm">
            <thead>
                <tr class="font-bold">
                    <th class="border border-black p-1 w-10 text-center" rowspan="2">STT</th>
                    <th class="border border-black p-1 text-left" rowspan="2">Tên, nhãn hiệu, quy cách vật tư, hàng hóa</th>
                    <th class="border border-black p-1 w-24 text-center" rowspan="2">Mã số</th>
                    <th class="border border-black p-1 w-16 text-center" rowspan="2">ĐVT</th>
                    <th class="border border-black p-1 text-center" colspan="2">Số lượng</th>
                    <th class="border border-black p-1 text-center" rowspan="2">Đơn giá</th>
                    <th class="border border-black p-1 text-center" rowspan="2">Thành tiền</th>
                </tr>
                <tr class="font-bold">
                    <th class="border border-black p-1 w-20 text-center">Yêu cầu</th>
                    <th class="border border-black p-1 w-20 text-center">Thực xuất</th>
                </tr>
                <tr class="italic text-xs text-center">
                    <td class="border border-black p-1">A</td>
                    <td class="border border-black p-1">B</td>
                    <td class="border border-black p-1">C</td>
                    <td class="border border-black p-1">D</td>
                    <td class="border border-black p-1">1</td>
                    <td class="border border-black p-1">2</td>
                    <td class="border border-black p-1">3</td>
                    <td class="border border-black p-1">4</td>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                    decimal totalQty = 0;
                }
                @foreach (var item in Model.Receipt.Details)
                {
                    totalQty += item.Quantity;
                    <tr>
                        <td class="border border-black p-1 text-center">@(i++)</td>
                        <td class="border border-black p-1">
                            @item.SkuName
                            @if (!string.IsNullOrEmpty(item.LocationName) || !string.IsNullOrEmpty(item.PalletCode))
                            {
                                <div class="text-xs italic text-gray-600">
                                    (Vị trí: @item.LocationName - Pallet: @item.PalletCode)
                                </div>
                            }
                        </td>
                        <td class="border border-black p-1 text-center">@item.SkuCode</td>
                        <td class="border border-black p-1 text-center">@item.UnitName</td>
                        <td class="border border-black p-1 text-center">@item.Quantity.ToString("N0")</td>
                        <td class="border border-black p-1 text-center">@item.Quantity.ToString("N0")</td>
                        <td class="border border-black p-1 text-right"></td>
                        <td class="border border-black p-1 text-right"></td>
                    </tr>
                }
                @* TOTAL ROW *@
                <tr class="font-bold uppercase text-center">
                    <td colspan="4" class="border border-black p-1">Cộng</td>
                    <td class="border border-black p-1">@totalQty.ToString("N0")</td>
                    <td class="border border-black p-1">@totalQty.ToString("N0")</td>
                    <td class="border border-black p-1"></td>
                    <td class="border border-black p-1"></td>
                </tr>
            </tbody>
        </table>

        @* --- FOOTER INFO --- *@
        <div class="mt-4 text-sm space-y-1">
            <p>- Tổng số tiền (viết bằng chữ): ........................................................................................................</p>
            <p>- Số chứng từ gốc kèm theo: ........................................................................................................</p>
        </div>

        @* --- SIGNATURES --- *@
        <div class="mt-2 flex justify-between text-center mt-10 w-full break-inside-avoid print:flex">
            <div class="w-1/4 h-24">
                <b class="block font-bold">Người lập phiếu</b>
                <i class="text-xs">(Ký, họ tên)</i>
            </div>
            <div class="w-1/4 h-24">
                <b class="block font-bold">Người nhận hàng</b>
                <i class="text-xs">(Ký, họ tên)</i>
            </div>
            <div class="w-1/4 h-24">
                <b class="block font-bold">Thủ kho</b>
                <i class="text-xs">(Ký, họ tên)</i>
            </div>
            <div class="w-1/4 h-24">
                <b class="block font-bold">Kế toán trưởng</b>
                <i class="text-xs">(Ký, họ tên)</i>
            </div>
        </div>
    }
</div>