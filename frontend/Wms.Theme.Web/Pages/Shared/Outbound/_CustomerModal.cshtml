@inject Microsoft.Extensions.Localization.IStringLocalizer<Wms.Theme.Web.SharedResource> Localizer

<div id="customerModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50 transition-opacity">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl mx-4 transform transition-all">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">@Localizer["CreateOutboundReceipt_NewCustomerTitle"]</h3>
            <button type="button" onclick="closeCustomerModal()" class="text-gray-400 hover:text-gray-600 focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="px-6 py-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
                <label for="newCusName" class="block text-sm font-medium text-gray-700 mb-1">
                    @Localizer["CreateOutboundReceipt_CustomerName"] <span class="text-red-500">*</span>
                </label>
                <input type="text" id="newCusName" placeholder="VD: Công ty TNHH Vận tải ABC"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label for="newCusCity" class="block text-sm font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_City"]</label>
                <input type="text" id="newCusCity" placeholder="VD: Hồ Chí Minh"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label for="newCusContactTel" class="block text-sm font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_Phone"]</label>
                <input type="text" id="newCusContactTel" placeholder="VD: 0909123456"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label for="newCusManager" class="block text-sm font-medium text-gray-700 mb-1">Người phụ trách</label>
                <input type="text" id="newCusManager" placeholder="VD: Nguyễn Văn A"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label for="newCusEmail" class="block text-sm font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_Email"]</label>
                <input type="email" id="newCusEmail" placeholder="VD: contact@company.com"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="md:col-span-2">
                <label for="newCusAddress" class="block text-sm font-medium text-gray-700 mb-1">@Localizer["CreateReceipt_Address"]</label>
                <input type="text" id="newCusAddress" placeholder="VD: 123 Lê Lợi, Quận 1"
                       class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
        </div>

        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3 bg-gray-50 rounded-b-lg">
            <button type="button" onclick="closeCustomerModal()" class="px-4 py-2 bg-white border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 font-medium transition-colors">
                @Localizer["Common_Cancel"]
            </button>
            <button type="button" onclick="saveNewCustomer()" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 font-medium shadow-sm transition-colors">
                @Localizer["CreateOutboundReceipt_SaveCustomerButton"]
            </button>
        </div>
    </div>
</div>