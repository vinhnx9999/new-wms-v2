@if (TempData.ContainsKey("SuccessMessage"))
{
    <div class="toast-container toast-success" id="successToast">
        <div class="toast-content">
            <svg class="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="toast-message">@TempData["SuccessMessage"]</span>
            <button class="toast-close" onclick="closeToast('successToast')">&times;</button>
        </div>
    </div>
}

@if (TempData.ContainsKey("ErrorMessage"))
{
    <div class="toast-container toast-error" id="errorToast">
        <div class="toast-content">
            <svg class="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="toast-message">@TempData["ErrorMessage"]</span>
            <button class="toast-close" onclick="closeToast('errorToast')">&times;</button>
        </div>
    </div>
}

@if (TempData.ContainsKey("WarningMessage"))
{
    <div class="toast-container toast-warning" id="warningToast">
        <div class="toast-content">
            <svg class="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4v2m0 4v2M12 3a9 9 0 110 18 9 9 0 010-18z" />
            </svg>
            <span class="toast-message">@TempData["WarningMessage"]</span>
            <button class="toast-close" onclick="closeToast('warningToast')">&times;</button>
        </div>
    </div>
}

@if (TempData.ContainsKey("InfoMessage"))
{
    <div class="toast-container toast-info" id="infoToast">
        <div class="toast-content">
            <svg class="toast-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="toast-message">@TempData["InfoMessage"]</span>
            <button class="toast-close" onclick="closeToast('infoToast')">&times;</button>
        </div>
    </div>
}

<script>
    function closeToast(toastId) {
        const toast = document.getElementById(toastId);
        if (toast) {
            toast.classList.add('hiding');
            setTimeout(() => toast.remove(), 300);
        }
    }

    // Auto-dismiss toast after 3 seconds
    document.addEventListener('DOMContentLoaded', function () {
        const toasts = document.querySelectorAll('.toast-container');
        toasts.forEach(toast => {
            setTimeout(() => {
                if (document.body.contains(toast)) {
                    toast.classList.add('hiding');
                    setTimeout(() => toast.remove(), 300);
                }
            }, 3000);
        });
    });
</script>
