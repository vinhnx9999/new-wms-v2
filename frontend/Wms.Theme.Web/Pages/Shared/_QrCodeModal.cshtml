@using Microsoft.Extensions.Localization
@using Wms.Theme.Web.Model.ShareModel
@inject IStringLocalizer<SharedResource> L

<!-- QR Code Modal -->
<div x-show="showModal" 
     class="fixed inset-0 bg-gray-900/90 dark:bg-black/90 overflow-y-auto h-full w-full z-50 transition-opacity duration-300 no-print backdrop-blur-sm"
     x-transition:enter="ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="ease-in duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     style="display: none;">
     
    <div class="relative top-5 mx-auto p-0 border dark:border-gray-700 w-11/12 md:w-3/4 lg:w-2/3 shadow-2xl rounded-xl bg-white dark:bg-gray-800 transition-colors duration-200"
         @@click.outside="closeModal()">

        <!-- Header -->
        <div class="flex justify-between items-center px-6 py-4 border-b dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 rounded-t-xl">
            <div>
                <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100">@L["PrintQR"]</h3>
                <div class="flex items-center gap-4 mt-1">
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        @L["Loaded"] <span class="font-bold text-indigo-600 dark:text-indigo-400" x-text="qrData.length"></span>
                    </p>

                    <label class="inline-flex items-center cursor-pointer" x-show="qrData.length > 0">
                        <input type="checkbox" x-model="allSelected" 
                               class="form-checkbox h-4 w-4 text-indigo-600 transition duration-150 ease-in-out border-gray-300 dark:border-gray-600 rounded focus:ring-indigo-500 bg-white dark:bg-gray-700">
                        <span class="ml-2 text-sm text-gray-600 dark:text-gray-400 select-none">@L["SelectAll"]</span>
                    </label>
                </div>
            </div>

            <button @@click="closeModal()" class="text-gray-400 hover:text-red-500 transition-colors p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 bg-gray-100 dark:bg-gray-900/50 min-h-[300px] max-h-[70vh] overflow-y-auto custom-scrollbar">

            <!-- Loading State inside Modal -->
            <div x-show="isModalLoading" class="flex flex-col items-center justify-center py-10">
                <svg class="animate-spin h-10 w-10 text-indigo-600 dark:text-indigo-400 mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-gray-500 dark:text-gray-400 font-medium">@L["GeneratingQR"]</span>
            </div>

            <!-- Error State -->
            <div x-show="showError" class="flex flex-col items-center justify-center py-10 text-red-500">
                <svg class="w-10 h-10 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span x-text="errorMessage"></span>
            </div>

            <!-- No Data State -->
            <div x-show="!isModalLoading && !showError && qrData.length === 0" class="text-center py-10 text-gray-500">
                @L["NoQRData"]
            </div>

            <!-- QR Cards Grid -->
            <div x-show="!isModalLoading && qrData.length > 0" class="grid grid-cols-1 md:grid-cols-2 gap-4" id="qrCodeContainer">
                <template x-for="(item, index) in qrData" :key="index">
                    
                    <!-- QR Card -->
                    <div :id="'qr-card-' + index"
                         @@click="toggleQrSelection(index)"
                         class="bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 border-l-4 flex flex-row justify-between items-stretch gap-4 print-card relative overflow-hidden cursor-pointer transition-all duration-200 hover:shadow-md break-inside-avoid page-break-inside-avoid"
                         :class="{ 
                            'qr-card-selected border-l-indigo-600': isSelected(index),
                            'border-l-gray-300 dark:border-l-gray-600': !isSelected(index),
                            'print-hidden': !isSelected(index)
                         }">

                        <!-- Checkbox -->
                        <div class="absolute top-3 right-3 z-10 no-print-checkbox">
                            <input type="checkbox" 
                                   class="qr-card-checkbox form-checkbox text-indigo-600 rounded focus:ring-indigo-500 border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700"
                                   :checked="isSelected(index)">
                        </div>

                        <!-- Info Section -->
                        <div class="flex-1 flex flex-col justify-between h-full font-sans pointer-events-none">
                            <div class="mb-2 pr-8">
                                <h4 class="font-bold text-lg text-gray-900 dark:text-gray-100 leading-tight mb-1 line-clamp-2" x-text="item.spuName || item.spu_name || `Product: ${item.spuCode}`"></h4>
                                <p class="text-xs text-gray-500 dark:text-gray-400">ASN: <span class="font-mono font-bold text-gray-700 dark:text-gray-300" x-text="item.asnNo || item.asn_no || '---'"></span></p>
                            </div>

                            <div class="grid grid-cols-2 gap-2 mb-3">
                                <div class="bg-gray-50 dark:bg-gray-700/50 p-1.5 rounded border border-gray-100 dark:border-gray-700">
                                    <span class="text-[9px] uppercase text-gray-400 font-bold block">SPU Code</span>
                                    <span class="text-xs font-semibold text-gray-800 dark:text-gray-200 block truncate" :title="item.spuCode || item.spu_code" x-text="item.spuCode || item.spu_code || '---'"></span>
                                </div>
                                <div class="bg-gray-50 dark:bg-gray-700/50 p-1.5 rounded border border-gray-100 dark:border-gray-700">
                                    <span class="text-[9px] uppercase text-gray-400 font-bold block">SKU Code</span>
                                    <span class="text-xs font-semibold text-gray-800 dark:text-gray-200 block truncate" :title="item.skuCode || item.sku_code" x-text="item.skuCode || item.sku_code || '---'"></span>
                                </div>
                            </div>

                            <div class="flex justify-between items-end mt-auto gap-2">
                                <div>
                                    <span class="text-[9px] uppercase text-indigo-400 font-bold tracking-wider block">Series Number</span>
                                    <span class="font-mono text-xl font-bold text-gray-900 dark:text-white tracking-tight block" x-text="item.seriesNumber || item.series_number || '---'"></span>
                                </div>

                                <div class="text-right">
                                    <template x-if="item.locationName || item.location_name">
                                        <div>
                                            <span class="text-[9px] uppercase text-gray-500 dark:text-gray-400 font-bold tracking-wider block">Location</span>
                                            <span class="font-mono text-lg font-bold text-indigo-700 dark:text-indigo-400 tracking-tight block" x-text="item.locationName || item.location_name"></span>
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </div>

                        <!-- QR Code Section -->
                        <div class="flex flex-col items-center justify-center pl-4 border-l border-dashed border-gray-200 dark:border-gray-700 w-[140px] pointer-events-none">
                            <div :id="'qrcode-container-' + index" class="bg-white p-1 rounded border border-gray-200 mb-1"
                                 x-init="generateQr($el, item)"></div>
                            <span class="text-[9px] text-gray-400 dark:text-gray-500 font-bold tracking-widest uppercase">@L["ScanMe"]</span>
                        </div>

                    </div>
                </template>
            </div>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t dark:border-gray-700 bg-white dark:bg-gray-800 rounded-b-xl flex justify-end gap-3">
            <button @@click="printQrCodes()"
                class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 shadow-lg shadow-indigo-200 dark:shadow-none transition-all transform hover:-translate-y-0.5"
                :class="{ 'opacity-50 cursor-not-allowed': selectedQrIndices.length === 0 }"
                :disabled="selectedQrIndices.length === 0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                </svg>
                @L["Print"] <span class="ml-1 font-bold" x-text="'(' + selectedQrIndices.length + ')'"></span>
            </button>
            <button @@click="closeModal()"
                class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                @L["Close"]
            </button>
        </div>
    </div>
</div>

<style>
    .qr-card-selected {
        border-color: #4f46e5 !important;
        background-color: rgba(79, 70, 229, 0.05) !important;
    }

    .dark .qr-card-selected {
        background-color: rgba(79, 70, 229, 0.1) !important;
    }

    .qr-card-checkbox {
        width: 1.25rem;
        height: 1.25rem;
        cursor: pointer;
    }

    @@media print {
        @@page {
            size: A5;
            margin: 10mm;
        }
        body * {
            visibility: hidden;
        }

        #qrCodeContainer,
        #qrCodeContainer * {
            visibility: visible;
        }
        
        /* Ensure modal is visible (parent container) */
        .no-print {
            display: none !important;
        }
        
        /* Specifically target the container inside modal for printing */
        div[x-show="showModal"] {
            display: block !important;
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            height: auto;
            background: white;
            border: none;
        }

        #qrCodeContainer {
            position: absolute;
            left: 0;
            top: 0;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
        }

        .print-card {
            break-inside: avoid;
            border: 1px solid #000 !important;
            box-shadow: none !important;
            background-color: white !important;
            height: 80mm; 
        }

        .print-hidden {
            display: none !important;
        }
        
        .no-print-checkbox {
            display: none !important;
        }
        
        .overflow-y-auto {
            overflow: visible !important;
            height: auto !important;
        }
    }
</style>